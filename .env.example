BASE_URL=
PORT=4207
SESSION_STORE=mysql
SESSION_SECRET=replace-with-a-long-random-secret
PAYMENT_LINK_SECRET=replace-with-a-second-long-random-secret
ALLOW_MAINTENANCE_ROUTES=false
ALLOW_MAKE_ADMIN_ROUTE=false
EXPOSE_ERROR_DETAILS=false

# Optional privileged accounts auto-synced into MySQL on startup
# Leave these empty in production unless you intentionally want bootstrap accounts.
DEFAULT_ADMIN_USERNAME=Admin
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_TEACHER_NAME=Nguyen Hoang Anh
DEFAULT_TEACHER_PHONE=0912345601
DEFAULT_TEACHER_EMAIL=
DEFAULT_TEACHER_PASSWORD=
DEMO_TEACHER_PASSWORD=

# Preferred database variables
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=student_platform
DB_PORT=3306

# Optional provider-native aliases for Railway MySQL
MYSQLHOST=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=
MYSQLPORT=

SMTP_SERVICE=
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Optional public origin for OAuth callbacks.
# Example local value: http://localhost:4207
# Google callback: <AUTH_BASE_URL>/auth/google/callback
# Facebook callback: <AUTH_BASE_URL>/auth/facebook/callback
AUTH_BASE_URL=

# Optional: professional AI chatbot mode
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_CHATBOT_MODEL=gpt-5.2-chat-latest
OPENAI_CHATBOT_MAX_OUTPUT=500
