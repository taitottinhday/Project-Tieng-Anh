<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --ps-bg: #f7f3ed;
      --ps-surface: #ffffff;
      --ps-soft: #f8fafc;
      --ps-line: rgba(15, 23, 42, 0.1);
      --ps-text: #172033;
      --ps-muted: #637083;
      --ps-accent: #c63a31;
      --ps-accent-soft: rgba(198, 58, 49, 0.12);
      --ps-dark: #132238;
      --ps-shadow: 0 22px 48px rgba(15, 23, 42, 0.08);
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      min-height: 100%;
      font-family: "Manrope", "Segoe UI", sans-serif;
      color: var(--ps-text);
      background:
        radial-gradient(circle at top left, rgba(198, 58, 49, 0.08), transparent 28%),
        radial-gradient(circle at top right, rgba(59, 130, 246, 0.08), transparent 24%),
        linear-gradient(180deg, #fdfbf7 0%, var(--ps-bg) 100%);
    }

    body {
      padding: 14px;
      overflow: hidden;
    }

    button,
    input,
    audio {
      font: inherit;
    }

    .ps-form {
      height: calc(100dvh - 28px);
      min-height: 720px;
    }

    .ps-shell {
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      gap: 14px;
      height: 100%;
      min-height: 0;
      align-items: start;
    }

    .ps-sidebar,
    .ps-main {
      border-radius: 26px;
      border: 1px solid var(--ps-line);
      background: rgba(255, 255, 255, 0.92);
      box-shadow: var(--ps-shadow);
      backdrop-filter: blur(18px);
    }

    .ps-sidebar {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      position: sticky;
      top: 0;
      height: 100%;
      max-height: 100%;
    }

    .ps-side-top {
      padding: 18px;
      background: linear-gradient(180deg, rgba(19, 34, 56, 0.98) 0%, rgba(31, 41, 55, 0.98) 100%);
      color: #fff;
      display: grid;
      gap: 14px;
    }

    .ps-back {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: rgba(255, 255, 255, 0.92);
      text-decoration: none;
      font-weight: 700;
    }

    .ps-kicker {
      display: inline-flex;
      width: fit-content;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      font-size: 0.84rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .ps-side-top h1,
    .ps-headline,
    .ps-question-stage h2,
    .ps-summary strong {
      margin: 0;
      font-family: "Sora", "Manrope", sans-serif;
      letter-spacing: -0.04em;
    }

    .ps-side-top h1 {
      font-size: 1.55rem;
      line-height: 1.1;
    }

    .ps-side-top p {
      margin: 0;
      color: rgba(255, 255, 255, 0.78);
      line-height: 1.65;
    }

    .ps-summary {
      display: grid;
      gap: 12px;
      padding: 16px 18px;
      border-bottom: 1px solid var(--ps-line);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(248, 250, 252, 0.96) 100%);
    }

    .ps-summary-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .ps-summary-card {
      padding: 12px;
      border-radius: 18px;
      background: var(--ps-soft);
      border: 1px solid var(--ps-line);
    }

    .ps-summary-card span {
      display: block;
      color: var(--ps-muted);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .ps-summary-card strong {
      display: block;
      margin-top: 8px;
      font-size: 1.05rem;
    }

    .ps-scroll {
      flex: 1;
      min-height: 0;
      overflow: auto;
      padding: 18px 14px;
      display: grid;
      gap: 16px;
    }

    .ps-part {
      display: grid;
      gap: 10px;
    }

    .ps-part h3 {
      margin: 0;
      color: var(--ps-dark);
      font-size: 1rem;
      font-family: "Sora", "Manrope", sans-serif;
    }

    .ps-nav-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
    }

    .ps-nav-btn {
      position: relative;
      width: 52px;
      min-width: 52px;
      height: 56px;
      padding: 0;
      border-radius: 18px;
      border: 1px solid var(--ps-line);
      background: linear-gradient(180deg, #ffffff 0%, #f7fafe 100%);
      color: var(--ps-muted);
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 10px 20px rgba(19, 34, 56, 0.08);
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease, color 0.18s ease;
    }

    .ps-nav-btn.flagged::after {
      content: "";
      position: absolute;
      top: 8px;
      right: 8px;
      width: 10px;
      height: 15px;
      border-radius: 2px;
      background: linear-gradient(180deg, #f05b52 0%, var(--ps-accent) 100%);
      clip-path: polygon(0 0, 100% 0, 100% 74%, 52% 58%, 0 74%);
      box-shadow: 0 6px 12px rgba(198, 58, 49, 0.25);
      pointer-events: none;
    }

    .ps-nav-btn.current.flagged::after {
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 6px 12px rgba(19, 34, 56, 0.24);
    }

    .ps-nav-btn:hover {
      transform: translateY(-1px);
      border-color: rgba(19, 34, 56, 0.22);
      color: var(--ps-dark);
      box-shadow: 0 14px 24px rgba(19, 34, 56, 0.12);
    }

    .ps-nav-btn.current {
      background: linear-gradient(180deg, #132238 0%, #1d3554 100%);
      border-color: #132238;
      color: #fff;
      box-shadow: 0 16px 28px rgba(19, 34, 56, 0.2);
    }

    .ps-nav-btn.answered {
      background: linear-gradient(180deg, #fff4ec 0%, #ffe7d7 100%);
      border-color: rgba(198, 58, 49, 0.18);
      color: var(--ps-accent);
    }

    .ps-nav-btn.current.answered {
      background: linear-gradient(180deg, #132238 0%, #274262 72%, #c63a31 180%);
      color: #fff;
      border-color: #132238;
    }

    .ps-side-footer {
      display: grid;
      gap: 10px;
      padding: 16px 14px;
      border-top: 1px solid var(--ps-line);
      background: rgba(255, 255, 255, 0.95);
    }

    .ps-count {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      padding: 14px 16px;
      border-radius: 18px;
      background: var(--ps-soft);
      border: 1px solid var(--ps-line);
      font-weight: 800;
    }

    .ps-count-copy {
      display: grid;
      gap: 4px;
    }

    .ps-count-copy > span {
      color: var(--ps-muted);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .ps-count-copy small {
      color: var(--ps-muted);
      font-size: 0.76rem;
      font-weight: 700;
      line-height: 1.4;
    }

    .ps-submit,
    .ps-control,
    .ps-secondary {
      min-height: 48px;
      border-radius: 16px;
      border: 1px solid transparent;
      cursor: pointer;
      font-weight: 800;
      transition: transform 0.18s ease, opacity 0.18s ease;
    }

    .ps-submit {
      background: linear-gradient(135deg, #c63a31 0%, #e05b52 100%);
      color: #fff;
      box-shadow: 0 18px 34px rgba(198, 58, 49, 0.2);
    }

    .ps-control,
    .ps-secondary {
      background: #fff;
      color: var(--ps-dark);
      border-color: var(--ps-line);
    }

    .ps-submit:hover,
    .ps-control:hover,
    .ps-secondary:hover {
      transform: translateY(-1px);
    }

    .ps-submit:disabled,
    .ps-control:disabled,
    .ps-secondary:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      transform: none;
    }

    .ps-main {
      display: flex;
      flex-direction: column;
      min-width: 0;
      min-height: 0;
      height: 100%;
      overflow: hidden;
    }

    .ps-main-head {
      padding: 20px 24px;
      border-bottom: 1px solid var(--ps-line);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.96) 100%);
      display: grid;
      gap: 12px;
    }

    .ps-head-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      color: var(--ps-muted);
      font-size: 0.92rem;
      font-weight: 700;
    }

    .ps-chip {
      display: inline-flex;
      align-items: center;
      padding: 9px 12px;
      border-radius: 999px;
      background: rgba(19, 34, 56, 0.05);
      color: var(--ps-dark);
    }

    .ps-headline {
      font-size: clamp(1.6rem, 2.2vw, 2.4rem);
      line-height: 1.04;
      color: var(--ps-dark);
    }

    .ps-subline {
      color: var(--ps-muted);
      min-height: 24px;
    }

    .ps-stack {
      flex: 1;
      min-height: 0;
      padding: 14px;
      overflow: hidden;
    }

    .ps-screen {
      display: none;
      height: 100%;
      min-height: 0;
    }

    .ps-screen.active {
      display: block;
      height: 100%;
    }

    .ps-content {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 252px;
      gap: 14px;
      height: 100%;
      min-height: 0;
      align-items: start;
    }

    .ps-question-stage,
    .ps-answer-stage {
      border-radius: 22px;
      border: 1px solid var(--ps-line);
      background: rgba(255, 255, 255, 0.98);
    }

    .ps-question-stage {
      display: flex;
      flex-direction: column;
      gap: 16px;
      height: 100%;
      min-height: 0;
      overflow: auto;
      padding: 18px 18px 28px;
      scroll-padding-top: 16px;
    }

    .ps-answer-stage {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 16px;
      background: linear-gradient(180deg, rgba(248, 250, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
      position: sticky;
      top: 0;
      align-self: start;
    }

    .ps-stage-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--ps-line);
    }

    .ps-stage-kicker {
      display: inline-flex;
      width: fit-content;
      padding: 8px 12px;
      border-radius: 999px;
      background: var(--ps-accent-soft);
      color: var(--ps-accent);
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .ps-question-stage h2 {
      margin-top: 10px;
      font-size: 1.4rem;
      color: var(--ps-dark);
    }

    .ps-question-code {
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(19, 34, 56, 0.06);
      color: var(--ps-dark);
      font-weight: 800;
      white-space: nowrap;
    }

    .ps-block {
      padding: 16px;
      border-radius: 20px;
      border: 1px solid var(--ps-line);
      background: var(--ps-soft);
    }

    .ps-block strong {
      display: block;
      margin-bottom: 8px;
      color: var(--ps-dark);
      font-family: "Sora", "Manrope", sans-serif;
    }

    .ps-block audio {
      width: 100%;
    }

    .ps-block p {
      margin: 0;
      color: var(--ps-muted);
      line-height: 1.78;
      white-space: pre-wrap;
    }

    .ps-prompt {
      font-size: 1.06rem;
      color: var(--ps-text);
      line-height: 1.85;
      white-space: pre-wrap;
    }

    .ps-images {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 14px;
    }

    .ps-images img {
      width: 100%;
      border-radius: 18px;
      border: 1px solid var(--ps-line);
      display: block;
      background: #fff;
      object-fit: contain;
      max-height: 560px;
    }

    .ps-answer-head {
      display: grid;
      gap: 8px;
    }

    .ps-answer-head-main {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .ps-answer-head strong {
      font-family: "Sora", "Manrope", sans-serif;
      font-size: 1.2rem;
    }

    .ps-answer-head > span {
      color: var(--ps-muted);
      line-height: 1.6;
    }

    .ps-flag-toggle {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 38px;
      padding: 0 12px;
      border-radius: 999px;
      border: 1px solid rgba(198, 58, 49, 0.18);
      background: rgba(198, 58, 49, 0.08);
      color: var(--ps-accent);
      font-family: "Sora", "Manrope", sans-serif;
      font-size: 0.8rem;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
    }

    .ps-flag-toggle:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 22px rgba(198, 58, 49, 0.14);
    }

    .ps-flag-toggle:focus-visible {
      outline: 3px solid rgba(198, 58, 49, 0.18);
      outline-offset: 2px;
    }

    .ps-flag-toggle.active {
      background: linear-gradient(135deg, #c63a31 0%, #e05b52 100%);
      border-color: #c63a31;
      color: #ffffff;
      box-shadow: 0 16px 26px rgba(198, 58, 49, 0.2);
    }

    .ps-flag-icon {
      width: 10px;
      height: 16px;
      border-radius: 2px;
      background: currentColor;
      clip-path: polygon(0 0, 100% 0, 100% 70%, 55% 55%, 0 70%);
    }

    .ps-flag-status {
      color: var(--ps-muted);
      font-size: 0.84rem;
      font-weight: 700;
      line-height: 1.45;
    }

    .ps-choices {
      display: grid;
      gap: 12px;
    }

    .ps-choice {
      display: block;
      cursor: pointer;
    }

    .ps-choice input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .ps-choice-ui {
      display: grid;
      grid-template-columns: 30px minmax(0, 1fr);
      gap: 12px;
      align-items: center;
      padding: 12px;
      border-radius: 18px;
      border: 1px solid transparent;
      transition: background 0.18s ease, border-color 0.18s ease;
    }

    .ps-choice:hover .ps-choice-ui {
      background: rgba(19, 34, 56, 0.04);
      border-color: var(--ps-line);
    }

    .ps-choice input:checked + .ps-choice-ui {
      background: rgba(198, 58, 49, 0.08);
      border-color: rgba(198, 58, 49, 0.22);
    }

    .ps-choice-dot {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      border: 1.6px solid rgba(19, 34, 56, 0.2);
      background: #fff;
      position: relative;
    }

    .ps-choice input:checked + .ps-choice-ui .ps-choice-dot::after {
      content: "";
      position: absolute;
      inset: 5px;
      border-radius: 50%;
      background: var(--ps-accent);
    }

    .ps-choice-copy {
      color: var(--ps-text);
      line-height: 1.75;
      font-weight: 700;
    }

    .ps-choice-copy strong {
      margin-right: 6px;
      font-family: "Sora", "Manrope", sans-serif;
    }

    .ps-choice-copy.only-letter {
      letter-spacing: 0.04em;
    }

    .ps-answer-actions {
      display: grid;
      gap: 10px;
      margin-top: 8px;
      padding-top: 12px;
      border-top: 1px solid var(--ps-line);
    }

    .ps-answer-footer {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .ps-empty {
      display: grid;
      place-items: center;
      height: 100%;
      text-align: center;
      color: var(--ps-muted);
      font-size: 1.02rem;
    }

    .confirm-backdrop[hidden] {
      display: none;
    }

    .confirm-backdrop {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: grid;
      place-items: center;
      padding: 18px;
      background: rgba(8, 16, 28, 0.58);
      backdrop-filter: blur(3px);
    }

    .confirm-dialog {
      width: min(100%, 420px);
      padding: 22px;
      border-radius: 24px;
      background: #ffffff;
      border: 1px solid var(--ps-line);
      box-shadow: 0 28px 58px rgba(8, 16, 28, 0.24);
    }

    .confirm-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .confirm-head h2 {
      margin: 0;
      font-family: "Sora", "Manrope", sans-serif;
      font-size: 1.35rem;
      color: var(--ps-dark);
    }

    .confirm-close {
      width: 42px;
      height: 42px;
      border-radius: 999px;
      border: 1px solid var(--ps-line);
      background: #ffffff;
      color: var(--ps-dark);
      cursor: pointer;
      font-size: 1.3rem;
    }

    .confirm-copy {
      margin: 0;
      color: var(--ps-text);
      font-size: 1.1rem;
      font-weight: 700;
      line-height: 1.6;
    }

    .confirm-note {
      margin: 10px 0 0;
      color: var(--ps-muted);
      line-height: 1.6;
    }

    .confirm-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 18px;
    }

    @media (max-width: 1180px) {
      body {
        overflow: auto;
      }

      .ps-form {
        height: auto;
        min-height: 0;
      }

      .ps-shell {
        grid-template-columns: 1fr;
        height: auto;
      }

      .ps-content {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .ps-answer-stage {
        order: -1;
        position: static;
      }

      .ps-scroll {
        max-height: 320px;
      }

      .ps-sidebar,
      .ps-main {
        position: static;
        height: auto;
        max-height: none;
      }

      .ps-question-stage {
        height: auto;
        overflow: visible;
      }
    }

    @media (max-width: 720px) {
      body {
        padding: 10px;
        overflow: auto;
      }

      .ps-form,
      .ps-shell {
        height: auto;
        min-height: auto;
      }

      .ps-main-head,
      .ps-stack,
      .ps-question-stage,
      .ps-answer-stage {
        padding: 16px;
      }

      .ps-answer-footer,
      .ps-summary-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .ps-nav-grid {
        gap: 8px;
      }

      .ps-nav-btn {
        width: 48px;
        min-width: 48px;
        height: 52px;
        border-radius: 16px;
      }
    }
  </style>
</head>
<body>
  <%
    const examData = exam || {};
    const questions = Array.isArray(examData.flatQuestions) ? examData.flatQuestions : [];
    const groups = Array.isArray(examData.groups) ? examData.groups : [];
    const partSummary = Array.isArray(examData.partSummary) ? examData.partSummary : [];
    const durationMinutes = Number(examData.durationMinutes || 0);
    const totalQuestions = Number(examData.totalQuestions || questions.length || 0);
    const hasQuestions = questions.length > 0;
    const firstQuestion = hasQuestions ? questions[0] : null;
    const questionViews = questions.map((question) => {
      const group = groups.find((item) => Array.isArray(item.questions) && item.questions.some((candidate) => candidate.number === question.number)) || {};
      const part = partSummary.find((item) => item.partNumber === question.partNumber) || {};
      return Object.assign({}, question, {
        partTitle: part.title || ('Part ' + question.partNumber),
        partInstructions: part.instructions || '',
        sharedContent: group.sharedContent || '',
        sharedAudioUrl: group.sharedAudioUrl || null,
        sharedImages: Array.isArray(group.sharedImages) ? group.sharedImages : []
      });
    });
    const partSections = partSummary
      .map((part) => Object.assign({}, part, {
        questions: questionViews.filter((question) => question.partNumber === part.partNumber)
      }))
      .filter((part) => part.questions.length > 0);
    const firstHeadline = firstQuestion ? ('Part ' + firstQuestion.partNumber + ' | Câu ' + firstQuestion.number) : (examData.title || 'Practice Session');
  %>
  <form action="<%= examData.submitHref || '#' %>" method="POST" class="ps-form" data-practice-form data-session-key="student-practice-<%= examData.id || 'session' %>">
    <input type="hidden" name="furthest_question_number" value="<%= firstQuestion ? firstQuestion.number : '' %>" data-furthest-question>
    <div class="ps-shell">
      <aside class="ps-sidebar">
        <div class="ps-side-top">
          <a href="<%= examData.libraryHref || '#' %>" class="ps-back">&lt; <%= examData.libraryLabel || 'Quay lại' %></a>
          <span class="ps-kicker"><%= examData.modeLabel || 'Practice Session' %></span>
          <h1><%= examData.title || 'Practice Session' %></h1>
          <p><%= examData.subtitle || examData.bookName || '' %></p>
        </div>

        <div class="ps-summary">
          <div class="ps-summary-grid">
            <div class="ps-summary-card">
              <span>Thời gian</span>
              <strong id="timer" data-duration="<%= durationMinutes %>">00:00:00</strong>
            </div>
            <div class="ps-summary-card">
              <span>Đã làm</span>
              <strong><span id="answeredCount">0</span>/<%= totalQuestions %></strong>
            </div>
            <div class="ps-summary-card">
              <span>Câu hỏi</span>
              <strong><%= totalQuestions %> câu</strong>
            </div>
            <div class="ps-summary-card">
              <span>Chế độ</span>
              <strong><%= examData.modeLabel || 'Practice' %></strong>
            </div>
          </div>
        </div>

        <div class="ps-scroll">
          <% partSections.forEach((part) => { %>
            <section class="ps-part">
              <h3>Part <%= part.partNumber %></h3>
              <div class="ps-nav-grid">
                <% part.questions.forEach((question) => { %>
                  <button type="button" class="ps-nav-btn" data-go-question="<%= question.number %>"><%= question.number %></button>
                <% }) %>
              </div>
            </section>
          <% }) %>
        </div>

        <div class="ps-side-footer">
          <div class="ps-count">
            <div class="ps-count-copy">
              <span>Tiến độ</span>
              <small><span id="flaggedCountFooter">0</span> câu đang gắn cờ</small>
            </div>
            <strong><span id="answeredCountFooter">0</span>/<%= totalQuestions %></strong>
          </div>
          <button type="submit" class="ps-submit" <%= hasQuestions ? '' : 'disabled' %>>Nộp bài</button>
        </div>
      </aside>

      <main class="ps-main">
        <header class="ps-main-head">
          <div class="ps-head-meta">
            <span class="ps-chip"><%= examData.modeLabel || 'Practice' %></span>
            <span class="ps-chip"><%= examData.bookName || '' %></span>
            <span class="ps-chip"><%= totalQuestions %> câu</span>
          </div>
          <h2 class="ps-headline" id="currentHeadline"><%= firstHeadline %></h2>
          <div class="ps-subline" id="currentSubline"><%= firstQuestion ? (firstQuestion.partTitle || '') : 'Chưa có dữ liệu luyện tập' %></div>
        </header>

        <div class="ps-stack">
          <% if (!hasQuestions) { %>
            <div class="ps-empty">Bộ luyện này chưa có dữ liệu câu hỏi để hiển thị.</div>
          <% } else { %>
            <% questionViews.forEach((question, index) => { %>
              <section
                class="ps-screen <%= index === 0 ? 'active' : '' %>"
                data-question-screen
                data-question-id="<%= question.number %>"
                data-part-number="<%= question.partNumber %>"
                data-part-title="<%= question.partTitle %>"
                data-headline="Part <%= question.partNumber %> | Câu <%= question.number %>">
                <div class="ps-content">
                  <div class="ps-question-stage">
                    <div class="ps-stage-head">
                      <div>
                        <span class="ps-stage-kicker">Part <%= question.partNumber %></span>
                        <h2><%= question.partTitle %></h2>
                      </div>
                      <span class="ps-question-code">Câu <%= question.number %></span>
                    </div>

                    <% if (question.sharedAudioUrl) { %>
                      <div class="ps-block">
                        <strong>Âm thanh</strong>
                        <audio controls preload="metadata">
                          <source src="<%= question.sharedAudioUrl %>" type="audio/mpeg">
                        </audio>
                      </div>
                    <% } %>

                    <% if (question.sharedContent) { %>
                      <div class="ps-block">
                        <strong>Đoạn văn / ngữ cảnh</strong>
                        <p><%= question.sharedContent %></p>
                      </div>
                    <% } %>

                    <% if (question.sharedImages && question.sharedImages.length) { %>
                      <div class="ps-images">
                        <% question.sharedImages.forEach((imageUrl) => { %>
                          <img src="<%= imageUrl %>" alt="Tư liệu câu <%= question.number %>">
                        <% }) %>
                      </div>
                    <% } %>

                    <div class="ps-block">
                      <strong>Hướng dẫn</strong>
                      <p><%= question.partInstructions %></p>
                      <div class="ps-prompt"><%= question.prompt %></div>
                    </div>
                  </div>

                  <aside class="ps-answer-stage">
                    <div class="ps-answer-head">
                      <div class="ps-answer-head-main">
                        <button
                          type="button"
                          class="ps-flag-toggle"
                          data-flag-question="<%= question.number %>"
                          aria-pressed="false"
                          aria-label="Gắn cờ câu <%= question.number %>">
                          <span class="ps-flag-icon" aria-hidden="true"></span>
                          <span data-flag-label>Gắn cờ</span>
                        </button>
                        <strong>Câu <%= question.number %></strong>
                      </div>
                      <span>Chọn một đáp án phù hợp nhất trước khi chuyển sang câu tiếp theo.</span>
                      <div class="ps-flag-status" data-flag-status>Chưa gắn cờ cho câu này.</div>
                    </div>

                    <div class="ps-choices">
                      <% question.options.forEach((option) => { %>
                        <label class="ps-choice">
                          <input
                            type="radio"
                            name="<%= question.inputName %>"
                            value="<%= option.label %>"
                            data-question-input="<%= question.number %>">
                          <span class="ps-choice-ui">
                            <span class="ps-choice-dot"></span>
                            <% if (option.isLetterOnly) { %>
                              <span class="ps-choice-copy only-letter"><strong><%= option.label %></strong></span>
                            <% } else { %>
                              <span class="ps-choice-copy"><strong><%= option.label %></strong><%= option.text %></span>
                            <% } %>
                          </span>
                        </label>
                      <% }) %>
                    </div>

                    <div class="ps-answer-actions">
                      <div class="ps-answer-footer">
                        <button type="button" class="ps-control" data-direction="-1">Câu trước</button>
                        <button type="button" class="ps-control" data-direction="1">Câu tiếp</button>
                      </div>

                      <button type="button" class="ps-secondary" data-jump-pending>Đến câu chưa làm</button>
                      <button type="button" class="ps-secondary" data-jump-flagged>Đến câu gắn cờ</button>
                    </div>
                  </aside>
                </div>
              </section>
            <% }) %>
          <% } %>
        </div>
      </main>
    </div>

    <div class="confirm-backdrop" hidden data-submit-confirm>
      <div class="confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="practice-submit-confirm-title">
        <div class="confirm-head">
          <h2 id="practice-submit-confirm-title">Xác nhận</h2>
          <button type="button" class="confirm-close" data-submit-close aria-label="Đóng">&times;</button>
        </div>
        <p class="confirm-copy">Bạn có muốn nộp bài?</p>
        <div class="confirm-actions">
          <button type="button" class="ps-secondary" data-submit-cancel>Quay lại</button>
          <button type="button" class="ps-submit" data-submit-accept>Nộp bài</button>
        </div>
        <p class="confirm-note">Hãy kiểm tra lại kỹ bài trước khi nộp.</p>
      </div>
    </div>
  </form>

  <script>
    (() => {
      const form = document.querySelector('[data-practice-form]');
      if (!form) return;

      const sessionKey = form.dataset.sessionKey || '';
      const screens = Array.from(form.querySelectorAll('[data-question-screen]'));
      const navButtons = Array.from(form.querySelectorAll('[data-go-question]'));
      const radioInputs = Array.from(form.querySelectorAll('[data-question-input]'));
      const flagButtons = Array.from(form.querySelectorAll('[data-flag-question]'));
      const timerEl = document.getElementById('timer');
      const answeredEl = document.getElementById('answeredCount');
      const answeredFooterEl = document.getElementById('answeredCountFooter');
      const flaggedFooterEl = document.getElementById('flaggedCountFooter');
      const headlineEl = document.getElementById('currentHeadline');
      const sublineEl = document.getElementById('currentSubline');
      const jumpPendingButtons = Array.from(form.querySelectorAll('[data-jump-pending]'));
      const jumpFlaggedButtons = Array.from(form.querySelectorAll('[data-jump-flagged]'));
      const furthestQuestionInput = form.querySelector('[data-furthest-question]');
      const submitConfirm = form.querySelector('[data-submit-confirm]');
      const submitAcceptButton = form.querySelector('[data-submit-accept]');
      const submitCancelButtons = Array.from(form.querySelectorAll('[data-submit-cancel], [data-submit-close]'));
      const orderedIds = screens.map((screen) => String(screen.dataset.questionId));
      let currentQuestionId = orderedIds[0] || null;
      let furthestQuestionId = currentQuestionId;
      let lastPendingJumpId = null;
      let lastFlaggedJumpId = null;
      let flaggedQuestionIds = new Set();
      let isSubmitConfirmed = false;

      const readState = () => {
        if (!sessionKey) return null;
        try {
          const raw = sessionStorage.getItem(sessionKey);
          return raw ? JSON.parse(raw) : null;
        } catch (error) {
          return null;
        }
      };

      const writeState = () => {
        if (!sessionKey) return;
        const answers = {};
        radioInputs.forEach((input) => {
          if (input.checked) {
            answers[input.name] = input.value;
          }
        });

        try {
          sessionStorage.setItem(sessionKey, JSON.stringify({
            currentQuestionId,
            furthestQuestionId,
            lastPendingJumpId,
            lastFlaggedJumpId,
            flaggedQuestionIds: Array.from(flaggedQuestionIds),
            answers
          }));
        } catch (error) {
          console.warn('Cannot save practice state:', error);
        }
      };

      const restoreState = () => {
        const stored = readState();
        if (!stored) return;

        Object.entries(stored.answers || {}).forEach(([name, value]) => {
          const matched = form.querySelector(`input[name="${name}"][value="${value}"]`);
          if (matched) {
            matched.checked = true;
          }
        });

        if (stored.currentQuestionId && orderedIds.includes(String(stored.currentQuestionId))) {
          currentQuestionId = String(stored.currentQuestionId);
        }

        if (stored.furthestQuestionId && orderedIds.includes(String(stored.furthestQuestionId))) {
          furthestQuestionId = String(stored.furthestQuestionId);
        }

        if (stored.lastPendingJumpId) {
          lastPendingJumpId = String(stored.lastPendingJumpId);
        }

        if (stored.lastFlaggedJumpId) {
          lastFlaggedJumpId = String(stored.lastFlaggedJumpId);
        }

        if (Array.isArray(stored.flaggedQuestionIds)) {
          flaggedQuestionIds = new Set(
            stored.flaggedQuestionIds
              .map((questionId) => String(questionId))
              .filter((questionId) => orderedIds.includes(questionId))
          );
        }
      };

      const getAnsweredSet = () => new Set(
        radioInputs
          .filter((input) => input.checked)
          .map((input) => String(input.dataset.questionInput))
      );

      const getFlaggedSet = () => new Set(Array.from(flaggedQuestionIds));

      const getScreen = (questionId) => screens.find((screen) => screen.dataset.questionId === String(questionId));

      const getNeighborId = (questionId, direction) => {
        const currentIndex = orderedIds.indexOf(String(questionId));
        if (currentIndex === -1) return null;
        return orderedIds[currentIndex + direction] || null;
      };

      const updateFurthestQuestion = (questionId) => {
        const nextIndex = orderedIds.indexOf(String(questionId));
        const furthestIndex = orderedIds.indexOf(String(furthestQuestionId));

        if (nextIndex !== -1 && (furthestIndex === -1 || nextIndex > furthestIndex)) {
          furthestQuestionId = String(questionId);
        }

        if (!furthestQuestionId) {
          furthestQuestionId = String(questionId);
        }

        if (furthestQuestionInput) {
          furthestQuestionInput.value = furthestQuestionId || '';
        }
      };

      const closeSubmitConfirm = () => {
        if (submitConfirm) {
          submitConfirm.hidden = true;
        }
      };

      const openSubmitConfirm = () => {
        if (submitConfirm) {
          submitConfirm.hidden = false;
        }
      };

      const submitExam = () => {
        isSubmitConfirmed = true;
        closeSubmitConfirm();

        if (typeof form.requestSubmit === 'function') {
          form.requestSubmit();
          return;
        }

        if (sessionKey) {
          sessionStorage.removeItem(sessionKey);
        }

        form.submit();
      };

      const updateFooterControls = () => {
        screens.forEach((screen) => {
          const questionId = screen.dataset.questionId;
          const prevButton = screen.querySelector('[data-direction="-1"]');
          const nextButton = screen.querySelector('[data-direction="1"]');
          if (prevButton) prevButton.disabled = !getNeighborId(questionId, -1);
          if (nextButton) nextButton.disabled = !getNeighborId(questionId, 1);
        });
      };

      const updateShortcutButtons = (answeredSet, flaggedSet) => {
        const hasPending = orderedIds.some((questionId) => !answeredSet.has(questionId));
        const hasFlagged = flaggedSet.size > 0;

        jumpPendingButtons.forEach((button) => {
          button.disabled = !hasPending;
        });

        jumpFlaggedButtons.forEach((button) => {
          button.disabled = !hasFlagged;
        });
      };

      const syncUi = () => {
        const answeredSet = getAnsweredSet();
        const flaggedSet = getFlaggedSet();
        const activeScreen = getScreen(currentQuestionId) || screens[0];

        screens.forEach((screen) => {
          screen.classList.toggle('active', screen === activeScreen);
        });

        navButtons.forEach((button) => {
          const questionId = button.dataset.goQuestion;
          button.classList.toggle('current', questionId === String(currentQuestionId));
          button.classList.toggle('answered', answeredSet.has(questionId));
          button.classList.toggle('flagged', flaggedSet.has(questionId));
        });

        flagButtons.forEach((button) => {
          const questionId = String(button.dataset.flagQuestion);
          const isFlagged = flaggedSet.has(questionId);
          const label = button.querySelector('[data-flag-label]');
          const status = getScreen(questionId)?.querySelector('[data-flag-status]');

          button.classList.toggle('active', isFlagged);
          button.setAttribute('aria-pressed', isFlagged ? 'true' : 'false');
          button.setAttribute('aria-label', `${isFlagged ? 'Bỏ gắn cờ' : 'Gắn cờ'} câu ${questionId}`);

          if (label) {
            label.textContent = isFlagged ? 'Bỏ cờ' : 'Gắn cờ';
          }

          if (status) {
            status.textContent = isFlagged
              ? 'Đã gắn cờ, nhớ xem lại trước khi nộp.'
              : 'Chưa gắn cờ cho câu này.';
          }
        });

        if (answeredEl) {
          answeredEl.textContent = String(answeredSet.size);
        }

        if (answeredFooterEl) {
          answeredFooterEl.textContent = String(answeredSet.size);
        }

        if (flaggedFooterEl) {
          flaggedFooterEl.textContent = String(flaggedSet.size);
        }

        if (activeScreen) {
          currentQuestionId = String(activeScreen.dataset.questionId);
          updateFurthestQuestion(currentQuestionId);
          if (headlineEl) {
            headlineEl.textContent = activeScreen.dataset.headline || ('Câu ' + currentQuestionId);
          }
          if (sublineEl) {
            const answeredLabel = answeredSet.has(currentQuestionId) ? 'Đã chọn đáp án' : 'Chưa trả lời';
            const flaggedLabel = flaggedSet.has(currentQuestionId) ? 'Đã gắn cờ xem lại' : 'Không gắn cờ';
            sublineEl.textContent = (activeScreen.dataset.partTitle || '') + ' | ' + answeredLabel + ' | ' + flaggedLabel;
          }
        }

        updateFooterControls();
        updateShortcutButtons(answeredSet, flaggedSet);
        writeState();
      };

      const setCurrentQuestion = (questionId) => {
        if (!orderedIds.includes(String(questionId))) return;
        currentQuestionId = String(questionId);
        syncUi();
      };

      const jumpToNextPending = () => {
        const answeredSet = getAnsweredSet();
        const pendingIds = orderedIds.filter((questionId) => !answeredSet.has(questionId));

        if (!pendingIds.length) {
          return;
        }

        const nextPending = lastPendingJumpId
          ? (pendingIds.find((questionId) => Number(questionId) > Number(lastPendingJumpId)) || pendingIds[0])
          : pendingIds[0];

        lastPendingJumpId = nextPending;
        setCurrentQuestion(nextPending);
      };

      const jumpToNextFlagged = () => {
        const flaggedIds = orderedIds.filter((questionId) => flaggedQuestionIds.has(questionId));

        if (!flaggedIds.length) {
          return;
        }

        const nextFlagged = lastFlaggedJumpId
          ? (flaggedIds.find((questionId) => Number(questionId) > Number(lastFlaggedJumpId)) || flaggedIds[0])
          : flaggedIds[0];

        lastFlaggedJumpId = nextFlagged;
        setCurrentQuestion(nextFlagged);
      };

      const toggleFlag = (questionId) => {
        const normalizedQuestionId = String(questionId);
        if (!orderedIds.includes(normalizedQuestionId)) {
          return;
        }

        if (flaggedQuestionIds.has(normalizedQuestionId)) {
          flaggedQuestionIds.delete(normalizedQuestionId);
          if (lastFlaggedJumpId === normalizedQuestionId) {
            lastFlaggedJumpId = null;
          }
        } else {
          flaggedQuestionIds.add(normalizedQuestionId);
        }

        syncUi();
      };

      restoreState();
      syncUi();

      navButtons.forEach((button) => {
        button.addEventListener('click', () => {
          setCurrentQuestion(button.dataset.goQuestion);
        });
      });

      radioInputs.forEach((input) => {
        input.addEventListener('change', () => {
          currentQuestionId = String(input.dataset.questionInput);
          syncUi();
        });
      });

      flagButtons.forEach((button) => {
        button.addEventListener('click', () => {
          currentQuestionId = String(button.dataset.flagQuestion);
          toggleFlag(button.dataset.flagQuestion);
        });
      });

      screens.forEach((screen) => {
        const questionId = screen.dataset.questionId;
        const prevButton = screen.querySelector('[data-direction="-1"]');
        const nextButton = screen.querySelector('[data-direction="1"]');

        if (prevButton) {
          prevButton.addEventListener('click', () => {
            const prevId = getNeighborId(questionId, -1);
            if (prevId) {
              setCurrentQuestion(prevId);
            }
          });
        }

        if (nextButton) {
          nextButton.addEventListener('click', () => {
            const nextId = getNeighborId(questionId, 1);
            if (nextId) {
              setCurrentQuestion(nextId);
            }
          });
        }
      });

      jumpPendingButtons.forEach((button) => {
        button.addEventListener('click', jumpToNextPending);
      });

      jumpFlaggedButtons.forEach((button) => {
        button.addEventListener('click', jumpToNextFlagged);
      });

      submitCancelButtons.forEach((button) => {
        button.addEventListener('click', closeSubmitConfirm);
      });

      if (submitConfirm) {
        submitConfirm.addEventListener('click', (event) => {
          if (event.target === submitConfirm) {
            closeSubmitConfirm();
          }
        });
      }

      if (submitAcceptButton) {
        submitAcceptButton.addEventListener('click', submitExam);
      }

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && submitConfirm && !submitConfirm.hidden) {
          closeSubmitConfirm();
        }
      });

      form.addEventListener('submit', (event) => {
        if (!isSubmitConfirmed) {
          event.preventDefault();
          openSubmitConfirm();
          return;
        }

        if (sessionKey) {
          sessionStorage.removeItem(sessionKey);
        }
      });

      if (timerEl) {
        let timeLeft = Number(timerEl.dataset.duration || 0) * 60;

        const renderTimer = () => {
          const hours = Math.floor(timeLeft / 3600);
          const minutes = Math.floor((timeLeft % 3600) / 60);
          const seconds = timeLeft % 60;
          timerEl.textContent = `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
          if (timeLeft <= 0) {
            alert('Hết thời gian làm bài. Hệ thống sẽ tự động nộp bài.');
            submitExam();
            return;
          }
          timeLeft -= 1;
        };

        renderTimer();
        setInterval(renderTimer, 1000);
      }
    })();
  </script>
</body>
</html>
