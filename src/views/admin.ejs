  <section class="admin-grid admin-grid-3" data-admin-block="overview" style="<%= isOverviewView ? '' : 'display:none' %>">
    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Chỉ số sức khỏe</h2>
          <p>Những điểm cần theo dõi mỗi ngày để giữ vận hành ổn định.</p>
        </div>
      </div>

      <div class="admin-health-grid">
        <div class="admin-health-card">
          <span>Học sinh mỗi lớp</span>
          <strong><%= safeHealth.averageStudentsPerClass || "0.0" %></strong>
        </div>
        <div class="admin-health-card">
          <span>Tỷ lệ thu tiền</span>
          <strong><%= numberFmt(safeHealth.collectionRate) %>%</strong>
        </div>
        <div class="admin-health-card">
          <span>Phản hồi tư vấn</span>
          <strong><%= numberFmt(safeHealth.leadResponseRate) %>%</strong>
        </div>
        <div class="admin-health-card">
          <span>Hồ sơ đủ thông tin</span>
          <strong><%= numberFmt(safeHealth.studentProfileCoverage) %>%</strong>
        </div>
      </div>

      <div class="admin-bar-list">
        <% if (!roleMix.length) { %>
          <div class="admin-empty">Chưa có dữ liệu cơ cấu tài khoản.</div>
        <% } %>

        <% roleMix.forEach((item) => { %>
          <div class="admin-bar-row">
            <div class="admin-bar-top">
              <span><%= roleLabelMap[item.key] || item.label || item.key %></span>
              <small><%= numberFmt(item.total) %> tài khoản</small>
            </div>
            <div class="admin-progress"><i style="width: <%= Math.max(item.percentage || 0, item.total ? 8 : 0) %>%"></i></div>
          </div>
        <% }) %>
      </div>
    </article>

    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Cảnh báo ưu tiên</h2>
          <p>Các việc nên xử lý sớm để tránh tắc vận hành hoặc chậm doanh thu.</p>
        </div>
      </div>

      <div class="admin-list">
        <% if (!safeAlerts.length) { %>
          <div class="admin-empty">Hiện chưa có cảnh báo nào cần lưu ý.</div>
        <% } %>

        <% safeAlerts.forEach((alert) => { %>
          <div class="admin-alert">
            <span class="admin-alert-badge <%= toneClassMap[alert.tone] || '' %>"><%= numberFmt(alert.value) %></span>
            <div>
              <h3><%= alertTitleMap[alert.title] || alert.title %></h3>
              <p><%= alertDescriptionMap[alert.title] || alert.description %></p>
            </div>
            <a class="admin-alert-link" href="<%= alert.href %>">Mở</a>
          </div>
        <% }) %>
      </div>
    </article>

    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Hoạt động gần đây</h2>
          <p>Dòng sự kiện mới nhất từ tư vấn, ghi danh và thanh toán.</p>
        </div>
      </div>

      <div class="admin-feed">
        <% if (!safeActivityFeed.length) { %>
          <div class="admin-empty">Chưa có hoạt động nào được ghi nhận.</div>
        <% } %>

        <% safeActivityFeed.forEach((item) => { %>
          <div class="admin-feed-item">
            <span class="admin-feed-dot <%= toneClassMap[item.tone] || '' %>"></span>
            <div>
              <h3><%= item.title %></h3>
              <p><%= item.meta %></p>
              <div class="admin-feed-meta">
                <span class="admin-inline-badge"><%= activityLabelMap[item.label] || item.label %></span>
                <span><%= shortDateTime(item.at) %></span>
                <a class="admin-panel-link" href="<%= item.href %>">Mở chi tiết</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </article>
  </section>

  <section class="admin-grid admin-grid-2" id="classes" data-admin-block="overview" style="<%= isOverviewView ? '' : 'display:none' %>">
    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Danh mục lớp học</h2>
          <p>Theo dõi tình trạng lớp, giáo viên phụ trách và doanh thu đã chốt.</p>
        </div>
        <a class="admin-panel-link" href="<%= safeBaseUrl %>/database">Mở dữ liệu</a>
      </div>

      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Lớp học</th>
              <th>Lịch học</th>
              <th>Giáo viên</th>
              <th>Học viên</th>
              <th>Doanh thu</th>
              <th>Trạng thái</th>
            </tr>
          </thead>
          <tbody>
            <% if (!safeClasses.length) { %>
              <tr>
                <td colspan="6"><div class="admin-empty">Chưa có lớp học nào trong hệ thống.</div></td>
              </tr>
            <% } %>

            <% safeClasses.forEach((item) => {
              const state = classState(item);
              const statusClass =
                state === "Đang hoạt động"
                  ? "status-active"
                  : state === "Sắp khai giảng"
                    ? "status-upcoming"
                    : state === "Đã kết thúc"
                      ? "status-ended"
                      : state === "Chưa phân công"
                        ? "status-unassigned"
                        : "";
            %>
              <tr>
                <td>
                  <strong><%= item.course_name || "Chưa có tên khóa học" %></strong>
                  <small>Mã lớp: <%= item.code || "Đang cập nhật" %> · Phòng: <%= item.room || "Chưa gán" %></small>
                </td>
                <td>
                  <strong><%= shortDate(item.start_date) %></strong>
                  <small><%= item.schedule_text || "Chưa có lịch học" %></small>
                </td>
                <td>
                  <strong><%= item.teacher_name || "Chưa phân công" %></strong>
                  <small><%= item.category || "Chưa phân loại" %></small>
                </td>
                <td><%= numberFmt(item.enrollment_count) %></td>
                <td><%= moneyFmt(item.confirmed_revenue) %></td>
                <td><span class="admin-status <%= statusClass %>"><%= state %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </article>

    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Trạng thái vận hành</h2>
          <p>Tóm tắt nhanh hộp thư, kênh thanh toán và tiến độ xử lý.</p>
        </div>
      </div>

      <div class="admin-list">
        <div class="admin-table-card">
          <h3>Trạng thái tin nhắn</h3>
          <p>Phân loại yêu cầu tư vấn để đội ngũ xử lý không bị bỏ sót.</p>
          <div class="admin-bar-list">
            <% if (!messageStatuses.length) { %>
              <div class="admin-empty">Chưa có dữ liệu trạng thái tin nhắn.</div>
            <% } %>

            <% messageStatuses.forEach((item) => { %>
              <div class="admin-bar-row">
                <div class="admin-bar-top">
                  <span><%= messageStatusMap[item.key] || item.label || item.key %></span>
                  <small><%= numberFmt(item.total) %> yêu cầu</small>
                </div>
                <div class="admin-progress"><i style="width: <%= Math.max(item.percentage || 0, item.total ? 8 : 0) %>%"></i></div>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="admin-table-card">
          <h3>Kênh thanh toán</h3>
          <p>Ưu tiên những kênh tạo doanh thu tốt và xử lý thuận tiện nhất.</p>
          <div class="admin-bar-list">
            <% if (!paymentMethods.length) { %>
              <div class="admin-empty">Chưa có dữ liệu kênh thanh toán.</div>
            <% } %>

            <% paymentMethods.forEach((item) => {
              const maxMethodRevenue = Math.max(...paymentMethods.map((entry) => Number(entry.revenue || 0)), 1);
              const width = Math.max((Number(item.revenue || 0) / maxMethodRevenue) * 100, item.revenue ? 8 : 0);
            %>
              <div class="admin-bar-row">
                <div class="admin-bar-top">
                  <span><%= paymentMethodMap[item.key] || paymentMethodMap[item.label] || item.label || item.key %></span>
                  <small><%= moneyFmt(item.revenue) %></small>
                </div>
                <div class="admin-progress"><i style="width: <%= width %>%"></i></div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </article>
  </section>

  <style>
    .admin-section-grid {
      display: grid;
      grid-template-columns: 340px minmax(0, 1fr);
      gap: 18px;
    }

    .admin-form-card {
      padding: 20px;
      border-radius: 22px;
      border: 1px solid rgba(148, 163, 184, 0.14);
      background: rgba(248, 251, 255, 0.86);
    }

    .admin-form-card h3,
    .admin-table-card h3 {
      margin: 0;
      color: #17314c;
      font-size: 1.05rem;
    }

    .admin-form-card p {
      margin: 8px 0 0;
      color: #71859b;
      line-height: 1.6;
    }

    .admin-form-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: 18px;
    }

    .admin-form-grid .full {
      grid-column: 1 / -1;
    }

    .admin-field {
      display: grid;
      gap: 8px;
    }

    .admin-field label {
      color: #355779;
      font-size: 0.9rem;
      font-weight: 700;
    }

    .admin-input {
      width: 100%;
      padding: 13px 14px;
      border-radius: 16px;
      border: 1px solid rgba(191, 219, 254, 0.7);
      background: rgba(255, 255, 255, 0.96);
      color: #17314c;
      outline: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .admin-input:focus {
      border-color: rgba(95, 132, 194, 0.72);
      box-shadow: 0 0 0 4px rgba(95, 132, 194, 0.12);
    }

    .admin-actions,
    .admin-toolbar {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
    }

    .admin-toolbar {
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .admin-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 11px 15px;
      border-radius: 14px;
      border: 1px solid transparent;
      background: linear-gradient(135deg, #466a98 0%, #6f93c2 100%);
      color: #ffffff;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
    }

    .admin-button.secondary {
      background: rgba(95, 132, 194, 0.12);
      color: #32577b;
      border-color: rgba(148, 163, 184, 0.16);
    }

    .admin-button.danger {
      background: rgba(244, 63, 94, 0.12);
      color: #be123c;
      border-color: rgba(244, 63, 94, 0.18);
    }

    .admin-button:hover {
      filter: brightness(0.98);
    }

    .admin-search {
      min-width: min(100%, 280px);
    }

    .admin-edit-row.hidden {
      display: none;
    }

    .admin-inline-form {
      display: grid;
      gap: 14px;
      padding: 18px;
      border-radius: 18px;
      background: rgba(244, 248, 252, 0.96);
      border: 1px solid rgba(148, 163, 184, 0.14);
    }

    .admin-inline-form .admin-form-grid {
      margin-top: 0;
    }

    .admin-micro-list {
      display: grid;
      gap: 12px;
    }

    .admin-user-card strong {
      display: block;
      color: #17314c;
      font-size: 1rem;
    }

    .admin-user-card small {
      display: block;
      margin-top: 6px;
      color: #7a8ea3;
      line-height: 1.6;
    }

    @media (max-width: 980px) {
      .admin-section-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .admin-form-grid {
        grid-template-columns: 1fr;
      }

      .admin-toolbar {
        align-items: stretch;
      }

      .admin-search {
        min-width: 100%;
      }
    }
  </style>

