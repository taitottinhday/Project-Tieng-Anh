const chartWidth = 560;
const chartHeight = 230;
const padX = 28;
const padY = 24;
const enrollmentMax = Math.max(...enrollmentTrend.map((item) => Number(item.value || 0)), 1);
const buildLinePoints = (series, maxValue) => {
  if (!series.length) return "";
  const spanX = chartWidth - padX * 2;
  const spanY = chartHeight - padY * 2;
  const divisor = Math.max(series.length - 1, 1);
  return series
    .map((item, index) => {
      const x = padX + (spanX * index) / divisor;
      const y = chartHeight - padY - (spanY * Number(item.value || 0)) / Math.max(maxValue, 1);
      return `${x},${y}`;
    })
    .join(" ");
};
const buildAreaPoints = (series, maxValue) => {
  if (!series.length) return "";
  const linePoints = buildLinePoints(series, maxValue);
  const firstX = padX;
  const lastX = chartWidth - padX;
  const baseY = chartHeight - padY;
  return `${firstX},${baseY} ${linePoints} ${lastX},${baseY}`;
};
const enrollmentLine = buildLinePoints(enrollmentTrend, enrollmentMax);
const enrollmentArea = buildAreaPoints(enrollmentTrend, enrollmentMax);

const classState = (item) => {
  if (!item || !item.teacher_name) return "Chưa phân công";
  const now = new Date();
  const start = item.start_date ? new Date(item.start_date) : null;
  const end = item.end_date ? new Date(item.end_date) : null;

  if (end && !Number.isNaN(end.getTime()) && end < now) return "Đã kết thúc";
  if (start && !Number.isNaN(start.getTime())) {
    const diffDays = Math.ceil((start.getTime() - now.getTime()) / 86400000);
    if (diffDays >= 0 && diffDays <= 14) return "Sắp khai giảng";
    if (start <= now && (!end || end >= now)) return "Đang hoạt động";
  }
  return "Đã lên lịch";
};
