  <section class="admin-grid admin-grid-2" id="content">
    <article class="admin-panel" id="class-student-ops-panel" data-admin-ops-panel style="<%= (isOverviewView || isStudentsView) ? '' : 'display:none' %>">
      <div class="admin-panel-header">
        <div>
          <h2>Van hanh lop hoc</h2>
          <p>Tao lop moi va xu ly ghi danh offline theo dung logic ho so, tai khoan va classroom.</p>
        </div>
      </div>

      <div class="admin-ops-stack">
        <div class="admin-ops-card" id="class-operations" data-admin-card-view="overview" style="<%= isOverviewView ? '' : 'display:none' %>">
          <h3>Tao lop hoc moi</h3>
          <p>Moi lop duoc gan khoa hoc, lich hoc, phong hoc va giao vien phu trach ngay tu dau.</p>
          <form method="POST" action="<%= safeBaseUrl %>/admin/classes/add" class="admin-form-grid">
            <div class="admin-field">
              <label for="class-code-create">Ma lop</label>
              <input class="admin-input" id="class-code-create" name="code" type="text" placeholder="VD: ETS-2027-A1" required>
            </div>
            <div class="admin-field">
              <label for="class-room-create">Phong hoc</label>
              <input class="admin-input" id="class-room-create" name="room" type="text" placeholder="VD: P201">
            </div>
            <div class="admin-field full">
              <label for="class-course-create">Khoa hoc</label>
              <select class="admin-input" id="class-course-create" name="course_id" required>
                <option value="">Chon khoa hoc</option>
                <% safeCourseOptions.forEach((item) => { %>
                  <option value="<%= item.id %>"><%= item.name %> <% if (item.category) { %>· <%= item.category %><% } %></option>
                <% }) %>
              </select>
            </div>
            <div class="admin-field full">
              <label for="class-teacher-create">Giao vien phu trach</label>
              <select class="admin-input" id="class-teacher-create" name="teacher_id">
                <option value="">Chua gan giao vien</option>
                <% safeTeacherOptions.forEach((item) => { %>
                  <option value="<%= item.id %>"><%= item.full_name %><% if (item.email) { %> · <%= item.email %><% } %></option>
                <% }) %>
              </select>
            </div>
            <div class="admin-field">
              <label for="class-start-create">Ngay bat dau</label>
              <input class="admin-input" id="class-start-create" name="start_date" type="date">
            </div>
            <div class="admin-field">
              <label for="class-end-create">Ngay ket thuc</label>
              <input class="admin-input" id="class-end-create" name="end_date" type="date">
            </div>
            <div class="admin-field full">
              <label for="class-schedule-create">Lich hoc</label>
              <input class="admin-input" id="class-schedule-create" name="schedule_text" type="text" placeholder="VD: Thu 2 - Thu 4 - Thu 6 · 19:00 - 20:30">
            </div>
            <div class="admin-actions full">
              <button class="admin-button" type="submit">Tao lop hoc</button>
            </div>
          </form>
        </div>

        <div class="admin-ops-card" id="student-operations" data-admin-card-view="students" style="<%= isStudentsView ? '' : 'display:none' %>">
          <h3>Ghi danh offline + mo classroom</h3>
          <p>Khi admin tao ghi danh offline, hoc vien duoc luu vao database, gan vao lop va co the vao classroom ngay neu da co tai khoan portal.</p>
          <form method="POST" action="<%= safeBaseUrl %>/admin/students/add" class="admin-form-grid">
            <div class="admin-field full">
              <label for="offline-student-name">Hoc vien</label>
              <input class="admin-input" id="offline-student-name" name="full_name" type="text" placeholder="Nhap ho va ten hoc vien" required>
            </div>
            <div class="admin-field">
              <label for="offline-student-phone">So dien thoai</label>
              <input class="admin-input" id="offline-student-phone" name="phone" type="text" placeholder="Nhap so dien thoai">
            </div>
            <div class="admin-field">
              <label for="offline-student-email">Email dang nhap</label>
              <input class="admin-input" id="offline-student-email" name="email" type="email" placeholder="Nhap email cua hoc vien">
            </div>
            <div class="admin-field">
              <label for="offline-student-dob">Ngay sinh</label>
              <input class="admin-input" id="offline-student-dob" name="dob" type="date">
            </div>
            <div class="admin-field">
              <label for="offline-student-password">Mat khau portal</label>
              <input class="admin-input" id="offline-student-password" name="portal_password" type="text" placeholder="Toi thieu 6 ky tu">
            </div>
            <div class="admin-field full">
              <label for="offline-student-class">Lop hoc se gan</label>
              <select class="admin-input" id="offline-student-class" name="class_id" required>
                <option value="">Chon lop hoc</option>
                <% safeClassOptions.forEach((item) => { %>
                  <option value="<%= item.id %>"><%= item.code %> · <%= item.course_name || 'Chua co khoa hoc' %><% if (item.teacher_name) { %> · <%= item.teacher_name %><% } %></option>
                <% }) %>
              </select>
            </div>
            <div class="admin-field">
              <label for="offline-enrollment-status">Trang thai ghi danh</label>
              <select class="admin-input" id="offline-enrollment-status" name="enrollment_status">
                <option value="active">Active</option>
                <option value="pending">Pending</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="offline-payment-status">Trang thai thanh toan</label>
              <select class="admin-input" id="offline-payment-status" name="payment_status">
                <option value="confirmed">Confirmed</option>
                <option value="pending">Pending</option>
                <option value="rejected">Rejected</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="offline-payment-method">Kenh thu</label>
              <select class="admin-input" id="offline-payment-method" name="payment_method">
                <option value="cash">Tien mat</option>
                <option value="bank">Ngan hang</option>
                <option value="momo">MoMo</option>
                <option value="other">Khac</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="offline-payment-amount">So tien</label>
              <input class="admin-input" id="offline-payment-amount" name="payment_amount" type="number" min="0" step="1000" placeholder="Neu de trong se lay hoc phi khoa hoc">
            </div>
            <div class="admin-field full">
              <label for="offline-payment-note">Ghi chu thanh toan</label>
              <textarea class="admin-input admin-textarea" id="offline-payment-note" name="payment_note" placeholder="VD: Dang ky tai trung tam, thu tien mat, can bo sung bien lai"></textarea>
            </div>
            <div class="admin-field full">
              <label style="display:flex;align-items:center;gap:10px;">
                <input type="checkbox" name="create_portal_account" value="1" checked>
                Tao hoac lien ket tai khoan portal de hoc vien thay lop trong classroom
              </label>
            </div>
            <div class="admin-actions full">
              <button class="admin-button" type="submit">Ghi danh offline</button>
            </div>
          </form>
          <div class="admin-helper-note" data-admin-card-view="students" style="<%= isStudentsView ? '' : 'display:none' %>">Neu lop da co bai assignment trong classroom, he thong se tao san record nop bai cho hoc vien moi duoc them.</div>
        </div>
      </div>
    </article>

    <article class="admin-panel" id="teacher-resource-ops-panel" data-admin-ops-panel style="<%= (isTeachersView || isResourcesView) ? '' : 'display:none' %>">
      <div class="admin-panel-header">
        <div>
          <h2>Giao vien va kho noi dung</h2>
          <p>Quan ly tao giao vien, phan cong lop va dua de thi hoac tai lieu moi len web ngay trong luong admin.</p>
        </div>
      </div>

      <div class="admin-ops-stack">
        <div class="admin-ops-card" id="teacher-operations" data-admin-card-view="teachers" style="<%= isTeachersView ? '' : 'display:none' %>">
          <h3>Onboarding giao vien</h3>
          <p>Tao ho so giao vien, mo tai khoan giao vien va gan ngay vao cac lop dang co.</p>
          <form method="POST" action="<%= safeBaseUrl %>/admin/teachers/add" class="admin-form-grid">
            <div class="admin-field full">
              <label for="ops-teacher-name">Ho va ten</label>
              <input class="admin-input" id="ops-teacher-name" name="full_name" type="text" placeholder="Nhap ho va ten giao vien" required>
            </div>
            <div class="admin-field">
              <label for="ops-teacher-phone">So dien thoai</label>
              <input class="admin-input" id="ops-teacher-phone" name="phone" type="text" placeholder="Nhap so dien thoai">
            </div>
            <div class="admin-field">
              <label for="ops-teacher-email">Email giao vien</label>
              <input class="admin-input" id="ops-teacher-email" name="email" type="email" placeholder="Nhap email giao vien">
            </div>
            <div class="admin-field full">
              <label for="ops-teacher-password">Mat khau portal giao vien</label>
              <input class="admin-input" id="ops-teacher-password" name="portal_password" type="text" placeholder="Toi thieu 6 ky tu">
            </div>
            <div class="admin-field full">
              <label for="ops-teacher-classes">Gan vao cac lop hien co</label>
              <select class="admin-input" id="ops-teacher-classes" name="class_ids" multiple>
                <% safeClassOptions.forEach((item) => { %>
                  <option value="<%= item.id %>"><%= item.code %> · <%= item.course_name || 'Chua co khoa hoc' %></option>
                <% }) %>
              </select>
            </div>
            <div class="admin-field full">
              <label style="display:flex;align-items:center;gap:10px;">
                <input type="checkbox" name="create_portal_account" value="1" checked>
                Tao hoac lien ket tai khoan giao vien
              </label>
            </div>
            <div class="admin-actions full">
              <button class="admin-button" type="submit">Tao giao vien va gan lop</button>
            </div>
          </form>
        </div>

        <div class="admin-ops-card" data-admin-card-view="teachers" style="<%= isTeachersView ? '' : 'display:none' %>">
          <h3>Cap nhat phan cong lop</h3>
          <p>Chon giao vien va danh sach lop hien tai. He thong se thay toan bo danh sach phan cong bang danh sach ban chon.</p>
          <form method="POST" action="<%= safeBaseUrl %>/admin/teachers/assign-classes" class="admin-form-grid">
            <div class="admin-field full">
              <label for="assign-teacher-id">Giao vien</label>
              <select class="admin-input" id="assign-teacher-id" name="teacher_id" required>
                <option value="">Chon giao vien</option>
                <% safeTeacherOptions.forEach((item) => { %>
                  <option value="<%= item.id %>"><%= item.full_name %><% if (item.email) { %> · <%= item.email %><% } %></option>
                <% }) %>
              </select>
            </div>
            <div class="admin-field full">
              <label for="assign-class-ids">Danh sach lop phu trach</label>
              <select class="admin-input" id="assign-class-ids" name="class_ids" multiple>
                <% safeClassOptions.forEach((item) => { %>
                  <option value="<%= item.id %>"><%= item.code %> · <%= item.course_name || 'Chua co khoa hoc' %></option>
                <% }) %>
              </select>
            </div>
            <div class="admin-actions full">
              <button class="admin-button secondary" type="submit">Cap nhat phan cong</button>
            </div>
          </form>
        </div>

        <div class="admin-ops-card" data-admin-card-view="resources" style="<%= isResourcesView ? '' : 'display:none' %>">
          <h3>Dang de thi full test moi</h3>
          <p>Chi can tai file de va answer key, de full test moi se xuat hien o full test, theo part va reading.</p>
          <form method="POST" action="<%= safeBaseUrl %>/admin/content/exams/add" enctype="multipart/form-data" class="admin-form-grid">
            <div class="admin-field">
              <label for="exam-year">Nam de</label>
              <input class="admin-input" id="exam-year" name="year" type="number" min="2020" step="1" placeholder="2027" required>
            </div>
            <div class="admin-field">
              <label for="exam-test-number">So test</label>
              <input class="admin-input" id="exam-test-number" name="test_number" type="number" min="1" step="1" placeholder="1" required>
            </div>
            <div class="admin-field full">
              <label for="exam-title">Tieu de hien thi</label>
              <input class="admin-input" id="exam-title" name="title" type="text" placeholder="VD: De ETS 2027 Test 1" required>
            </div>
            <div class="admin-field full">
              <label for="exam-book-name">Nhan sach / bo de</label>
              <input class="admin-input" id="exam-book-name" name="book_name" type="text" placeholder="VD: ETS 2027">
            </div>
            <div class="admin-field full">
              <label for="exam-data-file">File de thi (.json / .js)</label>
              <input class="admin-file-input" id="exam-data-file" name="exam_data_file" type="file" accept=".json,.js" required>
            </div>
            <div class="admin-field full">
              <label for="exam-answer-file">File answer key (.json / .js)</label>
              <input class="admin-file-input" id="exam-answer-file" name="answer_key_file" type="file" accept=".json,.js" required>
            </div>
            <div class="admin-actions full">
              <button class="admin-button" type="submit">Dang de thi moi</button>
            </div>
          </form>
        </div>

        <div class="admin-ops-card" data-admin-card-view="resources" style="<%= isResourcesView ? '' : 'display:none' %>">
          <h3>Dang tai lieu len web</h3>
          <p>Tai lieu duoc dua vao thu vien hoc tap de hoc vien truy cap nhanh ngay tren web.</p>
          <form method="POST" action="<%= safeBaseUrl %>/admin/content/resources/add" enctype="multipart/form-data" class="admin-form-grid">
            <div class="admin-field full">
              <label for="resource-title">Tieu de tai lieu</label>
              <input class="admin-input" id="resource-title" name="title" type="text" placeholder="VD: Bo tai lieu Reading 2027" required>
            </div>
            <div class="admin-field full">
              <label for="resource-description">Mo ta ngan</label>
              <textarea class="admin-input admin-textarea" id="resource-description" name="description" placeholder="Mo ta ngan de hoc vien biet tai lieu nay dung de lam gi"></textarea>
            </div>
            <div class="admin-field">
              <label for="resource-audience">Doi tuong hien thi</label>
              <select class="admin-input" id="resource-audience" name="audience">
                <option value="public">Public</option>
                <option value="student">Student</option>
              </select>
            </div>
            <div class="admin-field full">
              <label for="resource-file">File tai lieu</label>
              <input class="admin-file-input" id="resource-file" name="resource_file" type="file" required>
            </div>
            <div class="admin-actions full">
              <button class="admin-button secondary" type="submit">Dang tai lieu</button>
            </div>
          </form>
        </div>
      </div>
    </article>
  </section>

  <section class="admin-grid admin-grid-2" id="resource-library" data-admin-block="resources" style="<%= isResourcesView ? '' : 'display:none' %>">
    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>De thi da dang ky</h2>
          <p>Danh sach full test duoc admin tai len truc tiep. Cac de nay se tu dong di vao thu vien full test va cac thu vien tach theo part/reading.</p>
        </div>
      </div>

      <div class="admin-content-list">
        <% if (!safeUploadedExamEntries.length) { %>
          <div class="admin-empty">Chua co de thi nao duoc dang ky tu khu admin.</div>
        <% } %>

        <% safeUploadedExamEntries.forEach((item) => { %>
          <div class="admin-content-item">
            <strong><%= item.title || `De ETS ${item.year} Test ${item.testNumber}` %></strong>
            <small><%= item.bookName || `ETS ${item.year}` %> · Nam <%= item.year %> · Test <%= item.testNumber %></small>
            <small>ID: <%= item.id %></small>
          </div>
        <% }) %>
      </div>
    </article>

    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Tai lieu da dua len web</h2>
          <p>Cac file tai lieu duoc quan ly tap trung de tranh that lac va de hoc vien truy cap dung phien ban.</p>
        </div>
      </div>

      <div class="admin-content-list">
        <% if (!safeUploadedResourceEntries.length) { %>
          <div class="admin-empty">Chua co tai lieu nao duoc tai len tu khu admin.</div>
        <% } %>

        <% safeUploadedResourceEntries.forEach((item) => { %>
          <div class="admin-content-item">
            <strong><%= item.title || item.originalName || 'Tai lieu moi' %></strong>
            <small>Doi tuong: <%= item.audience || 'public' %></small>
            <small><%= item.description || item.originalName || 'Khong co mo ta.' %></small>
            <small><a href="<%= item.publicPath %>" target="_blank" rel="noreferrer">Mo tai lieu</a></small>
          </div>
        <% }) %>
      </div>
    </article>
  </section>

  <section class="admin-grid admin-grid-2" id="system" data-admin-block="overview" style="<%= isOverviewView ? '' : 'display:none' %>">
    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Tài khoản mới tạo</h2>
          <p>Danh sách tài khoản gần nhất để kiểm tra phân quyền và hoạt động onboarding.</p>
        </div>
      </div>

      <div class="admin-micro-list">
        <% if (!safeUsers.length) { %>
          <div class="admin-empty">Chưa có tài khoản nào được ghi nhận.</div>
        <% } %>

        <% safeUsers.forEach((item) => { %>
          <div class="admin-user-card">
            <h3><%= item.username || item.email || "Tài khoản mới" %></h3>
            <p><%= item.email || "Chưa có email" %></p>
            <small>
              Vai trò: <%= roleLabelMap[item.role] || item.role || "Khác" %> · Tạo lúc <%= shortDateTime(item.created_at) %>
            </small>
          </div>
        <% }) %>
      </div>
    </article>

    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Năng lực đội ngũ và khóa học</h2>
          <p>So sánh tải giảng dạy của giáo viên và hiệu suất ghi danh theo khóa học.</p>
        </div>
      </div>

      <div class="admin-list">
        <div class="admin-table-card">
          <h3>Tải giảng dạy</h3>
          <div class="admin-bar-list">
            <% if (!teacherLoad.length) { %>
              <div class="admin-empty">Chưa có dữ liệu tải giảng dạy.</div>
            <% } %>

            <% teacherLoad.forEach((item) => {
              const maxTeacherLoad = Math.max(...teacherLoad.map((entry) => Number(entry.enrollment_count || 0)), 1);
              const width = Math.max((Number(item.enrollment_count || 0) / maxTeacherLoad) * 100, item.enrollment_count ? 10 : 0);
            %>
              <div class="admin-bar-row">
                <div class="admin-bar-top">
                  <span><%= item.full_name || "Giáo viên" %></span>
                  <small><%= numberFmt(item.enrollment_count) %> học viên</small>
                </div>
                <div class="admin-progress"><i style="width: <%= width %>%"></i></div>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="admin-table-card">
          <h3>Khóa học nổi bật</h3>
          <div class="admin-bar-list">
            <% if (!coursePerformance.length) { %>
              <div class="admin-empty">Chưa có dữ liệu hiệu quả khóa học.</div>
            <% } %>

            <% coursePerformance.forEach((item) => {
              const maxCourseEnrollments = Math.max(...coursePerformance.map((entry) => Number(entry.enrollment_count || 0)), 1);
              const width = Math.max((Number(item.enrollment_count || 0) / maxCourseEnrollments) * 100, item.enrollment_count ? 10 : 0);
            %>
              <div class="admin-bar-row">
                <div class="admin-bar-top">
                  <span><%= item.name || "Khóa học" %></span>
                  <small><%= numberFmt(item.enrollment_count) %> ghi danh</small>
                </div>
                <div class="admin-progress"><i style="width: <%= width %>%"></i></div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </article>
  </section>

  <section class="admin-grid admin-grid-2" data-admin-block="overview" style="<%= isOverviewView ? '' : 'display:none' %>">
    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Tin nhắn mới</h2>
          <p>Những yêu cầu tư vấn gần nhất để đội ngũ phản hồi đúng nhịp.</p>
        </div>
        <a class="admin-panel-link" href="<%= safeBaseUrl %>/messages">Mở hộp thư</a>
      </div>

      <div class="admin-list">
        <% if (!safeMessages.length) { %>
          <div class="admin-empty">Chưa có yêu cầu tư vấn mới.</div>
        <% } %>

        <% safeMessages.forEach((item) => { %>
          <div class="admin-table-card">
            <h3><%= item.name || item.email || "Yêu cầu mới" %></h3>
            <p><%= item.message || "Chưa có nội dung." %></p>
            <div class="admin-feed-meta">
              <span class="admin-inline-badge"><%= messageStatusMap[item.status || "new"] || item.status || "Mới" %></span>
              <span><%= shortDateTime(item.created_at) %></span>
            </div>
          </div>
        <% }) %>
      </div>
    </article>

    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Thanh toán gần đây</h2>
          <p>Kiểm tra tình trạng xác nhận và đối chiếu nhanh theo lớp hoặc khóa học.</p>
        </div>
        <a class="admin-panel-link" href="<%= safeBaseUrl %>/payments">Mở thanh toán</a>
      </div>

      <div class="admin-list">
        <% if (!safePayments.length) { %>
          <div class="admin-empty">Chưa có giao dịch nào được ghi nhận.</div>
        <% } %>

        <% safePayments.forEach((item) => {
          const statusClass =
            item.status === "confirmed"
              ? "status-active"
              : item.status === "pending"
                ? "status-pending"
                : item.status === "rejected"
                  ? "status-rejected"
                  : "";
        %>
          <div class="admin-table-card">
            <h3><%= item.student_name || "Học viên" %></h3>
            <p>
              <%= item.course_name || "Chưa có khóa học" %>
              <% if (item.class_code) { %>· Lớp <%= item.class_code %><% } %>
            </p>
            <div class="admin-feed-meta">
              <span class="admin-status <%= statusClass %>"><%= paymentStatusMap[item.status] || item.status || "Chưa cập nhật" %></span>
              <span><%= paymentMethodMap[item.method] || item.method || "Khác" %></span>
              <span><%= moneyFmt(item.amount) %></span>
              <span><%= shortDateTime(item.paid_at) %></span>
            </div>
          </div>
        <% }) %>
      </div>
    </article>
  </section>
</div>

<script>
  const adminWorkspaceView = "<%= currentAdminView %>";
  const adminViewMetaClient = <%- JSON.stringify(adminViewMeta) %>;
  const adminModuleLinksClient = <%- JSON.stringify(adminModuleLinks) %>;

  function toggleAdminEditor(id) {
    const row = document.getElementById(id);
    if (!row) return;
    row.classList.toggle("hidden");
    if (!row.classList.contains("hidden")) {
      row.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }
  }

  function applyAdminWorkspaceView() {
    const heroTopBadge = document.querySelector(".admin-hero-topline .admin-badge");
    const heroBadge = document.querySelector(".admin-hero-content > .admin-badge");
    const heroTitle = document.querySelector(".admin-hero-content h1");
    const heroDescription = document.querySelector(".admin-hero-content > p");
    const heroActions = document.querySelectorAll(".admin-hero-actions a");
    const heroHighlights = document.querySelector(".admin-hero-highlights");
    const anchorBar = document.querySelector(".admin-anchorbar");

    if (heroTopBadge) heroTopBadge.textContent = adminViewMetaClient.badge || "";
    if (heroBadge) heroBadge.textContent = adminViewMetaClient.badge || "";
    if (heroTitle) heroTitle.textContent = adminViewMetaClient.title || "";
    if (heroDescription) heroDescription.textContent = adminViewMetaClient.description || "";

    if (heroActions[0]) {
      heroActions[0].textContent = adminViewMetaClient.primaryLabel || "Mở mục này";
      heroActions[0].setAttribute("href", adminViewMetaClient.primaryHref || "#overview");
    }

    if (heroActions[1]) {
      heroActions[1].textContent = adminViewMetaClient.secondaryLabel || "Mở chi tiết";
      heroActions[1].setAttribute("href", adminViewMetaClient.secondaryHref || "#overview");
    }

    if (heroHighlights) {
      heroHighlights.innerHTML = (adminViewMetaClient.highlights || [])
        .map((item) => {
          const value = typeof item.value === "string" ? item.value : Number(item.value || 0).toLocaleString("vi-VN");
          return `<article class="admin-highlight"><strong>${value}</strong><span>${item.label || ""}</span></article>`;
        })
        .join("");
    }

    if (anchorBar) {
      anchorBar.innerHTML = adminModuleLinksClient
        .map((item) => {
          const isActive = item.key === adminWorkspaceView;
          return `<a class="admin-anchor${isActive ? " is-active" : ""}" href="${item.href}">${item.label}</a>`;
        })
        .join("");
    }

    document.querySelectorAll("[data-admin-block]").forEach((block) => {
      const blockView = block.getAttribute("data-admin-block");
      block.style.display = blockView === adminWorkspaceView ? "" : "none";
    });

    const contentSection = document.getElementById("content");
    if (contentSection) {
      contentSection.style.display = "";

      contentSection.querySelectorAll("[data-admin-card-view]").forEach((card) => {
        const cardView = card.getAttribute("data-admin-card-view");
        card.style.display = cardView === adminWorkspaceView ? "" : "none";
      });

      contentSection.querySelectorAll("[data-admin-ops-panel]").forEach((panel) => {
        const hasVisibleCard = Array.from(panel.querySelectorAll("[data-admin-card-view]")).some(
          (card) => card.style.display !== "none"
        );
        panel.style.display = hasVisibleCard ? "" : "none";
      });

      const hasVisiblePanel = Array.from(contentSection.querySelectorAll("[data-admin-ops-panel]")).some(
        (panel) => panel.style.display !== "none"
      );
      contentSection.style.display = hasVisiblePanel ? "" : "none";

      const classStudentPanel = document.getElementById("class-student-ops-panel");
      if (classStudentPanel) {
        const panelTitle = classStudentPanel.querySelector(".admin-panel-header h2");
        const panelDescription = classStudentPanel.querySelector(".admin-panel-header p");

        if (adminWorkspaceView === "students") {
          if (panelTitle) panelTitle.textContent = "Vận hành học viên";
          if (panelDescription) panelDescription.textContent = "Ghi danh offline, mở classroom và liên kết tài khoản cho học viên từ một khu thao tác riêng.";
        } else {
          if (panelTitle) panelTitle.textContent = "Vận hành lớp học";
          if (panelDescription) panelDescription.textContent = "Tạo lớp mới và xử lý các thao tác lớp học cốt lõi ngay trên khu quản trị.";
        }
      }

      const teacherResourcePanel = document.getElementById("teacher-resource-ops-panel");
      if (teacherResourcePanel) {
        const panelTitle = teacherResourcePanel.querySelector(".admin-panel-header h2");
        const panelDescription = teacherResourcePanel.querySelector(".admin-panel-header p");

        if (adminWorkspaceView === "teachers") {
          if (panelTitle) panelTitle.textContent = "Điều phối giáo viên";
          if (panelDescription) panelDescription.textContent = "Tạo giáo viên mới, gán lớp phụ trách và quản lý phân công theo đúng luồng vận hành.";
        } else if (adminWorkspaceView === "resources") {
          if (panelTitle) panelTitle.textContent = "Kho nội dung";
          if (panelDescription) panelDescription.textContent = "Đăng đề thi mới và tải tài liệu mới lên web mà không cần đi qua các khối quản trị khác.";
        }
      }
    }
  }

  applyAdminWorkspaceView();

  document.querySelectorAll("[data-admin-search]").forEach((input) => {
    const group = input.getAttribute("data-admin-search");
    const rows = Array.from(document.querySelectorAll(`[data-filter-row="${group}"]`));

    input.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();

      rows.forEach((row) => {
        const haystack = (row.getAttribute("data-filter-text") || row.textContent || "").toLowerCase();
        const visible = !query || haystack.includes(query);
        row.style.display = visible ? "" : "none";

        const editRowId = row.getAttribute("data-edit-row");
        if (editRowId) {
          const editRow = document.getElementById(editRowId);
          if (editRow && !visible) {
            editRow.classList.add("hidden");
          }
        }
      });
    });
  });
</script>
