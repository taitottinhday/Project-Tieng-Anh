                      </form>
                    </div>
                  </td>
                </tr>
                <tr id="student-edit-<%= item.id %>" class="admin-edit-row hidden">
                  <td colspan="6">
                    <form class="admin-inline-form" method="POST" action="<%= safeBaseUrl %>/admin/students/<%= item.id %>/update">
                      <div class="admin-form-grid">
                        <div class="admin-field full">
                          <label>Họ và tên</label>
                          <input class="admin-input" name="full_name" type="text" value="<%= item.full_name || '' %>" required>
                        </div>
                        <div class="admin-field">
                          <label>Số điện thoại</label>
                          <input class="admin-input" name="phone" type="text" value="<%= item.phone || '' %>">
                        </div>
                        <div class="admin-field">
                          <label>Email</label>
                          <input class="admin-input" name="email" type="email" value="<%= item.email || '' %>">
                        </div>
                        <div class="admin-field full">
                          <label>Ngày sinh</label>
                          <input class="admin-input" name="dob" type="date" value="<%= dateFieldValue(item.dob) %>">
