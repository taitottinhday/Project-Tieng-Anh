<div class="admin-page">
  <section class="admin-hero" id="overview">
    <div class="admin-hero-content">
      <div class="admin-hero-topline">
        <span class="admin-badge">Trung tâm điều hành</span>
        <span class="admin-live-pill">Dữ liệu trực tiếp</span>
      </div>
      <span class="admin-badge">Trung tâm điều hành</span>
      <h1>Quản lý trung tâm dễ dàng – theo dõi học viên, giảng viên và doanh thu trong một nền tảng duy nhất.</h1>
      <p>
        Theo dõi sức khỏe vận hành của trung tâm theo thời gian thực, xử lý lớp học chưa phân công, hoàn thiện hồ sơ
        và phản hồi các yêu cầu tư vấn ngay từ cùng một dashboard.
      </p>
      <div class="admin-hero-actions">
        <a class="admin-hero-action primary" href="#classes">Xem lớp học</a>
        <a class="admin-hero-action secondary" href="<%= safeBaseUrl %>/payments">Duyệt thanh toán</a>
      </div>

      <div class="admin-hero-highlights">
        <article class="admin-highlight">
          <strong><%= numberFmt(safeStats.classesStartingSoon) %></strong>
          <span>Lớp sắp khai giảng</span>
        </article>
        <article class="admin-highlight">
          <strong><%= numberFmt(safeStats.unassignedClasses) %></strong>
          <span>Lớp cần phân công</span>
        </article>
        <article class="admin-highlight">
          <strong><%= numberFmt(safeStats.pendingPayments) %></strong>
          <span>Thanh toán chờ duyệt</span>
        </article>
      </div>
    </div>

    <div class="admin-hero-meta">
      <div class="admin-info-card admin-info-card-primary">
        <span>Cập nhật gần nhất</span>
        <strong><%= shortDateTime(generatedOn) %></strong>
      </div>
      <div class="admin-info-card">
        <span>Doanh thu tháng này</span>
        <strong><%= moneyFmt(safeStats.thisMonthRevenue) %></strong>
      </div>
      <div class="admin-info-card">
        <span>Tỷ lệ phản hồi tư vấn</span>
        <strong><%= numberFmt(safeHealth.leadResponseRate) %>%</strong>
      </div>
      <div class="admin-hero-pulse">
        <div>
          <span>Tỷ lệ thu tiền</span>
          <strong><%= numberFmt(safeHealth.collectionRate) %>%</strong>
        </div>
        <div>
          <span>Học viên mỗi lớp</span>
          <strong><%= safeHealth.averageStudentsPerClass || "0.0" %></strong>
        </div>
        <div>
          <span>Hồ sơ đủ thông tin</span>
          <strong><%= numberFmt(safeHealth.studentProfileCoverage) %>%</strong>
        </div>
      </div>
    </div>
  </section>

  <div class="admin-anchorbar">
    <a class="admin-anchor" href="#overview">Tổng quan</a>
    <a class="admin-anchor" href="#classes">Lớp học</a>
    <a class="admin-anchor" href="#students">Học sinh</a>
    <a class="admin-anchor" href="#teachers">Giáo viên</a>
    <a class="admin-anchor" href="#system">Hệ thống</a>
  </div>

  <section class="admin-kpi-grid" data-admin-block="overview" style="<%= isOverviewView ? '' : 'display:none' %>">
    <article class="admin-kpi">
      <span>Tổng học sinh</span>
      <strong><%= numberFmt(safeStats.totalStudents) %></strong>
      <small><%= numberFmt(safeStats.studentsMissingContact) %> hồ sơ cần bổ sung</small>
    </article>
    <article class="admin-kpi">
      <span>Tổng giáo viên</span>
      <strong><%= numberFmt(safeStats.totalTeachers) %></strong>
      <small><%= numberFmt(safeStats.teachersMissingContact) %> hồ sơ cần cập nhật</small>
    </article>
    <article class="admin-kpi">
      <span>Lớp đang vận hành</span>
      <strong><%= numberFmt(safeStats.totalClasses) %></strong>
      <small><%= numberFmt(safeStats.classesStartingSoon) %> lớp sắp khai giảng</small>
    </article>
    <article class="admin-kpi">
      <span>Tổng doanh thu</span>
      <strong><%= moneyFmt(safeStats.totalRevenue) %></strong>
      <small><%= numberFmt(safeStats.pendingPayments) %> thanh toán chờ duyệt</small>
    </article>
  </section>

  <section class="admin-grid admin-grid-2" data-admin-block="overview" style="<%= isOverviewView ? '' : 'display:none' %>">
    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Xu hướng ghi danh</h2>
          <p>Số lượng ghi danh trong 6 tháng gần nhất để theo dõi nhịp tăng trưởng.</p>
        </div>
      </div>

      <div class="admin-chart">
        <svg viewBox="0 0 560 230" aria-hidden="true">
          <% [48, 96, 144, 192].forEach((lineY) => { %>
            <line class="chart-grid-line" x1="20" y1="<%= lineY %>" x2="540" y2="<%= lineY %>"></line>
          <% }) %>
          <% if (enrollmentArea) { %>
            <polygon class="chart-area" points="<%= enrollmentArea %>"></polygon>
          <% } %>
          <% if (enrollmentLine) { %>
            <polyline class="chart-line" points="<%= enrollmentLine %>"></polyline>
          <% } %>
          <% enrollmentTrend.forEach((item, index) => {
            const spanX = chartWidth - padX * 2;
            const spanY = chartHeight - padY * 2;
            const divisor = Math.max(enrollmentTrend.length - 1, 1);
            const x = padX + (spanX * index) / divisor;
            const y = chartHeight - padY - (spanY * Number(item.value || 0)) / Math.max(enrollmentMax, 1);
          %>
            <circle class="chart-dot" cx="<%= x %>" cy="<%= y %>" r="5"></circle>
          <% }) %>
        </svg>

        <div class="chart-axis">
          <% enrollmentTrend.forEach((item) => { %>
            <span><%= item.label %> · <%= numberFmt(item.value) %></span>
          <% }) %>
        </div>
      </div>
    </article>

    <article class="admin-panel">
      <div class="admin-panel-header">
        <div>
          <h2>Doanh thu và cơ cấu người dùng</h2>
          <p>Tổng hợp nguồn thu theo tháng và tỷ trọng các nhóm tài khoản hiện có.</p>
        </div>
        <a class="admin-panel-link" href="<%= safeBaseUrl %>/payments">Xem thanh toán</a>
      </div>

      <div class="admin-mini-grid">
        <% if (!revenueTrend.length) { %>
          <div class="admin-empty">Chưa có dữ liệu doanh thu theo tháng.</div>
        <% } %>

        <% revenueTrend.forEach((item) => {
          const maxRevenue = Math.max(...revenueTrend.map((entry) => Number(entry.value || 0)), 1);
          const width = Math.max((Number(item.value || 0) / maxRevenue) * 100, item.value ? 10 : 0);
        %>
          <div class="admin-quick-card">
            <strong><%= moneyFmt(item.value) %></strong>
            <span><%= item.label %></span>
            <div class="admin-progress"><i style="width: <%= width %>%"></i></div>
          </div>
        <% }) %>
      </div>
    </article>
  </section>

