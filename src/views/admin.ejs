      .admin-kpi-grid,
      .admin-health-grid {
        grid-template-columns: 1fr;
      }

      .admin-panel,
      .admin-hero {
        padding: 22px;
      }

      .admin-anchorbar {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
