    line-height: 1;
  }

  .admin-highlight span {
    display: block;
    margin-top: 10px;
    color: rgba(224, 233, 244, 0.76);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .admin-meta-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .admin-hero .admin-info-card {
    overflow: hidden;
    border-color: rgba(191, 219, 254, 0.14);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(18px);
  }

  .admin-hero .admin-info-card::before {
    content: "";
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, rgba(125, 211, 252, 0.9), rgba(94, 234, 212, 0));
  }

  .admin-info-card-primary {
    min-height: 132px;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.16) 0%, rgba(255, 255, 255, 0.06) 100%),
      rgba(255, 255, 255, 0.05);
  }

  .admin-hero .admin-info-card span {
    color: rgba(224, 233, 244, 0.72);
    font-size: 0.9rem;
  }

  .admin-hero .admin-info-card strong {
    color: #ffffff;
    font-size: clamp(1.7rem, 2.5vw, 2.2rem);
    line-height: 1.08;
  }

  .admin-hero-pulse {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    padding: 14px;
    border-radius: 22px;
    border: 1px solid rgba(191, 219, 254, 0.14);
    background: rgba(8, 18, 31, 0.26);
    backdrop-filter: blur(18px);
  }

  .admin-hero-pulse div {
    padding: 14px 14px 12px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.05);
  }

  .admin-hero-pulse span {
    display: block;
    color: rgba(224, 233, 244, 0.7);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .admin-hero-pulse strong {
    display: block;
    margin-top: 8px;
    color: #f8fbff;
    font-size: 1.25rem;
    line-height: 1.1;
  }

  .admin-anchorbar {
    padding: 10px;
    border-radius: 24px;
    background: linear-gradient(135deg, rgba(17, 34, 54, 0.92) 0%, rgba(33, 63, 94, 0.82) 100%);
    border: 1px solid rgba(148, 163, 184, 0.16);
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.14);
  }

  .admin-anchor {
    min-width: 154px;
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.05);
    color: #e6eef8;
    backdrop-filter: blur(14px);
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }

  .admin-anchor:hover {
    transform: translateY(-2px);
    border-color: rgba(191, 219, 254, 0.22);
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.18) 0%, rgba(34, 211, 238, 0.16) 100%);
    box-shadow: 0 16px 28px rgba(10, 20, 34, 0.16);
  }

  .admin-kpi {
    overflow: hidden;
    min-height: 156px;
    border-color: rgba(148, 163, 184, 0.12);
    background: linear-gradient(160deg, rgba(17, 31, 48, 0.98) 0%, rgba(26, 44, 67, 0.98) 64%, rgba(31, 58, 90, 0.98) 100%);
    box-shadow: 0 24px 44px rgba(15, 23, 42, 0.16);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .admin-kpi::before {
    content: "";
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, #7dd3fc, #38bdf8);
  }

  .admin-kpi::after {
    content: "";
    position: absolute;
    inset: auto -28px -34px auto;
    width: 132px;
    height: 132px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(125, 211, 252, 0.2), transparent 72%);
    pointer-events: none;
  }

  .admin-kpi:hover {
    transform: translateY(-3px);
    box-shadow: 0 28px 54px rgba(15, 23, 42, 0.2);
  }

  .admin-kpi span {
    color: rgba(219, 233, 247, 0.76);
  }

  .admin-kpi strong {
    color: #ffffff;
    font-size: clamp(2rem, 3vw, 2.45rem);
  }

  .admin-kpi small {
    color: #b8cbe2;
  }

  .admin-kpi:nth-child(2)::before {
    background: linear-gradient(90deg, #6ee7b7, #14b8a6);
  }

  .admin-kpi:nth-child(3)::before {
    background: linear-gradient(90deg, #f9a8d4, #c084fc);
  }

  .admin-kpi:nth-child(4)::before {
    background: linear-gradient(90deg, #fcd34d, #fb923c);
  }

  .admin-hero-content,
  .admin-hero-meta,
  .admin-anchorbar,
  .admin-kpi {
    animation: adminFadeUp 0.72s cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }

  .admin-hero-meta {
    animation-delay: 0.08s;
  }

  .admin-anchorbar {
    animation-delay: 0.14s;
  }

  .admin-kpi:nth-child(1) {
    animation-delay: 0.2s;
  }

  .admin-kpi:nth-child(2) {
    animation-delay: 0.26s;
  }

  .admin-kpi:nth-child(3) {
    animation-delay: 0.32s;
  }

  .admin-kpi:nth-child(4) {
    animation-delay: 0.38s;
  }

  @keyframes adminAurora {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(-18px, -14px, 0) scale(1.06);
    }
  }

  @keyframes adminFadeUp {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes adminPulse {
    0% {
      box-shadow: 0 0 0 0 rgba(94, 234, 212, 0.55);
    }
    70% {
      box-shadow: 0 0 0 12px rgba(94, 234, 212, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(94, 234, 212, 0);
    }
  }

  @media (max-width: 1180px) {
    .admin-hero-highlights,
    .admin-hero-pulse {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 920px) {
    .admin-hero-meta,
    .admin-meta-grid,
    .admin-hero-highlights,
    .admin-hero-pulse {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .admin-hero::after,
    .admin-live-pill::before,
    .admin-hero-content,
    .admin-hero-meta,
    .admin-anchorbar,
    .admin-kpi {
      animation: none !important;
    }
  }
</style>

