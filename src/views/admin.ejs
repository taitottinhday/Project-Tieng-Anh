                        </div>
                        <div class="admin-field">
                          <label>Số điện thoại</label>
                          <input class="admin-input" name="phone" type="text" value="<%= item.phone || '' %>">
                        </div>
                        <div class="admin-field">
                          <label>Email</label>
                          <input class="admin-input" name="email" type="email" value="<%= item.email || '' %>">
                        </div>
                      </div>
                      <div class="admin-actions">
                        <button class="admin-button" type="submit">Lưu thay đổi</button>
                        <button class="admin-button secondary" type="button" onclick="toggleAdminEditor('teacher-edit-<%= item.id %>')">Đóng</button>
                      </div>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <style>
