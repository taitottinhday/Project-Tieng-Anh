                        <button class="admin-button secondary" type="button" onclick="toggleAdminEditor('student-edit-<%= item.id %>')">Đóng</button>
                      </div>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
