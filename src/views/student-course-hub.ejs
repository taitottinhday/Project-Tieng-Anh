<%
const safeBaseUrl = typeof baseUrl !== "undefined" ? baseUrl : "";
const hub = typeof courseHub !== "undefined" && courseHub ? courseHub : {};
const cards = Array.isArray(hub.cards) ? hub.cards : [];
const comboBanner = hub.comboBanner || null;
const promoCards = Array.isArray(hub.promoCards) ? hub.promoCards : [];

function renderMedia(url, alt, placeholder, className) {
  if (url) {
    return `<div class="${className}"><img src="${url}" alt="${alt}"></div>`;
  }

  return `
    <div class="${className}">
      <div class="sch-media-placeholder">
        <span>${placeholder}</span>
      </div>
    </div>
  `;
}
%>

<style>
  .sch-page {
    display: grid;
    width: min(1320px, calc(100% - 56px));
    margin: 0 auto;
    gap: 20px;
    padding: 16px 0 28px;
  }

  .sch-banner {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    min-height: 42px;
    padding: 0 18px;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(255, 108, 108, 0.14) 0%, rgba(255, 179, 71, 0.18) 100%);
    color: #c2410c;
    font-weight: 800;
    border: 1px solid rgba(251, 146, 60, 0.2);
  }

  .sch-grid,
  .sch-promo-grid {
    display: grid;
    gap: 20px;
  }

  .sch-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .sch-promo-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .sch-card,
  .sch-combo,
  .sch-promo-card {
    position: relative;
    overflow: hidden;
    color: inherit;
  }

  .sch-card {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(200px, 0.78fr);
    gap: 18px;
    min-height: 324px;
    padding: 24px 24px 0;
  }

  .sch-card.starter {
    background: #f5e8fb;
  }

  .sch-card.a {
    background: #dee0ff;
  }

  .sch-card.b {
    background: #f8dfd5;
  }

  .sch-card.sw {
    background: #dbf7ec;
  }

  .sch-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    min-width: 0;
    padding-top: 4px;
  }

  .sch-title,
  .sch-combo-copy h2,
  .sch-promo-title {
    margin: 0;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    letter-spacing: -0.06em;
  }

  .sch-title {
    font-size: clamp(2.6rem, 4vw, 4rem);
    line-height: 0.92;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .sch-card.starter .sch-title {
    color: #d76bcb;
  }

  .sch-card.a .sch-title {
    color: #7c3aed;
  }

  .sch-card.b .sch-title {
    color: #ff5d7a;
  }

  .sch-card.sw .sch-title {
    color: #14b8c5;
  }

  .sch-bullets {
    margin: 0;
    padding-left: 22px;
    color: #2f3640;
    font-size: 1rem;
    line-height: 1.7;
  }

  .sch-price {
    display: grid;
    gap: 6px;
    margin-top: 8px;
    justify-self: start;
  }

  .sch-price-original {
    color: #7c8598;
    font-size: 1rem;
    text-decoration: line-through;
    text-decoration-thickness: 2px;
  }

  .sch-price strong {
    font-size: 2rem;
    line-height: 1;
    letter-spacing: -0.05em;
    color: #111827;
  }

  .sch-price span {
    color: #44403c;
    font-size: 0.98rem;
  }

  .sch-price-note {
    color: #c2410c;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .sch-note {
    margin: 0;
    max-width: 320px;
    color: #4b5563;
    font-size: 0.84rem;
    line-height: 1.55;
  }

  .sch-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: auto;
    padding-bottom: 24px;
  }

  .sch-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 24px;
    border-radius: 999px;
    background: #000000;
    color: #ffffff;
    font-size: 1rem;
    font-weight: 800;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .sch-btn:hover,
  .sch-card:hover,
  .sch-combo:hover,
  .sch-promo-card:hover {
    transform: translateY(-1px);
  }

  .sch-combo {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.9fr);
    gap: 18px;
    align-items: center;
    min-height: 392px;
    padding: 24px 24px 0;
    background: linear-gradient(180deg, #e84b31 0%, #ef7158 100%);
  }

  .sch-combo-copy {
    display: grid;
    justify-items: center;
    gap: 16px;
    text-align: center;
    color: #ffffff;
  }

  .sch-combo-copy h2 {
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1.02;
  }

  .sch-combo-copy strong {
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .sch-promo-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(180px, 0.76fr);
    gap: 16px;
    align-items: end;
    min-height: 324px;
    padding: 22px 0 0 22px;
  }

  .sch-promo-card.placement {
    background: linear-gradient(180deg, #e49a00 0%, #efb31a 100%);
  }

  .sch-promo-card.schedule {
    background: linear-gradient(180deg, #77adc2 0%, #8ec5d6 100%);
  }

  .sch-promo-card.video {
    background: linear-gradient(180deg, #8f67ff 0%, #5b4ee6 100%);
  }

  .sch-promo-copy {
    display: grid;
    align-content: start;
    gap: 12px;
    padding-bottom: 24px;
  }

  .sch-promo-title {
    color: #ffffff;
    font-size: clamp(2.1rem, 3.6vw, 3.8rem);
    line-height: 0.94;
    white-space: pre-line;
  }

  .sch-media,
  .sch-media-placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .sch-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sch-media.course {
    min-height: 296px;
  }

  .sch-media.combo {
    min-height: 360px;
  }

  .sch-media.promo {
    min-height: 298px;
  }

  .sch-media-placeholder {
    position: relative;
    display: grid;
    place-items: center;
    gap: 10px;
    padding: 24px;
    text-align: center;
    color: rgba(17, 24, 39, 0.9);
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.28), transparent 28%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0.08) 100%);
  }

  .sch-combo .sch-media-placeholder,
  .sch-promo-card .sch-media-placeholder {
    color: rgba(255, 255, 255, 0.96);
  }

  .sch-media-placeholder::before {
    content: "";
    position: absolute;
    inset: 14px;
    border: 1.5px dashed currentColor;
    border-radius: 24px;
    opacity: 0.35;
  }

  .sch-media-placeholder span {
    position: relative;
    z-index: 1;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    font-size: clamp(1.05rem, 2vw, 1.45rem);
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  @media (max-width: 1180px) {
    .sch-grid,
    .sch-promo-grid {
      grid-template-columns: 1fr;
    }

    .sch-card,
    .sch-combo,
    .sch-promo-card {
      grid-template-columns: 1fr;
      padding-right: 26px;
    }

    .sch-copy {
      align-items: center;
      text-align: center;
    }

    .sch-promo-copy,
    .sch-combo-copy {
      justify-items: center;
      text-align: center;
    }

    .sch-bullets {
      text-align: left;
    }

    .sch-price,
    .sch-actions {
      justify-self: center;
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .sch-page {
      width: min(100% - 20px, 1320px);
      gap: 14px;
      padding-bottom: 12px;
    }

    .sch-card,
    .sch-combo,
    .sch-promo-card {
      min-height: auto;
      padding: 18px 18px 0;
    }

    .sch-title {
      font-size: clamp(2.1rem, 12vw, 3rem);
    }

    .sch-promo-title {
      font-size: clamp(2rem, 12vw, 3.2rem);
    }
  }
</style>

<div class="sch-page">
  <div class="sch-banner">Ưu đãi học viên: giảm 25% học phí khi đăng ký online</div>

  <section class="sch-grid">
    <% cards.forEach((item) => { %>
      <article class="sch-card <%= item.tone %>">
        <div class="sch-copy">
          <h2 class="sch-title"><%= item.title %></h2>
          <ul class="sch-bullets">
            <% (item.bullets || []).forEach((bullet) => { %>
              <li><%= bullet %></li>
            <% }) %>
          </ul>

          <div class="sch-price">
            <span class="sch-price-original"><%= Number(item.originalFee || 0).toLocaleString("vi-VN") %>đ</span>
            <strong><%= Number(item.discountedFee || 0).toLocaleString("vi-VN") %>đ</strong>
            <span><%= item.sessions %></span>
            <span class="sch-price-note">Số tiền thực đóng sau ưu đãi 25%</span>
          </div>

          <% if (item.note) { %>
            <p class="sch-note"><%= item.note %></p>
          <% } %>

          <div class="sch-actions">
            <a href="<%= item.registerHref %>" class="sch-btn">Đăng ký</a>
          </div>
        </div>

        <%- renderMedia(item.image, item.title, item.placeholder, "sch-media course") %>
      </article>
    <% }) %>
  </section>

  <% if (comboBanner) { %>
    <a href="<%= comboBanner.href %>" class="sch-combo">
      <div class="sch-combo-copy">
        <h2><%= comboBanner.title %></h2>
        <strong><%= comboBanner.price %></strong>
        <span class="sch-btn"><%= comboBanner.ctaLabel || "Tìm hiểu ngay" %></span>
      </div>

      <%- renderMedia(comboBanner.image, comboBanner.title, comboBanner.placeholder, "sch-media combo") %>
    </a>
  <% } %>

  <section class="sch-promo-grid">
    <% promoCards.forEach((item) => { %>
      <a href="<%= item.href %>" class="sch-promo-card <%= item.tone %>">
        <div class="sch-promo-copy">
          <h2 class="sch-promo-title"><%= item.title %></h2>
        </div>

        <%- renderMedia(item.image, item.title, item.placeholder, "sch-media promo") %>
      </a>
    <% }) %>
  </section>
</div>
