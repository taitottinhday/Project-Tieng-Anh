<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - Thầy Tài Toeic
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --bg: #e8eeff;
            --surface: rgba(255, 255, 255, .94);
            --surface-strong: rgba(255, 255, 255, .98);
            --surface-soft: linear-gradient(145deg, rgba(219, 233, 255, .74) 0%, rgba(255, 221, 239, .74) 100%);
            --surface-soft-alt: linear-gradient(180deg, rgba(248, 251, 255, .98) 0%, rgba(255, 247, 252, .98) 100%);
            --line: rgba(89, 106, 191, .16);
            --line-soft: rgba(89, 106, 191, .1);
            --text: #0f1d32;
            --muted: #5d6e84;
            --brand: #2f78ed;
            --brand-soft: rgba(47, 120, 237, .1);
            --accent: #e89bbc;
            --accent-soft: rgba(232, 155, 188, .14);
            --dark: #163f73;
            --dark-strong: #102845;
            --shadow-lg: 0 28px 54px rgba(39, 62, 122, .14);
            --shadow-sm: 0 16px 30px rgba(39, 62, 122, .1)
        }

        * {
            box-sizing: border-box
        }

        html {
            scroll-behavior: smooth
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at top left, rgba(47, 120, 237, .28), transparent 24%),
                radial-gradient(circle at top right, rgba(242, 169, 210, .24), transparent 22%),
                radial-gradient(circle at bottom left, rgba(177, 154, 255, .18), transparent 28%),
                linear-gradient(180deg, #eaf0ff 0%, #f9deef 52%, var(--bg) 100%)
        }

        body.menu-open {
            overflow: hidden
        }

        a {
            text-decoration: none;
            color: inherit
        }

        .s-header {
            position: sticky;
            top: 0;
            z-index: 50;
            background: linear-gradient(135deg, rgba(222, 236, 255, .78) 0%, rgba(255, 233, 242, .72) 100%);
            backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--line-soft)
        }

        .s-wrap {
            width: min(1780px, calc(100% - 32px));
            margin: 0 auto
        }

        .s-bar {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            align-items: center;
            gap: 14px;
            padding: 8px 0
        }

        .s-brand {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            flex: 0 0 auto
        }

        .s-brand-mark {
            width: 72px;
            height: 46px;
            border-radius: 16px;
            border: 1px solid var(--line);
            background: linear-gradient(135deg, rgba(224, 238, 255, .88) 0%, rgba(255, 233, 242, .9) 100%);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 16px 32px rgba(47, 120, 237, .12);
            overflow: hidden
        }

        .s-brand-mark img {
            width: 100%;
            height: 100%;
            display: block;
            object-fit: contain;
            padding: 3px
        }

        .s-brand-copy {
            display: grid;
            gap: 1px
        }

        .s-brand-copy strong {
            font-family: "Sora", "Be Vietnam Pro", sans-serif;
            font-size: .82rem;
            line-height: 1.08;
            letter-spacing: -.02em;
            color: #1d4f8f;
            text-transform: uppercase
        }

        .s-brand-copy span {
            display: none;
            font-size: .72rem;
            color: var(--muted)
        }

        .s-nav {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 2px;
            min-width: 0;
            padding-inline: 6px;
            overflow: visible
        }

        .s-nav::-webkit-scrollbar {
            display: none
        }

        .s-nav-item {
            position: relative;
            display: inline-flex;
            align-items: center
        }

        .s-link {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            padding: 10px 8px;
            border-radius: 999px;
            color: #45576d;
            font-size: .83rem;
            font-weight: 500;
            white-space: nowrap;
            transition: .2s ease
        }

        .s-link-toggle {
            border: 0;
            background: transparent;
            cursor: pointer;
            gap: 7px
        }

        .s-link-caret {
            flex: 0 0 auto;
            transition: transform .2s ease
        }

        .s-nav-group:hover .s-link-caret,
        .s-nav-group:focus-within .s-link-caret,
        .s-nav-group.is-open .s-link-caret {
            transform: rotate(180deg)
        }

        .s-link:hover {
            transform: translateY(-1px);
            color: #102845;
            background: linear-gradient(135deg, var(--brand-soft) 0%, var(--accent-soft) 100%)
        }

        .s-link.active {
            color: #102845;
            background: linear-gradient(135deg, rgba(47, 120, 237, .1) 0%, rgba(232, 155, 188, .12) 100%)
        }

        .s-link.active::after {
            content: "";
            position: absolute;
            left: 14px;
            right: 14px;
            bottom: 2px;
            height: 3px;
            border-radius: 999px;
            background: linear-gradient(90deg, #2f78ed 0%, #e89bbc 100%)
        }

        .s-link-label-full {
            display: inline
        }

        .s-link-label-short {
            display: none
        }

        .s-subnav {
            position: absolute;
            top: calc(100% + 8px);
            left: 50%;
            width: min(350px, 38vw);
            padding: 14px;
            border-radius: 28px;
            border: 1px solid var(--line);
            background: var(--surface-strong);
            box-shadow: var(--shadow-lg);
            display: grid;
            gap: 8px;
            opacity: 0;
            pointer-events: none;
            transform: translate(-50%, 12px);
            transition: opacity .18s ease, transform .18s ease
        }

        .s-subnav::before {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            top: -18px;
            height: 22px
        }

        .s-nav-group:hover .s-subnav,
        .s-nav-group:focus-within .s-subnav,
        .s-nav-group.is-open .s-subnav {
            opacity: 1;
            pointer-events: auto;
            transform: translate(-50%, 0)
        }

        .s-subnav-link {
            display: grid;
            gap: 4px;
            padding: 14px 16px;
            border-radius: 18px;
            color: #334155;
            transition: transform .2s ease, background .2s ease, color .2s ease
        }

        .s-subnav-link:hover {
            transform: translateY(-1px);
            background: linear-gradient(135deg, var(--brand-soft) 0%, var(--accent-soft) 100%);
            color: #102845
        }

        .s-subnav-link.active {
            background: linear-gradient(135deg, rgba(47, 120, 237, .12) 0%, rgba(232, 155, 188, .14) 100%);
            color: #102845
        }

        .s-subnav-title {
            font-size: .96rem;
            font-weight: 700;
            line-height: 1.35
        }

        .s-subnav-note {
            font-size: .78rem;
            line-height: 1.5;
            color: #64748b;
            white-space: normal
        }

        .s-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            flex: 0 0 auto;
            justify-self: end
        }

        .s-badge {
            display: none;
            align-items: center;
            padding: 7px 12px;
            border-radius: 999px;
            background: linear-gradient(135deg, var(--brand-soft) 0%, var(--accent-soft) 100%);
            color: #1d4f8f;
            font-size: .82rem;
            font-weight: 700
        }

        .s-bell-wrap,
        .s-mail-wrap {
            position: relative;
            flex: 0 0 auto
        }

        .s-bell,
        .s-mail {
            position: relative;
            width: 46px;
            height: 46px;
            border-radius: 16px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .9);
            color: #102845;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: var(--shadow-sm);
            transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease, background .2s ease
        }

        .s-bell:hover,
        .s-bell[aria-expanded="true"],
        .s-mail:hover,
        .s-mail[aria-expanded="true"] {
            transform: translateY(-1px);
            border-color: rgba(89, 106, 191, .2);
            background: linear-gradient(135deg, rgba(226, 239, 255, .96) 0%, rgba(255, 239, 247, .96) 100%);
            box-shadow: 0 18px 34px rgba(47, 120, 237, .14)
        }

        .s-bell-count {
            position: absolute;
            top: -5px;
            right: -4px;
            min-width: 22px;
            height: 22px;
            padding: 0 6px;
            border-radius: 999px;
            background: linear-gradient(135deg, #2f78ed 0%, #e89bbc 100%);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: .72rem;
            font-weight: 800;
            box-shadow: 0 10px 22px rgba(47, 120, 237, .24)
        }

        .s-notify-panel,
        .s-mail-panel {
            position: absolute;
            top: calc(100% + 14px);
            right: 0;
            width: min(420px, calc(100vw - 24px));
            padding: 18px;
            border-radius: 28px;
            border: 1px solid var(--line);
            background: var(--surface-strong);
            box-shadow: var(--shadow-lg);
            display: grid;
            gap: 14px;
            opacity: 0;
            pointer-events: none;
            transform: translateY(12px);
            transition: opacity .18s ease, transform .18s ease;
            z-index: 60
        }

        .s-bell-wrap.is-open .s-notify-panel,
        .s-mail-wrap.is-open .s-mail-panel {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0)
        }

        .s-notify-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px
        }

        .s-notify-copy {
            display: grid;
            gap: 5px
        }

        .s-notify-copy strong {
            color: #0f172a;
            font-size: 1rem
        }

        .s-notify-copy span {
            color: #64748b;
            font-size: .84rem;
            line-height: 1.6
        }

        .s-notify-list {
            display: grid;
            gap: 10px;
            max-height: 420px;
            overflow-y: auto;
            padding-right: 2px
        }

        .s-notify-item {
            display: grid;
            gap: 10px;
            padding: 15px 16px;
            border-radius: 22px;
            border: 1px solid var(--line-soft);
            background: rgba(255, 255, 255, .96)
        }

        .s-notify-item.is-new {
            border-color: rgba(89, 106, 191, .18);
            background: linear-gradient(180deg, rgba(240, 246, 255, .94) 0%, rgba(255, 244, 248, .98) 100%)
        }

        .s-notify-item-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            flex-wrap: wrap
        }

        .s-notify-item-head strong {
            color: #0f172a;
            font-size: .95rem;
            line-height: 1.45
        }

        .s-notify-meta {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #64748b;
            font-size: .78rem;
            font-weight: 700
        }

        .s-notify-tag {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 24px;
            padding: 0 8px;
            border-radius: 999px;
            background: linear-gradient(135deg, rgba(47, 120, 237, .12) 0%, rgba(232, 155, 188, .14) 100%);
            color: #1d4f8f;
            font-size: .7rem;
            font-weight: 800
        }

        .s-notify-item p {
            margin: 0;
            color: #475569;
            line-height: 1.72;
            font-size: .88rem
        }

        .s-notify-item a,
        .s-notify-mark,
        .s-notify-empty-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: fit-content;
            min-height: 40px;
            padding: 0 15px;
            border-radius: 999px;
            font-size: .84rem;
            font-weight: 800
        }

        .s-notify-item a {
            background: linear-gradient(135deg, var(--brand-soft) 0%, var(--accent-soft) 100%);
            color: #1d4f8f
        }

        .s-notify-mark {
            border: 0;
            background: rgba(16, 40, 69, .08);
            color: #102845;
            cursor: pointer
        }

        .s-notify-empty {
            padding: 18px;
            border-radius: 22px;
            background: linear-gradient(180deg, rgba(248, 251, 255, .98) 0%, rgba(255, 247, 252, .98) 100%);
            border: 1px dashed rgba(89, 106, 191, .28);
            display: grid;
            gap: 12px;
            justify-items: start
        }

        .s-notify-empty strong {
            color: #0f172a;
            font-size: .98rem
        }

        .s-notify-empty span {
            color: #64748b;
            line-height: 1.7;
            font-size: .88rem
        }

        .s-notify-empty-link {
            background: linear-gradient(135deg, var(--brand-soft) 0%, var(--accent-soft) 100%);
            color: #1d4f8f
        }

        .s-notifications {
            display: none !important
        }

        .s-profile {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 5px;
            border-radius: 999px;
            background: linear-gradient(135deg, rgba(222, 236, 255, .58) 0%, rgba(255, 255, 255, .92) 100%);
            border: 1px solid var(--line-soft);
            transition: transform .2s ease, background .2s ease, box-shadow .2s ease
        }

        .s-profile:hover {
            transform: translateY(-1px);
            background: linear-gradient(135deg, rgba(226, 239, 255, .96) 0%, rgba(255, 239, 247, .9) 100%);
            box-shadow: var(--shadow-sm)
        }

        .s-profile-meta {
            display: grid;
            gap: 2px;
            max-width: 112px;
            padding-left: 4px
        }

        .s-profile-meta strong,
        .s-profile-meta span {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap
        }

        .s-profile-meta strong {
            font-size: .84rem;
            line-height: 1.1
        }

        .s-profile-meta span {
            font-size: .72rem;
            color: var(--muted)
        }

        .s-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #173f73 0%, #2f78ed 58%, #e89bbc 100%);
            color: #fff;
            font-weight: 800;
            box-shadow: 0 12px 24px rgba(47, 120, 237, .22)
        }

        .s-logout {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 14px;
            border-radius: 999px;
            background: linear-gradient(135deg, var(--dark-strong) 0%, var(--dark) 100%);
            color: #fff;
            font-size: .94rem;
            font-weight: 700;
            box-shadow: 0 16px 30px rgba(22, 63, 115, .18);
            transition: transform .2s ease
        }

        .s-logout:hover {
            transform: translateY(-1px)
        }

        .s-logout-quick {
            display: none;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 46px;
            padding: 0 14px;
            border-radius: 14px;
            border: 1px solid var(--line);
            background: linear-gradient(135deg, rgba(224, 238, 255, .9) 0%, rgba(255, 236, 245, .94) 100%);
            color: #1d4f8f;
            font-size: .88rem;
            font-weight: 800;
            white-space: nowrap;
            box-shadow: 0 12px 26px rgba(47, 120, 237, .12)
        }

        .s-logout-quick svg {
            flex: 0 0 auto
        }

        .s-menu {
            display: none;
            width: 46px;
            height: 46px;
            border-radius: 14px;
            border: 1px solid var(--line);
            background: linear-gradient(135deg, rgba(224, 238, 255, .88) 0%, rgba(255, 233, 242, .88) 100%);
            align-items: center;
            justify-content: center
        }

        .s-mobile {
            display: none;
            position: relative;
            z-index: 120;
            border-top: 1px solid var(--line-soft);
            background: linear-gradient(180deg, rgba(229, 240, 255, .94) 0%, rgba(255, 223, 239, .94) 100%);
            max-height: calc(100vh - 80px);
            overflow-y: auto;
            overscroll-behavior: contain
        }

        body.menu-open .s-mobile {
            display: block
        }
        body.menu-open .s-header {
            z-index: 140
        }
        body.menu-open .eng-fixed-left,
        body.menu-open .eng-fixed-stack {
            opacity: 0;
            pointer-events: none
        }

        .s-mobile-inner {
            width: min(1380px, calc(100% - 32px));
            margin: 0 auto;
            padding: 14px 0 18px;
            display: grid;
            gap: 10px
        }

        .s-mobile-account {
            display: grid;
            gap: 12px;
            padding: 16px;
            border-radius: 22px;
            border: 1px solid var(--line);
            background: var(--surface-soft-alt);
            box-shadow: var(--shadow-sm)
        }

        .s-mobile-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            color: inherit
        }

        .s-mobile-profile-copy {
            display: grid;
            gap: 4px;
            min-width: 0
        }

        .s-mobile-profile-copy strong {
            color: var(--text);
            font-size: .96rem;
            line-height: 1.2
        }

        .s-mobile-profile-copy span {
            color: var(--muted);
            font-size: .8rem;
            line-height: 1.4
        }

        .s-mobile-actions {
            display: grid;
            gap: 10px
        }

        .s-mobile-nav {
            display: grid;
            gap: 12px
        }

        .s-mobile-group {
            display: grid;
            gap: 10px
        }

        .s-mobile-link,
        .s-mobile-group-toggle {
            width: 100%;
            border: 1px solid var(--line-soft);
            border-radius: 16px;
            background: rgba(255, 255, 255, .98);
            box-shadow: 0 12px 28px rgba(39, 62, 122, .08);
            transition: transform .2s ease, border-color .2s ease, background .2s ease, box-shadow .2s ease, color .2s ease
        }

        .s-mobile-link {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: center;
            gap: 14px;
            padding: 16px 18px;
            color: inherit
        }

        .s-mobile-group-toggle {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: center;
            gap: 14px;
            min-height: 0;
            padding: 16px 18px;
            color: #4b5563;
            font: inherit;
            font-size: .92rem;
            font-weight: 700;
            text-align: left;
            cursor: pointer
        }

        .s-mobile-link:hover,
        .s-mobile-group-toggle:hover {
            transform: translateY(-1px);
            border-color: rgba(89, 106, 191, .16);
            box-shadow: 0 16px 30px rgba(47, 120, 237, .1)
        }

        .s-mobile-link-copy,
        .s-mobile-group-copy {
            display: grid;
            gap: 4px;
            min-width: 0
        }

        .s-mobile-link-title {
            color: var(--text);
            font-size: .95rem;
            font-weight: 800;
            line-height: 1.3
        }

        .s-mobile-link-note,
        .s-mobile-group-note,
        .s-mobile-subnav-note {
            color: #64748b;
            font-size: .8rem;
            line-height: 1.55
        }

        .s-mobile-link-icon,
        .s-mobile-group-caret {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 34px;
            height: 34px;
            flex: 0 0 auto;
            padding: 8px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(224, 238, 255, .82) 0%, rgba(255, 233, 242, .84) 100%);
            color: #51657f
        }

        .s-mobile-link.active,
        .s-mobile-group-toggle.active,
        .s-mobile-group.is-open .s-mobile-group-toggle {
            color: #102845;
            background: linear-gradient(180deg, rgba(240, 246, 255, .98) 0%, rgba(255, 242, 248, .98) 100%);
            border-color: rgba(89, 106, 191, .16);
            box-shadow: 0 16px 30px rgba(47, 120, 237, .12)
        }

        .s-mobile-link.active .s-mobile-link-icon,
        .s-mobile-group-toggle.active .s-mobile-group-caret,
        .s-mobile-group.is-open .s-mobile-group-caret {
            background: linear-gradient(135deg, rgba(47, 120, 237, .12) 0%, rgba(232, 155, 188, .14) 100%);
            color: #1d4f8f
        }

        .s-mobile-group-caret {
            transition: transform .2s ease
        }

        .s-mobile-group.is-open .s-mobile-group-caret {
            transform: rotate(180deg)
        }

        .s-mobile-subnav {
            display: none;
            gap: 10px;
            padding: 4px 0 0 16px;
            margin-left: 6px;
            border-left: 1px solid rgba(89, 106, 191, .16)
        }

        .s-mobile-group.is-open .s-mobile-subnav {
            display: grid
        }

        .s-mobile-subnav-link {
            display: grid;
            gap: 4px;
            padding: 14px 16px;
            border-radius: 14px;
            background: rgba(248, 251, 255, .96);
            border: 1px solid var(--line-soft);
            color: #334155;
            font-size: .9rem;
            font-weight: 600;
            transition: transform .2s ease, background .2s ease, border-color .2s ease, color .2s ease
        }

        .s-mobile-subnav-link:hover {
            transform: translateY(-1px);
            border-color: rgba(89, 106, 191, .14)
        }

        .s-mobile-subnav-link.active {
            background: linear-gradient(135deg, rgba(240, 246, 255, .96) 0%, rgba(255, 242, 248, .96) 100%);
            border-color: rgba(89, 106, 191, .16);
            color: #102845
        }

        .s-mobile-link,
        .s-mobile .s-logout {
            width: 100%;
            position: relative;
            z-index: 1;
            pointer-events: auto;
            touch-action: manipulation
        }

        .s-brand,
        .s-link,
        .s-bell,
        .s-mail,
        .s-profile,
        .s-logout,
        .s-mobile-link,
        .s-logout-quick,
        .s-menu,
        .s-mobile-profile {
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent
        }

        .s-stage {
            min-height: calc(100vh - 80px)
        }

        .s-stage :is(h1, h2) {
            font-family: "Sora", "Be Vietnam Pro", sans-serif;
            letter-spacing: -0.05em;
            background: linear-gradient(90deg, #2f78ed 0%, #e89bbc 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .s-flash {
            width: min(1380px, calc(100% - 32px));
            margin: 18px auto 0;
            display: grid;
            gap: 12px
        }

        .s-flash-card {
            padding: 14px 18px;
            border-radius: 20px;
            border: 1px solid var(--line);
            background: var(--surface-soft-alt);
            box-shadow: 0 12px 28px rgba(39, 62, 122, .08)
        }

        .s-flash-card.success {
            color: #166534;
            border-color: rgba(22, 101, 52, .12)
        }

        .s-flash-card.error {
            color: #b91c1c;
            border-color: rgba(185, 28, 28, .12)
        }

        .s-flash-card.info {
            color: #1d4f8f;
            border-color: rgba(89, 106, 191, .16)
        }

        .s-notifications {
            width: min(1380px, calc(100% - 32px));
            margin: 18px auto 0;
            padding: 20px 22px;
            display: grid;
            gap: 16px;
            border-radius: 28px;
            border: 1px solid var(--line);
            background: linear-gradient(135deg, rgba(240, 246, 255, .96) 0%, rgba(255, 242, 248, .96) 100%);
            box-shadow: 0 16px 34px rgba(47, 120, 237, .1)
        }

        .s-notifications-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap
        }

        .s-notifications-headline {
            display: grid;
            gap: 5px
        }

        .s-notifications-headline strong {
            font-size: 1rem;
            color: #0f172a
        }

        .s-notifications-headline span {
            color: #475569;
            font-size: .9rem;
            line-height: 1.6
        }

        .s-notifications-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 999px;
            background: linear-gradient(135deg, rgba(47, 120, 237, .12) 0%, rgba(232, 155, 188, .14) 100%);
            color: #1d4f8f;
            font-size: .84rem;
            font-weight: 800
        }

        .s-notifications-list {
            display: grid;
            gap: 12px
        }

        .s-notification-card {
            display: grid;
            gap: 10px;
            padding: 16px 18px;
            border-radius: 20px;
            border: 1px solid var(--line-soft);
            background: rgba(255, 255, 255, .96)
        }

        .s-notification-card.is-new {
            border-color: rgba(89, 106, 191, .2);
            box-shadow: 0 10px 24px rgba(47, 120, 237, .1)
        }

        .s-notification-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            flex-wrap: wrap
        }

        .s-notification-top strong {
            color: #0f172a;
            font-size: .96rem
        }

        .s-notification-meta {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #64748b;
            font-size: .82rem;
            font-weight: 700
        }

        .s-notification-status {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 5px 9px;
            border-radius: 999px;
            background: rgba(16, 185, 129, .12);
            color: #047857;
            font-size: .74rem;
            font-weight: 800
        }

        .s-notification-body {
            margin: 0;
            color: #475569;
            line-height: 1.75
        }

        .s-notification-actions {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap
        }

        .s-notification-link,
        .s-notification-read {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 42px;
            padding: 0 16px;
            border-radius: 999px;
            font-size: .88rem;
            font-weight: 800
        }

        .s-notification-link {
            background: linear-gradient(135deg, var(--dark-strong) 0%, var(--brand) 100%);
            color: #fff
        }

        .s-notification-read {
            border: 0;
            background: linear-gradient(135deg, rgba(224, 238, 255, .78) 0%, rgba(255, 233, 242, .78) 100%);
            color: #41546c;
            cursor: pointer
        }

        .s-footer {
            margin-top: 48px;
            background:
                radial-gradient(circle at top right, rgba(242, 183, 207, .12), transparent 24%),
                linear-gradient(180deg, #102845 0%, #0c2038 100%);
            border-top: 1px solid rgba(255, 255, 255, .08)
        }

        .s-footer-inner {
            width: min(1380px, calc(100% - 32px));
            margin: 0 auto;
            padding: 38px 0 28px
        }

        .s-footer-grid {
            display: grid;
            grid-template-columns: 1.2fr 1fr 1fr 1.1fr;
            gap: 28px
        }

        .s-footer-col h3 {
            margin: 0 0 16px;
            font-family: "Sora", "Be Vietnam Pro", sans-serif;
            font-size: 1.05rem;
            letter-spacing: -.02em
        }

        .s-footer-col p,
        .s-footer-col a {
            display: block;
            margin: 0 0 10px;
            color: #d7e6ff;
            line-height: 1.55
        }

        .s-footer-col .lead {
            color: rgba(229, 239, 255, .76)
        }

        .s-footer-col strong {
            color: #ffffff
        }

        .s-legal {
            margin-top: 24px;
            padding-top: 18px;
            border-top: 1px solid rgba(255, 255, 255, .08);
            color: rgba(229, 239, 255, .76);
            font-size: .95rem
        }

        @media (max-width:1780px) {

            .s-badge,
            .s-brand-copy span {
                display: none
            }

            .s-link {
                padding: 10px 6px;
                font-size: .81rem
            }

            .s-profile-meta {
                max-width: 112px
            }

            .s-logout {
                padding: 10px 12px;
                font-size: .9rem
            }
        }

        @media (max-width:1620px) {
            .s-bar {
                gap: 7px
            }

            .s-brand {
                gap: 8px
            }

            .s-brand-mark {
                width: 66px;
                height: 42px
            }

            .s-brand-copy strong {
                font-size: .76rem
            }

            .s-link {
                padding: 9px 4px;
                font-size: .78rem
            }

            .s-profile {
                gap: 6px
            }

            .s-profile-meta {
                max-width: 96px
            }

            .s-profile-meta strong {
                font-size: .8rem
            }

            .s-avatar {
                width: 38px;
                height: 38px
            }

            .s-logout {
                padding: 9px 11px;
                font-size: .86rem
            }
        }

        @media (max-width:1520px) {
            .s-nav,
            .s-profile-meta,
            .s-logout {
                display: none
            }

            .s-logout-quick,
            .s-menu {
                display: inline-flex
            }
        }

        @media (max-width:1440px) {

            .s-nav,
            .s-badge,
            .s-profile-meta,
            .s-logout {
                display: none
            }

            .s-logout-quick,
            .s-menu {
                display: inline-flex
            }

            .s-footer-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr))
            }
        }

        @media (max-width:720px) {

            .s-wrap,
            .s-flash,
            .s-notifications,
            .s-footer-inner,
            .s-mobile-inner {
                width: min(100% - 20px, 1380px)
            }

            .s-brand-copy span {
                display: none
            }

            .s-logout-quick {
                min-width: 46px;
                padding: 0 12px;
                gap: 6px;
                font-size: .82rem
            }

            .s-footer-grid {
                grid-template-columns: 1fr
            }
        }
    </style>
</head>

<body>
    <% const normalizePath=(value)=> {
        const raw = String(value || '/').split('?')[0].split('#')[0];
        const trimmed = raw.replace(/\/+$/, '');
        return trimmed || '/';
        };

        const safeBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : '';
        const buildHref = (path) => `${safeBaseUrl}${path}`;
        const currentRequestPath = typeof currentPath !== 'undefined' ? currentPath : '/';
        const currentRoute = normalizePath(currentRequestPath);
        const notificationReturnPath =
        safeBaseUrl && currentRequestPath.startsWith(safeBaseUrl)
        ? (currentRequestPath.slice(safeBaseUrl.length) || '/')
        : currentRequestPath;

        const safeSuccessMessages = typeof success_msg !== 'undefined' ? success_msg : [];
        const safeErrorMessages = typeof error_msg !== 'undefined' ? error_msg : [];
        const safeInfoMessages = typeof info !== 'undefined' ? info : [];
        const safeStudentNotifications = Array.isArray(typeof studentNotifications !== 'undefined' ? studentNotifications : null) ? studentNotifications : [];
        const safeStudentMailboxNotifications = Array.isArray(typeof studentMailboxNotifications !== 'undefined' ? studentMailboxNotifications : null) ? studentMailboxNotifications : [];
        const unreadNotificationCount = Number(typeof unreadStudentNotificationCount !== 'undefined' ? unreadStudentNotificationCount : 0);
        const unreadMailboxCount = Number(typeof unreadStudentMailboxCount !== 'undefined' ? unreadStudentMailboxCount : 0);

        const brandLogo = 'https://i.postimg.cc/P5r5F9Mt/logo.jpg';

        const safeStudentName =
        typeof studentName !== 'undefined' && studentName
        ? studentName
        : 'Học viên';

        const formatNotificationTime = (value) => {
        if (!value) return 'Vừa cập nhật';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return 'Vừa cập nhật';
        return new Intl.DateTimeFormat('vi-VN', {
        hour: '2-digit',
        minute: '2-digit',
        day: '2-digit',
        month: '2-digit'
        }).format(date);
        };

        const studentInitial = safeStudentName.trim().charAt(0).toUpperCase() || 'H';

        const courseMenuItems = [
        {
        label: 'Tổng hợp khóa học',
        href: buildHref('/student/courses'),
        matches: ['/student/courses'],
        exact: true,
        note: 'Xem lộ trình, học phí ưu đãi và đăng ký nhanh cho từng khóa.'
        },
        {
        label: 'TOEIC 2 kỹ năng',
        href: buildHref('/courses-blog/toeic-2-ky-nang'),
        matches: ['/courses-blog/toeic-2-ky-nang'],
        note: 'Lộ trình nền tảng nghe đọc và tăng band theo từng chặng.'
        },
        {
        label: 'TOEIC 4 kỹ năng',
        href: buildHref('/courses-blog/toeic-4-ky-nang'),
        matches: ['/courses-blog/toeic-4-ky-nang'],
        note: 'Bổ sung speaking, writing và lộ trình học đồng bộ hơn.'
        },
        {
        label: 'Khóa học cấp tốc',
        href: buildHref('/courses-blog/khoa-hoc-cap-toc'),
        matches: ['/courses-blog/khoa-hoc-cap-toc'],
        note: 'Phù hợp khi cần rút ngắn thời gian ôn và bứt tốc điểm số.'
        },
        {
        label: 'Tiếng Anh doanh nghiệp',
        href: buildHref('/courses-blog/tieng-anh-doanh-nghiep'),
        matches: ['/courses-blog/tieng-anh-doanh-nghiep'],
        note: 'Tập trung email, meeting và tiếng Anh công sở.'
        },
        {
        label: 'Video bài giảng',
        href: buildHref('/student/courses/video-bai-giang'),
        matches: [
        '/student/courses/video-bai-giang',
        '/student/courses/toeic-part-5',
        '/student/courses/toeic-grammar-core',
        '/student/courses/tap-su-vocabulary'
        ],
        note: 'Mở thư viện video bài giảng và xem lại ngay trong tài khoản.'
        }
        ];

        let navItems = [
        {
        label: 'Trang chủ',
        href: buildHref('/'),
        matches: ['/'],
        note: 'Quay về tổng quan học tập và các lối tắt quan trọng nhất.'
        },
        {
        label: 'Classroom',
        shortLabel: 'Classroom',
        href: buildHref('/student/classroom'),
        matches: ['/student/classroom'],
        note: 'Theo dõi lớp đang học, bài đăng, tài liệu và bài nộp.'
        },
        {
        label: 'Luyện Tập Full Test',
        href: buildHref('/placement-tests'),
        matches: ['/placement-tests', '/test-start', '/test-result'],
        note: 'Luyện trọn bộ đề TOEIC với giao diện làm bài đầy đủ.'
        },
        {
        label: 'Thi Thử Full Test',
        href: buildHref('/student/mock-tests'),
        matches: ['/student/mock-tests'],
        note: 'Làm đề theo nhịp thi thật để rèn độ tập trung và phản xạ.'
        },
        {
        label: 'Luyện Tập Theo Part',
        shortLabel: 'Theo Part',
        href: buildHref('/student/practice/parts'),
        matches: ['/student/practice/parts'],
        note: 'Tập trung đúng Part bạn đang yếu để ôn nhanh hơn.'
        },
        {
        label: 'Luyện Tập Reading',
        shortLabel: 'Reading',
        href: buildHref('/student/practice/reading'),
        matches: ['/student/practice/reading'],
        note: 'Luyện riêng phần Reading để tăng tốc độ và độ chính xác.'
        },
        {
        label: 'Nghe - Chép chính tả',
        shortLabel: 'Nghe - Chép',
        href: buildHref('/student/dictation'),
        matches: ['/student/dictation'],
        note: 'Rèn phản xạ nghe và độ chắc từ vựng qua dictation.'
        },
        {
        label: 'Khóa học',
        children: courseMenuItems,
        note: 'Mở thư viện khóa học và tìm lộ trình phù hợp với mục tiêu của bạn.'
        },
        {
        label: 'Lịch học',
        href: buildHref('/student/schedule'),
        matches: ['/student/schedule'],
        note: 'Xem lịch lớp đang học và các lịch khai giảng mới nhất.'
        },
        {
        label: 'Liên Hệ',
        href: buildHref('/student/contact'),
        matches: ['/student/contact'],
        note: 'Gửi câu hỏi tới trung tâm và nhận hỗ trợ ngay trong tài khoản.'
        },
        {
        label: 'Góp Ý',
        href: buildHref('/student/feedback'),
        matches: ['/student/feedback'],
        note: 'Phản hồi trải nghiệm học tập để đội ngũ cải thiện nhanh hơn.'
        },
        {
        label: 'Đăng ký khóa học',
        shortLabel: 'Đăng ký',
        href: buildHref('/register-course'),
        matches: ['/register-course', '/payment'],
        note: 'Đăng ký khóa học mới hoặc giữ chỗ lịch học phù hợp.'
        }
        ];

        const studyHubPaths = new Set([
        buildHref('/placement-tests'),
        buildHref('/student/practice/parts'),
        buildHref('/student/practice/reading'),
        buildHref('/student/dictation')
        ]);

        const studyHubNotes = new Map([
        [buildHref('/placement-tests'), 'Luyện trọn bộ full test với thanh audio hiển thị đầy đủ để bạn dùng linh hoạt khi ôn luyện.'],
        [buildHref('/student/practice/parts'), 'Tập trung đúng phần đang yếu và ôn theo từng dạng câu hỏi.'],
        [buildHref('/student/practice/reading'), 'Tăng tốc đọc hiểu, định vị ý chính và xử lý bài đọc dài.'],
        [buildHref('/student/dictation'), 'Rèn phản xạ nghe, độ chính xác và vốn từ qua dictation.']
        ]);

        const studyHubItems = navItems
        .filter((item) => studyHubPaths.has(item.href))
        .map((item) => ({
        ...item,
        note: studyHubNotes.get(item.href) || ''
        }));

        navItems = navItems.filter((item) => !studyHubPaths.has(item.href));
        navItems.splice(2, 0, {
        label: 'Góc học tập',
        shortLabel: 'Học tập',
        note: 'Mở nhanh full test, luyện theo Part, Reading và dictation.',
        children: studyHubItems
        });
        const isActive = (item) => (item.matches || []).some((target) => {
        const normalized = normalizePath(safeBaseUrl + target);
        if (normalized === '/') return currentRoute === '/';
        if (item.exact) return currentRoute === normalized;
        return currentRoute === normalized || currentRoute.startsWith(normalized + '/');
        });

        const isItemActive = (item) => Array.isArray(item.children) && item.children.length
        ? item.children.some((child) => isActive(child))
        : isActive(item);
        %>

        <header class="s-header">
            <div class="s-wrap s-bar">
                <a href="<%= buildHref('/') %>" class="s-brand">
                    <span class="s-brand-mark" aria-hidden="true">
                        <img src="<%= brandLogo %>" alt="Logo Thầy Tài Toeic">
                    </span>
                    <span class="s-brand-copy">
                        <strong>THẦY TÀI TOEIC</strong>
                        <span>Luyện thi và học trực tuyến</span>
                    </span>
                </a>

                <nav class="s-nav" aria-label="Điều hướng học viên">
                    <% navItems.forEach((item)=> { const itemActive = isItemActive(item); %>
                        <% if (item.children && item.children.length) { %>
                            <div class="s-nav-item s-nav-group">
                                <button type="button" class="s-link s-link-toggle <%= itemActive ? 'active' : '' %>" data-subnav-toggle aria-expanded="false">
                                    <span class="s-link-label-full <%= item.shortLabel ? 'is-long' : '' %>">
                                        <%= item.label %>
                                    </span>
                                    <% if (item.shortLabel) { %>
                                        <span class="s-link-label-short">
                                            <%= item.shortLabel %>
                                        </span>
                                    <% } %>
                                    <svg class="s-link-caret" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="m6 9 6 6 6-6"></path>
                                    </svg>
                                </button>
                                <div class="s-subnav" role="menu" aria-label="<%= item.label %>">
                                    <% item.children.forEach((child) => { const childActive = isActive(child); %>
                                        <a href="<%= child.href %>" class="s-subnav-link <%= childActive ? 'active' : '' %>" role="menuitem">
                                            <span class="s-subnav-title"><%= child.label %></span>
                                            <span class="s-subnav-note"><%= child.note %></span>
                                        </a>
                                    <% }) %>
                                </div>
                            </div>
                        <% } else { %>
                            <a href="<%= item.href %>" class="s-link <%= itemActive ? 'active' : '' %>">
                                <span class="s-link-label-full <%= item.shortLabel ? 'is-long' : '' %>">
                                    <%= item.label %>
                                </span>
                                <% if (item.shortLabel) { %>
                                    <span class="s-link-label-short">
                                        <%= item.shortLabel %>
                                    </span>
                                <% } %>
                            </a>
                        <% } %>
                    <% }) %>
                </nav>

                <div class="s-actions">
                    <div class="s-bell-wrap" id="studentNotificationRoot">
                        <button
                            type="button"
                            class="s-bell"
                            id="studentNotificationToggle"
                            aria-label="Mở thông báo học viên"
                            aria-controls="studentNotificationPanel"
                            aria-expanded="false"
                        >
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5"></path>
                                <path d="M9 17a3 3 0 0 0 6 0"></path>
                            </svg>
                            <% if (unreadNotificationCount > 0) { %>
                                <span class="s-bell-count"><%= unreadNotificationCount > 9 ? '9+' : unreadNotificationCount %></span>
                            <% } %>
                        </button>

                        <section class="s-notify-panel" id="studentNotificationPanel" aria-label="Thông báo học viên">
                            <div class="s-notify-head">
                                <div class="s-notify-copy">
                                    <strong>Thông báo học viên</strong>
                                    <span>Thanh toán, lớp học và các cập nhật hệ thống sẽ được cập nhật tại đây.</span>
                                </div>
                                <% if (safeStudentNotifications.length) { %>
                                    <form method="POST" action="<%= buildHref('/student/notifications/read-all') %>">
                                        <input type="hidden" name="redirect" value="<%= notificationReturnPath %>">
                                        <button type="submit" class="s-notify-mark">Đánh dấu đã xem</button>
                                    </form>
                                <% } %>
                            </div>

                            <% if (safeStudentNotifications.length) { %>
                                <div class="s-notify-list">
                                    <% safeStudentNotifications.forEach((notification) => { %>
                                        <article class="s-notify-item <%= notification.is_read ? '' : 'is-new' %>">
                                            <div class="s-notify-item-head">
                                                <strong><%= notification.title %></strong>
                                                <span class="s-notify-meta">
                                                    <% if (!notification.is_read) { %>
                                                        <span class="s-notify-tag">Mới</span>
                                                    <% } %>
                                                    <span><%= formatNotificationTime(notification.created_at) %></span>
                                                </span>
                                            </div>
                                            <p><%= notification.message || 'Trung tâm vừa cập nhật thông tin mới cho tài khoản học viên của bạn.' %></p>
                                            <% if (notification.href) { %>
                                                <a href="<%= buildHref(notification.href) %>">Mở chi tiết</a>
                                            <% } %>
                                        </article>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="s-notify-empty">
                                    <strong>Chưa có thông báo mới</strong>
                                    <span>Khi trung tâm xác nhận thanh toán, thêm bạn vào lớp hoặc cập nhật hệ thống, thông báo sẽ hiện tại đây.</span>
                                    <a href="<%= buildHref('/student/contact') %>" class="s-notify-empty-link">Liên hệ trung tâm</a>
                                </div>
                            <% } %>
                        </section>
                    </div>
                    <div class="s-mail-wrap" id="studentMailboxRoot">
                        <button
                            type="button"
                            class="s-mail"
                            id="studentMailboxToggle"
                            aria-label="Mở hộp thư học viên"
                            aria-controls="studentMailboxPanel"
                            aria-expanded="false"
                        >
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M4 6h16a2 2 0 0 1 2 2v8a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8a2 2 0 0 1 2-2Z"></path>
                                <path d="m4 9 8 5 8-5"></path>
                            </svg>
                            <% if (unreadMailboxCount > 0) { %>
                                <span class="s-bell-count"><%= unreadMailboxCount > 9 ? '9+' : unreadMailboxCount %></span>
                            <% } %>
                        </button>

                        <section class="s-mail-panel" id="studentMailboxPanel" aria-label="Hộp thư học viên">
                            <div class="s-notify-head">
                                <div class="s-notify-copy">
                                    <strong>Hộp thư phản hồi từ admin</strong>
                                    <span>Các phản hồi cho yêu cầu liên hệ của bạn sẽ được lưu riêng tại đây để dễ theo dõi hơn.</span>
                                </div>
                                <% if (safeStudentMailboxNotifications.length) { %>
                                    <form method="POST" action="<%= buildHref('/student/mailbox/notifications/read-all') %>">
                                        <input type="hidden" name="redirect" value="<%= notificationReturnPath %>">
                                        <button type="submit" class="s-notify-mark">Đánh dấu đã xem</button>
                                    </form>
                                <% } %>
                            </div>

                            <% if (safeStudentMailboxNotifications.length) { %>
                                <div class="s-notify-list">
                                    <% safeStudentMailboxNotifications.forEach((notification) => { %>
                                        <article class="s-notify-item <%= notification.is_read ? '' : 'is-new' %>">
                                            <div class="s-notify-item-head">
                                                <strong><%= notification.title %></strong>
                                                <span class="s-notify-meta">
                                                    <% if (!notification.is_read) { %>
                                                        <span class="s-notify-tag">Mới</span>
                                                    <% } %>
                                                    <span><%= formatNotificationTime(notification.created_at) %></span>
                                                </span>
                                            </div>
                                            <p><%= notification.message || 'Admin vừa gửi phản hồi mới cho yêu cầu hỗ trợ của bạn.' %></p>
                                            <a href="<%= buildHref(notification.href || '/student/mailbox') %>">Mở hộp thư</a>
                                        </article>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="s-notify-empty">
                                    <strong>Hộp thư đang trống</strong>
                                    <span>Khi admin phản hồi các yêu cầu bạn đã gửi ở mục liên hệ, nội dung sẽ xuất hiện tại đây.</span>
                                    <a href="<%= buildHref('/student/mailbox') %>" class="s-notify-empty-link">Mở hộp thư</a>
                                </div>
                            <% } %>
                        </section>
                    </div>
                    <span class="s-badge">Tài khoản học viên</span>

                    <a href="<%= buildHref('/student/profile') %>" class="s-profile" aria-label="Mở hồ sơ học viên">
                        <div class="s-profile-meta">
                            <strong>
                                <%= safeStudentName %>
                            </strong>
                            <span>Đang học TOEIC online</span>
                        </div>
                        <span class="s-avatar">
                            <%= studentInitial %>
                        </span>
                    </a>

                    <a href="<%= buildHref('/logout') %>" class="s-logout">Đăng xuất</a>

                    <a href="<%= buildHref('/logout') %>" class="s-logout-quick" aria-label="Đăng xuất">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M15 3h3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-3"></path>
                            <path d="M10 17l5-5-5-5"></path>
                            <path d="M15 12H4"></path>
                        </svg>
                        <span>Thoát</span>
                    </a>

                    <button type="button" class="s-menu" id="studentMenuToggle" aria-label="Mở menu" aria-expanded="false" aria-controls="studentMobilePanel">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 7H20"></path>
                            <path d="M4 12H20"></path>
                            <path d="M4 17H20"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="s-mobile" id="studentMobilePanel">
                <div class="s-mobile-inner">
                    <div class="s-mobile-account">
                        <a href="<%= buildHref('/student/profile') %>" class="s-mobile-profile" aria-label="M&#7903; h&#7891; s&#417; h&#7885;c vi&#234;n">
                            <span class="s-avatar">
                                <%= studentInitial %>
                            </span>
                            <span class="s-mobile-profile-copy">
                                <strong><%= safeStudentName %></strong>
                                <span>T&#224;i kho&#7843;n h&#7885;c vi&#234;n TOEIC</span>
                            </span>
                        </a>
                        <div class="s-mobile-actions">
                            <a href="<%= buildHref('/logout') %>" class="s-logout">&#272;&#259;ng xu&#7845;t</a>
                        </div>
                    </div>

                    <div class="s-mobile-nav">
                        <% navItems.forEach((item)=> { const itemActive = isItemActive(item); %>
                            <% if (item.children && item.children.length) { %>
                                <div class="s-mobile-group <%= itemActive ? 'is-open' : '' %>">
                                    <button type="button" class="s-mobile-group-toggle <%= itemActive ? 'active' : '' %>" data-mobile-subnav-toggle aria-expanded="<%= itemActive ? 'true' : 'false' %>">
                                        <span class="s-mobile-group-copy">
                                            <span class="s-mobile-link-title"><%= item.label %></span>
                                            <% if (item.note) { %>
                                                <span class="s-mobile-group-note"><%= item.note %></span>
                                            <% } %>
                                        </span>
                                        <svg class="s-mobile-group-caret" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                            <path d="m6 9 6 6 6-6"></path>
                                        </svg>
                                    </button>
                                    <div class="s-mobile-subnav">
                                        <% item.children.forEach((child) => { %>
                                            <a href="<%= child.href %>" class="s-mobile-subnav-link <%= isActive(child) ? 'active' : '' %>">
                                                <span class="s-mobile-link-title"><%= child.label %></span>
                                                <% if (child.note) { %>
                                                    <span class="s-mobile-subnav-note"><%= child.note %></span>
                                                <% } %>
                                            </a>
                                        <% }) %>
                                    </div>
                                </div>
                            <% } else { %>
                                <a href="<%= item.href %>" class="s-mobile-link <%= itemActive ? 'active' : '' %>">
                                    <span class="s-mobile-link-copy">
                                        <span class="s-mobile-link-title"><%= item.label %></span>
                                        <% if (item.note) { %>
                                            <span class="s-mobile-link-note"><%= item.note %></span>
                                        <% } %>
                                    </span>
                                    <span class="s-mobile-link-icon" aria-hidden="true">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M9 6l6 6-6 6"></path>
                                        </svg>
                                    </span>
                                </a>
                            <% } %>
                        <% }) %>
                    </div>
                </div>
            </div>
        </header>

        <% if (safeSuccessMessages.length || safeErrorMessages.length || safeInfoMessages.length) { %>
            <section class="s-flash">
                <% safeSuccessMessages.forEach((msg)=> { %>
                    <div class="s-flash-card success">
                        <%= msg %>
                    </div>
                    <% }) %>

                        <% safeErrorMessages.forEach((msg)=> { %>
                            <div class="s-flash-card error">
                                <%= msg %>
                            </div>
                            <% }) %>

                                <% safeInfoMessages.forEach((msg)=> { %>
                                    <div class="s-flash-card info">
                                        <%= msg %>
                                    </div>
                                    <% }) %>
            </section>
            <% } %>

                <% if (safeStudentNotifications.length) { %>
                    <section class="s-notifications" id="studentNotifications">
                        <div class="s-notifications-head">
                            <div class="s-notifications-headline">
                                <strong>Thông báo học viên</strong>
                                <span>Trung tâm sẽ cập nhật tại đây khi thanh toán được xác nhận hoặc lớp học của bạn sẵn sàng.</span>
                            </div>
                            <div class="s-notifications-head">
                                <% if (unreadNotificationCount > 0) { %>
                                    <span class="s-notifications-pill"><%= unreadNotificationCount %> thông báo mới</span>
                                <% } %>
                                <form method="POST" action="<%= buildHref('/student/notifications/read-all') %>">
                                    <input type="hidden" name="redirect" value="<%= currentRoute %>">
                                    <button type="submit" class="s-notification-read">Đánh dấu đã xem</button>
                                </form>
                            </div>
                        </div>

                        <div class="s-notifications-list">
                            <% safeStudentNotifications.forEach((notification) => { %>
                                <article class="s-notification-card <%= notification.is_read ? '' : 'is-new' %>">
                                    <div class="s-notification-top">
                                        <strong><%= notification.title %></strong>
                                        <div class="s-notification-meta">
                                            <% if (!notification.is_read) { %>
                                                <span class="s-notification-status">Mới</span>
                                            <% } %>
                                            <span><%= formatNotificationTime(notification.created_at) %></span>
                                        </div>
                                    </div>
                                    <p class="s-notification-body"><%= notification.message || 'Trung tâm vừa cập nhật trạng thái học tập cho bạn.' %></p>
                                    <div class="s-notification-actions">
                                        <% if (notification.href) { %>
                                            <a href="<%= buildHref(notification.href) %>" class="s-notification-link">Mở ngay</a>
                                        <% } else { %>
                                            <span class="s-notification-meta">Đã lưu vào tài khoản học viên</span>
                                        <% } %>
                                    </div>
                                </article>
                            <% }) %>
                        </div>
                    </section>
                <% } %>

                <main class="s-stage"><%- content %></main>

                <footer class="s-footer">
                    <div class="s-footer-inner">
                        <div class="s-footer-grid">
                            <section class="s-footer-col">
                                <h3>Thầy Tài Toeic</h3>
                                <p class="lead">Thầy Tài Toeic đào tạo và luyện thi TOEIC. Chất lượng luôn là ưu tiên
                                    hàng đầu cho học viên.</p>
                                <a href="<%= buildHref('/student/feedback') %>">Quy định lớp học</a>
                                <a href="<%= buildHref('/student/contact') %>">Chính sách quyền riêng tư</a>
                            </section>

                            <section class="s-footer-col">
                                <h3>Khóa học</h3>
                                <a href="<%= buildHref('/student/courses') %>">Thư viện khóa học</a>
                                <a href="<%= buildHref('/student/courses') %>">Khóa học TOEIC A</a>
                                <a href="<%= buildHref('/student/courses') %>">Khóa học TOEIC B</a>
                                <a href="<%= buildHref('/register-course') %>">Lớp Tập Sự</a>
                            </section>

                            <section class="s-footer-col">
                                <h3>Liên hệ</h3>
                                <p><strong>Email:</strong> realtoeiccentral@gmail.com</p>
                                <a href="<%= buildHref('/student/contact') %>">Fanpage: Thầy Tài Toeic</a>
                                <a href="<%= buildHref('/student/feedback') %>">Cộng đồng học TOEIC Thầy Tài Toeic</a>
                                <a href="<%= buildHref('/student/courses') %>">Góc học tập TOEIC Speaking &amp;
                                    Writing</a>
                            </section>

                            <section class="s-footer-col">
                                <h3>Địa chỉ</h3>
                                <p><strong>Cs1:</strong> Hồ Tùng Mậu</p>
                                <p>ĐC: Số 17, Ngõ 20 Đường Hồ Tùng Mậu, Cầu Giấy</p>
                                <p><strong>Hotline:</strong> 0344772436</p>
                                <p><strong>Cs2:</strong> Lê Đức Thọ</p>
                                <p>ĐC: Số 9 Ngách 59 Ngõ 21 Lê Đức Thọ, Nam Từ Liêm, Hà Nội</p>
                            </section>
                        </div>

                        <div class="s-legal">Copyright © Thầy Tài Toeic - v1.4.8</div>
                    </div>
                </footer>

                <script>
                    (() => {
                        const toggle = document.getElementById('studentMenuToggle');
                        if (!toggle) return;

                        const header = document.querySelector('.s-header');
                        const mobilePanel = document.getElementById('studentMobilePanel');
                        const desktopGroups = Array.from(document.querySelectorAll('.s-nav-group'));
                        const notificationRoot = document.getElementById('studentNotificationRoot');
                        const notificationToggle = document.getElementById('studentNotificationToggle');
                        const mailboxRoot = document.getElementById('studentMailboxRoot');
                        const mailboxToggle = document.getElementById('studentMailboxToggle');

                        const setMenuState = (isOpen) => {
                            document.body.classList.toggle('menu-open', isOpen);
                            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                        };

                        const closeMenu = () => setMenuState(false);

                        const closeDesktopGroups = (except = null) => {
                            desktopGroups.forEach((group) => {
                                if (group === except) return;
                                group.classList.remove('is-open');
                                const button = group.querySelector('[data-subnav-toggle]');
                                if (button) button.setAttribute('aria-expanded', 'false');
                            });
                        };

                        const closePopover = (root, button) => {
                            if (!root || !button) return;
                            root.classList.remove('is-open');
                            button.setAttribute('aria-expanded', 'false');
                        };

                        const openPopover = (root, button) => {
                            if (!root || !button) return;
                            root.classList.add('is-open');
                            button.setAttribute('aria-expanded', 'true');
                        };

                        const closeNotifications = () => closePopover(notificationRoot, notificationToggle);
                        const closeMailbox = () => closePopover(mailboxRoot, mailboxToggle);
                        const closeFloatingPanels = () => {
                            closeNotifications();
                            closeMailbox();
                        };

                        const bindPopoverToggle = ({ root, button, onBeforeOpen }) => {
                            if (!root || !button) return;

                            button.addEventListener('click', (event) => {
                                event.preventDefault();
                                event.stopPropagation();

                                const shouldOpen = !root.classList.contains('is-open');
                                if (shouldOpen && typeof onBeforeOpen === 'function') {
                                    onBeforeOpen();
                                }

                                closePopover(root, button);
                                if (shouldOpen) {
                                    openPopover(root, button);
                                }
                            });

                            root.addEventListener('click', (event) => {
                                event.stopPropagation();
                            });
                        };

                        toggle.addEventListener('click', (event) => {
                            event.preventDefault();
                            event.stopPropagation();
                            closeDesktopGroups();
                            closeFloatingPanels();
                            setMenuState(!document.body.classList.contains('menu-open'));
                        });

                        if (mobilePanel) {
                            mobilePanel.addEventListener('click', (event) => {
                                event.stopPropagation();
                            });
                        }

                        bindPopoverToggle({
                            root: notificationRoot,
                            button: notificationToggle,
                            onBeforeOpen: () => {
                                closeDesktopGroups();
                                closeMailbox();
                            }
                        });

                        bindPopoverToggle({
                            root: mailboxRoot,
                            button: mailboxToggle,
                            onBeforeOpen: () => {
                                closeDesktopGroups();
                                closeNotifications();
                            }
                        });

                        document.querySelectorAll('[data-subnav-toggle]').forEach((button) => {
                            const group = button.closest('.s-nav-group');
                            if (!group) return;

                            button.addEventListener('click', (event) => {
                                event.preventDefault();
                                event.stopPropagation();

                                const shouldOpen = !group.classList.contains('is-open');
                                closeFloatingPanels();
                                closeDesktopGroups(group);
                                group.classList.toggle('is-open', shouldOpen);
                                button.setAttribute('aria-expanded', String(shouldOpen));
                            });
                        });

                        document.querySelectorAll('[data-mobile-subnav-toggle]').forEach((button) => {
                            const group = button.closest('.s-mobile-group');
                            if (!group) return;

                            button.addEventListener('click', () => {
                                const shouldOpen = !group.classList.contains('is-open');
                                group.classList.toggle('is-open', shouldOpen);
                                button.setAttribute('aria-expanded', String(shouldOpen));
                            });
                        });

                        document.querySelectorAll('#studentMobilePanel a').forEach((link) => {
                            link.addEventListener('click', closeMenu);
                        });

                        document.addEventListener('click', (event) => {
                            closeDesktopGroups();
                            closeFloatingPanels();
                            if (header && !header.contains(event.target)) {
                                closeMenu();
                            }
                        });

                        window.addEventListener('resize', () => {
                            if (window.innerWidth > 1440) {
                                closeMenu();
                            }
                            closeDesktopGroups();
                            closeFloatingPanels();
                        });

                        window.addEventListener('keydown', (event) => {
                            if (event.key === 'Escape') {
                                closeDesktopGroups();
                                closeFloatingPanels();
                                closeMenu();
                            }
                        });
                    })();
                </script>
                <%- include('partials/engagement-widgets', { widgetScopeValue: 'student' }) %>
</body>

</html>
