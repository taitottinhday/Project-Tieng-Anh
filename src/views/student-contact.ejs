<%
const safeBaseUrl = typeof baseUrl !== "undefined" ? baseUrl : "";
const studentName = user && user.username ? user.username : "";
const studentEmail = user && user.email ? user.email : "";
const safeSuccessMessages = typeof success_msg !== "undefined" ? success_msg : [];
const safeErrorMessages = typeof error_msg !== "undefined" ? error_msg : [];
const channels = [
  { label: "Hotline tư vấn", value: "0344772436", note: "Phản hồi nhanh trong giờ hành chính" },
  { label: "Email", value: "realtoeiccentral@gmail.com", note: "Phù hợp khi cần gửi thông tin chi tiết" },
  { label: "Cơ sở hỗ trợ", value: "Hồ Tùng Mậu • Lê Đức Thọ", note: "Có thể hẹn tư vấn trực tiếp theo lịch" },
];
const preferredContactConfigs = {
  "Nhắn trong hệ thống": {
    label: "Nội dung bạn muốn được phản hồi trong hệ thống",
    placeholder: "Ví dụ: Em muốn nhận phản hồi trực tiếp trong hộp thư học viên.",
    note: "Trung tâm sẽ ưu tiên trả lời trong tài khoản học viên của bạn.",
    inputType: "text",
    inputMode: "text",
    targetField: "",
  },
  "Gọi điện": {
    label: "Số điện thoại để trung tâm gọi lại",
    placeholder: "Nhập số điện thoại bạn muốn nhận cuộc gọi",
    note: "Nội dung này sẽ tự điền vào mục số điện thoại/Zalo bên trên.",
    inputType: "tel",
    inputMode: "tel",
    targetField: "phone",
  },
  Zalo: {
    label: "Số điện thoại/Zalo để trung tâm nhắn bạn",
    placeholder: "Nhập số điện thoại dùng cho Zalo",
    note: "Nội dung này sẽ tự điền vào mục số điện thoại/Zalo bên trên.",
    inputType: "text",
    inputMode: "tel",
    targetField: "phone",
  },
  Email: {
    label: "Email bạn muốn nhận phản hồi",
    placeholder: "Nhập email để trung tâm phản hồi",
    note: "Nội dung này sẽ tự điền vào mục email bên trên.",
    inputType: "email",
    inputMode: "email",
    targetField: "email",
  },
  "Tư vấn trực tiếp": {
    label: "Cơ sở hoặc hình thức bạn muốn hẹn",
    placeholder: "Ví dụ: Cơ sở Hồ Tùng Mậu hoặc gặp trực tiếp cuối tuần",
    note: "Thông tin này giúp trung tâm hẹn đúng địa điểm hoặc hình thức tư vấn.",
    inputType: "text",
    inputMode: "text",
    targetField: "",
  },
};
%>

<style>
  .sc-page{width:min(1380px,calc(100% - 32px));margin:0 auto;padding:34px 0 48px;display:grid;gap:24px}
  .sc-hero,.sc-panel,.sc-channel-grid article,.sc-request-card{border-radius:32px;border:1px solid var(--line-soft);box-shadow:0 18px 40px rgba(39,62,122,.10);background:rgba(255,255,255,.96)}
  .sc-hero,.sc-panel,.sc-channel-grid article,.sc-request-card{padding:28px}
  .sc-hero{display:grid;gap:14px;background:linear-gradient(135deg,rgba(244,248,255,.98) 0%,rgba(255,240,247,.96) 52%,rgba(231,239,255,.98) 100%)}
  .sc-hero h1,.sc-panel h2,.sc-request-title{margin:0;font-family:"Sora","Be Vietnam Pro",sans-serif;letter-spacing:-.04em;color:var(--text)}
  .sc-hero h1{font-size:clamp(2.2rem,4.4vw,3.7rem);line-height:1.04}
  .sc-hero p,.sc-panel p,.sc-channel-grid span,.sc-request-body,.sc-empty p{margin:0;color:var(--muted);line-height:1.8}
  .sc-flash-stack{display:grid;gap:12px}
  .sc-flash{padding:14px 16px;border-radius:18px;font-weight:700}
  .sc-flash.success{background:rgba(34,197,94,.10);color:#166534;border:1px solid rgba(34,197,94,.18)}
  .sc-flash.error{background:rgba(239,68,68,.10);color:#b91c1c;border:1px solid rgba(239,68,68,.18)}
  .sc-panel-kicker{display:inline-flex;align-items:center;min-height:36px;padding:0 14px;border-radius:999px;background:linear-gradient(135deg,var(--brand-soft) 0%,var(--accent-soft) 100%);color:#1d4f8f;font-weight:800}
  .sc-channel-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px}
  .sc-channel-grid strong{display:block;font-size:1.05rem;color:var(--text)}
  .sc-channel-grid span{display:block;margin-top:8px}
  .sc-panel-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:18px}
  .sc-form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}
  .sc-field{display:grid;gap:8px}
  .sc-field.full{grid-column:1 / -1}
  .sc-field label{font-weight:700;color:#334155}
  .sc-field input,.sc-field select,.sc-field textarea{width:100%;min-height:54px;padding:0 16px;border-radius:18px;border:1px solid var(--line-soft);background:#fff;color:var(--text);font:inherit}
  .sc-field textarea{min-height:150px;padding:14px 16px;resize:vertical}
  .sc-field input:focus,.sc-field select:focus,.sc-field textarea:focus{outline:none;border-color:rgba(37,99,235,.34);box-shadow:0 0 0 4px rgba(37,99,235,.08)}
  .sc-field-note{color:#64748b;font-size:.92rem;line-height:1.7}
  .sc-contact-detail{padding:18px;border-radius:24px;border:1px solid var(--line);background:linear-gradient(180deg,rgba(248,251,255,.98) 0%,rgba(255,243,248,.98) 100%)}
  .sc-contact-detail[hidden]{display:none}
  .sc-actions{display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin-top:18px}
  .sc-btn{display:inline-flex;align-items:center;justify-content:center;min-height:50px;padding:0 22px;border-radius:999px;border:0;background:linear-gradient(135deg,var(--dark-strong) 0%,var(--brand) 100%);color:#fff;font-weight:800;text-decoration:none;cursor:pointer;box-shadow:0 16px 30px rgba(47,120,237,.18)}
  .sc-btn.secondary{background:linear-gradient(135deg,rgba(255,255,255,.96) 0%,rgba(248,251,255,.98) 100%);color:var(--text);border:1px solid var(--line-soft)}
  .sc-hint{color:#64748b;font-size:.95rem;line-height:1.7}
  .sc-mailbox-note{display:grid;gap:14px;padding:24px;border-radius:24px;background:linear-gradient(135deg,rgba(244,248,255,.98) 0%,rgba(255,240,247,.96) 52%,rgba(255,255,255,.98) 100%);border:1px solid var(--line)}
  .sc-mailbox-note strong{font-size:1.15rem;color:var(--text)}
  .sc-mailbox-note p{margin:0;color:var(--muted);line-height:1.8}
  @media (max-width:1100px){.sc-channel-grid,.sc-form-grid{grid-template-columns:1fr 1fr}}
  @media (max-width:760px){.sc-page{width:min(100% - 20px,1380px);padding:22px 0 30px}.sc-channel-grid,.sc-form-grid{grid-template-columns:1fr}.sc-hero,.sc-panel,.sc-channel-grid article{padding:20px;border-radius:24px}.sc-mailbox-note{padding:20px;border-radius:20px}}
</style>

<div class="sc-page">
  <section class="sc-hero">
    <span class="sc-panel-kicker">Liên hệ học viên</span>
    <h1>Gửi yêu cầu tư vấn nhanh cho trung tâm ngay trong tài khoản.</h1>
    <p>Trang này tập trung cho việc tạo yêu cầu mới và theo dõi trạng thái xử lý. Phản hồi chi tiết từ admin sẽ được chuyển sang icon hộp thư riêng để bạn xem gọn hơn và không bị trộn ở cuối mục liên hệ.</p>
  </section>

  <% if (success || safeSuccessMessages.length || safeErrorMessages.length) { %>
    <div class="sc-flash-stack">
      <% if (success) { %>
        <div class="sc-flash success">Yêu cầu của bạn đã được gửi thành công. Trung tâm sẽ phản hồi sớm nhất có thể.</div>
      <% } %>
      <% safeSuccessMessages.forEach((item) => { %>
        <div class="sc-flash success"><%= item %></div>
      <% }) %>
      <% safeErrorMessages.forEach((item) => { %>
        <div class="sc-flash error"><%= item %></div>
      <% }) %>
    </div>
  <% } %>

  <section class="sc-channel-grid">
    <% channels.forEach((item) => { %>
      <article>
        <strong><%= item.label %></strong>
        <span><%= item.value %></span>
        <span><%= item.note %></span>
      </article>
    <% }) %>
  </section>

  <section class="sc-panel">
    <div class="sc-panel-head">
      <div>
        <h2>Tạo yêu cầu tư vấn mới</h2>
        <p>Điền thông tin càng rõ, trung tâm càng dễ hẹn đúng khung giờ, đúng cơ sở và đúng người hỗ trợ cho bạn.</p>
      </div>
    </div>

    <form action="<%= safeBaseUrl %>/contact" method="POST" data-contact-form>
      <input type="hidden" name="return_to" value="/student/contact">
      <input type="hidden" name="preferred_contact_detail" value="" data-preferred-contact-detail>

      <div class="sc-form-grid">
        <div class="sc-field">
          <label>Họ tên</label>
          <input type="text" name="name" value="<%= studentName %>" required>
        </div>
        <div class="sc-field">
          <label>Email</label>
          <input type="email" name="email" value="<%= studentEmail %>" data-contact-email>
        </div>
        <div class="sc-field">
          <label>Số điện thoại hoặc Zalo</label>
          <input type="text" name="phone" placeholder="Ví dụ: 0344xxxxxx" data-contact-phone>
        </div>
        <div class="sc-field">
          <label>Kênh phản hồi mong muốn</label>
          <select name="preferred_contact_method" data-contact-method-select>
            <option value="Nhắn trong hệ thống">Nhắn trong hệ thống</option>
            <option value="Gọi điện">Gọi điện</option>
            <option value="Zalo">Zalo</option>
            <option value="Email">Email</option>
            <option value="Tư vấn trực tiếp">Tư vấn trực tiếp</option>
          </select>
        </div>
        <div class="sc-field full sc-contact-detail" data-contact-detail-block>
          <label data-contact-detail-label>Nội dung bạn muốn được phản hồi trong hệ thống</label>
          <input type="text" data-contact-detail-input placeholder="Ví dụ: Em muốn nhận phản hồi trực tiếp trong hộp thư học viên.">
          <span class="sc-field-note" data-contact-detail-note>Trung tâm sẽ ưu tiên trả lời trong tài khoản học viên của bạn.</span>
        </div>
        <div class="sc-field">
          <label>Mục tiêu hỗ trợ</label>
          <select name="goal">
            <option value="Tư vấn khóa học học viên">Tư vấn khóa học</option>
            <option value="Hỏi lịch khai giảng">Hỏi lịch khai giảng</option>
            <option value="Hỗ trợ thanh toán">Hỗ trợ thanh toán</option>
            <option value="Hẹn tư vấn trực tiếp">Hẹn tư vấn trực tiếp</option>
            <option value="Hỗ trợ tài khoản">Hỗ trợ tài khoản</option>
          </select>
        </div>
        <div class="sc-field">
          <label>Khóa học quan tâm</label>
          <input type="text" name="course_interest" placeholder="Ví dụ: TOEIC A, TOEIC B, Tập Sự">
        </div>
        <div class="sc-field full">
          <label>Khung giờ mong muốn</label>
          <input type="text" name="schedule_preference" placeholder="Ví dụ: Tối 2-4-6, cuối tuần, sau 19:00">
        </div>
        <div class="sc-field full">
          <label>Nội dung cần tư vấn</label>
          <textarea name="message" placeholder="Ví dụ: Em muốn được tư vấn lộ trình, xin lịch hẹn trực tiếp ở cơ sở Hồ Tùng Mậu, và nếu cần thì trung tâm có thể liên hệ qua Zalo." required></textarea>
        </div>
      </div>

      <div class="sc-actions">
        <button type="submit" class="sc-btn">Gửi yêu cầu tư vấn</button>
        <span class="sc-hint">Khi admin phản hồi, nội dung mới sẽ được chuyển sang icon hộp thư cạnh chuông thông báo để bạn theo dõi tách biệt.</span>
      </div>
    </form>
  </section>

  <section class="sc-panel">
    <div class="sc-panel-head">
      <div>
        <h2>Phản hồi của admin nằm trong Hòm thư</h2>
        <p>Trang Liên hệ chỉ dùng để học viên tạo yêu cầu mới. Khi trung tâm trả lời, toàn bộ lịch hẹn, kênh liên hệ và lời nhắn sẽ được gom vào Hòm thư học viên để bạn xem tập trung hơn.</p>
      </div>
    </div>

    <div class="sc-mailbox-note">
      <strong>Mọi phản hồi từ admin sẽ không hiển thị lại ở mục Liên hệ.</strong>
      <p>Bạn chỉ cần gửi yêu cầu tại đây, sau đó mở icon hộp thư cạnh chuông thông báo để xem các phản hồi mới nhất từ admin.</p>
      <div class="sc-actions" style="margin-top:0">
        <a href="<%= safeBaseUrl %>/student/mailbox" class="sc-btn">Mở hộp thư học viên</a>
      </div>
    </div>
  </section>
</div>

<script>
  (() => {
    const form = document.querySelector('[data-contact-form]');
    if (!form) return;

    const configs = <%- JSON.stringify(preferredContactConfigs) %>;
    const methodSelect = form.querySelector('[data-contact-method-select]');
    const detailBlock = form.querySelector('[data-contact-detail-block]');
    const detailLabel = form.querySelector('[data-contact-detail-label]');
    const detailInput = form.querySelector('[data-contact-detail-input]');
    const detailNote = form.querySelector('[data-contact-detail-note]');
    const detailHidden = form.querySelector('[data-preferred-contact-detail]');
    const emailInput = form.querySelector('[data-contact-email]');
    const phoneInput = form.querySelector('[data-contact-phone]');

    if (!methodSelect || !detailBlock || !detailLabel || !detailInput || !detailNote || !detailHidden) {
      return;
    }

    const syncDetailValue = () => {
      detailHidden.value = detailInput.value.trim();

      const config = configs[methodSelect.value] || {};
      if (config.targetField === 'email' && emailInput) {
        emailInput.value = detailInput.value;
      }
      if (config.targetField === 'phone' && phoneInput) {
        phoneInput.value = detailInput.value;
      }
    };

    const renderPreferredContact = () => {
      const config = configs[methodSelect.value] || configs['Nhắn trong hệ thống'];
      const seedValue = config.targetField === 'email'
        ? (emailInput ? emailInput.value.trim() : '')
        : config.targetField === 'phone'
          ? (phoneInput ? phoneInput.value.trim() : '')
          : detailHidden.value.trim();

      detailBlock.hidden = false;
      detailLabel.textContent = config.label || 'Chi tiết kênh phản hồi';
      detailInput.type = config.inputType || 'text';
      detailInput.inputMode = config.inputMode || 'text';
      detailInput.placeholder = config.placeholder || '';
      detailInput.value = seedValue;
      detailNote.textContent = config.note || '';
      syncDetailValue();
    };

    methodSelect.addEventListener('change', renderPreferredContact);
    detailInput.addEventListener('input', syncDetailValue);

    if (emailInput) {
      emailInput.addEventListener('input', () => {
        if ((configs[methodSelect.value] || {}).targetField === 'email') {
          detailInput.value = emailInput.value;
          syncDetailValue();
        }
      });
    }

    if (phoneInput) {
      phoneInput.addEventListener('input', () => {
        if ((configs[methodSelect.value] || {}).targetField === 'phone') {
          detailInput.value = phoneInput.value;
          syncDetailValue();
        }
      });
    }

    renderPreferredContact();
  })();
</script>
