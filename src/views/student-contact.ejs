<%
const safeBaseUrl = typeof baseUrl !== "undefined" ? baseUrl : "";
const studentName = user && user.username ? user.username : "";
const studentEmail = user && user.email ? user.email : "";
const safeSuccessMessages = typeof success_msg !== "undefined" ? success_msg : [];
const safeErrorMessages = typeof error_msg !== "undefined" ? error_msg : [];
const consultationList = Array.isArray(consultations) ? consultations : [];
const channels = [
  { label: "Hotline tư vấn", value: "0344772436", note: "Phản hồi nhanh trong giờ hành chính" },
  { label: "Email", value: "realtoeiccentral@gmail.com", note: "Phù hợp khi cần gửi thông tin chi tiết" },
  { label: "Cơ sở hỗ trợ", value: "Hồ Tùng Mậu • Lê Đức Thọ", note: "Có thể hẹn tư vấn trực tiếp theo lịch" },
];

function formatDateTime(value) {
  if (!value) {
    return "Chưa có thời gian";
  }

  const date = new Date(value);
  if (Number.isNaN(date.getTime())) {
    return "Chưa có thời gian";
  }

  return date.toLocaleString("vi-VN");
}

function getStatusMeta(status) {
  if (status === "contacted") {
    return { label: "Đã phản hồi", className: "is-contacted" };
  }

  if (status === "viewed") {
    return { label: "Đang xử lý", className: "is-viewed" };
  }

  return { label: "Mới gửi", className: "is-new" };
}
%>

<style>
  .sc-page{width:min(1380px,calc(100% - 32px));margin:0 auto;padding:34px 0 48px;display:grid;gap:24px}
  .sc-hero,.sc-panel,.sc-channel-grid article,.sc-request-card{border-radius:32px;border:1px solid rgba(15,23,42,.08);box-shadow:0 18px 40px rgba(15,23,42,.06);background:rgba(255,255,255,.96)}
  .sc-hero,.sc-panel,.sc-channel-grid article,.sc-request-card{padding:28px}
  .sc-hero{display:grid;gap:14px;background:linear-gradient(135deg,#f8fbff 0%,#eef4ff 52%,#fff7ed 100%)}
  .sc-hero h1,.sc-panel h2,.sc-request-title{margin:0;font-family:"Sora","Be Vietnam Pro",sans-serif;letter-spacing:-.04em;color:#0f172a}
  .sc-hero h1{font-size:clamp(2.2rem,4.4vw,3.7rem);line-height:1.04}
  .sc-hero p,.sc-panel p,.sc-channel-grid span,.sc-request-body,.sc-empty p{margin:0;color:#475569;line-height:1.8}
  .sc-flash-stack{display:grid;gap:12px}
  .sc-flash{padding:14px 16px;border-radius:18px;font-weight:700}
  .sc-flash.success{background:rgba(34,197,94,.10);color:#166534;border:1px solid rgba(34,197,94,.18)}
  .sc-flash.error{background:rgba(239,68,68,.10);color:#b91c1c;border:1px solid rgba(239,68,68,.18)}
  .sc-panel-kicker{display:inline-flex;align-items:center;min-height:36px;padding:0 14px;border-radius:999px;background:#e0ecff;color:#1d4ed8;font-weight:800}
  .sc-channel-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px}
  .sc-channel-grid strong{display:block;font-size:1.05rem;color:#0f172a}
  .sc-channel-grid span{display:block;margin-top:8px}
  .sc-panel-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:18px}
  .sc-form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}
  .sc-field{display:grid;gap:8px}
  .sc-field.full{grid-column:1 / -1}
  .sc-field label{font-weight:700;color:#334155}
  .sc-field input,.sc-field select,.sc-field textarea{width:100%;min-height:54px;padding:0 16px;border-radius:18px;border:1px solid rgba(15,23,42,.10);background:#fff;color:#0f172a;font:inherit}
  .sc-field textarea{min-height:150px;padding:14px 16px;resize:vertical}
  .sc-field input:focus,.sc-field select:focus,.sc-field textarea:focus{outline:none;border-color:rgba(37,99,235,.34);box-shadow:0 0 0 4px rgba(37,99,235,.08)}
  .sc-actions{display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin-top:18px}
  .sc-btn{display:inline-flex;align-items:center;justify-content:center;min-height:50px;padding:0 22px;border-radius:999px;border:0;background:#111827;color:#fff;font-weight:800;text-decoration:none;cursor:pointer}
  .sc-btn.secondary{background:#fff;color:#0f172a;border:1px solid rgba(15,23,42,.12)}
  .sc-hint{color:#64748b;font-size:.95rem;line-height:1.7}
  .sc-request-list{display:grid;gap:18px}
  .sc-request-card{display:grid;gap:18px}
  .sc-request-head{display:flex;flex-wrap:wrap;align-items:flex-start;justify-content:space-between;gap:14px}
  .sc-request-title{font-size:1.35rem}
  .sc-request-meta{display:flex;flex-wrap:wrap;gap:10px;align-items:center}
  .sc-badge{display:inline-flex;align-items:center;min-height:34px;padding:0 14px;border-radius:999px;font-weight:800}
  .sc-badge.is-new{background:rgba(59,130,246,.12);color:#1d4ed8}
  .sc-badge.is-viewed{background:rgba(245,158,11,.14);color:#b45309}
  .sc-badge.is-contacted{background:rgba(34,197,94,.14);color:#15803d}
  .sc-time{color:#64748b;font-weight:600}
  .sc-detail-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
  .sc-detail{padding:16px;border-radius:20px;background:#f8fafc;border:1px solid rgba(148,163,184,.18)}
  .sc-detail label{display:block;margin-bottom:6px;color:#64748b;font-size:.88rem;font-weight:700}
  .sc-detail strong{color:#0f172a;font-size:1rem}
  .sc-request-body{padding:18px;border-radius:22px;background:linear-gradient(180deg,#fff 0%,#f8fbff 100%);border:1px solid rgba(15,23,42,.08)}
  .sc-request-body strong{display:block;margin-bottom:8px;color:#0f172a}
  .sc-alert{padding:14px 16px;border-radius:18px;background:rgba(59,130,246,.08);border:1px solid rgba(59,130,246,.16);color:#1e3a8a;font-weight:700;line-height:1.7}
  .sc-empty{padding:30px;border-radius:28px;background:#fff;border:1px dashed rgba(148,163,184,.4);text-align:center}
  .sc-empty strong{display:block;margin-bottom:8px;font-size:1.15rem;color:#0f172a}
  @media (max-width:1100px){.sc-channel-grid,.sc-detail-grid,.sc-form-grid{grid-template-columns:1fr 1fr}}
  @media (max-width:760px){.sc-page{width:min(100% - 20px,1380px);padding:22px 0 30px}.sc-channel-grid,.sc-detail-grid,.sc-form-grid{grid-template-columns:1fr}.sc-hero,.sc-panel,.sc-channel-grid article,.sc-request-card{padding:20px;border-radius:24px}}
</style>

<div class="sc-page">
  <section class="sc-hero">
    <span class="sc-panel-kicker">Liên hệ học viên</span>
    <h1>Gửi yêu cầu tư vấn nhanh cho trung tâm ngay trong tài khoản.</h1>
    <p>Trang này tập trung cho việc tạo yêu cầu mới và theo dõi trạng thái xử lý. Phản hồi chi tiết từ admin sẽ được chuyển sang icon hộp thư riêng để bạn xem gọn hơn và không bị trộn ở cuối mục liên hệ.</p>
  </section>

  <% if (success || safeSuccessMessages.length || safeErrorMessages.length) { %>
    <div class="sc-flash-stack">
      <% if (success) { %>
        <div class="sc-flash success">Yêu cầu của bạn đã được gửi thành công. Trung tâm sẽ phản hồi sớm nhất có thể.</div>
      <% } %>
      <% safeSuccessMessages.forEach((item) => { %>
        <div class="sc-flash success"><%= item %></div>
      <% }) %>
      <% safeErrorMessages.forEach((item) => { %>
        <div class="sc-flash error"><%= item %></div>
      <% }) %>
    </div>
  <% } %>

  <section class="sc-channel-grid">
    <% channels.forEach((item) => { %>
      <article>
        <strong><%= item.label %></strong>
        <span><%= item.value %></span>
        <span><%= item.note %></span>
      </article>
    <% }) %>
  </section>

  <section class="sc-panel">
    <div class="sc-panel-head">
      <div>
        <h2>Tạo yêu cầu tư vấn mới</h2>
        <p>Điền thông tin càng rõ, trung tâm càng dễ hẹn đúng khung giờ, đúng cơ sở và đúng người hỗ trợ cho bạn.</p>
      </div>
      <span class="sc-panel-kicker">Biểu mẫu an toàn</span>
    </div>

    <form action="<%= safeBaseUrl %>/contact" method="POST">
      <input type="hidden" name="return_to" value="/student/contact">

      <div class="sc-form-grid">
        <div class="sc-field">
          <label>Họ tên</label>
          <input type="text" name="name" value="<%= studentName %>" required>
        </div>
        <div class="sc-field">
          <label>Email</label>
          <input type="email" name="email" value="<%= studentEmail %>" required>
        </div>
        <div class="sc-field">
          <label>Số điện thoại hoặc Zalo</label>
          <input type="text" name="phone" placeholder="Ví dụ: 0344xxxxxx">
        </div>
        <div class="sc-field">
          <label>Kênh phản hồi mong muốn</label>
          <select name="preferred_contact_method">
            <option value="Nhắn trong hệ thống">Nhắn trong hệ thống</option>
            <option value="Gọi điện">Gọi điện</option>
            <option value="Zalo">Zalo</option>
            <option value="Email">Email</option>
            <option value="Tư vấn trực tiếp">Tư vấn trực tiếp</option>
          </select>
        </div>
        <div class="sc-field">
          <label>Mục tiêu hỗ trợ</label>
          <select name="goal">
            <option value="Tư vấn khóa học học viên">Tư vấn khóa học</option>
            <option value="Hỏi lịch khai giảng">Hỏi lịch khai giảng</option>
            <option value="Hỗ trợ thanh toán">Hỗ trợ thanh toán</option>
            <option value="Hẹn tư vấn trực tiếp">Hẹn tư vấn trực tiếp</option>
            <option value="Hỗ trợ tài khoản">Hỗ trợ tài khoản</option>
          </select>
        </div>
        <div class="sc-field">
          <label>Khóa học quan tâm</label>
          <input type="text" name="course_interest" placeholder="Ví dụ: TOEIC A, TOEIC B, Tập Sự">
        </div>
        <div class="sc-field full">
          <label>Khung giờ mong muốn</label>
          <input type="text" name="schedule_preference" placeholder="Ví dụ: Tối 2-4-6, cuối tuần, sau 19:00">
        </div>
        <div class="sc-field full">
          <label>Nội dung cần tư vấn</label>
          <textarea name="message" placeholder="Ví dụ: Em muốn được tư vấn lộ trình, xin lịch hẹn trực tiếp ở cơ sở Hồ Tùng Mậu, và nếu cần thì trung tâm có thể liên hệ qua Zalo." required></textarea>
        </div>
      </div>

      <div class="sc-actions">
        <button type="submit" class="sc-btn">Gửi yêu cầu tư vấn</button>
        <span class="sc-hint">Khi admin phản hồi, nội dung mới sẽ được chuyển sang icon hộp thư cạnh chuông thông báo để bạn theo dõi tách biệt.</span>
      </div>
    </form>
  </section>

  <section class="sc-panel">
    <div class="sc-panel-head">
      <div>
        <h2>Theo dõi trạng thái yêu cầu</h2>
        <p>Bạn vẫn có thể xem mỗi yêu cầu đang ở trạng thái nào tại đây. Các lời nhắn phản hồi chi tiết từ admin sẽ nằm trong hộp thư học viên.</p>
      </div>
      <span class="sc-panel-kicker"><%= consultationList.length %> yêu cầu</span>
    </div>

    <% if (!consultationList.length) { %>
      <div class="sc-empty">
        <strong>Bạn chưa có yêu cầu tư vấn nào.</strong>
        <p>Hãy gửi biểu mẫu ở trên, trung tâm sẽ tiếp nhận và cập nhật tiến độ xử lý trực tiếp vào tài khoản này.</p>
      </div>
    <% } else { %>
      <div class="sc-request-list">
        <% consultationList.forEach((item) => { const statusMeta = getStatusMeta(item.status); const hasMailboxResponse = Number(item.response_count || 0) > 0 || (item.responses && item.responses.length); %>
          <article class="sc-request-card">
            <div class="sc-request-head">
              <div>
                <h3 class="sc-request-title"><%= item.goal || "Yêu cầu tư vấn khóa học" %></h3>
                <div class="sc-time">Gửi lúc <%= formatDateTime(item.created_at) %></div>
              </div>
              <div class="sc-request-meta">
                <span class="sc-badge <%= statusMeta.className %>"><%= statusMeta.label %></span>
                <% if (item.contacted_at) { %>
                  <span class="sc-time">Cập nhật gần nhất <%= formatDateTime(item.contacted_at) %></span>
                <% } %>
              </div>
            </div>

            <div class="sc-detail-grid">
              <div class="sc-detail">
                <label>Email</label>
                <strong><%= item.email || "Chưa cung cấp" %></strong>
              </div>
              <div class="sc-detail">
                <label>Điện thoại / Zalo</label>
                <strong><%= item.phone || "Chưa cung cấp" %></strong>
              </div>
              <div class="sc-detail">
                <label>Khóa học quan tâm</label>
                <strong><%= item.course_interest || "Chưa chọn" %></strong>
              </div>
              <div class="sc-detail">
                <label>Khung giờ mong muốn</label>
                <strong><%= item.schedule_preference || "Chưa chọn" %></strong>
              </div>
            </div>

            <div class="sc-request-body">
              <strong>Nội dung bạn đã gửi</strong>
              <p><%= item.message_body || item.message || "Không có nội dung." %></p>
            </div>

            <% if (hasMailboxResponse) { %>
              <div class="sc-alert">Yêu cầu này đã có phản hồi từ admin. Mở hộp thư học viên để xem chi tiết lịch hẹn, kênh liên hệ và lời nhắn mới nhất.</div>
              <div class="sc-actions" style="margin-top:0">
                <a href="<%= safeBaseUrl %>/student/mailbox" class="sc-btn">Mở hộp thư học viên</a>
              </div>
            <% } else { %>
              <div class="sc-alert">Yêu cầu của bạn đã được ghi nhận. Khi đội ngũ tư vấn cập nhật, nội dung chi tiết sẽ xuất hiện trong hộp thư học viên.</div>
            <% } %>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>
