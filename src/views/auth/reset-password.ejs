<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Đặt lại mật khẩu' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-top: #eff7ff;
      --bg-mid: #f8fbff;
      --bg-bottom: #ffe8f1;
      --panel-edge: rgba(110, 143, 204, 0.14);
      --field: rgba(248, 251, 255, 0.98);
      --field-edge: rgba(110, 143, 204, 0.14);
      --text: #17314c;
      --muted: #667c96;
      --muted-strong: #44607e;
      --accent-start: #ff7a59;
      --accent-mid: #ff5d8f;
      --accent-end: #ffb14a;
      --accent-text: #ffffff;
      --line: rgba(110, 143, 204, 0.14);
      --success: #067647;
      --danger: #b42318;
      --info: #175cd3;
      --shadow: 0 36px 90px rgba(44, 78, 129, 0.14);
      --brand: #2f78ed;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      min-height: 100%;
      margin: 0;
      font-family: "Manrope", "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(47, 120, 237, 0.16), transparent 28%),
        radial-gradient(circle at top right, rgba(255, 93, 143, 0.14), transparent 22%),
        radial-gradient(circle at bottom left, rgba(255, 177, 74, 0.16), transparent 26%),
        linear-gradient(160deg, var(--bg-top) 0%, var(--bg-mid) 42%, var(--bg-bottom) 100%);
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background:
        linear-gradient(rgba(110, 143, 204, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(110, 143, 204, 0.05) 1px, transparent 1px);
      background-size: 28px 28px;
      opacity: 0.34;
      pointer-events: none;
      mask-image: radial-gradient(circle at center, black, transparent 88%);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    input {
      font: inherit;
    }

    .reset-page {
      min-height: 100vh;
      padding: 34px 22px 48px;
      display: flex;
      flex-direction: column;
    }

    .reset-shell {
      width: min(100%, 1080px);
      margin: 0 auto;
      flex: 1;
      display: grid;
      gap: 28px;
      align-content: start;
    }

    .reset-brand {
      display: inline-flex;
      align-items: center;
      gap: 16px;
      width: fit-content;
      margin-left: 6px;
    }

    .reset-brand-mark {
      width: 54px;
      height: 54px;
      border-radius: 18px;
      overflow: hidden;
      background: linear-gradient(135deg, rgba(47, 120, 237, 0.14) 0%, rgba(255, 93, 143, 0.18) 100%);
      box-shadow: 0 16px 32px rgba(47, 120, 237, 0.14);
    }

    .reset-brand-mark img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 4px;
      display: block;
    }

    .reset-brand-copy {
      font-family: "Sora", "Manrope", sans-serif;
      font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 800;
      letter-spacing: -0.05em;
      background: linear-gradient(90deg, var(--accent-start) 0%, var(--accent-mid) 48%, var(--accent-end) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .reset-stage {
      display: grid;
      justify-content: center;
    }

    .reset-card {
      width: min(100%, 760px);
      padding: 40px 34px 34px;
      border-radius: 40px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(251, 253, 255, 0.98) 100%);
      border: 1px solid var(--panel-edge);
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }

    .reset-card::before {
      content: "";
      position: absolute;
      inset: -20% auto auto -18%;
      width: 220px;
      height: 220px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(47, 120, 237, 0.12), transparent 72%);
      pointer-events: none;
    }

    .reset-card::after {
      content: "";
      position: absolute;
      inset: auto -14% -16% auto;
      width: 260px;
      height: 260px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(255, 93, 143, 0.14), transparent 72%);
      pointer-events: none;
    }

    .reset-stack {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 24px;
    }

    .reset-copy {
      display: grid;
      gap: 12px;
    }

    .reset-overline {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      width: fit-content;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(47, 120, 237, 0.08);
      color: var(--brand);
      font-size: 0.84rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .reset-copy h1 {
      margin: 0;
      font-family: "Sora", "Manrope", sans-serif;
      font-size: clamp(2.2rem, 5vw, 3.3rem);
      line-height: 1;
      letter-spacing: -0.05em;
      background: linear-gradient(90deg, var(--accent-start) 0%, var(--accent-mid) 48%, var(--accent-end) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .reset-copy p {
      margin: 0;
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.75;
    }

    .reset-highlight {
      padding: 16px 18px;
      border-radius: 20px;
      background: rgba(47, 120, 237, 0.08);
      color: var(--brand);
      font-weight: 700;
    }

    .reset-flash-stack,
    .reset-aside {
      display: grid;
      gap: 10px;
    }

    .reset-flash,
    .reset-note {
      padding: 14px 16px;
      border-radius: 18px;
      border: 1px solid var(--line);
      font-size: 0.97rem;
      line-height: 1.7;
      background: rgba(255, 255, 255, 0.94);
    }

    .reset-flash.success {
      color: var(--success);
      background: rgba(236, 253, 243, 0.96);
      border-color: rgba(6, 118, 71, 0.14);
    }

    .reset-flash.error {
      color: var(--danger);
      background: rgba(254, 243, 242, 0.96);
      border-color: rgba(180, 35, 24, 0.14);
    }

    .reset-note.info {
      color: var(--info);
      background: rgba(239, 248, 255, 0.96);
      border-color: rgba(23, 92, 211, 0.14);
    }

    .reset-form {
      display: grid;
      gap: 18px;
    }

    .reset-label {
      color: var(--muted-strong);
      font-size: 0.86rem;
      font-weight: 800;
      letter-spacing: 0.09em;
      text-transform: uppercase;
    }

    .reset-field-grid {
      display: grid;
      gap: 16px;
    }

    .reset-input-wrap {
      display: grid;
      grid-template-columns: 28px minmax(0, 1fr) auto;
      align-items: center;
      gap: 14px;
      min-height: 76px;
      padding: 0 22px;
      border-radius: 22px;
      background: var(--field);
      border: 1px solid transparent;
      box-shadow: inset 0 0 0 1px var(--field-edge);
      transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    }

    .reset-input-wrap:focus-within {
      border-color: rgba(47, 120, 237, 0.28);
      transform: translateY(-1px);
      box-shadow: inset 0 0 0 1px rgba(47, 120, 237, 0.2), 0 18px 34px rgba(44, 78, 129, 0.12);
    }

    .reset-input-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #557190;
    }

    .reset-input {
      width: 100%;
      min-width: 0;
      border: 0;
      outline: none;
      background: transparent;
      color: var(--text);
      font-size: 1.04rem;
    }

    .reset-input::placeholder {
      color: rgba(102, 124, 150, 0.58);
    }

    .reset-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      border: 0;
      border-radius: 999px;
      background: transparent;
      color: #6480a1;
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease;
    }

    .reset-toggle:hover {
      background: rgba(47, 120, 237, 0.08);
      color: var(--brand);
    }

    .reset-submit {
      min-height: 72px;
      border: 0;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--accent-start) 0%, var(--accent-mid) 48%, var(--accent-end) 100%);
      color: var(--accent-text);
      font-family: "Sora", "Manrope", sans-serif;
      font-size: clamp(1.1rem, 3vw, 1.4rem);
      font-weight: 800;
      letter-spacing: -0.04em;
      cursor: pointer;
      box-shadow: 0 22px 46px rgba(255, 93, 143, 0.24);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .reset-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 28px 52px rgba(255, 93, 143, 0.3);
    }

    .reset-footer {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 14px;
      color: var(--muted);
      font-size: 0.98rem;
    }

    .reset-footer a {
      color: var(--brand);
      font-weight: 700;
    }

    @media (max-width: 720px) {
      .reset-page {
        padding: 28px 14px 40px;
      }

      .reset-card {
        padding: 32px 22px 24px;
        border-radius: 32px;
      }

      .reset-input-wrap {
        min-height: 70px;
        padding: 0 18px;
        border-radius: 18px;
      }
    }
  </style>
</head>
<body>
  <%
    const safeBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : '';
    const safeSuccessMessages = typeof success_msg !== 'undefined' ? success_msg : [];
    const safeErrorMessages = typeof error_msg !== 'undefined' ? error_msg : [];
    const rawToken = typeof token !== 'undefined' ? token : '';
    const emailMask = typeof maskedEmail !== 'undefined' ? maskedEmail : '';
    const tokenExpiryMinutes = typeof expiresMinutes !== 'undefined' ? expiresMinutes : 30;
    const brandLogo = 'https://i.postimg.cc/P5r5F9Mt/logo.jpg';
  %>

  <main class="reset-page">
    <div class="reset-shell">
      <a href="<%= safeBaseUrl %>/" class="reset-brand" aria-label="Về trang chủ">
        <span class="reset-brand-mark" aria-hidden="true">
          <img src="<%= brandLogo %>" alt="Logo Thầy Tài Toeic">
        </span>
        <span class="reset-brand-copy">THAYTAI</span>
      </a>

      <section class="reset-stage">
        <div class="reset-card">
          <div class="reset-stack">
            <div class="reset-copy">
              <span class="reset-overline">Thiết lập mật khẩu mới</span>
              <h1>Đặt lại mật khẩu</h1>
              <p>Liên kết này dành cho tài khoản <strong><%= emailMask %></strong>. Hãy tạo một mật khẩu mới đủ an toàn rồi dùng mật khẩu đó để đăng nhập ngay.</p>
            </div>

            <div class="reset-highlight">
              Liên kết khôi phục có hiệu lực trong khoảng <strong><%= tokenExpiryMinutes %> phút</strong> kể từ lúc bạn yêu cầu.
            </div>

            <% if (safeSuccessMessages.length || safeErrorMessages.length) { %>
              <div class="reset-flash-stack">
                <% safeSuccessMessages.forEach((msg) => { %>
                  <div class="reset-flash success"><%= msg %></div>
                <% }) %>
                <% safeErrorMessages.forEach((msg) => { %>
                  <div class="reset-flash error"><%= msg %></div>
                <% }) %>
              </div>
            <% } %>

            <div class="reset-aside">
              <div class="reset-note info">Mật khẩu mới nên dễ nhớ với bạn nhưng khó đoán với người khác. Không dùng lại mật khẩu cũ hoặc các chuỗi quá quen thuộc.</div>
            </div>

            <form action="<%= safeBaseUrl %>/reset-password" method="POST" class="reset-form">
              <input type="hidden" name="token" value="<%= rawToken %>">

              <div class="reset-field-grid">
                <label class="reset-label" for="newPassword">Mật khẩu mới</label>
                <label class="reset-input-wrap" for="newPassword">
                  <span class="reset-input-icon" aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="5" y="11" width="14" height="10" rx="2"></rect>
                      <path d="M8 11V8a4 4 0 1 1 8 0v3"></path>
                    </svg>
                  </span>
                  <input class="reset-input" id="newPassword" type="password" name="password" placeholder="Tối thiểu 6 ký tự" autocomplete="new-password" minlength="6" required>
                  <button class="reset-toggle" type="button" data-toggle-target="newPassword" aria-label="Hiển thị mật khẩu mới">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"></path>
                      <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                  </button>
                </label>
              </div>

              <div class="reset-field-grid">
                <label class="reset-label" for="confirmPassword">Xác nhận mật khẩu</label>
                <label class="reset-input-wrap" for="confirmPassword">
                  <span class="reset-input-icon" aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 12.75 11.25 15 15.75 9"></path>
                      <rect x="5" y="11" width="14" height="10" rx="2"></rect>
                      <path d="M8 11V8a4 4 0 1 1 8 0v3"></path>
                    </svg>
                  </span>
                  <input class="reset-input" id="confirmPassword" type="password" name="confirmPassword" placeholder="Nhập lại mật khẩu mới" autocomplete="new-password" minlength="6" required>
                  <button class="reset-toggle" type="button" data-toggle-target="confirmPassword" aria-label="Hiển thị xác nhận mật khẩu">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"></path>
                      <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                  </button>
                </label>
              </div>

              <button class="reset-submit" type="submit">Cập nhật mật khẩu</button>
            </form>

            <div class="reset-footer">
              <span>Liên kết không còn hiệu lực? <a href="<%= safeBaseUrl %>/forgot-password">Yêu cầu liên kết mới</a></span>
              <span>Muốn quay lại ngay? <a href="<%= safeBaseUrl %>/login">Trang đăng nhập</a></span>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script>
    (() => {
      const toggleButtons = document.querySelectorAll('[data-toggle-target]');

      toggleButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const targetId = button.getAttribute('data-toggle-target');
          const input = document.getElementById(targetId);

          if (!input) {
            return;
          }

          input.type = input.type === 'password' ? 'text' : 'password';
        });
      });
    })();
  </script>
</body>
</html>
