<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : (typeof title !== 'undefined' ? title : 'Đăng ký') %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-1: #f7fbff;
      --bg-2: #edf5ff;
      --bg-3: #ffe7f0;
      --panel: rgba(255, 255, 255, 0.94);
      --panel-strong: rgba(255, 255, 255, 0.99);
      --line: rgba(96, 122, 190, 0.14);
      --ink: #16304a;
      --muted: #61768f;
      --hot-1: #ff7a59;
      --hot-2: #ff5d8f;
      --hot-3: #ffb14a;
      --brand: #2f78ed;
      --success: #067647;
      --danger: #b42318;
      --info: #175cd3;
      --shadow: 0 36px 90px rgba(44, 78, 129, 0.16);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Manrope", "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(47, 120, 237, 0.16), transparent 26%),
        radial-gradient(circle at top right, rgba(255, 93, 143, 0.14), transparent 24%),
        radial-gradient(circle at bottom left, rgba(255, 177, 74, 0.18), transparent 28%),
        linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 52%, var(--bg-3) 100%);
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background:
        linear-gradient(rgba(96, 122, 190, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(96, 122, 190, 0.05) 1px, transparent 1px);
      background-size: 30px 30px;
      mask-image: radial-gradient(circle at center, black, transparent 84%);
      pointer-events: none;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    input {
      font: inherit;
    }

    .register-page {
      min-height: 100vh;
      padding: 32px 20px 48px;
      display: grid;
      align-items: start;
    }

    .register-shell {
      width: min(1160px, 100%);
      margin: 0 auto;
      display: grid;
      gap: 28px;
    }

    .register-brand {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      width: fit-content;
    }

    .register-mark {
      width: 54px;
      height: 54px;
      border-radius: 18px;
      overflow: hidden;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, rgba(47, 120, 237, 0.14) 0%, rgba(255, 93, 143, 0.18) 100%);
      box-shadow: 0 18px 34px rgba(47, 120, 237, 0.16);
    }

    .register-mark img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: contain;
      padding: 4px;
    }

    .register-brand strong {
      font-family: "Sora", "Manrope", sans-serif;
      font-size: clamp(1.9rem, 4vw, 2.6rem);
      letter-spacing: -0.06em;
      background: linear-gradient(90deg, var(--hot-1) 0%, var(--hot-2) 44%, var(--hot-3) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .register-layout {
      display: grid;
      grid-template-columns: minmax(320px, 0.95fr) minmax(420px, 0.88fr);
      gap: 26px;
      align-items: start;
    }

    .register-story,
    .register-card {
      position: relative;
      overflow: hidden;
      border-radius: 36px;
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
    }

    .register-story {
      padding: 34px;
      min-height: 100%;
      background:
        radial-gradient(circle at top right, rgba(255, 255, 255, 0.26), transparent 28%),
        linear-gradient(140deg, #17467a 0%, #2f78ed 48%, #ff7a59 100%);
      color: #fff;
    }

    .register-story::after,
    .register-card::after {
      content: "";
      position: absolute;
      inset: auto -60px -84px auto;
      width: 180px;
      height: 180px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.18), transparent 72%);
      pointer-events: none;
    }

    .register-story h1,
    .register-card h2 {
      margin: 0;
      font-family: "Sora", "Manrope", sans-serif;
      letter-spacing: -0.06em;
    }

    .register-story h1 {
      margin-top: 14px;
      font-size: clamp(2.6rem, 5vw, 4.2rem);
      line-height: 0.98;
      max-width: 10ch;
    }

    .register-story p {
      margin: 18px 0 0;
      line-height: 1.82;
      color: rgba(255, 255, 255, 0.86);
      max-width: 54ch;
    }

    .register-kicker {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .register-list {
      margin-top: 26px;
      display: grid;
      gap: 14px;
    }

    .register-list-item {
      padding: 16px 18px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(14px);
    }

    .register-list-item strong {
      display: block;
      font-size: 1rem;
    }

    .register-list-item span {
      display: block;
      margin-top: 8px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.78);
    }

    .register-card {
      padding: 34px 30px 28px;
      background: linear-gradient(180deg, var(--panel) 0%, var(--panel-strong) 100%);
    }

    .register-card h2 {
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1;
      background: linear-gradient(90deg, var(--hot-1) 0%, var(--hot-2) 48%, var(--hot-3) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .register-card p {
      margin: 12px 0 0;
      color: var(--muted);
      line-height: 1.8;
    }

    .register-flash-stack {
      margin-top: 20px;
      display: grid;
      gap: 10px;
    }

    .register-flash {
      padding: 14px 16px;
      border-radius: 18px;
      border: 1px solid var(--line);
      line-height: 1.6;
    }

    .register-flash.success {
      color: var(--success);
      border-color: rgba(6, 118, 71, 0.14);
      background: rgba(236, 253, 243, 0.96);
    }

    .register-flash.error {
      color: var(--danger);
      border-color: rgba(180, 35, 24, 0.14);
      background: rgba(254, 243, 242, 0.96);
    }

    .register-flash.info {
      color: var(--info);
      border-color: rgba(23, 92, 211, 0.14);
      background: rgba(239, 248, 255, 0.96);
    }

    .register-form {
      margin-top: 24px;
      display: grid;
      gap: 18px;
      position: relative;
      z-index: 1;
    }

    .register-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .register-field {
      display: grid;
      gap: 8px;
    }

    .register-field.full {
      grid-column: 1 / -1;
    }

    .register-field label {
      color: #324a66;
      font-size: 0.92rem;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .register-input {
      width: 100%;
      min-height: 56px;
      padding: 0 18px;
      border-radius: 18px;
      border: 1px solid rgba(96, 122, 190, 0.16);
      background: rgba(255, 255, 255, 0.98);
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    }

    .register-input:focus {
      border-color: rgba(47, 120, 237, 0.36);
      box-shadow: 0 0 0 4px rgba(47, 120, 237, 0.1);
      transform: translateY(-1px);
    }

    .register-human {
      position: relative;
      display: block;
      border-radius: 24px;
      border: 1px solid rgba(96, 122, 190, 0.18);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(246, 249, 255, 0.98));
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.42);
      overflow: hidden;
    }

    .register-human input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .register-human-ui {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 18px;
      min-height: 116px;
      padding: 20px 22px;
      cursor: pointer;
    }

    .register-human-box {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      border: 2px solid rgba(98, 117, 143, 0.42);
      background: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    }

    .register-human-box::after {
      content: "";
      width: 16px;
      height: 10px;
      border-left: 3px solid transparent;
      border-bottom: 3px solid transparent;
      transform: rotate(-45deg) translateY(-1px);
      transition: border-color 0.2s ease;
    }

    .register-human-copy strong {
      display: block;
      font-size: 1.12rem;
      color: #132f49;
    }

    .register-human-copy span {
      display: block;
      margin-top: 6px;
      color: var(--muted);
      line-height: 1.65;
      font-size: 0.94rem;
    }

    .register-human-badge {
      display: grid;
      justify-items: center;
      gap: 6px;
      color: #8193ab;
      text-align: center;
      font-size: 0.78rem;
    }

    .register-human-logo {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      background:
        linear-gradient(135deg, rgba(47, 120, 237, 0.95) 0%, rgba(47, 120, 237, 0.95) 52%, rgba(201, 211, 225, 0.95) 52%, rgba(201, 211, 225, 0.95) 100%);
      position: relative;
      overflow: hidden;
    }

    .register-human-logo::before {
      content: "";
      position: absolute;
      inset: 10px;
      border: 4px solid rgba(255, 255, 255, 0.95);
      border-left-color: transparent;
      border-bottom-color: transparent;
      border-radius: 50%;
      transform: rotate(28deg);
    }

    .register-human input:checked + .register-human-ui .register-human-box {
      border-color: rgba(6, 118, 71, 0.5);
      background: rgba(236, 253, 243, 0.98);
      transform: scale(1.03);
    }

    .register-human input:checked + .register-human-ui .register-human-box::after {
      border-left-color: #067647;
      border-bottom-color: #067647;
    }

    .register-human input:checked + .register-human-ui .register-human-copy strong {
      color: #0e5f43;
    }

    .register-captcha-panel {
      display: none;
      margin-top: 14px;
      padding: 18px;
      border-radius: 22px;
      border: 1px solid rgba(96, 122, 190, 0.16);
      background: linear-gradient(180deg, rgba(248, 251, 255, 0.98), rgba(241, 246, 255, 0.98));
      gap: 14px;
    }

    .register-captcha-panel.is-open {
      display: grid;
    }

    .register-captcha-code {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 70px;
      padding: 0 20px;
      border-radius: 18px;
      border: 1px dashed rgba(93, 109, 161, 0.35);
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.94) 0%, rgba(229, 236, 252, 0.92) 100%),
        repeating-linear-gradient(120deg, rgba(99, 102, 241, 0.08) 0 8px, rgba(255, 255, 255, 0.04) 8px 16px);
      color: #17324d;
      font-family: "Sora", "Be Vietnam Pro", sans-serif;
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      user-select: none;
    }

    .register-captcha-hint {
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.65;
    }

    .register-captcha-label {
      margin: 0;
      color: #17324d;
      font-size: 0.96rem;
      font-weight: 700;
    }

    .register-captcha-input {
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .register-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
    }

    .register-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 56px;
      padding: 0 22px;
      border-radius: 999px;
      border: 0;
      font-weight: 800;
      cursor: pointer;
      background: linear-gradient(135deg, var(--hot-1) 0%, var(--hot-2) 52%, var(--hot-3) 100%);
      color: #fff;
      box-shadow: 0 18px 36px rgba(255, 93, 143, 0.22);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .register-button:hover {
      transform: translateY(-2px);
    }

    .register-inline {
      color: var(--muted);
      line-height: 1.75;
    }

    .register-footer {
      margin-top: 18px;
      color: var(--muted);
      font-size: 1rem;
    }

    .register-footer a {
      color: #d9485f;
      font-weight: 800;
    }

    @media (max-width: 980px) {
      .register-layout {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      .register-page {
        padding: 24px 14px 34px;
      }

      .register-story,
      .register-card {
        border-radius: 28px;
      }

      .register-story,
      .register-card {
        padding: 24px 20px;
      }

      .register-grid {
        grid-template-columns: 1fr;
      }

      .register-human-ui {
        grid-template-columns: auto minmax(0, 1fr);
      }

      .register-human-badge {
        grid-column: 1 / -1;
        justify-items: start;
      }

      .register-captcha-code {
        min-height: 62px;
        font-size: 1.18rem;
        letter-spacing: 0.22em;
      }
    }
  </style>
</head>
<body>
  <%
    const safeBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : '';
    const safeSuccessMessages = typeof success_msg !== 'undefined' ? success_msg : [];
    const safeErrorMessages = typeof error_msg !== 'undefined' ? error_msg : [];
    const safeInfoMessages = typeof info !== 'undefined' ? info : [];
    const initialData = typeof formData !== 'undefined' ? formData : {};
    const intendedRedirect = typeof redirectTarget !== 'undefined' ? redirectTarget : '';
    const captchaData = typeof captcha !== 'undefined' && captcha ? captcha : {};
    const captchaCode = captchaData.code || '';
    const captchaOpen = Boolean(captchaData.open);
    const loginHref = intendedRedirect
      ? `${safeBaseUrl}/login?redirect=${encodeURIComponent(intendedRedirect)}`
      : `${safeBaseUrl}/login`;
    const brandLogo = 'https://i.postimg.cc/P5r5F9Mt/logo.jpg';
  %>

  <main class="register-page">
    <div class="register-shell">
      <a href="<%= safeBaseUrl %>/" class="register-brand" aria-label="Về trang chủ">
        <span class="register-mark">
          <img src="<%= brandLogo %>" alt="Logo Thầy Tài Toeic">
        </span>
        <strong>THAYTAI</strong>
      </a>

      <section class="register-layout">
        <article class="register-story">
          <span class="register-kicker">Đăng ký trực tiếp</span>
          <h1>Tạo tài khoản nhanh, gọn và dễ dùng hơn.</h1>
          <p>
            Luồng đăng ký đã được rút gọn còn một bước. Bạn chỉ cần nhập thông tin,
            xác nhận không phải robot và hệ thống sẽ tạo tài khoản ngay để bạn chuyển sang đăng nhập.
          </p>

          <div class="register-list">
            <div class="register-list-item">
              <strong>Bước 1. Nhập thông tin</strong>
              <span>Điền tên hiển thị, email đăng nhập và mật khẩu bạn muốn sử dụng cho tài khoản.</span>
            </div>
            <div class="register-list-item">
              <strong>Bước 2. Xác nhận thủ công</strong>
              <span>Tick vào ô “Tôi không phải robot” để mở mã captcha, sau đó nhập đúng dãy ký tự được hiển thị.</span>
            </div>
            <div class="register-list-item">
              <strong>Bước 3. Chuyển sang đăng nhập</strong>
              <span>Sau khi tạo tài khoản thành công, hệ thống sẽ tự đưa bạn về trang đăng nhập để bắt đầu sử dụng.</span>
            </div>
          </div>
        </article>

        <article class="register-card">
          <h2>Đăng ký tài khoản</h2>
          <p>
            Điền thông tin bên dưới, tick xác nhận để hiện captcha và nhập đúng mã trước khi tạo tài khoản.
          </p>

          <% if (safeSuccessMessages.length || safeErrorMessages.length || safeInfoMessages.length) { %>
            <div class="register-flash-stack">
              <% safeSuccessMessages.forEach((msg) => { %>
                <div class="register-flash success"><%= msg %></div>
              <% }) %>
              <% safeErrorMessages.forEach((msg) => { %>
                <div class="register-flash error"><%= msg %></div>
              <% }) %>
              <% safeInfoMessages.forEach((msg) => { %>
                <div class="register-flash info"><%= msg %></div>
              <% }) %>
            </div>
          <% } %>

          <form action="<%= safeBaseUrl %>/register" method="POST" class="register-form">
            <input type="hidden" name="redirect" value="<%= intendedRedirect %>">
            <div class="register-grid">
              <div class="register-field full">
                <label for="registerUsername">Tên hiển thị</label>
                <input class="register-input" id="registerUsername" type="text" name="username" placeholder="Nhập tên của bạn" required value="<%= initialData.username || '' %>">
              </div>
              <div class="register-field full">
                <label for="registerEmail">Email đăng nhập</label>
                <input class="register-input" id="registerEmail" type="email" name="email" placeholder="name@example.com" required value="<%= initialData.email || '' %>">
              </div>
              <div class="register-field full">
                <label for="registerPassword">Mật khẩu</label>
                <input class="register-input" id="registerPassword" type="password" name="password" minlength="6" placeholder="Tối thiểu 6 ký tự" required>
              </div>
              <div class="register-field full">
                <label>Xác nhận</label>
                <label class="register-human" for="notRobot">
                  <input id="notRobot" type="checkbox" name="not_robot" required <%= captchaOpen ? 'checked' : '' %>>
                  <span class="register-human-ui">
                    <span class="register-human-box" aria-hidden="true"></span>
                    <span class="register-human-copy">
                      <strong>Tôi không phải robot</strong>
                      <span>Tick vào đây để hiện mã captcha và hoàn tất bước xác nhận thủ công trước khi tạo tài khoản.</span>
                    </span>
                    <span class="register-human-badge" aria-hidden="true">
                      <span class="register-human-logo"></span>
                      <span>reCAPTCHA</span>
                      <span>Privacy - Terms</span>
                    </span>
                  </span>
                </label>
                <div class="register-captcha-panel <%= captchaOpen ? 'is-open' : '' %>" data-captcha-panel>
                  <div class="register-captcha-code" aria-live="polite"><%= captchaCode %></div>
                  <div class="register-captcha-hint">Nhập đúng dãy ký tự ở trên rồi mới có thể tạo tài khoản.</div>
                  <label class="register-captcha-label" for="registerCaptcha">Mã captcha</label>
                  <input
                    class="register-input register-captcha-input"
                    id="registerCaptcha"
                    type="text"
                    name="captcha_answer"
                    placeholder="Nhập lại mã captcha"
                    autocomplete="off"
                    autocapitalize="characters"
                    spellcheck="false"
                    <%= captchaOpen ? 'required' : 'disabled' %>
                  >
                </div>
              </div>
            </div>

            <div class="register-actions">
              <button type="submit" class="register-button">Tạo tài khoản</button>
            </div>

            <div class="register-inline">
              <%= intendedRedirect ? 'Sau khi đăng ký thành công, hệ thống sẽ đưa bạn vào thẳng khu học viên để xem khóa học.' : 'Sau khi đăng ký thành công, bạn sẽ được chuyển ngay sang trang đăng nhập.' %>
            </div>
          </form>

          <div class="register-footer">
            Đã có tài khoản? <a href="<%= loginHref %>">Đăng nhập ngay</a>
          </div>
        </article>
      </section>
    </div>
  </main>
  <script>
    (function () {
      const checkbox = document.getElementById('notRobot');
      const panel = document.querySelector('[data-captcha-panel]');
      const input = document.getElementById('registerCaptcha');

      if (!checkbox || !panel || !input) {
        return;
      }

      function syncCaptchaState(shouldFocus) {
        const isOpen = checkbox.checked;

        panel.classList.toggle('is-open', isOpen);
        input.disabled = !isOpen;
        input.required = isOpen;

        if (!isOpen) {
          input.value = '';
          return;
        }

        if (shouldFocus) {
          window.requestAnimationFrame(() => input.focus());
        }
      }

      checkbox.addEventListener('change', () => syncCaptchaState(true));
      syncCaptchaState(false);
    })();
  </script>
</body>
</html>
