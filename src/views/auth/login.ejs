<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : (typeof title !== 'undefined' ? title : 'Đăng nhập') %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-top: #eff7ff;
      --bg-mid: #f8fbff;
      --bg-bottom: #ffe8f1;
      --panel: rgba(255, 255, 255, 0.92);
      --panel-edge: rgba(110, 143, 204, 0.14);
      --field: rgba(248, 251, 255, 0.98);
      --field-edge: rgba(110, 143, 204, 0.14);
      --text: #17314c;
      --muted: #667c96;
      --muted-strong: #44607e;
      --accent-start: #ff7a59;
      --accent-mid: #ff5d8f;
      --accent-end: #ffb14a;
      --accent-text: #ffffff;
      --line: rgba(110, 143, 204, 0.12);
      --success: #067647;
      --danger: #b42318;
      --info: #175cd3;
      --shadow: 0 36px 90px rgba(44, 78, 129, 0.14);
      --brand: #2f78ed;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      min-height: 100%;
      margin: 0;
      font-family: "Manrope", "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(47, 120, 237, 0.16), transparent 28%),
        radial-gradient(circle at top right, rgba(255, 93, 143, 0.14), transparent 22%),
        radial-gradient(circle at bottom left, rgba(255, 177, 74, 0.16), transparent 26%),
        linear-gradient(160deg, var(--bg-top) 0%, var(--bg-mid) 42%, var(--bg-bottom) 100%);
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background:
        linear-gradient(rgba(110, 143, 204, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(110, 143, 204, 0.05) 1px, transparent 1px);
      background-size: 28px 28px;
      opacity: 0.34;
      pointer-events: none;
      mask-image: radial-gradient(circle at center, black, transparent 88%);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    input {
      font: inherit;
    }

    input {
      appearance: none;
      -webkit-appearance: none;
      border-radius: 0;
    }

    .auth-page {
      position: relative;
      min-height: 100vh;
      padding: 34px 22px 48px;
      display: flex;
      flex-direction: column;
    }

    .auth-shell {
      width: min(100%, 1180px);
      margin: 0 auto;
      flex: 1;
      display: grid;
      gap: 28px;
      align-content: start;
    }

    .auth-brand {
      display: inline-flex;
      align-items: center;
      gap: 16px;
      width: fit-content;
      margin-left: 6px;
    }

    .auth-brand-mark {
      width: 54px;
      height: 54px;
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(47, 120, 237, 0.14) 0%, rgba(255, 93, 143, 0.18) 100%);
      box-shadow: 0 16px 32px rgba(47, 120, 237, 0.14);
    }

    .auth-brand-mark img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: contain;
      padding: 4px;
    }

    .auth-brand-copy {
      font-family: "Sora", "Manrope", sans-serif;
      font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 800;
      letter-spacing: -0.05em;
      background: linear-gradient(90deg, var(--accent-start) 0%, var(--accent-mid) 48%, var(--accent-end) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .auth-stage {
      display: grid;
      justify-content: center;
    }

    .auth-card {
      width: min(100%, 660px);
      padding: 40px 34px 32px;
      border-radius: 44px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(251, 253, 255, 0.98) 100%);
      border: 1px solid var(--panel-edge);
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }

    .auth-card::before {
      content: "";
      position: absolute;
      inset: -20% auto auto -20%;
      width: 220px;
      height: 220px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(47, 120, 237, 0.12), transparent 72%);
      pointer-events: none;
    }

    .auth-card::after {
      content: "";
      position: absolute;
      inset: auto -14% -16% auto;
      width: 260px;
      height: 260px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(255, 93, 143, 0.14), transparent 72%);
      pointer-events: none;
    }

    .auth-stack {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 24px;
    }

    .auth-copy {
      display: grid;
      gap: 12px;
    }

    .auth-copy h1 {
      margin: 0;
      font-family: "Sora", "Manrope", sans-serif;
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      line-height: 0.98;
      letter-spacing: -0.06em;
      background: linear-gradient(90deg, var(--accent-start) 0%, var(--accent-mid) 48%, var(--accent-end) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .auth-copy p {
      margin: 0;
      max-width: 470px;
      font-size: clamp(1rem, 2vw, 1.16rem);
      line-height: 1.7;
      color: var(--muted);
    }

    .auth-flash-stack {
      display: grid;
      gap: 10px;
    }

    .auth-flash {
      padding: 14px 16px;
      border-radius: 18px;
      border: 1px solid var(--line);
      font-size: 0.97rem;
      line-height: 1.6;
    }

    .auth-flash.success {
      color: var(--success);
      background: rgba(236, 253, 243, 0.96);
      border-color: rgba(6, 118, 71, 0.14);
    }

    .auth-flash.error {
      color: var(--danger);
      background: rgba(254, 243, 242, 0.96);
      border-color: rgba(180, 35, 24, 0.14);
    }

    .auth-flash.info {
      color: var(--info);
      background: rgba(239, 248, 255, 0.96);
      border-color: rgba(23, 92, 211, 0.14);
    }

    .auth-form {
      display: grid;
      gap: 20px;
    }

    .auth-fieldset {
      display: grid;
      gap: 12px;
    }

    .auth-field-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      color: var(--muted-strong);
      font-size: 0.86rem;
      font-weight: 800;
      letter-spacing: 0.09em;
      text-transform: uppercase;
    }

    .auth-inline-link {
      color: var(--brand);
      font-size: 0.92rem;
      letter-spacing: 0;
      text-transform: none;
    }

    .auth-input-wrap {
      display: grid;
      grid-template-columns: 28px minmax(0, 1fr) auto;
      align-items: center;
      gap: 14px;
      min-height: 78px;
      padding: 0 22px;
      border-radius: 22px;
      background: var(--field);
      border: 1px solid transparent;
      box-shadow: inset 0 0 0 1px var(--field-edge);
      transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    }

    .auth-input-wrap:focus-within {
      border-color: rgba(47, 120, 237, 0.28);
      transform: translateY(-1px);
      box-shadow: inset 0 0 0 1px rgba(47, 120, 237, 0.2), 0 18px 34px rgba(44, 78, 129, 0.12);
    }

    .auth-input-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #557190;
      opacity: 0.9;
    }

    .auth-input {
      width: 100%;
      min-width: 0;
      margin: 0;
      padding: 0;
      border: 0;
      outline: none;
      background: transparent !important;
      box-shadow: none !important;
      color: var(--text);
      caret-color: var(--text);
      font-size: 1.04rem;
    }

    .auth-input::placeholder {
      color: rgba(102, 124, 150, 0.58);
    }

    .auth-ghost-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      border: 0;
      border-radius: 999px;
      background: transparent;
      color: #6480a1;
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease;
    }

    .auth-ghost-btn:hover {
      background: rgba(47, 120, 237, 0.08);
      color: var(--brand);
    }

    .auth-submit {
      margin-top: 8px;
      min-height: 78px;
      border: 0;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--accent-start) 0%, var(--accent-mid) 48%, var(--accent-end) 100%);
      color: var(--accent-text);
      font-family: "Sora", "Manrope", sans-serif;
      font-size: clamp(1.35rem, 4vw, 1.8rem);
      font-weight: 800;
      letter-spacing: -0.05em;
      cursor: pointer;
      box-shadow: 0 22px 46px rgba(255, 93, 143, 0.24);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .auth-submit:hover {
      transform: translateY(-2px);
      box-shadow: 0 28px 52px rgba(255, 93, 143, 0.3);
    }

    .auth-divider {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 14px;
      color: rgba(68, 96, 126, 0.72);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.26em;
      text-transform: uppercase;
    }

    .auth-divider::before,
    .auth-divider::after {
      content: "";
      height: 1px;
      background: rgba(110, 143, 204, 0.18);
    }

    .auth-social-row {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .auth-social {
      min-height: 82px;
      padding: 0 20px;
      border-radius: 999px;
      border: 1px solid rgba(110, 143, 204, 0.12);
      background: rgba(255, 255, 255, 0.88);
      color: var(--text);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      font-size: 1rem;
      font-weight: 700;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.28);
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .auth-social:hover {
      transform: translateY(-2px);
      border-color: rgba(47, 120, 237, 0.2);
      box-shadow: 0 16px 30px rgba(44, 78, 129, 0.12);
    }

    .auth-social-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 1);
      color: #111827;
      font-weight: 800;
      flex: 0 0 auto;
      border: 1px solid rgba(110, 143, 204, 0.12);
    }

    .auth-social-icon.facebook {
      background: #1877f2;
      color: #fff;
      border-color: #1877f2;
    }

    .auth-social-note {
      margin: 4px 4px 0;
      color: rgba(102, 124, 150, 0.9);
      font-size: 0.92rem;
      text-align: center;
      line-height: 1.7;
      display: none;
    }

    .auth-footer {
      text-align: center;
      color: var(--muted);
      font-size: clamp(1rem, 2vw, 1.08rem);
    }

    .auth-footer a {
      color: var(--accent-mid);
      font-weight: 800;
    }

    @media (max-width: 720px) {
      .auth-page {
        padding: 28px 14px 40px;
      }

      .auth-card {
        border-radius: 34px;
        padding: 32px 22px 24px;
      }

      .auth-brand {
        gap: 12px;
      }

      .auth-brand-copy {
        font-size: 2.2rem;
      }

      .auth-copy h1 {
        font-size: 2.9rem;
      }

      .auth-input-wrap {
        min-height: 70px;
        padding: 0 18px;
        border-radius: 18px;
      }

      .auth-submit {
        min-height: 70px;
      }

      .auth-social-row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <%
    const safeBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : '';
    const safeSuccessMessages = typeof success_msg !== 'undefined' ? success_msg : [];
    const safeErrorMessages = typeof error_msg !== 'undefined' ? error_msg : [];
    const safeInfoMessages = typeof info !== 'undefined' ? info : [];
    const emailValue = typeof formEmail !== 'undefined' ? formEmail : '';
    const googleOAuthReady = typeof googleConfigured !== 'undefined' ? Boolean(googleConfigured) : false;
    const facebookOAuthReady = typeof facebookConfigured !== 'undefined' ? Boolean(facebookConfigured) : false;
    const brandLogo = 'https://i.postimg.cc/P5r5F9Mt/logo.jpg';
  %>

  <main class="auth-page">
    <div class="auth-shell">
      <a href="<%= safeBaseUrl %>/" class="auth-brand" aria-label="Về trang chủ">
        <span class="auth-brand-mark" aria-hidden="true">
          <img src="<%= brandLogo %>" alt="Logo Thầy Tài Toeic">
        </span>
        <span class="auth-brand-copy">THAYTAI</span>
      </a>

      <section class="auth-stage">
        <div class="auth-card">
          <div class="auth-stack">
            <div class="auth-copy">
              <h1>Đăng nhập tài khoản</h1>
              <p>Truy cập khu học viên, nhận tài liệu, nộp bài và theo dõi lớp học trong một không gian nhẹ, hiện đại và dễ đọc hơn.</p>
            </div>

            <% if (safeSuccessMessages.length || safeErrorMessages.length || safeInfoMessages.length) { %>
              <div class="auth-flash-stack">
                <% safeSuccessMessages.forEach((msg) => { %>
                  <div class="auth-flash success"><%= msg %></div>
                <% }) %>
                <% safeErrorMessages.forEach((msg) => { %>
                  <div class="auth-flash error"><%= msg %></div>
                <% }) %>
                <% safeInfoMessages.forEach((msg) => { %>
                  <div class="auth-flash info"><%= msg %></div>
                <% }) %>
              </div>
            <% } %>

            <form action="<%= safeBaseUrl %>/login" method="POST" class="auth-form">
              <div class="auth-fieldset">
                <div class="auth-field-head">
                  <span>Gmail / Email</span>
                </div>
                <label class="auth-input-wrap">
                  <span class="auth-input-icon" aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 6h16v12H4z"></path>
                      <path d="m4 7 8 6 8-6"></path>
                    </svg>
                  </span>
                  <input class="auth-input" type="email" name="email" placeholder="name@gmail.com" autocomplete="email" required value="<%= emailValue %>">
                </label>
              </div>

              <div class="auth-fieldset">
                <div class="auth-field-head">
                  <span>Mật khẩu</span>
                  <a href="<%= safeBaseUrl %>/contact" class="auth-inline-link">Cần hỗ trợ?</a>
                </div>
                <label class="auth-input-wrap">
                  <span class="auth-input-icon" aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="5" y="11" width="14" height="10" rx="2"></rect>
                      <path d="M8 11V8a4 4 0 1 1 8 0v3"></path>
                    </svg>
                  </span>
                  <input class="auth-input" id="passwordInput" type="password" name="password" placeholder="Nhập mật khẩu" autocomplete="current-password" required>
                  <button class="auth-ghost-btn" type="button" id="togglePassword" aria-label="Hiển thị mật khẩu" aria-pressed="false">
                    <svg id="eyeOpen" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"></path>
                      <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                  </button>
                </label>
              </div>

              <button class="auth-submit" type="submit">Đăng nhập</button>

              <div class="auth-divider">Hoặc tiếp tục bằng</div>

              <div class="auth-social-row" aria-label="Đăng nhập social">
                <a href="<%= safeBaseUrl %>/auth/google" class="auth-social">
                  <span class="auth-social-icon">G</span>
                  <span>Google</span>
                </a>
                <a href="<%= safeBaseUrl %>/auth/facebook" class="auth-social">
                  <span class="auth-social-icon facebook">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M13.5 22v-8.1h2.7l.4-3.2h-3.1V8.7c0-.9.3-1.5 1.6-1.5h1.7V4.4c-.3 0-1.3-.1-2.5-.1-2.5 0-4.2 1.5-4.2 4.3v2.4H7.8v3.2h2.8V22h2.9Z"></path>
                    </svg>
                  </span>
                  <span>Facebook</span>
                </a>
              </div>

              <div
                class="auth-social-note"
                data-google-ready="<%= googleOAuthReady ? 'true' : 'false' %>"
                data-facebook-ready="<%= facebookOAuthReady ? 'true' : 'false' %>"
              >
                Nút Google và Facebook sẽ dùng OAuth nếu đã cấu hình; nếu thiết bị của khách đang đăng nhập sẵn thì sẽ được chuyển sang phiên đăng nhập tương ứng.
              </div>
            </form>
          </div>
        </div>
      </section>

      <div class="auth-footer">
        Chưa có tài khoản? <a href="<%= safeBaseUrl %>/register">Đăng ký ngay</a>
      </div>
    </div>
  </main>

  <script>
    (() => {
      const passwordInput = document.getElementById('passwordInput');
      const toggleButton = document.getElementById('togglePassword');

      if (!passwordInput || !toggleButton) {
        return;
      }

      toggleButton.addEventListener('click', () => {
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';
        toggleButton.setAttribute('aria-pressed', isPassword ? 'true' : 'false');
      });
    })();

    (() => {
      const socialNote = document.querySelector('.auth-social-note');

      if (!socialNote) {
        return;
      }
      socialNote.remove();
    })();
  </script>
</body>
</html>
