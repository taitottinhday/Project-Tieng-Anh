<%
const sections = Array.isArray(studySections) ? studySections : [];
%>

<style>
  .ghub-page{display:grid;gap:28px}
  .ghub-hero{padding:36px;border-radius:32px;background:linear-gradient(135deg,#eff6ff 0%,#ffffff 52%,#dbeafe 100%);border:1px solid rgba(37,99,235,.12);box-shadow:0 24px 46px rgba(37,99,235,.10)}
  .ghub-hero h1{margin:0;font-family:"Sora","Be Vietnam Pro",sans-serif;font-size:clamp(2.2rem,5vw,4rem);line-height:1.03;letter-spacing:-.05em;color:#102a43}
  .ghub-hero p{margin:16px 0 0;max-width:820px;color:#4b6382;line-height:1.9}
  .ghub-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px}
  .ghub-card{padding:24px;border-radius:28px;background:linear-gradient(180deg,#ffffff 0%,#f7fbff 100%);border:1px solid rgba(37,99,235,.10);box-shadow:0 18px 34px rgba(15,23,42,.05);display:grid;gap:16px}
  .ghub-card h2{margin:0;font-family:"Sora","Be Vietnam Pro",sans-serif;font-size:1.35rem;letter-spacing:-.04em;color:#173f73}
  .ghub-card p{margin:0;color:#58708f;line-height:1.8}
  .ghub-link{display:inline-flex;align-items:center;justify-content:center;min-height:46px;padding:0 18px;border-radius:999px;background:linear-gradient(135deg,#60a5fa 0%,#2563eb 100%);color:#fff;text-decoration:none;font-weight:800;width:max-content;box-shadow:0 18px 28px rgba(37,99,235,.22)}
  @media (max-width:980px){.ghub-grid{grid-template-columns:1fr}}
</style>

<div class="ghub-page">
  <section class="ghub-hero">
    <h1>Góc học tập TOEIC.</h1>
    <p>
      Bắt đầu từ đây để đi đến đề thi online, khóa học và khu vực nhận tư vấn trong một hành trình thống nhất.
    </p>
  </section>

  <section class="ghub-grid">
    <% sections.forEach((section) => { %>
      <article class="ghub-card">
        <h2><%= section.title %></h2>
        <p><%= section.desc %></p>
        <a href="<%= section.href %>" class="ghub-link"><%= section.action %></a>
      </article>
    <% }) %>
  </section>
</div>
