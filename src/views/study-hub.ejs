<% const hub=studyHub || {}; const groups=Array.isArray(hub.groups) ? hub.groups : []; %>

  <style>
    .shub-page {
      display: grid;
      gap: 56px;
      padding: 24px 0 56px;
      background: #ffffff;
    }

    .shub-hero,
    .shub-group {
      width: min(1180px, calc(100% - 28px));
      margin: 0 auto;
    }

    .shub-hero-copy {
      display: grid;
      gap: 18px;
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
    }

    .shub-hero h1,
    .shub-group-title,
    .shub-card h3 {
      margin: 0;
      font-family: "Sora", "Be Vietnam Pro", sans-serif;
      letter-spacing: -0.05em;
      color: #040404;
    }

    .shub-hero h1 {
      color: #ff4f70;
      font-size: clamp(2.6rem, 5.8vw, 5rem);
      line-height: 1.14;
    }

    .shub-hero p {
      margin: 0 auto;
      max-width: 760px;
      color: #050505;
      font-size: clamp(1.18rem, 2.3vw, 1.9rem);
      line-height: 1.7;
    }

    .shub-helper {
      justify-self: center;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 0 18px;
      border-radius: 999px;
      background: #fff3f6;
      color: #9f1239;
      font-weight: 700;
      text-align: center;
    }

    .shub-group {
      display: grid;
      gap: 24px;
    }

    .shub-group-title {
      font-size: clamp(2.2rem, 4.5vw, 3.9rem);
      line-height: 1.06;
    }

    .shub-group-grid {
      display: grid;
      gap: 24px;
    }

    .shub-group-grid.is-two-column {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .shub-group-grid.is-single {
      grid-template-columns: 1fr;
    }

    .shub-card {
      display: grid;
      place-items: center;
      padding: 34px 28px;
      border-radius: 30px;
      min-height: 212px;
      box-shadow: 0 22px 40px rgba(15, 23, 42, 0.06);
    }

    .shub-card.is-list {
      min-height: 420px;
    }

    .shub-card.lavender {
      background: linear-gradient(180deg, #d9d8ee 0%, #d2d0ea 100%);
    }

    .shub-card.mint {
      background: linear-gradient(180deg, #7dddb2 0%, #73d8b0 100%);
    }

    .shub-card.sky {
      background: linear-gradient(180deg, #bfdcff 0%, #b5d6ff 100%);
    }

    .shub-card.powder {
      background: linear-gradient(180deg, #c8dfff 0%, #bdd9ff 100%);
    }

    .shub-card-body {
      width: min(100%, 520px);
      display: grid;
      gap: 26px;
      justify-items: center;
      text-align: center;
    }

    .shub-card h3 {
      font-size: clamp(1.9rem, 3.1vw, 3rem);
      line-height: 1.18;
    }

    .shub-card.is-list h3 {
      max-width: 12ch;
    }

    .shub-pill-list {
      display: grid;
      gap: 18px;
      justify-items: center;
    }

    .shub-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      padding: 0 28px;
      border-radius: 999px;
      border: 0;
      background: #ffffff;
      color: #2383ff;
      font-size: 1rem;
      font-weight: 800;
      text-decoration: none;
      box-shadow: 0 16px 24px rgba(255, 255, 255, 0.36);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .shub-pill:hover {
      transform: translateY(-1px);
      box-shadow: 0 18px 28px rgba(15, 23, 42, 0.08);
    }

    .shub-pill-primary {
      color: #0f9fc7;
      font-size: 1.08rem;
      padding-inline: 30px;
    }

    @media (max-width: 920px) {
      .shub-page {
        gap: 44px;
      }

      .shub-group-grid.is-two-column {
        grid-template-columns: 1fr;
      }

      .shub-card.is-list {
        min-height: 360px;
      }
    }

    @media (max-width: 720px) {
      .shub-page {
        gap: 36px;
        padding: 18px 0 42px;
      }

      .shub-hero,
      .shub-group {
        width: min(100% - 20px, 1180px);
      }

      .shub-hero-copy {
        gap: 14px;
      }

      .shub-hero p {
        font-size: 1.06rem;
      }

      .shub-group {
        gap: 18px;
      }

      .shub-card {
        padding: 24px 18px;
        border-radius: 24px;
        min-height: 188px;
      }

      .shub-card.is-list {
        min-height: 328px;
      }

      .shub-card-body {
        gap: 18px;
      }

      .shub-card h3 {
        font-size: clamp(1.7rem, 6vw, 2.35rem);
      }

      .shub-pill-list {
        gap: 14px;
      }

      .shub-pill {
        min-height: 48px;
        padding: 0 22px;
      }
    }
  </style>

  <div class="shub-page">
    <section class="shub-hero">
      <div class="shub-hero-copy">
        <h1>
          <%= hub.heroTitle || "Luyện tập TOEIC online cùng Lớp TOEIC thầy Tài" %>
        </h1>
        <p>
          <%= hub.heroSummary || "Cùng luyện tập những bài test TOEIC được các thầy cô tổng hợp, kèm đáp án chi tiết."
            %>
        </p>
        <% if (hub.helperText) { %>
          <div class="shub-helper">
            <%= hub.helperText %>
          </div>
          <% } %>
      </div>
    </section>

    <% groups.forEach((group)=> { %>
      <section class="shub-group">
        <h2 class="shub-group-title">
          <%= group.heading %>
        </h2>

        <div class="shub-group-grid <%= group.layout === 'two-column' ? 'is-two-column' : 'is-single' %>">
          <% (group.cards || []).forEach((card)=> { %>
            <article class="shub-card <%= card.tone || 'sky' %> <%= card.kind === 'list' ? 'is-list' : 'is-cta' %>">
              <div class="shub-card-body">
                <h3>
                  <%= card.title %>
                </h3>

                <% if (card.kind==='list' ) { %>
                  <div class="shub-pill-list">
                    <% (card.actions || []).forEach((action)=> { %>
                      <a href="<%= action.href %>" class="shub-pill" title="<%= action.note || action.label %>">
                        <%= action.label %>
                      </a>
                      <% }) %>
                  </div>
                  <% } else { %>
                    <a href="<%= card.href || '#' %>" class="shub-pill shub-pill-primary">
                      <%= card.action || "Làm thử ngay!" %>
                    </a>
                    <% } %>
              </div>
            </article>
            <% }) %>
        </div>
      </section>
      <% }) %>
  </div>