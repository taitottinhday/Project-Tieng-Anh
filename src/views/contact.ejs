<%
const safeBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : '';
%>

<style>
  .gf-page{display:grid;gap:28px}
  .gf-hero{padding:36px;border-radius:32px;background:linear-gradient(135deg,#eff6ff 0%,#ffffff 52%,#dbeafe 100%);border:1px solid rgba(37,99,235,.12);box-shadow:0 24px 46px rgba(37,99,235,.10)}
  .gf-hero h1{margin:0;font-family:"Sora","Be Vietnam Pro",sans-serif;font-size:clamp(2.2rem,5vw,4rem);letter-spacing:-.05em;line-height:1.02;color:#102a43}
  .gf-hero p{margin:16px 0 0;max-width:820px;color:#4b6382;line-height:1.9}
  .gf-actions{margin-top:24px;display:flex;flex-wrap:wrap;gap:12px}
  .gf-btn{display:inline-flex;align-items:center;justify-content:center;min-height:50px;padding:0 20px;border-radius:999px;text-decoration:none;font-weight:800;transition:.2s ease}
  .gf-btn:hover{transform:translateY(-1px)}
  .gf-btn-primary{background:linear-gradient(135deg,#60a5fa 0%,#2563eb 100%);color:#fff;box-shadow:0 18px 30px rgba(37,99,235,.24)}
  .gf-btn-secondary{background:#173f73;color:#fff;box-shadow:0 18px 30px rgba(23,63,115,.18)}
  .gf-grid{display:grid;grid-template-columns:minmax(0,.9fr) minmax(0,1.1fr);gap:20px}
  .gf-info,.gf-form{padding:26px;border-radius:30px;background:#fff;border:1px solid rgba(37,99,235,.10);box-shadow:0 18px 34px rgba(15,23,42,.05)}
  .gf-info h2,.gf-form h2{margin:0 0 14px;font-family:"Sora","Be Vietnam Pro",sans-serif;font-size:1.6rem;letter-spacing:-.04em;color:#173f73}
  .gf-info p,.gf-form p{margin:0;color:#58708f;line-height:1.8}
  .gf-stack{margin-top:20px;display:grid;gap:14px}
  .gf-item{padding:18px;border-radius:22px;background:#f7fbff;border:1px solid rgba(37,99,235,.08)}
  .gf-item strong{display:block;color:#102a43}
  .gf-item span{display:block;margin-top:6px;color:#58708f;line-height:1.7}
  .gf-form-grid{margin-top:22px;display:grid;gap:16px}
  .gf-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}
  .gf-field{display:grid;gap:8px}
  .gf-field label{font-size:.94rem;font-weight:700;color:#365278}
  .gf-field input,.gf-field select,.gf-field textarea{width:100%;min-height:52px;padding:0 16px;border-radius:18px;border:1px solid rgba(37,99,235,.12);background:#fff;color:#102a43;outline:none;transition:border-color .2s ease,box-shadow .2s ease}
  .gf-field textarea{min-height:140px;padding:14px 16px;resize:vertical}
  .gf-field input:focus,.gf-field select:focus,.gf-field textarea:focus{border-color:rgba(37,99,235,.34);box-shadow:0 0 0 4px rgba(37,99,235,.08)}
  .gf-banner{padding:16px 18px;border-radius:20px;background:rgba(37,99,235,.08);border:1px solid rgba(37,99,235,.12);color:#1d4ed8;font-weight:700}
  @media (max-width:980px){.gf-grid,.gf-row{grid-template-columns:1fr}}
</style>

<div class="gf-page">
  <section class="gf-hero">
    <h1>Gửi yêu cầu tư vấn.</h1>
    <p>
      Để lại thông tin để nhận gợi ý lộ trình, xem lịch khai giảng và tiếp tục sang bước đăng ký khóa học nếu cần.
    </p>
    <div class="gf-actions">
      <a href="<%= safeBaseUrl %>/lich-khai-giang" class="gf-btn gf-btn-secondary">Lịch khai giảng</a>
      <a href="<%= safeBaseUrl %>/register-course" class="gf-btn gf-btn-primary">Đăng ký khóa học</a>
    </div>
  </section>

  <% if (typeof success !== 'undefined' && success) { %><div class="gf-banner">Trung tâm đã nhận được yêu cầu của bạn. Chúng tôi sẽ liên hệ sớm.</div><% } %>

  <section class="gf-grid">
    <article class="gf-info">
      <h2>Thông tin liên hệ</h2>
      <p>Chúng tôi sẵn sàng hỗ trợ bạn tìm lộ trình TOEIC phù hợp với mục tiêu và thời gian học.</p>
      <div class="gf-stack">
        <div class="gf-item"><strong>Hotline</strong><span>0344772436</span></div>
        <div class="gf-item"><strong>Email</strong><span>realtoeiccentral@gmail.com</span></div>
        <div class="gf-item"><strong>Cơ sở 1</strong><span>Số 17, ngõ 20 Hồ Tùng Mậu, Cầu Giấy</span></div>
        <div class="gf-item"><strong>Cơ sở 2</strong><span>Số 9 ngách 59 ngõ 21 Lê Đức Thọ, Nam Từ Liêm</span></div>
      </div>
    </article>

    <article class="gf-form">
      <h2>Form tư vấn</h2>
      <p>Điền thông tin để trung tâm gọi lại và gợi ý lộ trình TOEIC phù hợp với mục tiêu của bạn.</p>
      <form action="<%= safeBaseUrl %>/contact" method="POST" class="gf-form-grid">
        <div class="gf-field"><label>Họ và tên</label><input type="text" name="name" placeholder="Nhập họ và tên" required></div>
        <div class="gf-row">
          <div class="gf-field"><label>Số điện thoại</label><input type="text" name="phone" placeholder="Nhập số điện thoại" required></div>
          <div class="gf-field"><label>Email</label><input type="email" name="email" placeholder="Nhập email"></div>
        </div>
        <div class="gf-row">
          <div class="gf-field">
            <label>Mục tiêu học</label>
            <select name="goal">
              <option value="">Chọn mục tiêu</option>
              <option value="Mất gốc TOEIC">Mất gốc TOEIC</option>
              <option value="TOEIC 450+">TOEIC 450+</option>
              <option value="TOEIC 650+">TOEIC 650+</option>
              <option value="Speaking & Writing">Speaking & Writing</option>
            </select>
          </div>
          <div class="gf-field">
            <label>Khóa học quan tâm</label>
            <select name="course_interest">
              <option value="">Chọn khóa học</option>
              <option value="Lớp Tập sự TOEIC">Lớp Tập sự TOEIC</option>
              <option value="TOEIC A">TOEIC A</option>
              <option value="TOEIC B">TOEIC B</option>
              <option value="TOEIC Speaking & Writing">TOEIC Speaking & Writing</option>
            </select>
          </div>
        </div>
        <div class="gf-field">
          <label>Khung giờ mong muốn</label>
          <select name="schedule_preference">
            <option value="">Chọn khung giờ</option>
            <option value="Sáng">Sáng</option>
            <option value="Chiều">Chiều</option>
            <option value="Tối">Tối</option>
            <option value="Cuối tuần">Cuối tuần</option>
          </select>
        </div>
        <div class="gf-field">
          <label>Kênh phản hồi mong muốn</label>
          <select name="preferred_contact_method">
            <option value="Gọi điện">Gọi điện</option>
            <option value="Zalo">Zalo</option>
            <option value="Email">Email</option>
            <option value="Tư vấn trực tiếp">Tư vấn trực tiếp</option>
          </select>
        </div>
        <div class="gf-field"><label>Nội dung cần tư vấn</label><textarea name="message" placeholder="Ví dụ: mình muốn học lại nền tảng và tìm lớp phù hợp với lịch đi làm..." required></textarea></div>
        <button type="submit" class="gf-btn gf-btn-primary">Gửi yêu cầu</button>
      </form>
    </article>
  </section>
</div>
