<%
const practice = exam || {};
const noteItems = practice.mode === 'mock_full_test'
  ? [
      'Hãy dùng tai nghe ổn định và ngồi trong môi trường yên tĩnh trước khi bắt đầu thi thử.',
      'Listening từ câu 1-100 sẽ chạy theo audio gốc, không hiện thanh phát lại, không tua lại và không cho quay về câu cũ.',
      'Sau khi kết thúc phần nghe, hệ thống sẽ mở nút chuyển sang Reading để bạn tiếp tục làm câu 101-200.'
    ]
  : practice.mode === 'reading'
  ? [
      'Hãy dùng Google Chrome để bài nghe, ảnh và thao tác chuyển câu ổn định hơn.',
      'Đồng hồ sẽ bắt đầu chạy ngay khi bạn nhấn nút vào làm bài ở bên dưới.',
      'Làm trọn bộ Part 5, 6, 7 trong một phiên Reading hoàn chỉnh.'
    ]
  : [
      'Hãy dùng Google Chrome để làm bài ổn định hơn trên cả desktop và laptop.',
      'Thời gian sẽ bắt đầu tính ngay khi bạn bấm nút vào luyện tập.',
      'Chọn đúng Part bạn muốn ôn để luyện tập tập trung hơn.'
    ];
%>

<style>
  .pps-page {
    width: min(1280px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 44px;
    display: grid;
    gap: 22px;
  }

  .pps-panel {
    border-radius: 34px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 24px 56px rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }

  .pps-hero {
    padding: 44px 32px 34px;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.72), transparent 30%),
      linear-gradient(135deg, rgba(251, 247, 242, 0.98) 0%, rgba(248, 250, 252, 0.98) 56%, rgba(233, 240, 250, 0.98) 100%);
    text-align: center;
    display: grid;
    gap: 18px;
  }

  .pps-title,
  .pps-promo-copy h2 {
    margin: 0;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    letter-spacing: -0.05em;
    color: #20324d;
  }

  .pps-title {
    font-size: clamp(2.2rem, 4.6vw, 3.8rem);
    line-height: 1.04;
  }

  .pps-pills {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .pps-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    font-weight: 800;
  }

  .pps-pill.primary {
    background: #b88a73;
    color: #fff;
  }

  .pps-pill.soft {
    background: rgba(31, 41, 55, 0.06);
    color: #334155;
  }

  .pps-stats {
    width: min(360px, 100%);
    margin: 0 auto;
    display: grid;
    gap: 10px;
    text-align: left;
  }

  .pps-stat {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    color: #5f6b7a;
    font-size: 1.08rem;
  }

  .pps-stat strong {
    color: #334155;
  }

  .pps-note {
    width: min(1000px, 100%);
    margin: 8px auto 0;
    padding: 22px 18px;
    border-radius: 18px;
    border: 1px solid rgba(245, 158, 11, 0.2);
    background: linear-gradient(180deg, #fff9e7 0%, #fff7df 100%);
    text-align: left;
    display: grid;
    gap: 10px;
  }

  .pps-note-head {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #9a6700;
    font-weight: 800;
  }

  .pps-note-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid rgba(245, 158, 11, 0.5);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .pps-note ul {
    margin: 0;
    padding-left: 42px;
    color: #4b5563;
    line-height: 1.75;
  }

  .pps-note li strong {
    color: #334155;
  }

  .pps-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 2px;
  }

  .pps-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 24px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 800;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .pps-btn:hover {
    transform: translateY(-1px);
  }

  .pps-btn.primary {
    background: #2f3135;
    color: #fff;
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.16);
  }

  .pps-btn.secondary {
    background: #fff;
    color: #20324d;
    border: 1px solid rgba(15, 23, 42, 0.12);
  }

  .pps-sub {
    color: #5f6b7a;
    line-height: 1.75;
  }

  .pps-promo {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 18px;
    align-items: center;
    padding: 0;
    background: linear-gradient(135deg, rgba(250, 250, 250, 0.98) 0%, rgba(244, 247, 250, 0.98) 100%);
  }

  .pps-promo-copy {
    padding: 40px 38px;
    display: grid;
    gap: 14px;
  }

  .pps-promo-copy h2 {
    font-size: clamp(2.4rem, 4vw, 4.4rem);
    line-height: 1.02;
    max-width: 10ch;
  }

  .pps-promo-copy p {
    margin: 0;
    color: #4b5563;
    font-size: 1.08rem;
    line-height: 1.7;
    max-width: 28rem;
  }

  .pps-promo-cta {
    display: inline-flex;
    width: fit-content;
    min-height: 56px;
    align-items: center;
    justify-content: center;
    padding: 0 28px;
    border-radius: 999px;
    background: linear-gradient(135deg, #2f80ed 0%, #1263d6 100%);
    color: #fff;
    text-decoration: none;
    font-weight: 800;
  }

  .pps-promo-art {
    padding-right: 20px;
  }

  .pps-promo-art svg {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 960px) {
    .pps-promo {
      grid-template-columns: 1fr;
    }

    .pps-promo-art {
      padding: 0 20px 20px;
    }
  }

  @media (max-width: 720px) {
    .pps-page {
      width: min(100% - 20px, 1280px);
      padding-top: 18px;
    }

    .pps-hero {
      padding: 28px 16px 24px;
    }

    .pps-stat {
      font-size: 0.98rem;
    }

    .pps-note ul {
      padding-left: 24px;
    }

    .pps-actions {
      flex-direction: column;
    }

    .pps-btn {
      width: 100%;
    }

    .pps-promo-copy {
      padding: 24px 18px 8px;
    }
  }
</style>

<div class="pps-page">
  <section class="pps-panel pps-hero">
    <h1 class="pps-title"><%= practice.title || pageTitle || 'Practice Session' %></h1>

    <div class="pps-pills">
      <span class="pps-pill primary"><%= practice.accessLabel || 'Free' %></span>
      <% if (practice.badgeLabel) { %>
        <span class="pps-pill soft"><%= practice.badgeLabel %></span>
      <% } %>
    </div>

    <div class="pps-stats">
      <div class="pps-stat"><span>Thời gian:</span><strong><%= practice.durationMinutes || 0 %> phút</strong></div>
      <div class="pps-stat"><span>Phần thi:</span><strong><%= practice.partsCount || 0 %> phần</strong></div>
      <div class="pps-stat"><span>Câu hỏi:</span><strong><%= practice.totalQuestions || 0 %> câu</strong></div>
      <div class="pps-stat"><span>Điểm tối đa:</span><strong><%= practice.maxScore || 0 %> điểm</strong></div>
    </div>

    <div class="pps-note">
      <div class="pps-note-head">
        <span class="pps-note-icon">!</span>
        <span>Lưu ý</span>
      </div>
      <ul>
        <% noteItems.forEach((item, index) => { %>
          <% if (index === 0) { %>
            <li><strong><%= item %></strong></li>
          <% } else { %>
            <li><%= item %></li>
          <% } %>
        <% }) %>
      </ul>
    </div>

    <div class="pps-actions">
      <a href="<%= practice.takeHref || '#' %>" class="pps-btn primary"><%= practice.ctaLabel || 'Bắt đầu làm bài' %></a>
      <a href="<%= practice.libraryHref || '#' %>" class="pps-btn secondary"><%= practice.libraryLabel || 'Về thư viện' %></a>
    </div>
  </section>

  <section class="pps-panel pps-promo">
    <div class="pps-promo-copy">
      <h2>Đôi bạn cùng tiến</h2>
      <p>
        Giới thiệu bạn bè cùng học tại lớp TOEIC để cả hai cùng có thêm động lực,
        nhận tài liệu tốt hơn và được trung tâm hỗ trợ lộ trình rõ ràng hơn.
      </p>
      <a href="<%= baseUrl %>/student/courses" class="pps-promo-cta">Xem thêm</a>
    </div>
    <div class="pps-promo-art" aria-hidden="true">
      <svg viewBox="0 0 420 320" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="226" cy="294" rx="118" ry="18" fill="rgba(15,23,42,0.08)" />
        <circle cx="164" cy="90" r="38" fill="#f6c8b5" />
        <path d="M130 86C130 56 150 36 174 36C200 36 220 56 220 84V116H130V86Z" fill="#1f2937" />
        <path d="M112 286C120 182 142 128 178 128C212 128 232 182 238 286H112Z" fill="#111827" />
        <path d="M156 286L162 164H198L204 286H156Z" fill="#ffffff" />
        <rect x="154" y="172" width="54" height="80" rx="8" fill="#c63a31" />
        <rect x="164" y="190" width="34" height="8" rx="4" fill="#fee2e2" />
        <rect x="164" y="206" width="28" height="8" rx="4" fill="#fecaca" />
        <circle cx="280" cy="92" r="36" fill="#f6c8b5" />
        <path d="M246 90C246 58 268 40 292 40C316 40 334 58 338 82V118H246V90Z" fill="#2d3748" />
        <path d="M230 286C238 186 258 132 296 132C334 132 356 184 364 286H230Z" fill="#1f2937" />
        <path d="M272 286L278 166H314L320 286H272Z" fill="#ffffff" />
        <rect x="300" y="182" width="34" height="24" rx="4" fill="#2563eb" />
        <rect x="304" y="188" width="10" height="12" rx="2" fill="#ffffff" />
        <rect x="316" y="188" width="14" height="4" rx="2" fill="#bfdbfe" />
        <rect x="316" y="196" width="12" height="4" rx="2" fill="#bfdbfe" />
      </svg>
    </div>
  </section>
</div>
