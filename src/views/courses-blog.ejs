  %>

  <style>
    .cc-page {
      display: grid;
      gap: 18px;
      padding: 8px 0 24px;
    }

    .cc-grid,
    .cc-promo-grid {
      display: grid;
      gap: 18px;
    }

    .cc-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .cc-promo-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .cc-card,
    .cc-combo,
    .cc-promo-card {
      position: relative;
      overflow: hidden;
      border-radius: 0;
      text-decoration: none;
      color: inherit;
    }

    .cc-card {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(200px, 0.78fr);
      gap: 18px;
      min-height: 342px;
      padding: 28px 26px 0;
    }

    .cc-card.starter {
      background: #f5e8fb;
    }

    .cc-card.a {
      background: #dee0ff;
    }

    .cc-card.b {
      background: #f8dfd5;
    }

    .cc-card.sw {
      background: #dbf7ec;
    }

    .cc-copy {
      display: grid;
      align-content: start;
      gap: 16px;
      min-width: 0;
      padding-top: 4px;
    }

    .cc-title,
    .cc-combo-copy h2,
    .cc-promo-title {
      margin: 0;
      font-family: "Sora", "Be Vietnam Pro", sans-serif;
      letter-spacing: -0.06em;
    }

    .cc-title {
      font-size: clamp(2.6rem, 4vw, 4rem);
      line-height: 0.92;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .cc-card.starter .cc-title {
      color: #d76bcb;
    }

    .cc-card.a .cc-title {
      color: #7c3aed;
    }

    .cc-card.b .cc-title {
      color: #ff5d7a;
    }

    .cc-card.sw .cc-title {
      color: #14b8c5;
    }

    .cc-bullets {
      margin: 0;
      padding-left: 22px;
      color: #2f3640;
      font-size: 1rem;
      line-height: 1.7;
    }

    .cc-price {
      display: grid;
      gap: 4px;
      margin-top: 8px;
      text-align: center;
      justify-self: start;
      min-width: 160px;
    }

    .cc-price strong {
      font-size: 2rem;
      line-height: 1;
      letter-spacing: -0.05em;
      color: #111827;
    }

    .cc-price span {
      color: #44403c;
      font-size: 0.98rem;
    }

    .cc-note {
      margin: 0;
      max-width: 290px;
      color: #4b5563;
      font-size: 0.84rem;
      line-height: 1.55;
    }

    .cc-combo {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 0.9fr);
      gap: 18px;
      align-items: center;
      min-height: 420px;
      padding: 28px 26px 0;
      background: linear-gradient(180deg, #e84b31 0%, #ef7158 100%);
    }

    .cc-combo-copy {
      display: grid;
      justify-items: center;
      gap: 16px;
      text-align: center;
      color: #ffffff;
    }

    .cc-combo-copy h2 {
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 1.02;
    }

    .cc-combo-copy strong {
      font-family: "Sora", "Be Vietnam Pro", sans-serif;
      font-size: clamp(3rem, 6vw, 5rem);
      line-height: 0.96;
      letter-spacing: -0.06em;
    }

    .cc-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 56px;
      padding: 0 30px;
      border-radius: 999px;
      background: #000000;
      color: #ffffff;
      font-size: 1.15rem;
      font-weight: 800;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .cc-card:hover .cc-btn,
    .cc-combo:hover .cc-btn,
    .cc-promo-card:hover .cc-btn,
    .cc-card:hover,
    .cc-combo:hover,
    .cc-promo-card:hover {
      transform: translateY(-1px);
    }

    .cc-promo-card {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(180px, 0.76fr);
      gap: 16px;
      align-items: end;
      min-height: 344px;
      padding: 26px 0 0 26px;
    }

    .cc-promo-card.placement {
      background: linear-gradient(180deg, #e49a00 0%, #efb31a 100%);
    }

    .cc-promo-card.schedule {
      background: linear-gradient(180deg, #77adc2 0%, #8ec5d6 100%);
    }

    .cc-promo-copy {
      display: grid;
      align-content: start;
      gap: 12px;
      padding-bottom: 24px;
    }

    .cc-promo-title {
      color: #ffffff;
      font-size: clamp(2.4rem, 4vw, 4.5rem);
      line-height: 0.94;
      white-space: pre-line;
    }

    .cc-media,
    .cc-media-placeholder {
      width: 100%;
      height: 100%;
      display: block;
    }

    .cc-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .cc-media.course {
      min-height: 314px;
    }

    .cc-media.combo {
      min-height: 392px;
    }

    .cc-media.promo {
      min-height: 318px;
    }

    .cc-media-placeholder {
      position: relative;
      display: grid;
      place-items: center;
      gap: 10px;
      padding: 24px;
      text-align: center;
      background:
        radial-gradient(circle at top right, rgba(255, 255, 255, 0.28), transparent 28%),
        linear-gradient(135deg, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0.08) 100%);
      color: rgba(17, 24, 39, 0.9);
    }

    .cc-combo .cc-media-placeholder,
    .cc-promo-card .cc-media-placeholder {
      color: rgba(255, 255, 255, 0.96);
    }

    .cc-media-placeholder::before {
      content: "";
      position: absolute;
      inset: 14px;
      border: 1.5px dashed currentColor;
      border-radius: 24px;
      opacity: 0.35;
    }

    .cc-media-placeholder span,
    .cc-media-placeholder small {
      position: relative;
      z-index: 1;
    }

    .cc-media-placeholder span {
      font-family: "Sora", "Be Vietnam Pro", sans-serif;
      font-size: clamp(1.05rem, 2vw, 1.45rem);
      font-weight: 700;
      letter-spacing: -0.04em;
    }

    .cc-media-placeholder small {
      max-width: 220px;
      line-height: 1.6;
    }

    @media (max-width: 1024px) {

      .cc-grid,
      .cc-promo-grid {
        grid-template-columns: 1fr;
      }

      .cc-card,
      .cc-combo,
      .cc-promo-card {
        grid-template-columns: 1fr;
        padding-right: 26px;
      }

      .cc-price {
        justify-self: center;
      }

      .cc-copy,
      .cc-promo-copy {
        justify-items: center;
        text-align: center;
      }

      .cc-bullets {
        text-align: left;
      }
    }

    @media (max-width: 640px) {
      .cc-page {
        gap: 14px;
        padding-bottom: 12px;
      }

      .cc-card,
      .cc-combo,
      .cc-promo-card {
        min-height: auto;
        padding: 18px 18px 0;
      }

      .cc-title {
        font-size: clamp(2.1rem, 12vw, 3rem);
      }

      .cc-promo-title {
        font-size: clamp(2rem, 12vw, 3.2rem);
      }

      .cc-combo-copy strong {
        font-size: clamp(2.5rem, 13vw, 4rem);
      }

      .cc-btn {
        min-height: 50px;
        padding: 0 24px;
        font-size: 1rem;
      }
    }
  </style>

  <div class="cc-page">
    <section class="cc-grid">
      <% courseCards.forEach((item)=> { %>
        <a href="<%= item.href %>" class="cc-card <%= item.tone %>">
          <div class="cc-copy">
            <h2 class="cc-title">
              <%= item.title %>
            </h2>
            <ul class="cc-bullets">
              <% item.bullets.forEach((bullet)=> { %>
                <li>
                  <%= bullet %>
                </li>
                <% }) %>
            </ul>
            <div class="cc-price">
              <strong>
                <%= item.price %>
              </strong>
              <span>
                <%= item.sessions %>
              </span>
            </div>
            <% if (item.note) { %>
              <p class="cc-note">
                <%= item.note %>
              </p>
              <% } %>
          </div>

          <%- renderMedia(item.image, item.title, item.placeholder, 'cc-media course' ) %>
        </a>
        <% }) %>
    </section>

    <a href="<%= comboBanner.href %>" class="cc-combo">
      <div class="cc-combo-copy">
        <h2>
          <%= comboBanner.title %>
        </h2>
        <strong>
          <%= comboBanner.price %>
        </strong>
        <span class="cc-btn">Tìm hiểu ngay</span>
      </div>

      <%- renderMedia(comboBanner.image, comboBanner.title, comboBanner.placeholder, 'cc-media combo' ) %>
    </a>

    <section class="cc-promo-grid">
      <% promoCards.forEach((item)=> { %>
        <a href="<%= item.href %>" class="cc-promo-card <%= item.tone %>">
          <div class="cc-promo-copy">
            <h2 class="cc-promo-title">
              <%= item.title %>
            </h2>
          </div>

          <%- renderMedia(item.image, item.title, item.placeholder, 'cc-media promo' ) %>
        </a>
        <% }) %>
    </section>
  </div>
