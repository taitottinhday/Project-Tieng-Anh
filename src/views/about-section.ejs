  .abt-news-side-card, .abt-news-quick, .abt-news-form, .abt-news-social { padding: 20px; border-radius: 24px; background: rgba(255,255,255,.96); border: 1px solid rgba(15,23,42,.08); box-shadow: 0 18px 34px rgba(15,23,42,.05); }
  .abt-news-side-card { display: grid; gap: 10px; grid-template-columns: 104px minmax(0, 1fr); align-items: center; }
