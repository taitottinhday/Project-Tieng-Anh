  .abt-news-quick a { color: #0f172a; line-height: 1.6; }
  .abt-news-form { display: grid; gap: 14px; background: linear-gradient(180deg, rgba(255,255,255,.98) 0%, rgba(248,250,252,.98) 100%); }
  .abt-news-form-head { padding: 14px 16px; margin: -20px -20px 0; border-radius: 24px 24px 0 0; color: #fff; background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); }
  .abt-news-form-head h3 { color: #fff !important; }
  .abt-news-form-fields { display: grid; gap: 12px; }
  .abt-news-form input, .abt-news-form select { width: 100%; min-height: 48px; padding: 0 14px; border-radius: 14px; border: 1px solid rgba(15,23,42,.12); background: rgba(255,255,255,.96); font: inherit; color: #0f172a; }
  .abt-news-form-note { color: #64748b; font-size: .94rem; line-height: 1.65; }
  .abt-news-form button, .abt-news-form .abt-news-secondary { min-height: 50px; border: 0; border-radius: 16px; font-weight: 900; font: inherit; cursor: pointer; }
  .abt-news-form button { color: #fff; background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); }
  .abt-news-secondary { display: inline-flex; align-items: center; justify-content: center; color: #fff; background: linear-gradient(135deg, #38bdf8 0%, #2563eb 100%); }
  .abt-news-social-list { display: grid; gap: 10px; }
  .abt-news-social-list a, .abt-news-phone { display: flex; align-items: center; justify-content: space-between; gap: 10px; min-height: 52px; padding: 0 14px; border-radius: 14px; background: rgba(248,250,252,.96); border: 1px solid rgba(15,23,42,.08); color: #0f172a; font-weight: 700; }
  .abt-news-phone strong { color: #dc2626; }
  .abt-news-pagination { display: grid; gap: 10px; justify-items: start; }
