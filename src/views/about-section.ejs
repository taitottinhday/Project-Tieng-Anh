  .abt-news-featured-copy { display: grid; gap: 10px; }
  .abt-news-featured-copy h2 { font-size: clamp(1.6rem, 3vw, 2.3rem); line-height: 1.2; }
  .abt-news-date { color: #64748b; font-size: .95rem; }
  .abt-news-main { display: grid; gap: 28px; grid-template-columns: minmax(0, 1fr) 320px; align-items: start; }
  .abt-news-list-wrap { display: grid; gap: 20px; }
  .abt-news-list-wrap h2 { font-family: "Lexend", "Be Vietnam Pro", sans-serif; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.08; letter-spacing: -.04em; }
  .abt-news-list { display: grid; gap: 28px; }
  .abt-news-item { display: grid; gap: 18px; grid-template-columns: 320px minmax(0, 1fr); align-items: start; }
  .abt-news-item .abt-media { min-height: auto; aspect-ratio: 16 / 10; border-radius: 22px; }
  .abt-news-item-copy { display: grid; gap: 10px; }
