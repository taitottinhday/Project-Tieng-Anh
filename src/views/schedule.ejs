  <script>
    (() => {
      const anchorLinks = Array.from(document.querySelectorAll("[data-anchor-link]"));
      const anchorList = document.querySelector("[data-anchor-list]");
      if (!anchorLinks.length) return;

      const sectionEntries = anchorLinks
        .map((link) => {
          const href = link.getAttribute("href") || "";
          if (!href.startsWith("#")) return null;

          const section = document.querySelector(href);
          if (!section) return null;

          return { link, section };
        })
        .filter(Boolean);

      if (!sectionEntries.length) return;

      let activeId = "";

      const setActiveLink = (nextId) => {
        if (!nextId || nextId === activeId) return;

        activeId = nextId;
        sectionEntries.forEach(({ link, section }) => {
          const isActive = section.id === nextId;
          link.classList.toggle("is-active", isActive);
          link.setAttribute("aria-current", isActive ? "true" : "false");

          if (isActive && anchorList && anchorList.scrollWidth > anchorList.clientWidth + 8) {
            link.scrollIntoView({
              behavior: "smooth",
              inline: "center",
              block: "nearest"
            });
          }
        });
      };

      const resolveOffset = () => {
        const isMobile = window.innerWidth <= 720;
        return window.scrollY + (isMobile ? 170 : 190);
      };

      const syncActiveSection = () => {
        const offset = resolveOffset();
        let currentSectionId = sectionEntries[0].section.id;

        sectionEntries.forEach(({ section }) => {
          if (section.offsetTop <= offset) {
            currentSectionId = section.id;
          }
        });

        setActiveLink(currentSectionId);
      };

      let frameId = null;
      const queueSync = () => {
        if (frameId) return;
        frameId = window.requestAnimationFrame(() => {
          frameId = null;
          syncActiveSection();
        });
      };

      anchorLinks.forEach((link) => {
        link.addEventListener("click", (event) => {
          const href = link.getAttribute("href") || "";
          if (!href.startsWith("#")) return;
          const section = document.querySelector(href);
          if (!section) return;

          event.preventDefault();
          setActiveLink(section.id);
          section.scrollIntoView({
            behavior: "smooth",
            block: "start"
          });

          if (window.history && typeof window.history.replaceState === "function") {
            window.history.replaceState(null, "", href);
          }
        });
      });

      window.addEventListener("scroll", queueSync, { passive: true });
      window.addEventListener("resize", queueSync);
      window.addEventListener("load", queueSync);
      queueSync();
    })();
  </script>
