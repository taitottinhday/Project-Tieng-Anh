            <div class="gs-campus-footer">
              <a href="<%= safeBaseUrl %>/contact" class="gs-button gs-button-blue">Đăng ký học</a>
            </div>
          </article>
          <% }) %>
      </div>

      <%- renderMedia('https://thaylongtoeic.com/wp-content/uploads/2023/10/banner-thang-12.webp', 'Hoạt động lớp học'
