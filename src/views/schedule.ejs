      <div class="gs-preview-grid">
        <article class="gs-preview-card">
          <h3>Tập Sự</h3>
          <p>Phát triển kỹ năng nghe cơ bản, tích lũy từ vựng và học ngữ pháp nền tảng để chuẩn bị cho giai đoạn học
            TOEIC chính thức.</p>
          <%-
            renderMedia('https://thaylongtoeic.com/wp-content/uploads/2026/01/tap-su-tet-28-buoi-2500-1536x1025.webp', 'Lớp Tập Sự'
            , 'Ảnh preview lớp Tập Sự' , 'gs-media-frame gs-photo-course' ) %>
