            <span class="gs-pill is-active">TOEIC 2 kỹ năng (LR)</span>
            <span class="gs-pill">TOEIC 4 kỹ năng</span>
          </div>
        </div>

        <div class="gs-pill-group">
          <h3>Trình độ hiện tại:</h3>
          <div class="gs-pill-row">
            <span class="gs-pill is-active">Mất gốc</span>
            <span class="gs-pill">Có nền tảng</span>
            <span class="gs-pill">600+ TOEIC LR</span>
          </div>
        </div>

        <div class="gs-pill-group">
          <h3>Mục tiêu điểm số:</h3>
          <div class="gs-pill-row">
            <span class="gs-pill is-active">550+ TOEIC LR</span>
            <span class="gs-pill">700+ TOEIC LR</span>
          </div>
