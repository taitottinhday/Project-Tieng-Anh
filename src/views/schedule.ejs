            tiêu 550+.</p>
          <%-
            renderMedia('https://thaylongtoeic.com/wp-content/uploads/2024/12/toeic-A-2025-1536x1025.webp', 'Lớp TOEIC A'
            , 'Ảnh preview lớp TOEIC A' , 'gs-media-frame gs-photo-course' ) %>
