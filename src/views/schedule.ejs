          <a href="<%= safeBaseUrl %>/contact" class="gs-inline-link">Đăng ký học</a>
        </div>
      </div>

      <div class="gs-hero-cards">
        <% heroCards.forEach((item)=> { %>
          <article class="gs-hero-card">
            <div class="gs-hero-copy">
              <span class="gs-course-chip <%= item.tone %>">
                <%= item.title %>
              </span>
              <ul>
                <% item.bullets.forEach((bullet)=> { %>
                  <li>
                    <%= bullet %>
                  </li>
                  <% }) %>
              </ul>
              <div class="gs-price-line">
                <strong>
                  <%= item.price %>
                </strong>
                <span>
                  <%= item.sessions %>
                </span>
              </div>
            </div>

            <%- renderMedia(item.image, item.title, item.placeholder, 'gs-media-frame gs-photo-hero-card' ) %>
          </article>
          <% }) %>
      </div>
    </section>

    <section id="lich-khai-giang" class="gs-stack-section">
      <h2 class="gs-section-title"><span class="gs-underlined">Lịch khai giảng 2026</span></h2>

      <div class="gs-campus-list">
        <% tableGroups.forEach((group)=> { %>
          <article class="gs-campus-card">
            <div class="gs-campus-head">
              <h3>
                <%= group.campus %>
              </h3>
              <div class="gs-campus-actions">
                <a href="<%= safeBaseUrl %>/contact" class="gs-social-dot" aria-label="Facebook">f</a>
                <a href="<%= safeBaseUrl %>/contact" class="gs-social-dot" aria-label="Messenger">m</a>
              </div>
            </div>

