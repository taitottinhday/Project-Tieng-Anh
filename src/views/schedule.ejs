                    <th>Ca học</th>
                    <th>Khai giảng</th>
                    <th>Giáo viên</th>
                    <th>Địa chỉ</th>
                  </tr>
                </thead>
                <tbody>
                  <% group.classes.forEach((item)=> { %>
                    <tr>
                      <td data-label="Mã lớp">
                        <span class="gs-code tone-<%= item.tone %>">
                          <%= item.code %>
                        </span>
                      </td>
                      <td data-label="Ca học">
                        <%= item.scheduleText %>
                      </td>
                      <td data-label="Khai giảng"><strong>
                          <%= item.opening %>
                        </strong></td>
                      <td data-label="Giáo viên">
                        <%= item.teacher %>
                      </td>
                      <td data-label="Địa chỉ">
                        <%= item.locationLabel %>
                      </td>
                    </tr>
                    <% }) %>
