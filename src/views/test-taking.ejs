<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= pageTitle %>
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap"
    rel="stylesheet">
  <style>
    :root {
      --bg: #f4f7fb;
      --panel: #ffffff;
      --panel-soft: #f8fafc;
      --border: #d8e2ef;
      --border-strong: #c5d3e6;
      --text: #19314f;
      --muted: #6d83a0;
      --accent: #ffa313;
      --accent-deep: #ef8c00;
      --navy: #163c69;
      --navy-soft: #eef4fb;
      --success: #2c9a67;
      --shadow: 0 18px 45px rgba(30, 56, 95, 0.08);
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      min-height: 100%;
      font-family: "Manrope", "Segoe UI", sans-serif;
      background: linear-gradient(180deg, #f8fbff 0%, var(--bg) 100%);
      color: var(--text);
    }

    body {
      padding: 12px;
      overflow: hidden;
    }

    button,
    input,
    audio {
      font: inherit;
    }

    .exam-form {
      height: calc(100dvh - 24px);
      min-height: 720px;
    }

    .page-shell {
      display: grid;
      grid-template-columns: 264px minmax(0, 1fr);
      gap: 14px;
      height: 100%;
      min-height: 0;
      align-items: start;
    }

    .sidebar-card,
    .exam-panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 18px;
      box-shadow: var(--shadow);
    }

    .sidebar-card {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      position: sticky;
      top: 0;
      height: 100%;
      max-height: 100%;
    }

    .timer-panel {
      padding: 14px 18px;
      background: linear-gradient(180deg, #ffb11f 0%, var(--accent) 100%);
      color: #ffffff;
      text-align: center;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-weight: 800;
      font-size: 1.05rem;
      letter-spacing: 0.03em;
    }

    .sidebar-scroll {
      flex: 1;
      min-height: 0;
      overflow: auto;
      padding: 18px 14px 14px;
    }

    .sidebar-part+.sidebar-part {
      margin-top: 18px;
    }

    .sidebar-part h3 {
      margin: 0 0 10px;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 1.05rem;
      color: #122c4e;
    }

    .nav-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
    }

    .nav-btn {
      position: relative;
      width: 50px;
      min-width: 50px;
      height: 54px;
      padding: 0;
      border-radius: 16px;
      border: 1px solid var(--border-strong);
      background: linear-gradient(180deg, #ffffff 0%, #f7fafe 100%);
      color: #587190;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 10px 20px rgba(30, 56, 95, 0.08);
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease, color 0.18s ease;
    }

    .nav-btn.flagged::after {
      content: "";
      position: absolute;
      top: 7px;
      right: 7px;
      width: 10px;
      height: 15px;
      border-radius: 2px;
      background: linear-gradient(180deg, #ffb938 0%, var(--accent) 100%);
      clip-path: polygon(0 0, 100% 0, 100% 74%, 52% 58%, 0 74%);
      box-shadow: 0 6px 12px rgba(255, 163, 19, 0.25);
      pointer-events: none;
    }

    .nav-btn.current.flagged::after {
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 6px 12px rgba(17, 38, 67, 0.22);
    }

    .nav-btn:hover {
      border-color: #91a8c5;
      color: var(--navy);
      transform: translateY(-1px);
      box-shadow: 0 14px 24px rgba(30, 56, 95, 0.12);
    }

    .nav-btn.current {
      border-color: var(--navy);
      background: linear-gradient(180deg, #163c69 0%, #244d7d 100%);
      color: #ffffff;
      box-shadow: 0 16px 28px rgba(22, 60, 105, 0.22);
    }

    .nav-btn.answered {
      background: linear-gradient(180deg, #fff7eb 0%, #ffe8c2 100%);
      border-color: #f6c46e;
      color: var(--accent-deep);
    }

    .nav-btn.current.answered {
      background: linear-gradient(180deg, #163c69 0%, #245282 72%, #ef8c00 180%);
      border-color: var(--navy);
      color: #ffffff;
    }

    .sidebar-footer {
      display: grid;
      grid-template-columns: 1fr 1.6fr;
      gap: 10px;
      padding: 14px;
      border-top: 1px solid var(--border);
      background: #fbfdff;
    }

    .count-box {
      display: grid;
      place-items: center;
      gap: 2px;
      min-height: 48px;
      border-radius: 12px;
      border: 1px solid #f2bb56;
      background: #ffffff;
      color: var(--navy);
      text-align: center;
    }

    .count-box strong,
    .count-box small {
      display: block;
      font-family: "Plus Jakarta Sans", sans-serif;
    }

    .count-box strong {
      font-weight: 800;
      font-size: 1rem;
    }

    .count-box small {
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 700;
    }

    .submit-btn,
    .secondary-btn,
    .control-btn {
      min-height: 48px;
      border-radius: 12px;
      border: 1px solid transparent;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .submit-btn {
      background: linear-gradient(180deg, #ffaf1f 0%, var(--accent) 100%);
      color: #ffffff;
    }

    .submit-btn:hover,
    .secondary-btn:hover,
    .control-btn:hover {
      transform: translateY(-1px);
    }

    .secondary-btn,
    .control-btn {
      background: #ffffff;
      color: var(--navy);
      border-color: var(--border-strong);
    }

    .submit-btn:disabled,
    .secondary-btn:disabled,
    .control-btn:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      transform: none;
    }

    .exam-panel {
      display: flex;
      flex-direction: column;
      min-width: 0;
      min-height: 0;
      height: 100%;
      overflow: hidden;
    }

    .exam-header {
      padding: 14px 22px;
      border-bottom: 1px solid var(--border);
      text-align: center;
      background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    }

    .exam-meta {
      margin-bottom: 6px;
      color: var(--muted);
      font-size: 0.88rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .exam-header h1 {
      margin: 0;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: clamp(1.5rem, 2vw, 2rem);
      color: #203b60;
    }

    .exam-subline {
      margin-top: 6px;
      color: var(--muted);
      font-size: 0.96rem;
      min-height: 24px;
    }

    .demo-notice,
    .empty-state {
      margin: 18px 22px 0;
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid #ffd69b;
      background: #fff8ed;
      color: #8a5b0d;
      line-height: 1.6;
    }

    .screen-stack {
      flex: 1;
      min-height: 0;
      padding: 14px;
      overflow: hidden;
    }

    .question-screen {
      display: none;
      height: 100%;
      min-height: 0;
    }

    .question-screen.active {
      display: block;
      height: 100%;
    }

    .content-shell {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 248px;
      gap: 14px;
      height: 100%;
      min-height: 0;
      align-items: start;
    }

    .content-shell.content-shell-grouped {
      grid-template-columns: minmax(0, 1.38fr) minmax(360px, 0.82fr);
    }

    .question-stage,
    .answer-stage {
      border: 1px solid var(--border-strong);
      border-radius: 14px;
      background: #ffffff;
    }

    .question-stage {
      display: flex;
      flex-direction: column;
      gap: 14px;
      height: 100%;
      min-height: 0;
      padding: 18px 18px 28px;
      overflow: auto;
      scroll-padding-top: 16px;
    }

    .question-stage.question-stage-reading {
      padding-right: 12px;
    }

    .answer-stage {
      display: flex;
      flex-direction: column;
      gap: 12px;
      height: 100%;
      min-height: 0;
      padding: 16px;
      overflow: hidden;
      background: #fcfdff;
      position: sticky;
      top: 0;
      align-self: stretch;
    }

    .answer-stage-scroll {
      flex: 1 1 auto;
      height: 0;
      min-height: 0;
      overflow: auto;
      padding-right: 4px;
      display: grid;
      gap: 12px;
      align-content: start;
    }

    .stage-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }

    .stage-kicker {
      display: inline-block;
      margin-bottom: 6px;
      color: var(--accent-deep);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .stage-top h2 {
      margin: 0;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 1.35rem;
      color: #19375f;
    }

    .question-badge {
      white-space: nowrap;
      padding: 9px 12px;
      border-radius: 999px;
      background: var(--navy-soft);
      color: var(--navy);
      font-weight: 800;
      font-size: 0.92rem;
    }

    .audio-block,
    .info-block,
    .passage-block,
    .prompt-block {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--panel-soft);
      padding: 14px;
    }

    .audio-block strong,
    .info-block strong,
    .passage-block strong,
    .prompt-block strong {
      display: block;
      margin-bottom: 8px;
      color: #1f3b63;
      font-family: "Plus Jakarta Sans", sans-serif;
    }

    .info-block-empty {
      border-style: dashed;
    }

    .instruction-line-static {
      margin-bottom: 0;
    }

    .audio-block audio {
      width: 100%;
    }

    .passage-body {
      color: #35506f;
      line-height: 1.8;
      white-space: pre-wrap;
    }

    .image-stage {
      display: grid;
      gap: 14px;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    }

    .image-stage.image-stage-reading {
      grid-template-columns: 1fr;
      gap: 18px;
      align-content: start;
    }

    .image-stage img {
      width: 100%;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: #ffffff;
      display: block;
      object-fit: contain;
      max-height: 620px;
    }

    .image-stage.image-stage-reading img {
      max-height: none;
      width: 100%;
    }

    .instruction-line {
      margin: 0 0 8px;
      color: var(--muted);
      font-size: 0.94rem;
      line-height: 1.7;
    }

    .prompt-text {
      font-size: 1.06rem;
      line-height: 1.8;
      color: #1d3659;
      white-space: pre-wrap;
    }

    .prompt-text.compact {
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 1.02rem;
      font-weight: 700;
    }

    .answer-head {
      display: grid;
      gap: 8px;
      color: #23466f;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 1.05rem;
      font-weight: 800;
    }

    .answer-head-main {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .answer-number {
      color: #173862;
    }

    .answer-head-status {
      color: var(--muted);
      font-size: 0.85rem;
      font-weight: 700;
      line-height: 1.45;
    }

    .flag-toggle {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 36px;
      padding: 0 12px;
      border-radius: 999px;
      border: 1px solid #f2d39f;
      background: #fff8ea;
      color: var(--accent-deep);
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 0.8rem;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
    }

    .flag-toggle:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 18px rgba(255, 163, 19, 0.16);
    }

    .flag-toggle:focus-visible {
      outline: 3px solid rgba(255, 163, 19, 0.2);
      outline-offset: 2px;
    }

    .flag-toggle.active {
      border-color: #f1b24b;
      background: linear-gradient(180deg, #ffb938 0%, var(--accent) 100%);
      color: #ffffff;
      box-shadow: 0 14px 22px rgba(255, 163, 19, 0.24);
    }

    .answer-flag {
      width: 10px;
      height: 16px;
      border-radius: 2px;
      background: currentColor;
      clip-path: polygon(0 0, 100% 0, 100% 70%, 55% 55%, 0 70%);
    }

    .answer-options {
      display: grid;
      gap: 12px;
      align-content: start;
    }

    .choice {
      display: block;
      position: relative;
      cursor: pointer;
    }

    .choice input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .choice-ui {
      display: grid;
      grid-template-columns: 24px minmax(0, 1fr);
      gap: 10px;
      align-items: center;
      padding: 10px 10px;
      border-radius: 12px;
      border: 1px solid transparent;
      transition: 0.18s ease;
    }

    .choice:hover .choice-ui {
      background: #f7faff;
      border-color: #d5dfec;
    }

    .choice input:checked+.choice-ui {
      background: #fff5e8;
      border-color: #f6c46e;
    }

    .choice-dot {
      width: 20px;
      height: 20px;
      border-radius: 999px;
      border: 1.6px solid #c5d3e6;
      position: relative;
      background: #ffffff;
    }

    .choice input:checked+.choice-ui .choice-dot {
      border-color: var(--accent-deep);
      background: #ffffff;
    }

    .choice input:checked+.choice-ui .choice-dot::after {
      content: "";
      position: absolute;
      inset: 4px;
      border-radius: 999px;
      background: var(--accent-deep);
    }

    .choice-copy {
      color: #274669;
      line-height: 1.7;
      font-weight: 700;
    }

    .choice-copy strong {
      margin-right: 6px;
      color: #173862;
      font-family: "Plus Jakarta Sans", sans-serif;
    }

    .choice-copy.only-letter {
      font-family: "Plus Jakarta Sans", sans-serif;
      letter-spacing: 0.04em;
    }

    .answer-actions {
      display: grid;
      gap: 10px;
      margin-top: 8px;
      padding-top: 12px;
      border-top: 1px solid var(--border);
    }

    .answer-head-screen {
      gap: 0;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }

    .question-card {
      border: 1px solid var(--border);
      border-radius: 14px;
      background: #ffffff;
      padding: 14px;
      transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    }

    .question-card.current {
      border-color: #f1b24b;
      background: #fffaf1;
      box-shadow: 0 12px 28px rgba(255, 163, 19, 0.12);
    }

    .question-card-head {
      margin-bottom: 10px;
    }

    .question-copy-block {
      margin-bottom: 12px;
    }

    .question-copy-block .prompt-text {
      text-align: left;
    }

    .answer-footer {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .empty-state {
      margin-bottom: 22px;
    }

    .confirm-backdrop[hidden] {
      display: none;
    }

    .confirm-backdrop {
      position: fixed;
      inset: 0;
      z-index: 40;
      display: grid;
      place-items: center;
      padding: 18px;
      background: rgba(8, 16, 28, 0.56);
      backdrop-filter: blur(3px);
    }

    .confirm-dialog {
      width: min(100%, 420px);
      padding: 22px;
      border-radius: 22px;
      background: #ffffff;
      border: 1px solid var(--border);
      box-shadow: 0 28px 58px rgba(8, 16, 28, 0.24);
    }

    .confirm-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .confirm-head h2 {
      margin: 0;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 1.4rem;
      color: var(--navy);
    }

    .confirm-close {
      width: 42px;
      height: 42px;
      border-radius: 999px;
      border: 1px solid var(--border-strong);
      background: #ffffff;
      color: var(--navy);
      cursor: pointer;
      font-size: 1.3rem;
    }

    .confirm-copy {
      margin: 0;
      color: #253f63;
      font-size: 1.1rem;
      font-weight: 700;
      line-height: 1.6;
    }

    .confirm-note {
      margin: 10px 0 0;
      color: var(--muted);
      line-height: 1.6;
    }

    .confirm-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 18px;
    }

    @media (max-width: 1200px) {
      .page-shell {
        grid-template-columns: 220px minmax(0, 1fr);
      }

      .content-shell {
        grid-template-columns: minmax(0, 1fr) 220px;
      }

      .content-shell.content-shell-grouped {
        grid-template-columns: minmax(0, 1.18fr) minmax(320px, 0.9fr);
      }
    }

    @media (max-width: 960px) {
      body {
        padding: 10px;
        overflow: auto;
      }

      .exam-form {
        height: auto;
        min-height: 0;
      }

      .page-shell {
        grid-template-columns: 1fr;
        height: auto;
      }

      .sidebar-card {
        order: 2;
        position: static;
        height: auto;
        max-height: none;
      }

      .exam-panel {
        order: 1;
        height: auto;
      }

      .sidebar-scroll {
        max-height: 320px;
      }

      .content-shell {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .question-stage {
        height: auto;
        overflow: visible;
      }

      .answer-stage {
        order: -1;
        position: static;
      }

      .screen-stack {
        padding: 14px;
      }
    }

    @media (max-width: 640px) {
      .exam-header {
        padding: 14px;
      }

      .sidebar-footer,
      .answer-footer {
        grid-template-columns: 1fr;
      }

      .stage-top {
        flex-direction: column;
      }

      .nav-grid {
        gap: 8px;
      }

      .nav-btn {
        width: 46px;
        min-width: 46px;
        height: 50px;
        border-radius: 14px;
      }
    }
  </style>
</head>

<body>
  <%
    const fallbackExam =
      typeof defaultPlacementExam !== 'undefined' && defaultPlacementExam
        ? defaultPlacementExam
        : {};
    const requestedExam =
      typeof exam !== 'undefined' && exam
        ? exam
        : fallbackExam;
    const examData =
      Array.isArray(requestedExam.flatQuestions) && requestedExam.flatQuestions.length
        ? requestedExam
        : fallbackExam;
    const questions = Array.isArray(examData.flatQuestions) ? examData.flatQuestions : [];
    const groups = Array.isArray(examData.groups) ? examData.groups : [];
    const partSummary = Array.isArray(examData.partSummary) ? examData.partSummary : [];
    const durationMinutes = Number(examData.durationMinutes || 120);
    const formatQuestionLabel = (firstNumber, lastNumber = firstNumber) =>
      Number(firstNumber) === Number(lastNumber)
        ? 'Câu ' + firstNumber
        : 'Câu ' + firstNumber + '-' + lastNumber;
    const groupMetaByQuestionNumber = new Map();
    groups.forEach((group, groupIndex) => {
      const groupQuestions = Array.isArray(group.questions) ? group.questions : [];
      const questionNumbers = groupQuestions
        .map((groupQuestion) => Number(groupQuestion.number || 0))
        .filter((number) => number > 0)
        .sort((left, right) => left - right);
      const readingQuestionNumbers = questionNumbers.filter((number) => number >= 101);
      const meta = {
        group,
        groupIndex,
        questionNumbers,
        readingQuestionNumbers,
        hasGroupedReadingLayout: readingQuestionNumbers.length > 1,
        readingScreenId: readingQuestionNumbers.length
          ? 'reading-group-' + (groupIndex + 1) + '-' + readingQuestionNumbers[0]
          : ''
      };

      questionNumbers.forEach((questionNumber) => {
        groupMetaByQuestionNumber.set(questionNumber, meta);
      });
    });

    const questionViews = questions.map((question) => {
      const questionNumber = Number(question.number || 0);
      const groupMeta = groupMetaByQuestionNumber.get(questionNumber) || null;
      const group = groupMeta ? groupMeta.group : {};
      const part = partSummary.find((item) => item.partNumber === question.partNumber) || {};

      return Object.assign({}, question, {
        questionNumber,
        partTitle: part.title || ('Part ' + question.partNumber),
        partInstructions: part.instructions || '',
        sharedContent: group.sharedContent || '',
        sharedAudioUrl: group.sharedAudioUrl || null,
        sharedImages: Array.isArray(group.sharedImages) ? group.sharedImages : [],
        isReading: questionNumber >= 101,
        screenId:
          questionNumber >= 101 && groupMeta && groupMeta.hasGroupedReadingLayout
            ? groupMeta.readingScreenId
            : 'question-' + questionNumber,
        groupedQuestionNumbers:
          questionNumber >= 101 && groupMeta && groupMeta.hasGroupedReadingLayout
            ? groupMeta.readingQuestionNumbers
            : [questionNumber],
        groupLabel:
          questionNumber >= 101 && groupMeta && groupMeta.hasGroupedReadingLayout
            ? formatQuestionLabel(
                groupMeta.readingQuestionNumbers[0],
                groupMeta.readingQuestionNumbers[groupMeta.readingQuestionNumbers.length - 1]
              )
            : formatQuestionLabel(questionNumber),
        usesGroupedReadingLayout:
          questionNumber >= 101 && groupMeta ? groupMeta.hasGroupedReadingLayout : false
      });
    });
    const questionViewByNumber = new Map(
      questionViews.map((question) => [Number(question.number || 0), question])
    );
    const screenViews = [];
    const addedScreenIds = new Set();

    questionViews.forEach((question) => {
      if (addedScreenIds.has(question.screenId)) {
        return;
      }

      const screenQuestions = question.groupedQuestionNumbers
        .map((questionNumber) => questionViewByNumber.get(Number(questionNumber)))
        .filter(Boolean);
      const primaryQuestion = screenQuestions[0] || question;
      const lastQuestion = screenQuestions[screenQuestions.length - 1] || primaryQuestion;

      screenViews.push({
        id: question.screenId,
        partNumber: primaryQuestion.partNumber,
        partTitle: primaryQuestion.partTitle,
        partInstructions: primaryQuestion.partInstructions,
        sharedContent: primaryQuestion.sharedContent,
        sharedAudioUrl: primaryQuestion.sharedAudioUrl,
        sharedImages: primaryQuestion.sharedImages,
        questionIds: screenQuestions.map((item) => String(item.number)),
        primaryQuestionId: String(primaryQuestion.number),
        groupLabel:
          screenQuestions.length > 1
            ? formatQuestionLabel(primaryQuestion.number, lastQuestion.number)
            : formatQuestionLabel(primaryQuestion.number),
        usesGroupedReadingLayout: question.usesGroupedReadingLayout,
        questions: screenQuestions
      });

      addedScreenIds.add(question.screenId);
    });
    const partSections = partSummary
      .map((part) =>
        Object.assign({}, part, {
          questions: questionViews.filter((question) => question.partNumber === part.partNumber)
        })
      )
      .filter((part) => part.questions.length > 0);
    const totalQuestions = Number(examData.totalQuestions || questionViews.length || 0);
    const hasQuestions = questionViews.length > 0;
    const firstQuestion = hasQuestions ? questionViews[0] : null;
  %>
  <% const resolvedBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : ''; %>
      <form action="<%= resolvedBaseUrl %>/placement-tests/<%= examData.id %>/submit" method="POST" class="exam-form"
        data-test-form data-session-key="toeic-placement-<%= examData.id %>">
        <input type="hidden" name="guest_name" value="">
        <input type="hidden" name="guest_email" value="">
        <input type="hidden" name="furthest_question_number" value="<%= firstQuestion ? firstQuestion.number : '' %>"
          data-furthest-question>
        <div class="page-shell">
          <aside class="sidebar-card">
            <div class="timer-panel">
              <div id="timer" data-duration="<%= durationMinutes %>">00:00:00</div>
            </div>
            <div class="sidebar-scroll">
              <% partSections.forEach((part)=> { %>
                <section class="sidebar-part">
                  <h3>Part <%= part.partNumber %>
                  </h3>
                  <div class="nav-grid">
                    <% part.questions.forEach((question)=> { %>
                      <button type="button" class="nav-btn" data-go-question="<%= question.number %>">
                        <%= question.number %>
                      </button>
                      <% }) %>
                  </div>
                </section>
                <% }) %>
            </div>
            <div class="sidebar-footer">
              <div class="count-box">
                <strong><span id="answeredCount">0</span>/<%= totalQuestions %></strong>
                <small><span id="flaggedCount">0</span> câu gắn cờ</small>
              </div>
              <button type="submit" class="submit-btn" <%=hasQuestions ? '' : 'disabled' %>>Nộp bài</button>
            </div>
          </aside>

          <main class="exam-panel">
            <header class="exam-header">
              <div class="exam-meta">
                <%= examData.title || 'TOEIC Placement Test' %> | <%= examData.bookName || 'ETS 2024' %>
              </div>
              <h1 id="currentHeadline">
                <%= firstQuestion ? ('Part ' + firstQuestion.partNumber + ' | Câu ' + firstQuestion.number) : 'TOEIC Placement Test' %>
              </h1>
              <div class="exam-subline" id="currentSubline">
                <%= firstQuestion ? firstQuestion.partTitle : 'Chưa có dữ liệu đề thi' %>
              </div>
            </header>

            <div class="screen-stack">
              <% if (!hasQuestions) { %>
                <div class="empty-state">Chưa có dữ liệu để hiển thị. Kiểm tra lại file đề thi hoặc route đang truyền
                  vào view.</div>
                <% } else { %>
                  <% screenViews.forEach((screen, index)=> { %>
                    <% const question = screen.questions[0]; %>
                    <section class="question-screen<%= index === 0 ? ' active' : '' %>" data-question-screen
                      data-screen-id="<%= screen.id %>" data-primary-question-id="<%= screen.primaryQuestionId %>"
                      data-question-ids="<%= screen.questionIds.join(',') %>" data-part-number="<%= screen.partNumber %>"
                      data-part-title="<%= screen.partTitle %>" data-group-label="<%= screen.groupLabel %>"
                      data-headline="Part <%= question.partNumber %> | Câu <%= question.number %>">
                      <div class="content-shell<%= screen.usesGroupedReadingLayout ? ' content-shell-grouped' : '' %>">
                        <div class="question-stage<%= screen.usesGroupedReadingLayout ? ' question-stage-reading' : '' %>">
                          <div class="stage-top">
                            <div>
                              <span class="stage-kicker">Part <%= screen.partNumber %></span>
                              <h2>
                                <%= screen.partTitle %>
                              </h2>
                            </div>
                            <span class="question-badge"><%= screen.groupLabel %></span>
                          </div>

                          <% if (screen.usesGroupedReadingLayout) { %>
                            <div class="info-block">
                              <strong>Nhóm câu áp dụng</strong>
                              <p class="instruction-line instruction-line-static"><%= screen.groupLabel %></p>
                            </div>
                          <% } %>

                          <% if (question.sharedAudioUrl) { %>
                            <div class="audio-block">
                              <strong>Âm thanh</strong>
                              <audio controls preload="metadata">
                                <source src="<%= question.sharedAudioUrl %>" type="audio/mpeg">
                              </audio>
                            </div>
                            <% } %>

                              <% if (question.sharedContent) { %>
                                <div class="passage-block">
                                  <strong>Đoạn văn</strong>
                                  <div class="passage-body">
                                    <%= question.sharedContent %>
                                  </div>
                                </div>
                                <% } %>

                                  <% if (question.sharedImages && question.sharedImages.length) { %>
                                    <div class="image-stage<%= screen.usesGroupedReadingLayout ? ' image-stage-reading' : '' %>">
                                      <% question.sharedImages.forEach((imageUrl)=> { %>
                                        <img src="<%= imageUrl %>" alt="Tư liệu câu <%= question.number %>">
                                        <% }) %>
                                    </div>
                                    <% } %>

                                      <% if (!screen.usesGroupedReadingLayout) { %>
                                      <div class="prompt-block">
                                        <strong>Hướng dẫn</strong>
                                        <p class="instruction-line">
                                          <%= question.partInstructions %>
                                        </p>
                                        <div
                                          class="prompt-text<%= question.sharedImages && question.sharedImages.length ? ' compact' : '' %>">
                                          <%= question.prompt %>
                                        </div>
                                      </div>
                                      <% } %>
                        </div>

                        <aside class="answer-stage">
                          <% if (!screen.usesGroupedReadingLayout) { %>
                          <div class="answer-head">
                            <div class="answer-head-main">
                              <button type="button" class="flag-toggle" data-flag-question="<%= question.number %>"
                                aria-pressed="false" aria-label="Gắn cờ câu <%= question.number %>">
                                <span class="answer-flag" aria-hidden="true"></span>
                                <span data-flag-label>Gắn cờ</span>
                              </button>
                              <span class="answer-number">
                                <%= question.number %>.
                              </span>
                            </div>
                            <span class="answer-head-status" data-flag-status></span>
                          </div>
                          <% } else { %>
                          <div class="answer-head answer-head-screen">
                            <div class="answer-head-main">
                              <span class="answer-number"><%= screen.groupLabel %></span>
                            </div>
                          </div>

                          <div class="answer-stage-scroll" data-question-scroll>
                            <% screen.questions.forEach((groupQuestion)=> { %>
                              <article class="question-card" id="question-card-<%= groupQuestion.number %>" data-question-card
                                data-question-id="<%= groupQuestion.number %>" data-part-title="<%= groupQuestion.partTitle %>"
                                data-group-label="<%= screen.groupLabel %>"
                                data-headline="Part <%= groupQuestion.partNumber %> | Câu <%= groupQuestion.number %>">
                                <div class="answer-head question-card-head">
                                  <div class="answer-head-main">
                                    <button type="button" class="flag-toggle" data-flag-question="<%= groupQuestion.number %>"
                                      aria-pressed="false" aria-label="Gắn cờ câu <%= groupQuestion.number %>">
                                      <span class="answer-flag" aria-hidden="true"></span>
                                      <span data-flag-label>Gắn cờ</span>
                                    </button>
                                    <span class="answer-number"><%= groupQuestion.number %>.</span>
                                  </div>
                                  <span class="answer-head-status" data-flag-status></span>
                                </div>

                                <div class="prompt-block question-copy-block">
                                  <strong>Câu hỏi</strong>
                                  <div class="prompt-text<%= screen.sharedImages && screen.sharedImages.length ? ' compact' : '' %>">
                                    <%= groupQuestion.prompt %>
                                  </div>
                                </div>

                                <div class="answer-options">
                                  <% groupQuestion.options.forEach((option)=> { %>
                                    <label class="choice">
                                      <input type="radio" name="<%= groupQuestion.inputName %>" value="<%= option.label %>"
                                        data-question-input="<%= groupQuestion.number %>">
                                      <span class="choice-ui">
                                        <span class="choice-dot"></span>
                                        <% if (option.isLetterOnly) { %>
                                          <span class="choice-copy only-letter"><strong><%= option.label %></strong></span>
                                        <% } else { %>
                                          <span class="choice-copy"><strong><%= option.label %></strong><%= option.text %></span>
                                        <% } %>
                                      </span>
                                    </label>
                                  <% }) %>
                                </div>
                              </article>
                            <% }) %>
                          </div>
                          <% } %>

                          <% if (!screen.usesGroupedReadingLayout) { %>
                          <div class="answer-options">
                            <% question.options.forEach((option)=> { %>
                              <label class="choice">
                                <input type="radio" name="<%= question.inputName %>" value="<%= option.label %>"
                                  data-question-input="<%= question.number %>">
                                <span class="choice-ui">
                                  <span class="choice-dot"></span>
                                  <% if (option.isLetterOnly) { %>
                                    <span class="choice-copy only-letter"><strong>
                                        <%= option.label %>
                                      </strong></span>
                                    <% } else { %>
                                      <span class="choice-copy"><strong>
                                          <%= option.label %>
                                        </strong>
                                        <%= option.text %>
                                      </span>
                                      <% } %>
                                </span>
                              </label>
                              <% }) %>
                          </div>
                          <% } %>

                          <div class="answer-actions">
                            <div class="answer-footer">
                              <button type="button" class="control-btn" data-direction="-1">Câu trước</button>
                              <button type="button" class="control-btn" data-direction="1">Câu tiếp</button>
                            </div>

                            <button type="button" class="secondary-btn" data-jump-pending>Đến câu chưa làm</button>
                            <button type="button" class="secondary-btn" data-jump-flagged>Đến câu gắn cờ</button>
                          </div>
                        </aside>
                      </div>
                    </section>
                    <% }) %>
                      <% } %>
            </div>
          </main>
        </div>

        <div class="confirm-backdrop" hidden data-submit-confirm>
          <div class="confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="placement-submit-confirm-title">
            <div class="confirm-head">
              <h2 id="placement-submit-confirm-title">Xác nhận</h2>
              <button type="button" class="confirm-close" data-submit-close aria-label="Đóng">&times;</button>
            </div>
            <p class="confirm-copy">Bạn có muốn nộp bài?</p>
            <div class="confirm-actions">
              <button type="button" class="secondary-btn" data-submit-cancel>Quay lại</button>
              <button type="button" class="submit-btn" data-submit-accept>Nộp bài</button>
            </div>
            <p class="confirm-note">Hãy kiểm tra lại kỹ bài trước khi nộp.</p>
          </div>
        </div>
      </form>

      <script>
        (() => {
          const form = document.querySelector('[data-test-form]');
          if (!form) return;

          const sessionKey = form.dataset.sessionKey || '';
          const screens = Array.from(form.querySelectorAll('[data-question-screen]'));
          const navButtons = Array.from(form.querySelectorAll('[data-go-question]'));
          const radioInputs = Array.from(form.querySelectorAll('[data-question-input]'));
          const questionCards = Array.from(form.querySelectorAll('[data-question-card]'));
          const flagButtons = Array.from(form.querySelectorAll('[data-flag-question]'));
          const timerEl = document.getElementById('timer');
          const answeredEl = document.getElementById('answeredCount');
          const flaggedEl = document.getElementById('flaggedCount');
          const headlineEl = document.getElementById('currentHeadline');
          const sublineEl = document.getElementById('currentSubline');
          const jumpPendingButtons = Array.from(form.querySelectorAll('[data-jump-pending]'));
          const jumpFlaggedButtons = Array.from(form.querySelectorAll('[data-jump-flagged]'));
          const furthestQuestionInput = form.querySelector('[data-furthest-question]');
          const submitConfirm = form.querySelector('[data-submit-confirm]');
          const submitAcceptButton = form.querySelector('[data-submit-accept]');
          const submitCancelButtons = Array.from(form.querySelectorAll('[data-submit-cancel], [data-submit-close]'));
          const orderedIds = Array.from(new Set(
            radioInputs.map((input) => String(input.dataset.questionInput || ''))
          )).filter(Boolean);
          const questionMetaMap = new Map();
          radioInputs.forEach((input) => {
            const questionId = String(input.dataset.questionInput || '');
            if (!questionId || questionMetaMap.has(questionId)) return;

            const screen = input.closest('[data-question-screen]');
            const card = input.closest('[data-question-card]');
            const context = card || screen;

            questionMetaMap.set(questionId, {
              id: questionId,
              screen,
              card,
              partTitle: context?.dataset.partTitle || screen?.dataset.partTitle || '',
              groupLabel: context?.dataset.groupLabel || screen?.dataset.groupLabel || '',
              headline: 'Part ' + (screen?.dataset.partNumber || '') + ' | Câu ' + questionId
            });
          });
          let currentQuestionId = orderedIds[0] || null;
          let furthestQuestionId = currentQuestionId;
          let lastPendingJumpId = null;
          let lastFlaggedJumpId = null;
          let flaggedQuestionIds = new Set();
          let isSubmitConfirmed = false;

          const readState = () => {
            if (!sessionKey) return null;
            try {
              const raw = sessionStorage.getItem(sessionKey);
              return raw ? JSON.parse(raw) : null;
            } catch (error) {
              return null;
            }
          };

          const writeState = () => {
            if (!sessionKey) return;
            const answers = {};
            radioInputs.forEach((input) => {
              if (input.checked) {
                answers[input.name] = input.value;
              }
            });

            try {
              sessionStorage.setItem(sessionKey, JSON.stringify({
                currentQuestionId,
                furthestQuestionId,
                lastPendingJumpId,
                lastFlaggedJumpId,
                flaggedQuestionIds: Array.from(flaggedQuestionIds),
                answers
              }));
            } catch (error) {
              console.warn('Cannot save placement state:', error);
            }
          };

          const restoreState = () => {
            const stored = readState();
            if (!stored) return;

            Object.entries(stored.answers || {}).forEach(([name, value]) => {
              const matched = form.querySelector(`input[name="${name}"][value="${value}"]`);
              if (matched) {
                matched.checked = true;
              }
            });

            if (stored.currentQuestionId && orderedIds.includes(String(stored.currentQuestionId))) {
              currentQuestionId = String(stored.currentQuestionId);
            }

            if (stored.furthestQuestionId && orderedIds.includes(String(stored.furthestQuestionId))) {
              furthestQuestionId = String(stored.furthestQuestionId);
            }

            if (stored.lastPendingJumpId) {
              lastPendingJumpId = String(stored.lastPendingJumpId);
            }

            if (stored.lastFlaggedJumpId) {
              lastFlaggedJumpId = String(stored.lastFlaggedJumpId);
            }

            if (Array.isArray(stored.flaggedQuestionIds)) {
              flaggedQuestionIds = new Set(
                stored.flaggedQuestionIds
                  .map((questionId) => String(questionId))
                  .filter((questionId) => orderedIds.includes(questionId))
              );
            }
          };

          const getAnsweredSet = () => new Set(
            radioInputs
              .filter((input) => input.checked)
              .map((input) => String(input.dataset.questionInput))
          );

          const getFlaggedSet = () => new Set(Array.from(flaggedQuestionIds));

          const getQuestionMeta = (questionId) => questionMetaMap.get(String(questionId)) || null;
          const getScreen = (questionId) => getQuestionMeta(questionId)?.screen || null;
          const getCard = (questionId) => getQuestionMeta(questionId)?.card || null;

          const getNeighborId = (questionId, direction) => {
            const currentIndex = orderedIds.indexOf(String(questionId));
            if (currentIndex === -1) return null;
            return orderedIds[currentIndex + direction] || null;
          };

          const scrollQuestionIntoView = (questionId) => {
            const card = getCard(questionId);
            if (card) {
              const scrollHost = card.closest('[data-question-scroll]');
              if (scrollHost) {
                const nextTop = Math.max(card.offsetTop - scrollHost.offsetTop - 8, 0);
                scrollHost.scrollTo({
                  top: nextTop,
                  behavior: 'smooth'
                });
              } else {
                card.scrollIntoView({ block: 'nearest', inline: 'nearest' });
              }
              return;
            }

            const screen = getScreen(questionId);
            if (screen) {
              screen.scrollIntoView({ block: 'nearest', inline: 'nearest' });
            }
          };

          const updateFurthestQuestion = (questionId) => {
            const nextIndex = orderedIds.indexOf(String(questionId));
            const furthestIndex = orderedIds.indexOf(String(furthestQuestionId));

            if (nextIndex !== -1 && (furthestIndex === -1 || nextIndex > furthestIndex)) {
              furthestQuestionId = String(questionId);
            }

            if (!furthestQuestionId) {
              furthestQuestionId = String(questionId);
            }

            if (furthestQuestionInput) {
              furthestQuestionInput.value = furthestQuestionId || '';
            }
          };

          const closeSubmitConfirm = () => {
            if (submitConfirm) {
              submitConfirm.hidden = true;
            }
          };

          const openSubmitConfirm = () => {
            if (submitConfirm) {
              submitConfirm.hidden = false;
            }
          };

          const submitExam = () => {
            isSubmitConfirmed = true;
            closeSubmitConfirm();

            if (typeof form.requestSubmit === 'function') {
              form.requestSubmit();
              return;
            }

            if (sessionKey) {
              sessionStorage.removeItem(sessionKey);
            }

            form.submit();
          };

          const updateFooterControls = (activeScreen) => {
            screens.forEach((screen) => {
              const questionIds = String(screen.dataset.questionIds || '')
                .split(',')
                .map((questionId) => questionId.trim())
                .filter(Boolean);
              const questionId = screen === activeScreen
                ? String(currentQuestionId || screen.dataset.primaryQuestionId || questionIds[0] || '')
                : String(screen.dataset.primaryQuestionId || questionIds[0] || '');
              const prevButton = screen.querySelector('[data-direction="-1"]');
              const nextButton = screen.querySelector('[data-direction="1"]');
              if (prevButton) prevButton.disabled = !getNeighborId(questionId, -1);
              if (nextButton) nextButton.disabled = !getNeighborId(questionId, 1);
            });
          };

          const updateShortcutButtons = (answeredSet, flaggedSet) => {
            const hasPending = orderedIds.some((questionId) => !answeredSet.has(questionId));
            const hasFlagged = flaggedSet.size > 0;

            jumpPendingButtons.forEach((button) => {
              button.disabled = !hasPending;
            });

            jumpFlaggedButtons.forEach((button) => {
              button.disabled = !hasFlagged;
            });
          };

          const syncUi = (options = {}) => {
            const shouldScrollQuestionIntoView = Boolean(options.scrollQuestionIntoView);
            const preservedScrollHost = options.preserveScrollHost || null;
            const preservedScrollTop = Number.isFinite(options.preserveScrollTop)
              ? options.preserveScrollTop
              : null;
            const answeredSet = getAnsweredSet();
            const flaggedSet = getFlaggedSet();
            const activeScreen = getScreen(currentQuestionId) || screens[0];
            const activeMeta = getQuestionMeta(currentQuestionId);

            screens.forEach((screen) => {
              screen.classList.toggle('active', screen === activeScreen);
            });

            questionCards.forEach((card) => {
              card.classList.toggle('current', card.dataset.questionId === String(currentQuestionId));
            });

            navButtons.forEach((button) => {
              const questionId = button.dataset.goQuestion;
              button.classList.toggle('current', questionId === String(currentQuestionId));
              button.classList.toggle('answered', answeredSet.has(questionId));
              button.classList.toggle('flagged', flaggedSet.has(questionId));
            });

            flagButtons.forEach((button) => {
              const questionId = String(button.dataset.flagQuestion);
              const isFlagged = flaggedSet.has(questionId);
              const label = button.querySelector('[data-flag-label]');
              const status = button.closest('[data-question-card], [data-question-screen]')?.querySelector('[data-flag-status]');

              button.classList.toggle('active', isFlagged);
              button.setAttribute('aria-pressed', isFlagged ? 'true' : 'false');
              button.setAttribute('aria-label', `${isFlagged ? 'Bỏ gắn cờ' : 'Gắn cờ'} câu ${questionId}`);

              if (label) {
                label.textContent = isFlagged ? 'Bỏ cờ' : 'Gắn cờ';
              }

              if (status) {
                status.textContent = isFlagged
                  ? 'Đã gắn cờ, nhớ xem lại trước khi nộp.'
                  : '';
              }
            });

            const currentButton = navButtons.find((button) => button.dataset.goQuestion === String(currentQuestionId));
            if (currentButton) {
              currentButton.scrollIntoView({ block: 'nearest', inline: 'nearest' });
            }

            if (answeredEl) {
              answeredEl.textContent = String(answeredSet.size);
            }

            if (flaggedEl) {
              flaggedEl.textContent = String(flaggedSet.size);
            }

            if (activeScreen) {
              updateFurthestQuestion(currentQuestionId);
              if (headlineEl) {
                headlineEl.textContent = activeScreen.dataset.headline || ('Câu ' + currentQuestionId);
              }
              if (sublineEl) {
                const answeredLabel = answeredSet.has(currentQuestionId) ? 'Đã chọn đáp án' : 'Chưa trả lời';
                const flaggedLabel = flaggedSet.has(currentQuestionId) ? 'Đã gắn cờ xem lại' : 'Không gắn cờ';
                sublineEl.textContent = (activeScreen.dataset.partTitle || '') + ' | ' + answeredLabel + ' | ' + flaggedLabel;
              }
            }

            if (activeMeta) {
              if (headlineEl && activeMeta.headline) {
                headlineEl.textContent = activeMeta.headline;
              }
              if (sublineEl && activeMeta.groupLabel) {
                const safeAnsweredLabel = answeredSet.has(currentQuestionId) ? 'Đã chọn đáp án' : 'Chưa trả lời';
                const safeFlaggedLabel = flaggedSet.has(currentQuestionId) ? 'Đã gắn cờ xem lại' : 'Không gắn cờ';
                const answeredLabel = answeredSet.has(currentQuestionId) ? 'ÄÃ£ chá»n Ä‘Ã¡p Ã¡n' : 'ChÆ°a tráº£ lá»i';
                const flaggedLabel = flaggedSet.has(currentQuestionId) ? 'ÄÃ£ gáº¯n cá» xem láº¡i' : 'KhÃ´ng gáº¯n cá»';
                sublineEl.textContent = activeMeta.groupLabel + ' | ' + answeredLabel + ' | ' + flaggedLabel;
                sublineEl.textContent = activeMeta.groupLabel + ' | ' + safeAnsweredLabel + ' | ' + safeFlaggedLabel;
              }
            }

            if (preservedScrollHost && preservedScrollTop !== null) {
              preservedScrollHost.scrollTop = preservedScrollTop;
            }

            updateFooterControls(activeScreen);
            updateShortcutButtons(answeredSet, flaggedSet);
            if (shouldScrollQuestionIntoView) {
              requestAnimationFrame(() => {
                scrollQuestionIntoView(currentQuestionId);
              });
            }
            writeState();
          };

          const setCurrentQuestion = (questionId, options = {}) => {
            if (!orderedIds.includes(String(questionId))) return;
            currentQuestionId = String(questionId);
            syncUi({
              scrollQuestionIntoView: options.scrollQuestionIntoView !== false
            });
          };

          const jumpToNextPending = () => {
            const answeredSet = getAnsweredSet();
            const pendingIds = orderedIds.filter((questionId) => !answeredSet.has(questionId));

            if (!pendingIds.length) {
              return;
            }

            const nextPending = lastPendingJumpId
              ? (pendingIds.find((questionId) => Number(questionId) > Number(lastPendingJumpId)) || pendingIds[0])
              : pendingIds[0];

            lastPendingJumpId = nextPending;
            setCurrentQuestion(nextPending);
          };

          const jumpToNextFlagged = () => {
            const flaggedIds = orderedIds.filter((questionId) => flaggedQuestionIds.has(questionId));

            if (!flaggedIds.length) {
              return;
            }

            const nextFlagged = lastFlaggedJumpId
              ? (flaggedIds.find((questionId) => Number(questionId) > Number(lastFlaggedJumpId)) || flaggedIds[0])
              : flaggedIds[0];

            lastFlaggedJumpId = nextFlagged;
            setCurrentQuestion(nextFlagged);
          };

          const toggleFlag = (questionId) => {
            const normalizedQuestionId = String(questionId);
            if (!orderedIds.includes(normalizedQuestionId)) {
              return;
            }

            if (flaggedQuestionIds.has(normalizedQuestionId)) {
              flaggedQuestionIds.delete(normalizedQuestionId);
              if (lastFlaggedJumpId === normalizedQuestionId) {
                lastFlaggedJumpId = null;
              }
            } else {
              flaggedQuestionIds.add(normalizedQuestionId);
            }

            syncUi();
          };

          restoreState();
          syncUi();

          navButtons.forEach((button) => {
            button.addEventListener('click', () => {
              setCurrentQuestion(button.dataset.goQuestion);
            });
          });

          radioInputs.forEach((input) => {
            input.addEventListener('change', () => {
              const scrollHost = input.closest('[data-question-scroll]');
              const scrollTop = scrollHost ? scrollHost.scrollTop : null;
              setCurrentQuestion(String(input.dataset.questionInput), {
                scrollQuestionIntoView: false,
                preserveScrollHost: scrollHost,
                preserveScrollTop: scrollTop
              });
            });
          });

          flagButtons.forEach((button) => {
            button.addEventListener('click', () => {
              currentQuestionId = String(button.dataset.flagQuestion);
              toggleFlag(button.dataset.flagQuestion);
            });
          });

          screens.forEach((screen) => {
            const prevButton = screen.querySelector('[data-direction="-1"]');
            const nextButton = screen.querySelector('[data-direction="1"]');
            const getScreenQuestionId = () => String(
              currentQuestionId || screen.dataset.primaryQuestionId || ''
            );

            if (prevButton) {
              prevButton.addEventListener('click', () => {
                const prevId = getNeighborId(getScreenQuestionId(), -1);
                if (prevId) {
                  setCurrentQuestion(prevId);
                }
              });
            }

            if (nextButton) {
              nextButton.addEventListener('click', () => {
                const nextId = getNeighborId(getScreenQuestionId(), 1);
                if (nextId) {
                  setCurrentQuestion(nextId);
                }
              });
            }
          });

          jumpPendingButtons.forEach((button) => {
            button.addEventListener('click', jumpToNextPending);
          });

          jumpFlaggedButtons.forEach((button) => {
            button.addEventListener('click', jumpToNextFlagged);
          });

          submitCancelButtons.forEach((button) => {
            button.addEventListener('click', closeSubmitConfirm);
          });

          if (submitConfirm) {
            submitConfirm.addEventListener('click', (event) => {
              if (event.target === submitConfirm) {
                closeSubmitConfirm();
              }
            });
          }

          if (submitAcceptButton) {
            submitAcceptButton.addEventListener('click', submitExam);
          }

          document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && submitConfirm && !submitConfirm.hidden) {
              closeSubmitConfirm();
            }
          });

          form.addEventListener('submit', (event) => {
            if (!isSubmitConfirmed) {
              event.preventDefault();
              openSubmitConfirm();
              return;
            }

            if (sessionKey) {
              sessionStorage.removeItem(sessionKey);
            }
          });

          if (timerEl) {
            let timeLeft = Number(timerEl.dataset.duration || 120) * 60;
            const renderTimer = () => {
              const hours = Math.floor(timeLeft / 3600);
              const minutes = Math.floor((timeLeft % 3600) / 60);
              const seconds = timeLeft % 60;
              timerEl.textContent = `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
              if (timeLeft <= 0) {
                alert('Hết thời gian làm bài. Hệ thống sẽ tự động nộp bài.');
                submitExam();
                return;
              }
              timeLeft -= 1;
            };
            renderTimer();
            setInterval(renderTimer, 1000);
          }
        })();
      </script>
</body>

</html>
