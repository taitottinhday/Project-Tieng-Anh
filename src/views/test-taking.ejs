<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #f4f7fb;
      --panel: #ffffff;
      --panel-soft: #f8fafc;
      --border: #d8e2ef;
      --border-strong: #c5d3e6;
      --text: #19314f;
      --muted: #6d83a0;
      --accent: #ffa313;
      --accent-deep: #ef8c00;
      --navy: #163c69;
      --navy-soft: #eef4fb;
      --success: #2c9a67;
      --shadow: 0 18px 45px rgba(30, 56, 95, 0.08);
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      min-height: 100%;
      font-family: "Manrope", "Segoe UI", sans-serif;
      background: linear-gradient(180deg, #f8fbff 0%, var(--bg) 100%);
      color: var(--text);
    }

    body {
      padding: 12px;
      overflow: hidden;
    }

    button,
    input,
    audio {
      font: inherit;
    }

    .exam-form {
      height: calc(100dvh - 24px);
      min-height: 720px;
    }

    .page-shell {
      display: grid;
      grid-template-columns: 264px minmax(0, 1fr);
      gap: 14px;
      height: 100%;
      min-height: 0;
      align-items: start;
    }

    .sidebar-card,
    .exam-panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 18px;
      box-shadow: var(--shadow);
    }

    .sidebar-card {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      position: sticky;
      top: 0;
      height: 100%;
      max-height: 100%;
    }

    .timer-panel {
      padding: 14px 18px;
      background: linear-gradient(180deg, #ffb11f 0%, var(--accent) 100%);
      color: #ffffff;
      text-align: center;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-weight: 800;
      font-size: 1.05rem;
      letter-spacing: 0.03em;
    }

    .sidebar-scroll {
      flex: 1;
      min-height: 0;
      overflow: auto;
      padding: 18px 14px 14px;
    }

    .sidebar-part + .sidebar-part {
      margin-top: 18px;
    }

    .sidebar-part h3 {
      margin: 0 0 10px;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 1.05rem;
      color: #122c4e;
    }

    .nav-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
    }

    .nav-btn {
      position: relative;
      width: 50px;
      min-width: 50px;
      height: 54px;
      padding: 0;
      border-radius: 16px;
      border: 1px solid var(--border-strong);
      background: linear-gradient(180deg, #ffffff 0%, #f7fafe 100%);
      color: #587190;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 10px 20px rgba(30, 56, 95, 0.08);
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease, color 0.18s ease;
    }

    .nav-btn.flagged::after {
      content: "";
      position: absolute;
      top: 7px;
      right: 7px;
      width: 10px;
      height: 15px;
      border-radius: 2px;
      background: linear-gradient(180deg, #ffb938 0%, var(--accent) 100%);
      clip-path: polygon(0 0, 100% 0, 100% 74%, 52% 58%, 0 74%);
      box-shadow: 0 6px 12px rgba(255, 163, 19, 0.25);
      pointer-events: none;
    }

    .nav-btn.current.flagged::after {
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 6px 12px rgba(17, 38, 67, 0.22);
    }

    .nav-btn:hover {
      border-color: #91a8c5;
      color: var(--navy);
      transform: translateY(-1px);
      box-shadow: 0 14px 24px rgba(30, 56, 95, 0.12);
    }

    .nav-btn.current {
      border-color: var(--navy);
      background: linear-gradient(180deg, #163c69 0%, #244d7d 100%);
      color: #ffffff;
      box-shadow: 0 16px 28px rgba(22, 60, 105, 0.22);
    }

    .nav-btn.answered {
      background: linear-gradient(180deg, #fff7eb 0%, #ffe8c2 100%);
      border-color: #f6c46e;
      color: var(--accent-deep);
    }

    .nav-btn.current.answered {
      background: linear-gradient(180deg, #163c69 0%, #245282 72%, #ef8c00 180%);
      border-color: var(--navy);
      color: #ffffff;
    }

    .sidebar-footer {
      display: grid;
      grid-template-columns: 1fr 1.6fr;
      gap: 10px;
      padding: 14px;
      border-top: 1px solid var(--border);
      background: #fbfdff;
    }

    .count-box {
      display: grid;
      place-items: center;
      gap: 2px;
      min-height: 48px;
      border-radius: 12px;
      border: 1px solid #f2bb56;
      background: #ffffff;
      color: var(--navy);
      text-align: center;
    }

    .count-box strong,
    .count-box small {
      display: block;
      font-family: "Plus Jakarta Sans", sans-serif;
    }

    .count-box strong {
      font-weight: 800;
      font-size: 1rem;
    }

    .count-box small {
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 700;
    }

    .submit-btn,
    .secondary-btn,
    .control-btn {
      min-height: 48px;
      border-radius: 12px;
      border: 1px solid transparent;
      font-weight: 800;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .submit-btn {
      background: linear-gradient(180deg, #ffaf1f 0%, var(--accent) 100%);
      color: #ffffff;
    }

    .submit-btn:hover,
    .secondary-btn:hover,
    .control-btn:hover {
      transform: translateY(-1px);
    }

    .secondary-btn,
    .control-btn {
      background: #ffffff;
      color: var(--navy);
      border-color: var(--border-strong);
    }

    .submit-btn:disabled,
    .secondary-btn:disabled,
    .control-btn:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      transform: none;
    }

    .exam-panel {
      display: flex;
      flex-direction: column;
      min-width: 0;
      min-height: 0;
      height: 100%;
      overflow: hidden;
    }

    .exam-header {
      padding: 14px 22px;
      border-bottom: 1px solid var(--border);
      text-align: center;
      background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    }

    .exam-meta {
      margin-bottom: 6px;
      color: var(--muted);
      font-size: 0.88rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .exam-header h1 {
      margin: 0;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: clamp(1.5rem, 2vw, 2rem);
      color: #203b60;
    }

    .exam-subline {
      margin-top: 6px;
      color: var(--muted);
      font-size: 0.96rem;
      min-height: 24px;
    }

    .demo-notice,
    .empty-state {
      margin: 18px 22px 0;
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid #ffd69b;
      background: #fff8ed;
      color: #8a5b0d;
      line-height: 1.6;
    }

    .screen-stack {
      flex: 1;
      min-height: 0;
      padding: 14px;
      overflow: hidden;
    }

    .question-screen {
      display: none;
      height: 100%;
      min-height: 0;
    }

    .question-screen.active {
      display: block;
      height: 100%;
    }

    .content-shell {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 248px;
      gap: 14px;
      height: 100%;
      min-height: 0;
      align-items: start;
    }

    .question-stage,
    .answer-stage {
      border: 1px solid var(--border-strong);
      border-radius: 14px;
      background: #ffffff;
    }

    .question-stage {
      display: flex;
      flex-direction: column;
      gap: 14px;
      height: 100%;
      min-height: 0;
      padding: 18px 18px 28px;
      overflow: auto;
      scroll-padding-top: 16px;
    }

    .answer-stage {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 16px;
      background: #fcfdff;
      position: sticky;
      top: 0;
      align-self: start;
    }

    .stage-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }

    .stage-kicker {
      display: inline-block;
      margin-bottom: 6px;
      color: var(--accent-deep);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .stage-top h2 {
      margin: 0;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 1.35rem;
      color: #19375f;
    }

    .question-badge {
      white-space: nowrap;
      padding: 9px 12px;
      border-radius: 999px;
      background: var(--navy-soft);
      color: var(--navy);
      font-weight: 800;
      font-size: 0.92rem;
    }

    .audio-block,
    .passage-block,
    .prompt-block {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--panel-soft);
      padding: 14px;
    }

    .audio-block strong,
    .passage-block strong,
    .prompt-block strong {
      display: block;
      margin-bottom: 8px;
      color: #1f3b63;
      font-family: "Plus Jakarta Sans", sans-serif;
    }

    .audio-block audio {
      width: 100%;
    }

    .passage-body {
      color: #35506f;
      line-height: 1.8;
      white-space: pre-wrap;
    }

    .image-stage {
      display: grid;
      gap: 14px;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    }

    .image-stage img {
      width: 100%;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: #ffffff;
      display: block;
      object-fit: contain;
      max-height: 620px;
    }

    .instruction-line {
      margin: 0 0 8px;
      color: var(--muted);
      font-size: 0.94rem;
      line-height: 1.7;
    }

    .prompt-text {
      font-size: 1.06rem;
      line-height: 1.8;
      color: #1d3659;
      white-space: pre-wrap;
    }

    .prompt-text.compact {
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 1.02rem;
      font-weight: 700;
    }

    .answer-head {
      display: grid;
      gap: 8px;
      color: #23466f;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 1.05rem;
      font-weight: 800;
    }

    .answer-head-main {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .answer-number {
      color: #173862;
    }

    .answer-head-status {
      color: var(--muted);
      font-size: 0.85rem;
      font-weight: 700;
      line-height: 1.45;
    }

    .flag-toggle {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 36px;
      padding: 0 12px;
      border-radius: 999px;
      border: 1px solid #f2d39f;
      background: #fff8ea;
      color: var(--accent-deep);
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 0.8rem;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
    }

    .flag-toggle:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 18px rgba(255, 163, 19, 0.16);
    }

    .flag-toggle:focus-visible {
      outline: 3px solid rgba(255, 163, 19, 0.2);
      outline-offset: 2px;
    }

    .flag-toggle.active {
      border-color: #f1b24b;
      background: linear-gradient(180deg, #ffb938 0%, var(--accent) 100%);
      color: #ffffff;
      box-shadow: 0 14px 22px rgba(255, 163, 19, 0.24);
    }

    .answer-flag {
      width: 10px;
      height: 16px;
      border-radius: 2px;
      background: currentColor;
      clip-path: polygon(0 0, 100% 0, 100% 70%, 55% 55%, 0 70%);
    }

    .answer-options {
      display: grid;
      gap: 12px;
      align-content: start;
    }

    .choice {
      display: block;
      cursor: pointer;
    }

    .choice input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .choice-ui {
      display: grid;
      grid-template-columns: 24px minmax(0, 1fr);
      gap: 10px;
      align-items: center;
      padding: 10px 10px;
      border-radius: 12px;
      border: 1px solid transparent;
      transition: 0.18s ease;
    }

    .choice:hover .choice-ui {
      background: #f7faff;
      border-color: #d5dfec;
    }

    .choice input:checked + .choice-ui {
      background: #fff5e8;
      border-color: #f6c46e;
    }

    .choice-dot {
      width: 20px;
      height: 20px;
      border-radius: 999px;
      border: 1.6px solid #c5d3e6;
      position: relative;
      background: #ffffff;
    }

    .choice input:checked + .choice-ui .choice-dot {
      border-color: var(--accent-deep);
      background: #ffffff;
    }

    .choice input:checked + .choice-ui .choice-dot::after {
      content: "";
      position: absolute;
      inset: 4px;
      border-radius: 999px;
      background: var(--accent-deep);
    }

    .choice-copy {
      color: #274669;
      line-height: 1.7;
      font-weight: 700;
    }

    .choice-copy strong {
      margin-right: 6px;
      color: #173862;
      font-family: "Plus Jakarta Sans", sans-serif;
    }

    .choice-copy.only-letter {
      font-family: "Plus Jakarta Sans", sans-serif;
      letter-spacing: 0.04em;
    }

    .answer-actions {
      display: grid;
      gap: 10px;
      margin-top: 8px;
      padding-top: 12px;
      border-top: 1px solid var(--border);
    }

    .answer-footer {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .empty-state {
      margin-bottom: 22px;
    }

    .confirm-backdrop[hidden] {
      display: none;
    }

    .confirm-backdrop {
      position: fixed;
      inset: 0;
      z-index: 40;
      display: grid;
      place-items: center;
      padding: 18px;
      background: rgba(8, 16, 28, 0.56);
      backdrop-filter: blur(3px);
    }

    .confirm-dialog {
      width: min(100%, 420px);
      padding: 22px;
      border-radius: 22px;
      background: #ffffff;
      border: 1px solid var(--border);
      box-shadow: 0 28px 58px rgba(8, 16, 28, 0.24);
    }

    .confirm-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .confirm-head h2 {
      margin: 0;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-size: 1.4rem;
      color: var(--navy);
    }

    .confirm-close {
      width: 42px;
      height: 42px;
      border-radius: 999px;
      border: 1px solid var(--border-strong);
      background: #ffffff;
      color: var(--navy);
      cursor: pointer;
      font-size: 1.3rem;
    }

    .confirm-copy {
      margin: 0;
      color: #253f63;
      font-size: 1.1rem;
      font-weight: 700;
      line-height: 1.6;
    }

    .confirm-note {
      margin: 10px 0 0;
      color: var(--muted);
      line-height: 1.6;
    }

    .confirm-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 18px;
    }

    @media (max-width: 1200px) {
      .page-shell {
        grid-template-columns: 220px minmax(0, 1fr);
      }

      .content-shell {
        grid-template-columns: minmax(0, 1fr) 220px;
      }
    }

    @media (max-width: 960px) {
      body {
        padding: 10px;
        overflow: auto;
      }

      .exam-form {
        height: auto;
        min-height: 0;
      }

      .page-shell {
        grid-template-columns: 1fr;
        height: auto;
      }

      .sidebar-card {
        order: 2;
        position: static;
        height: auto;
        max-height: none;
      }

      .exam-panel {
        order: 1;
        height: auto;
      }

      .sidebar-scroll {
        max-height: 320px;
      }

      .content-shell {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .question-stage {
        height: auto;
        overflow: visible;
      }

      .answer-stage {
        order: -1;
        position: static;
      }

      .screen-stack {
        padding: 14px;
      }
    }

    @media (max-width: 640px) {
      .exam-header {
        padding: 14px;
      }

      .sidebar-footer,
      .answer-footer {
        grid-template-columns: 1fr;
      }

      .stage-top {
        flex-direction: column;
      }

      .nav-grid {
        gap: 8px;
      }

      .nav-btn {
        width: 46px;
        min-width: 46px;
        height: 50px;
        border-radius: 14px;
      }
    }
  </style>
</head>
<body>
  <%
    const fallbackExam =
      typeof defaultPlacementExam !== 'undefined' && defaultPlacementExam
        ? defaultPlacementExam
        : {};
    const requestedExam =
      typeof exam !== 'undefined' && exam
        ? exam
        : fallbackExam;
    const examData =
      Array.isArray(requestedExam.flatQuestions) && requestedExam.flatQuestions.length
        ? requestedExam
        : fallbackExam;
    const questions = Array.isArray(examData.flatQuestions) ? examData.flatQuestions : [];
    const groups = Array.isArray(examData.groups) ? examData.groups : [];
    const partSummary = Array.isArray(examData.partSummary) ? examData.partSummary : [];
    const durationMinutes = Number(examData.durationMinutes || 120);
    const questionViews = questions.map((question) => {
      const group = groups.find((item) => Array.isArray(item.questions) && item.questions.some((groupQuestion) => groupQuestion.number === question.number)) || {};
      const part = partSummary.find((item) => item.partNumber === question.partNumber) || {};
      return Object.assign({}, question, {
        partTitle: part.title || ('Part ' + question.partNumber),
        partInstructions: part.instructions || '',
        sharedContent: group.sharedContent || '',
        sharedAudioUrl: group.sharedAudioUrl || null,
        sharedImages: Array.isArray(group.sharedImages) ? group.sharedImages : []
      });
    });
    const partSections = partSummary
      .map((part) => Object.assign({}, part, {
        questions: questionViews.filter((question) => question.partNumber === part.partNumber)
      }))
      .filter((part) => part.questions.length > 0);
    const totalQuestions = Number(examData.totalQuestions || questionViews.length || 0);
    const hasQuestions = questionViews.length > 0;
    const firstQuestion = hasQuestions ? questionViews[0] : null;
  %>
  <%
    const resolvedBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : '';
  %>
  <form action="<%= resolvedBaseUrl %>/placement-tests/<%= examData.id %>/submit" method="POST" class="exam-form" data-test-form data-session-key="toeic-placement-<%= examData.id %>">
    <input type="hidden" name="guest_name" value="">
    <input type="hidden" name="guest_email" value="">
    <input type="hidden" name="furthest_question_number" value="<%= firstQuestion ? firstQuestion.number : '' %>" data-furthest-question>
    <div class="page-shell">
      <aside class="sidebar-card">
        <div class="timer-panel">
          <div id="timer" data-duration="<%= durationMinutes %>">00:00:00</div>
        </div>
        <div class="sidebar-scroll">
          <% partSections.forEach((part) => { %>
            <section class="sidebar-part">
              <h3>Part <%= part.partNumber %></h3>
              <div class="nav-grid">
                <% part.questions.forEach((question) => { %>
                  <button type="button" class="nav-btn" data-go-question="<%= question.number %>"><%= question.number %></button>
                <% }) %>
              </div>
            </section>
          <% }) %>
        </div>
        <div class="sidebar-footer">
          <div class="count-box">
            <strong><span id="answeredCount">0</span>/<%= totalQuestions %></strong>
            <small><span id="flaggedCount">0</span> câu gắn cờ</small>
          </div>
          <button type="submit" class="submit-btn" <%= hasQuestions ? '' : 'disabled' %>>Nộp bài</button>
        </div>
      </aside>

      <main class="exam-panel">
        <header class="exam-header">
          <div class="exam-meta"><%= examData.title || 'TOEIC Placement Test' %> | <%= examData.bookName || 'ETS 2024' %></div>
          <h1 id="currentHeadline"><%= firstQuestion ? ('Part ' + firstQuestion.partNumber + ' | Câu ' + firstQuestion.number) : 'TOEIC Placement Test' %></h1>
          <div class="exam-subline" id="currentSubline"><%= firstQuestion ? firstQuestion.partTitle : 'Chưa có dữ liệu đề thi' %></div>
        </header>

        <div class="screen-stack">
          <% if (!hasQuestions) { %>
            <div class="empty-state">Chưa có dữ liệu để hiển thị. Kiểm tra lại file đề thi hoặc route đang truyền vào view.</div>
          <% } else { %>
            <% questionViews.forEach((question, index) => { %>
              <section
                class="question-screen<%= index === 0 ? ' active' : '' %>"
                data-question-screen
                data-question-id="<%= question.number %>"
                data-part-number="<%= question.partNumber %>"
                data-part-title="<%= question.partTitle %>"
                data-headline="Part <%= question.partNumber %> | Câu <%= question.number %>">
                <div class="content-shell">
                  <div class="question-stage">
                    <div class="stage-top">
                      <div>
                        <span class="stage-kicker">Part <%= question.partNumber %></span>
                        <h2><%= question.partTitle %></h2>
                      </div>
                      <span class="question-badge">Câu <%= question.number %></span>
                    </div>

                    <% if (question.sharedAudioUrl) { %>
                      <div class="audio-block">
                        <strong>Âm thanh</strong>
                        <audio controls preload="metadata">
                          <source src="<%= question.sharedAudioUrl %>" type="audio/mpeg">
                        </audio>
                      </div>
                    <% } %>

                    <% if (question.sharedContent) { %>
                      <div class="passage-block">
                        <strong>Đoạn văn</strong>
                        <div class="passage-body"><%= question.sharedContent %></div>
                      </div>
                    <% } %>

                    <% if (question.sharedImages && question.sharedImages.length) { %>
                      <div class="image-stage">
                        <% question.sharedImages.forEach((imageUrl) => { %>
                          <img src="<%= imageUrl %>" alt="Tư liệu câu <%= question.number %>">
                        <% }) %>
                      </div>
                    <% } %>

                    <div class="prompt-block">
                      <strong>Hướng dẫn</strong>
                      <p class="instruction-line"><%= question.partInstructions %></p>
                      <div class="prompt-text<%= question.sharedImages && question.sharedImages.length ? ' compact' : '' %>"><%= question.prompt %></div>
                    </div>
                  </div>

                  <aside class="answer-stage">
                    <div class="answer-head">
                      <div class="answer-head-main">
                        <button
                          type="button"
                          class="flag-toggle"
                          data-flag-question="<%= question.number %>"
                          aria-pressed="false"
                          aria-label="Gắn cờ câu <%= question.number %>">
                          <span class="answer-flag" aria-hidden="true"></span>
                          <span data-flag-label>Gắn cờ</span>
                        </button>
                        <span class="answer-number"><%= question.number %>.</span>
                      </div>
                      <span class="answer-head-status" data-flag-status></span>
                    </div>

                    <div class="answer-options">
                      <% question.options.forEach((option) => { %>
                        <label class="choice">
                          <input
                            type="radio"
                            name="<%= question.inputName %>"
                            value="<%= option.label %>"
                            data-question-input="<%= question.number %>">
                          <span class="choice-ui">
                            <span class="choice-dot"></span>
                            <% if (option.isLetterOnly) { %>
                              <span class="choice-copy only-letter"><strong><%= option.label %></strong></span>
                            <% } else { %>
                              <span class="choice-copy"><strong><%= option.label %></strong><%= option.text %></span>
                            <% } %>
                          </span>
                        </label>
                      <% }) %>
                    </div>

                    <div class="answer-actions">
                      <div class="answer-footer">
                        <button type="button" class="control-btn" data-direction="-1">Câu trước</button>
                        <button type="button" class="control-btn" data-direction="1">Câu tiếp</button>
                      </div>

                      <button type="button" class="secondary-btn" data-jump-pending>Đến câu chưa làm</button>
                      <button type="button" class="secondary-btn" data-jump-flagged>Đến câu gắn cờ</button>
                    </div>
                  </aside>
                </div>
              </section>
            <% }) %>
          <% } %>
        </div>
      </main>
    </div>

    <div class="confirm-backdrop" hidden data-submit-confirm>
      <div class="confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="placement-submit-confirm-title">
        <div class="confirm-head">
          <h2 id="placement-submit-confirm-title">Xác nhận</h2>
          <button type="button" class="confirm-close" data-submit-close aria-label="Đóng">&times;</button>
        </div>
        <p class="confirm-copy">Bạn có muốn nộp bài?</p>
        <div class="confirm-actions">
          <button type="button" class="secondary-btn" data-submit-cancel>Quay lại</button>
          <button type="button" class="submit-btn" data-submit-accept>Nộp bài</button>
        </div>
        <p class="confirm-note">Hãy kiểm tra lại kỹ bài trước khi nộp.</p>
      </div>
    </div>
  </form>

  <script>
    (() => {
      const form = document.querySelector('[data-test-form]');
      if (!form) return;

      const sessionKey = form.dataset.sessionKey || '';
      const screens = Array.from(form.querySelectorAll('[data-question-screen]'));
      const navButtons = Array.from(form.querySelectorAll('[data-go-question]'));
      const radioInputs = Array.from(form.querySelectorAll('[data-question-input]'));
      const flagButtons = Array.from(form.querySelectorAll('[data-flag-question]'));
      const timerEl = document.getElementById('timer');
      const answeredEl = document.getElementById('answeredCount');
      const flaggedEl = document.getElementById('flaggedCount');
      const headlineEl = document.getElementById('currentHeadline');
      const sublineEl = document.getElementById('currentSubline');
      const jumpPendingButtons = Array.from(form.querySelectorAll('[data-jump-pending]'));
      const jumpFlaggedButtons = Array.from(form.querySelectorAll('[data-jump-flagged]'));
      const furthestQuestionInput = form.querySelector('[data-furthest-question]');
      const submitConfirm = form.querySelector('[data-submit-confirm]');
      const submitAcceptButton = form.querySelector('[data-submit-accept]');
      const submitCancelButtons = Array.from(form.querySelectorAll('[data-submit-cancel], [data-submit-close]'));
      const orderedIds = screens.map((screen) => String(screen.dataset.questionId));
      let currentQuestionId = orderedIds[0] || null;
      let furthestQuestionId = currentQuestionId;
      let lastPendingJumpId = null;
      let lastFlaggedJumpId = null;
      let flaggedQuestionIds = new Set();
      let isSubmitConfirmed = false;

      const readState = () => {
        if (!sessionKey) return null;
        try {
          const raw = sessionStorage.getItem(sessionKey);
          return raw ? JSON.parse(raw) : null;
        } catch (error) {
          return null;
        }
      };

      const writeState = () => {
        if (!sessionKey) return;
        const answers = {};
        radioInputs.forEach((input) => {
          if (input.checked) {
            answers[input.name] = input.value;
          }
        });

        try {
          sessionStorage.setItem(sessionKey, JSON.stringify({
            currentQuestionId,
            furthestQuestionId,
            lastPendingJumpId,
            lastFlaggedJumpId,
            flaggedQuestionIds: Array.from(flaggedQuestionIds),
            answers
          }));
        } catch (error) {
          console.warn('Cannot save placement state:', error);
        }
      };

      const restoreState = () => {
        const stored = readState();
        if (!stored) return;

        Object.entries(stored.answers || {}).forEach(([name, value]) => {
          const matched = form.querySelector(`input[name="${name}"][value="${value}"]`);
          if (matched) {
            matched.checked = true;
          }
        });

        if (stored.currentQuestionId && orderedIds.includes(String(stored.currentQuestionId))) {
          currentQuestionId = String(stored.currentQuestionId);
        }

        if (stored.furthestQuestionId && orderedIds.includes(String(stored.furthestQuestionId))) {
          furthestQuestionId = String(stored.furthestQuestionId);
        }

        if (stored.lastPendingJumpId) {
          lastPendingJumpId = String(stored.lastPendingJumpId);
        }

        if (stored.lastFlaggedJumpId) {
          lastFlaggedJumpId = String(stored.lastFlaggedJumpId);
        }

        if (Array.isArray(stored.flaggedQuestionIds)) {
          flaggedQuestionIds = new Set(
            stored.flaggedQuestionIds
              .map((questionId) => String(questionId))
              .filter((questionId) => orderedIds.includes(questionId))
          );
        }
      };

      const getAnsweredSet = () => new Set(
        radioInputs
          .filter((input) => input.checked)
          .map((input) => String(input.dataset.questionInput))
      );

      const getFlaggedSet = () => new Set(Array.from(flaggedQuestionIds));

      const getScreen = (questionId) => screens.find((screen) => screen.dataset.questionId === String(questionId));

      const getNeighborId = (questionId, direction) => {
        const currentIndex = orderedIds.indexOf(String(questionId));
        if (currentIndex === -1) return null;
        return orderedIds[currentIndex + direction] || null;
      };

      const updateFurthestQuestion = (questionId) => {
        const nextIndex = orderedIds.indexOf(String(questionId));
        const furthestIndex = orderedIds.indexOf(String(furthestQuestionId));

        if (nextIndex !== -1 && (furthestIndex === -1 || nextIndex > furthestIndex)) {
          furthestQuestionId = String(questionId);
        }

        if (!furthestQuestionId) {
          furthestQuestionId = String(questionId);
        }

        if (furthestQuestionInput) {
          furthestQuestionInput.value = furthestQuestionId || '';
        }
      };

      const closeSubmitConfirm = () => {
        if (submitConfirm) {
          submitConfirm.hidden = true;
        }
      };

      const openSubmitConfirm = () => {
        if (submitConfirm) {
          submitConfirm.hidden = false;
        }
      };

      const submitExam = () => {
        isSubmitConfirmed = true;
        closeSubmitConfirm();

        if (typeof form.requestSubmit === 'function') {
          form.requestSubmit();
          return;
        }

        if (sessionKey) {
          sessionStorage.removeItem(sessionKey);
        }

        form.submit();
      };

      const updateFooterControls = () => {
        screens.forEach((screen) => {
          const questionId = screen.dataset.questionId;
          const prevButton = screen.querySelector('[data-direction="-1"]');
          const nextButton = screen.querySelector('[data-direction="1"]');
          if (prevButton) prevButton.disabled = !getNeighborId(questionId, -1);
          if (nextButton) nextButton.disabled = !getNeighborId(questionId, 1);
        });
      };

      const updateShortcutButtons = (answeredSet, flaggedSet) => {
        const hasPending = orderedIds.some((questionId) => !answeredSet.has(questionId));
        const hasFlagged = flaggedSet.size > 0;

        jumpPendingButtons.forEach((button) => {
          button.disabled = !hasPending;
        });

        jumpFlaggedButtons.forEach((button) => {
          button.disabled = !hasFlagged;
        });
      };

      const syncUi = () => {
        const answeredSet = getAnsweredSet();
        const flaggedSet = getFlaggedSet();
        const activeScreen = getScreen(currentQuestionId) || screens[0];

        screens.forEach((screen) => {
          screen.classList.toggle('active', screen === activeScreen);
        });

        navButtons.forEach((button) => {
          const questionId = button.dataset.goQuestion;
          button.classList.toggle('current', questionId === String(currentQuestionId));
          button.classList.toggle('answered', answeredSet.has(questionId));
          button.classList.toggle('flagged', flaggedSet.has(questionId));
        });

        flagButtons.forEach((button) => {
          const questionId = String(button.dataset.flagQuestion);
          const isFlagged = flaggedSet.has(questionId);
          const label = button.querySelector('[data-flag-label]');
          const status = getScreen(questionId)?.querySelector('[data-flag-status]');

          button.classList.toggle('active', isFlagged);
          button.setAttribute('aria-pressed', isFlagged ? 'true' : 'false');
          button.setAttribute('aria-label', `${isFlagged ? 'Bỏ gắn cờ' : 'Gắn cờ'} câu ${questionId}`);

          if (label) {
            label.textContent = isFlagged ? 'Bỏ cờ' : 'Gắn cờ';
          }

          if (status) {
            status.textContent = isFlagged
              ? 'Đã gắn cờ, nhớ xem lại trước khi nộp.'
              : '';
          }
        });

        const currentButton = navButtons.find((button) => button.dataset.goQuestion === String(currentQuestionId));
        if (currentButton) {
          currentButton.scrollIntoView({ block: 'nearest', inline: 'nearest' });
        }

        if (answeredEl) {
          answeredEl.textContent = String(answeredSet.size);
        }

        if (flaggedEl) {
          flaggedEl.textContent = String(flaggedSet.size);
        }

        if (activeScreen) {
          currentQuestionId = String(activeScreen.dataset.questionId);
          updateFurthestQuestion(currentQuestionId);
          if (headlineEl) {
            headlineEl.textContent = activeScreen.dataset.headline || ('Câu ' + currentQuestionId);
          }
          if (sublineEl) {
            const answeredLabel = answeredSet.has(currentQuestionId) ? 'Đã chọn đáp án' : 'Chưa trả lời';
            const flaggedLabel = flaggedSet.has(currentQuestionId) ? 'Đã gắn cờ xem lại' : 'Không gắn cờ';
            sublineEl.textContent = (activeScreen.dataset.partTitle || '') + ' | ' + answeredLabel + ' | ' + flaggedLabel;
          }
        }

        updateFooterControls();
        updateShortcutButtons(answeredSet, flaggedSet);
        writeState();
      };

      const setCurrentQuestion = (questionId) => {
        if (!orderedIds.includes(String(questionId))) return;
        currentQuestionId = String(questionId);
        syncUi();
      };

      const jumpToNextPending = () => {
        const answeredSet = getAnsweredSet();
        const pendingIds = orderedIds.filter((questionId) => !answeredSet.has(questionId));

        if (!pendingIds.length) {
          return;
        }

        const nextPending = lastPendingJumpId
          ? (pendingIds.find((questionId) => Number(questionId) > Number(lastPendingJumpId)) || pendingIds[0])
          : pendingIds[0];

        lastPendingJumpId = nextPending;
        setCurrentQuestion(nextPending);
      };

      const jumpToNextFlagged = () => {
        const flaggedIds = orderedIds.filter((questionId) => flaggedQuestionIds.has(questionId));

        if (!flaggedIds.length) {
          return;
        }

        const nextFlagged = lastFlaggedJumpId
          ? (flaggedIds.find((questionId) => Number(questionId) > Number(lastFlaggedJumpId)) || flaggedIds[0])
          : flaggedIds[0];

        lastFlaggedJumpId = nextFlagged;
        setCurrentQuestion(nextFlagged);
      };

      const toggleFlag = (questionId) => {
        const normalizedQuestionId = String(questionId);
        if (!orderedIds.includes(normalizedQuestionId)) {
          return;
        }

        if (flaggedQuestionIds.has(normalizedQuestionId)) {
          flaggedQuestionIds.delete(normalizedQuestionId);
          if (lastFlaggedJumpId === normalizedQuestionId) {
            lastFlaggedJumpId = null;
          }
        } else {
          flaggedQuestionIds.add(normalizedQuestionId);
        }

        syncUi();
      };

      restoreState();
      syncUi();

      navButtons.forEach((button) => {
        button.addEventListener('click', () => {
          setCurrentQuestion(button.dataset.goQuestion);
        });
      });

      radioInputs.forEach((input) => {
        input.addEventListener('change', () => {
          currentQuestionId = String(input.dataset.questionInput);
          syncUi();
        });
      });

      flagButtons.forEach((button) => {
        button.addEventListener('click', () => {
          currentQuestionId = String(button.dataset.flagQuestion);
          toggleFlag(button.dataset.flagQuestion);
        });
      });

      screens.forEach((screen) => {
        const prevButton = screen.querySelector('[data-direction="-1"]');
        const nextButton = screen.querySelector('[data-direction="1"]');
        const questionId = screen.dataset.questionId;

        if (prevButton) {
          prevButton.addEventListener('click', () => {
            const prevId = getNeighborId(questionId, -1);
            if (prevId) {
              setCurrentQuestion(prevId);
            }
          });
        }

        if (nextButton) {
          nextButton.addEventListener('click', () => {
            const nextId = getNeighborId(questionId, 1);
            if (nextId) {
              setCurrentQuestion(nextId);
            }
          });
        }
      });

      jumpPendingButtons.forEach((button) => {
        button.addEventListener('click', jumpToNextPending);
      });

      jumpFlaggedButtons.forEach((button) => {
        button.addEventListener('click', jumpToNextFlagged);
      });

      submitCancelButtons.forEach((button) => {
        button.addEventListener('click', closeSubmitConfirm);
      });

      if (submitConfirm) {
        submitConfirm.addEventListener('click', (event) => {
          if (event.target === submitConfirm) {
            closeSubmitConfirm();
          }
        });
      }

      if (submitAcceptButton) {
        submitAcceptButton.addEventListener('click', submitExam);
      }

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && submitConfirm && !submitConfirm.hidden) {
          closeSubmitConfirm();
        }
      });

      form.addEventListener('submit', (event) => {
        if (!isSubmitConfirmed) {
          event.preventDefault();
          openSubmitConfirm();
          return;
        }

        if (sessionKey) {
          sessionStorage.removeItem(sessionKey);
        }
      });

      if (timerEl) {
        let timeLeft = Number(timerEl.dataset.duration || 120) * 60;
        const renderTimer = () => {
          const hours = Math.floor(timeLeft / 3600);
          const minutes = Math.floor((timeLeft % 3600) / 60);
          const seconds = timeLeft % 60;
          timerEl.textContent = `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
          if (timeLeft <= 0) {
            alert('Hết thời gian làm bài. Hệ thống sẽ tự động nộp bài.');
            submitExam();
            return;
          }
          timeLeft -= 1;
        };
        renderTimer();
        setInterval(renderTimer, 1000);
      }
    })();
  </script>
</body>
</html>
