<div class="space-y-10">

  <% const _stats=(typeof stats !=="undefined" && stats) ? stats : { students: (typeof students !=="undefined" &&
    students) ? students.length : 0, teachers: 0, courses: 0, classes: 0, enrollments: 0, revenue: 0 }; const
    _latestClasses=(typeof latestClasses !=="undefined" && latestClasses) ? latestClasses : []; %>

    <header class="rounded-2xl bg-gradient-to-r from-blue-600 to-indigo-600 p-8 text-white shadow-lg">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-3xl font-bold">Bảng điều khiển</h1>
          <p class="text-white/80 mt-2">Hệ thống quản lý trung tâm tiếng Anh</p>
        </div>

        <div class="text-right">
          <p class="text-sm text-white/70">Xin chào</p>
          <p class="text-xl font-semibold">
            <%= username %>
          </p>
        </div>
      </div>
    </header>


    <!-- THỐNG KÊ -->
    <section class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">

      <div class="bg-gray-800 p-6 rounded-xl shadow">
        <p class="text-sm text-gray-400">Tổng học viên</p>
        <p class="text-4xl font-bold text-blue-400">
          <%= _stats.students %>
        </p>
      </div>

      <div class="bg-gray-800 p-6 rounded-xl shadow">
        <p class="text-sm text-gray-400">Giáo viên</p>
        <p class="text-4xl font-bold text-green-400">
          <%= _stats.teachers %>
        </p>
      </div>

      <div class="bg-gray-800 p-6 rounded-xl shadow">
        <p class="text-sm text-gray-400">Khóa học</p>
        <p class="text-4xl font-bold text-purple-400">
          <%= _stats.courses %>
        </p>
      </div>

      <div class="bg-gray-800 p-6 rounded-xl shadow">
        <p class="text-sm text-gray-400">Lớp học</p>
        <p class="text-4xl font-bold text-yellow-400">
          <%= _stats.classes %>
        </p>
      </div>

      <div class="bg-gray-800 p-6 rounded-xl shadow">
        <p class="text-sm text-gray-400">Ghi danh</p>
        <p class="text-4xl font-bold text-pink-400">
          <%= _stats.enrollments %>
        </p>
      </div>

      <div class="bg-gray-800 p-6 rounded-xl shadow">
        <p class="text-sm text-gray-400">Tổng học phí</p>
        <p class="text-4xl font-bold text-red-400">
          <%= _stats.revenue %> đ
        </p>
      </div>

    </section>


    <!-- DANH SÁCH LỚP -->
    <section class="bg-gray-900 rounded-xl shadow p-6 text-slate-100 border border-slate-700/60">

      <h2 class="text-xl font-bold text-white mb-4">Lớp học gần đây</h2>

      <table class="w-full text-left text-sm text-slate-200">
        <thead class="text-gray-400 border-b border-gray-700">
          <tr>
            <th class="py-2">Mã lớp</th>
            <th>Khóa học</th>
            <th>Giáo viên</th>
            <th>Lịch học</th>
            <th>Phòng</th>
          </tr>
        </thead>

        <tbody>

          <% if(_latestClasses.length> 0){ %>

            <% _latestClasses.forEach(function(c){ %>

              <tr class="border-b border-gray-800 text-slate-200">
                <td class="py-2">
                  <%= c.class_code %>
                </td>
                <td>
                  <%= c.course_name %>
                </td>
                <td>
                  <%= c.teacher_name || 'Chưa có' %>
                </td>
                <td>
                  <%= c.schedule %>
                </td>
                <td>
                  <%= c.room %>
                </td>
              </tr>

              <% }) %>

                <% } else { %>

                  <tr>
                    <td colspan="5" class="text-center py-6 text-gray-400">
                      Chưa có lớp học nào
                    </td>
                  </tr>

                  <% } %>

        </tbody>
      </table>

    </section>

</div>
