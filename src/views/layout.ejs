<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - School Portal
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --primary: #3f6287;
            --primary-strong: #23415f;
            --accent: #5f84c2;
            --accent-soft: rgba(95, 132, 194, 0.14);
            --line: rgba(148, 163, 184, 0.2);
            --panel: rgba(255, 255, 255, 0.82);
            --panel-soft: rgba(248, 250, 252, 0.92);
            --text: #16283b;
            --muted: #62748a;
            --sidebar-text: #edf4fb;
            --sidebar-muted: #8ea0b5;
        }

        * {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Plus Jakarta Sans", "Segoe UI", sans-serif;
            background:
                radial-gradient(circle at top right, rgba(191, 219, 254, 0.45), transparent 28%),
                radial-gradient(circle at bottom left, rgba(226, 232, 240, 0.75), transparent 34%),
                linear-gradient(180deg, #f8fbff 0%, #eff4fa 52%, #e7eef6 100%);
            color: var(--text);
        }

        body.theme-teacher {
            background:
                radial-gradient(circle at top right, rgba(96, 165, 250, 0.36), transparent 28%),
                radial-gradient(circle at 18% 18%, rgba(244, 114, 182, 0.16), transparent 22%),
                radial-gradient(circle at bottom left, rgba(226, 232, 240, 0.82), transparent 34%),
                linear-gradient(180deg, #fbfdff 0%, #f3f7fd 52%, #edf2fa 100%);
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(148, 163, 184, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(148, 163, 184, 0.03) 1px, transparent 1px);
            background-size: 32px 32px;
            pointer-events: none;
            mask-image: radial-gradient(circle at center, black, transparent 85%);
        }

        body.nav-open {
            overflow: hidden;
        }

        .app-shell {
            position: relative;
            display: grid;
            grid-template-columns: 300px minmax(0, 1fr);
            min-height: 100vh;
        }

        .app-sidebar {
            position: sticky;
            top: 0;
            display: flex;
            flex-direction: column;
            gap: 22px;
            height: 100vh;
            padding: 22px 18px 30px;
            overflow-y: auto;
            overscroll-behavior: contain;
            scrollbar-width: thin;
            scrollbar-color: rgba(148, 163, 184, 0.32) transparent;
            background:
                radial-gradient(circle at top right, rgba(244, 114, 182, 0.14), transparent 22%),
                radial-gradient(circle at bottom left, rgba(96, 165, 250, 0.16), transparent 24%),
                linear-gradient(180deg, rgba(247, 250, 255, 0.98) 0%, rgba(237, 244, 252, 0.96) 100%);
            border-right: 1px solid var(--line);
            backdrop-filter: blur(20px);
            z-index: 30;
            color: #17314c;
        }

        .app-sidebar>* {
            flex-shrink: 0;
        }

        .theme-teacher .app-sidebar {
            background:
                radial-gradient(circle at top right, rgba(244, 114, 182, 0.16), transparent 20%),
                radial-gradient(circle at bottom left, rgba(96, 165, 250, 0.18), transparent 24%),
                linear-gradient(180deg, rgba(251, 252, 255, 0.98) 0%, rgba(242, 246, 253, 0.98) 48%, rgba(237, 243, 251, 0.98) 100%);
        }

        .app-sidebar::-webkit-scrollbar {
            width: 6px;
        }

        .app-sidebar::-webkit-scrollbar-thumb {
            border-radius: 999px;
            background: rgba(148, 163, 184, 0.28);
        }

        .sidebar-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .brand-link,
        .mobile-brand {
            display: flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
            color: inherit;
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 48px;
            height: 48px;
            border-radius: 16px;
            overflow: hidden;
            background: linear-gradient(135deg, rgba(143, 180, 232, 0.26) 0%, rgba(198, 216, 241, 0.4) 100%);
            box-shadow: 0 20px 36px rgba(24, 183, 216, 0.2);
        }

        .theme-teacher .brand-mark {
            background: linear-gradient(135deg, rgba(219, 234, 254, 0.28) 0%, rgba(251, 207, 232, 0.34) 100%);
            box-shadow: 0 20px 36px rgba(217, 70, 146, 0.16);
        }

        .brand-mark img {
            width: 100%;
            height: 100%;
            display: block;
            object-fit: contain;
            padding: 4px;
        }

        .brand-copy {
            display: flex;
            flex-direction: column;
        }

        .brand-copy strong,
        .mobile-brand strong {
            font-family: "Space Grotesk", sans-serif;
            font-size: 1rem;
            letter-spacing: -0.02em;
        }

        .brand-copy small,
        .mobile-brand small {
            color: #6c8099;
            font-size: 0.82rem;
        }

        .sidebar-close,
        .mobile-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 14px;
            border: 1px solid rgba(136, 166, 215, 0.18);
            background: rgba(255, 255, 255, 0.92);
            color: #17314c;
            cursor: pointer;
            transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
        }

        .sidebar-close:hover,
        .mobile-toggle:hover {
            transform: translateY(-1px);
            border-color: rgba(96, 165, 250, 0.24);
            background: rgba(241, 246, 255, 0.96);
        }

        .sidebar-close {
            display: none;
        }

        .sidebar-kicker,
        .nav-label {
            margin: 0;
            color: #68819b;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.16em;
            text-transform: uppercase;
        }

        .sidebar-user-card,
        .sidebar-note {
            position: relative;
            overflow: hidden;
            padding: 18px;
            border: 1px solid rgba(136, 166, 215, 0.16);
            border-radius: 24px;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(244, 248, 254, 0.9) 100%);
            box-shadow: 0 18px 34px rgba(53, 92, 153, 0.08);
        }

        .sidebar-user-card::after,
        .sidebar-note::after {
            content: "";
            position: absolute;
            inset: auto -50px -70px auto;
            width: 160px;
            height: 160px;
            border-radius: 999px;
            background: radial-gradient(circle, rgba(147, 197, 253, 0.2), transparent 72%);
            pointer-events: none;
        }

        .sidebar-user-card h2,
        .sidebar-note h3 {
            margin: 10px 0 8px;
            font-family: "Space Grotesk", sans-serif;
            font-size: 1.22rem;
            letter-spacing: -0.03em;
        }

        .sidebar-user-card p,
        .sidebar-note p {
            margin: 0;
            color: #60758c;
            line-height: 1.65;
            font-size: 0.95rem;
        }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 18px;
            min-height: 0;
            padding-right: 4px;
        }

        .nav-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .nav-items {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            border: 1px solid transparent;
            border-radius: 18px;
            color: #24415e;
            text-decoration: none;
            transition:
                transform 0.2s ease,
                border-color 0.2s ease,
                background 0.2s ease,
                box-shadow 0.2s ease;
        }

        .brand-link,
        .mobile-brand,
        .mobile-toggle,
        .sidebar-close,
        .nav-link,
        .note-link {
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent;
        }

        .nav-link:hover {
            transform: translateX(4px);
            border-color: rgba(96, 165, 250, 0.18);
            background: rgba(233, 243, 255, 0.92);
        }

        .nav-link.is-active {
            border-color: rgba(96, 165, 250, 0.22);
            background:
                linear-gradient(135deg, rgba(143, 180, 232, 0.22) 0%, rgba(251, 207, 232, 0.18) 100%);
            box-shadow: 0 18px 34px rgba(53, 92, 153, 0.12);
        }

        .theme-teacher .nav-link.is-active {
            border-color: rgba(244, 114, 182, 0.18);
            background:
                linear-gradient(135deg, rgba(147, 197, 253, 0.16) 0%, rgba(244, 114, 182, 0.12) 100%);
        }

        .nav-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            width: 42px;
            height: 42px;
            border-radius: 14px;
            background: rgba(233, 243, 255, 0.92);
            border: 1px solid rgba(136, 166, 215, 0.16);
            color: #2f78ed;
        }

        .nav-text {
            display: flex;
            flex-direction: column;
            gap: 2px;
            min-width: 0;
        }

        .nav-text strong {
            font-size: 0.96rem;
            line-height: 1.3;
            color: #17314c;
        }

        .nav-text small {
            font-size: 0.78rem;
            color: #60758c;
            line-height: 1.4;
        }

        .note-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-top: 16px;
            padding: 11px 16px;
            border-radius: 14px;
            background: var(--accent-soft);
            color: #1d4ed8;
            font-weight: 700;
            text-decoration: none;
            transition: transform 0.2s ease, background 0.2s ease;
        }

        .note-link:hover {
            transform: translateY(-1px);
            background: rgba(147, 197, 253, 0.22);
        }

        .app-main {
            min-width: 0;
            display: flex;
            flex-direction: column;
            background:
                radial-gradient(circle at top right, rgba(191, 219, 254, 0.36), transparent 20%),
                radial-gradient(circle at top left, rgba(255, 255, 255, 0.65), transparent 26%),
                linear-gradient(180deg, rgba(249, 251, 255, 0.92) 0%, rgba(239, 244, 250, 0.96) 55%, rgba(232, 239, 247, 0.98) 100%);
        }

        .theme-teacher .app-main {
            background:
                radial-gradient(circle at top right, rgba(191, 219, 254, 0.36), transparent 20%),
                radial-gradient(circle at top left, rgba(252, 231, 243, 0.46), transparent 24%),
                linear-gradient(180deg, rgba(251, 253, 255, 0.96) 0%, rgba(243, 247, 253, 0.98) 55%, rgba(237, 242, 250, 1) 100%);
        }

        .mobile-bar {
            display: none;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 16px 18px;
            position: sticky;
            top: 0;
            z-index: 20;
            background: rgba(245, 248, 252, 0.88);
            backdrop-filter: blur(22px);
            border-bottom: 1px solid rgba(148, 163, 184, 0.16);
        }

        .mobile-user {
            padding: 8px 12px;
            border-radius: 999px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, 0.84);
            font-size: 0.82rem;
            color: #23415f;
            white-space: nowrap;
        }

        .content-stage {
            width: min(100%, 1520px);
            margin: 0 auto;
            padding: 34px 32px 28px;
            flex: 1;
        }

        .content-stage :is(h1, h2) {
            font-family: "Space Grotesk", "Plus Jakarta Sans", sans-serif;
            letter-spacing: -0.05em;
            background: linear-gradient(90deg, #ff7a59 0%, #ff5d8f 44%, #ffb14a 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .flash-stack {
            display: grid;
            gap: 12px;
            margin-bottom: 24px;
        }

        .flash-card {
            padding: 16px 18px;
            border-radius: 18px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, 0.86);
            box-shadow: 0 16px 34px rgba(148, 163, 184, 0.14);
        }

        .flash-card.success {
            border-color: rgba(74, 222, 128, 0.28);
            color: #166534;
        }

        .flash-card.error {
            border-color: rgba(248, 113, 113, 0.28);
            color: #b91c1c;
        }

        .flash-card.info {
            border-color: rgba(56, 189, 248, 0.26);
            color: #1d4ed8;
        }

        .app-footer {
            padding: 0 32px 26px;
        }

        .app-footer p {
            width: min(100%, 1520px);
            margin: 0 auto;
            padding-top: 18px;
            border-top: 1px solid rgba(148, 163, 184, 0.1);
            color: #64748b;
            font-size: 0.9rem;
        }

        .sidebar-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(2, 6, 12, 0.58);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease;
            z-index: 25;
        }

        @media (max-width: 1024px) {
            .app-shell {
                grid-template-columns: 1fr;
            }

            .app-sidebar {
                position: fixed;
                inset: 0 auto 0 0;
                width: min(86vw, 320px);
                transform: translateX(-100%);
                transition: transform 0.28s ease;
                height: 100vh;
                box-shadow: 22px 0 60px rgba(1, 6, 12, 0.46);
            }

            .app-shell.sidebar-open .app-sidebar {
                transform: translateX(0);
            }

            .app-shell.sidebar-open .sidebar-backdrop {
                opacity: 1;
                pointer-events: auto;
            }

            .sidebar-close,
            .mobile-bar {
                display: flex;
            }

            .content-stage {
                width: 100%;
                padding: 24px 18px 22px;
            }

            .app-footer {
                padding: 0 18px 22px;
            }
        }

        @media (max-width: 640px) {

            .mobile-brand small,
            .mobile-user {
                display: none;
            }

            .content-stage {
                padding-left: 14px;
                padding-right: 14px;
            }

            .app-footer {
                padding-left: 14px;
                padding-right: 14px;
            }
        }
    </style>
</head>

