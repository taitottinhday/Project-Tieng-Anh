        schedule: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
            stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="3" />
            <path d="M16 2v4" />
            <path d="M8 2v4" />
            <path d="M3 10h18" />
            <path d="M12 14v4" />
            <path d="M12 14l3-2" />
        </svg>`,
        profile: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
            stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="4" />
            <path d="M4 20a8 8 0 0 1 16 0" />
        </svg>`,
        logout: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
            <path d="M16 17l5-5-5-5" />
            <path d="M21 12H9" />
        </svg>`,
        default: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
            stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9" />
            <path d="M12 8v4" />
            <path d="M12 16h.01" />
        </svg>`
        };
        const icon = (name) => iconMap[name] || iconMap.default;

        let userLabel = 'Guest account';
        let userRoleLabel = 'Explore courses, tests and support';
        let navGroups = [];
        let noteTitle = 'Giữ nhịp công việc';
        let noteText = user
            ? 'Theo dõi lịch học, kết quả bài test và các công việc hằng ngày trong một không gian gọn gàng.'
            : 'Khám phá khóa học, làm placement test và liên hệ tư vấn nhanh hơn với giao diện tập trung hơn.';
        let noteLinkLabel = user ? 'Liên hệ hỗ trợ' : 'Làm bài test ngay';
        let noteLinkHref = user ? buildHref('/contact') : buildHref('/placement-tests');
        const safeSuccessMessages = typeof success_msg !== 'undefined' ? success_msg : [];
        const safeErrorMessages = typeof error_msg !== 'undefined' ? error_msg : [];
        const safeInfoMessages = typeof error !== 'undefined' ? error : [];

        if (!user) {
        navGroups = [
        {
        label: 'Explore',
        items: [
        { label: 'Home', description: 'Landing page overview', href: buildHref('/'), icon: 'home' },
        { label: 'Courses', description: 'Programs and details', href: buildHref('/courses-blog'), icon: 'courses' },
        { label: 'Placement Test', description: 'Check your entry level', href: buildHref('/placement-tests'), icon:
        'tests' },
        { label: 'Contact', description: 'Talk to the center', href: buildHref('/contact'), icon: 'contact' }
        ]
        },
        {
        label: 'Account',
        items: [
        { label: 'Login', description: 'Access your dashboard', href: buildHref('/login'), icon: 'login' },
        { label: 'Register', description: 'Create a new account', href: buildHref('/register'), icon: 'register' }
        ]
        }
        ];
        } else if (user.role === 'admin') {
        userLabel = user.username;
        userRoleLabel = 'Không gian quản trị';
        navGroups = [
        {
        label: 'Điều hành',
        items: [
        { label: 'Tổng quan', description: 'Bức tranh vận hành', href: buildHref('/dashboard'), icon: 'dashboard' },
        { label: 'Cơ sở dữ liệu', description: 'Bảng và dữ liệu hệ thống', href: buildHref('/database'), icon:
        'database' },
        { label: 'Tin nhắn', description: 'Hộp thư phụ huynh và học viên', href: buildHref('/messages'), icon:
        'messages' },
        { label: 'Học viên', description: 'Quản lý hồ sơ và ghi danh', href: buildHref('/admin/students'), icon:
        'students' },
        { label: 'Giáo viên', description: 'Quản lý hồ sơ và phân công', href: buildHref('/admin/teachers'), icon:
        'teacher' },
        { label: 'Thêm tài liệu', description: 'Đề thi, tài liệu và kho nội dung', href: buildHref('/admin/resources'), icon:
        'library' },
        { label: 'Quản trị', description: 'Công cụ điều hành', href: buildHref('/admin'), icon: 'admin' }
        ]
        },
        {
        label: 'Phiên làm việc',
        items: [
        { label: 'Đăng xuất', description: 'Kết thúc phiên hiện tại', href: buildHref('/logout'), icon: 'logout' }
        ]
        }
        ];
        } else if (user.role === 'teacher') {
        userLabel = user.username;
        userRoleLabel = 'Không gian giáo viên hiện đại';
        noteTitle = 'Nhịp dạy học';
        noteText = 'Điểm danh, nhận xét, lịch dạy và toàn bộ lớp phụ trách được gom về một không gian làm việc mạch lạc, dễ theo dõi.';
        noteLinkLabel = 'Mở điểm danh';
        noteLinkHref = buildHref('/teacher/attendance');
        navGroups = [
        {
        label: 'Giảng dạy',
        items: [
        { label: 'Tổng quan', description: 'Bức tranh vận hành trong ngày', href: buildHref('/teacher/dashboard'), icon:
        'dashboard' },
        { label: 'Classroom', description: 'Đăng bài và chấm bài trong lớp', href: buildHref('/teacher/classroom'), icon:
        'courses' },
        { label: 'Lớp phụ trách', description: 'Các lớp bạn đang dẫn dắt', href: buildHref('/teacher/classes'), icon:
        'classes' },
        { label: 'Điểm danh', description: 'Theo dõi chuyên cần theo buổi', href: buildHref('/teacher/attendance'), icon:
        'attendance' },
        { label: 'Nhận xét', description: 'Phản hồi và ghi chú học viên', href: buildHref('/teacher/comments'), icon:
        'comments' },
        { label: 'Góp ý', description: 'Hộp thư góp ý từ học viên', href: buildHref('/teacher/feedback'), icon:
        'messages' },
        { label: 'Lịch dạy', description: 'Kế hoạch giảng dạy sắp tới', href: buildHref('/teacher/schedule'), icon:
        'schedule' },
        { label: 'Hồ sơ', description: 'Thông tin và dấu ấn giảng dạy', href: buildHref('/teacher/profile'), icon:
        'profile' }
        ]
        },
        {
        label: 'Phiên làm việc',
        items: [
        { label: 'Đăng xuất', description: 'Kết thúc phiên hiện tại', href: buildHref('/logout'), icon: 'logout' }
        ]
        }
        ];
        } else {
        userLabel = user.username;
        userRoleLabel = 'Student workspace';
        navGroups = [
        {
        label: 'Learning',
        items: [
        { label: 'Home', description: 'Back to landing page', href: buildHref('/'), icon: 'home' },
        { label: 'Courses', description: 'Browse available programs', href: buildHref('/courses-blog'), icon: 'courses'
        },
        { label: 'Placement Test', description: 'Retake entry assessment', href: buildHref('/placement-tests'), icon:
        'tests' },
        { label: 'Contact', description: 'Get support from the center', href: buildHref('/contact'), icon: 'contact' },
        { label: 'Register Course', description: 'Reserve your next class', href: buildHref('/register-course'), icon:
        'register' }
        ]
        },
        {
        label: 'Session',
        items: [
        { label: 'Logout', description: 'End current session', href: buildHref('/logout'), icon: 'logout' }
        ]
        }
        ];
        }
        %>

        <div class="app-shell" id="appShell">
            <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

            <aside class="app-sidebar" id="appSidebar">
                <div class="sidebar-top">
                    <a href="<%= buildHref('/') %>" class="brand-link">
                        <span class="brand-mark">
                            <img src="<%= brandLogo %>" alt="Logo Thầy Tài Toeic">
                        </span>
                        <span class="brand-copy">
                            <strong>Thầy Tài Toeic</strong>
                            <small>Learning platform</small>
                        </span>
                    </a>

                    <button type="button" class="sidebar-close" id="sidebarClose" aria-label="Close navigation">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 6L6 18"></path>
                            <path d="M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>

                <section class="sidebar-user-card">
                    <p class="sidebar-kicker">Workspace</p>
                    <h2>
                        <%= userLabel %>
                    </h2>
                    <p>
                        <%= userRoleLabel %>
                    </p>
                </section>

                <nav class="sidebar-nav" aria-label="Primary navigation">
                    <% navGroups.forEach((group)=> { %>
                        <section class="nav-group">
                            <p class="nav-label">
                                <%= group.label %>
                            </p>
                            <div class="nav-items">
                                <% group.items.forEach((item)=> { %>
                                    <a href="<%= item.href %>"
                                        class="nav-link <%= isActive(item) ? 'is-active' : '' %>">
                                        <span class="nav-icon"><%- icon(item.icon) %></span>
                                        <span class="nav-text">
                                            <strong>
                                                <%= item.label %>
                                            </strong>
                                            <small>
                                                <%= item.description %>
                                            </small>
                                        </span>
                                    </a>
                                    <% }) %>
                            </div>
                        </section>
                        <% }) %>
                </nav>

                <% if (!user || user.role !== 'admin') { %>
                    <section class="sidebar-note">
                        <p class="sidebar-kicker">Ghi chú nhanh</p>
                        <h3><%= noteTitle %></h3>
                        <p>
                            <%= noteText %>
                        </p>
                        <a href="<%= noteLinkHref %>" class="note-link">
                            <%= noteLinkLabel %>
                        </a>
                    </section>
                <% } %>
            </aside>

            <div class="app-main">
                <div class="mobile-bar">
                    <button type="button" class="mobile-toggle" id="sidebarToggle" aria-expanded="false"
                        aria-controls="appSidebar" aria-label="Open navigation">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 7h16"></path>
                            <path d="M4 12h16"></path>
                            <path d="M4 17h16"></path>
                        </svg>
                    </button>

                    <a href="<%= buildHref('/') %>" class="mobile-brand">
                        <span class="brand-mark">
                            <img src="<%= brandLogo %>" alt="Logo Thầy Tài Toeic">
                        </span>
                        <span>
                            <strong>Thầy Tài Toeic</strong>
                            <small>Learning platform</small>
                        </span>
                    </a>

                    <div class="mobile-user">
                        <%= user ? user.username : 'Guest' %>
                    </div>
                </div>

                <main class="content-stage">
                    <% if (safeSuccessMessages.length || safeErrorMessages.length || safeInfoMessages.length) { %>
                        <section class="flash-stack">
                            <% safeSuccessMessages.forEach((msg)=> { %>
                                <div class="flash-card success">
                                    <%= msg %>
                                </div>
                                <% }) %>
                                    <% safeErrorMessages.forEach((msg)=> { %>
                                        <div class="flash-card error">
                                            <%= msg %>
                                        </div>
                                        <% }) %>
                                            <% safeInfoMessages.forEach((msg)=> { %>
                                                <div class="flash-card info">
                                                    <%= msg %>
                                                </div>
                                                <% }) %>
                        </section>
                        <% } %>

                            <%- content %>
                </main>

                <footer class="app-footer">
                    <p>&copy; Copyright © Thầy Tài Toeic - v1.4.8</p>
                </footer>
            </div>
        </div>

        <script>
            (() => {
                const shell = document.getElementById('appShell');
                const toggle = document.getElementById('sidebarToggle');
                const closeButton = document.getElementById('sidebarClose');
                const backdrop = document.getElementById('sidebarBackdrop');

                if (!shell) {
                    return;
                }

                const setSidebarOpen = (open) => {
                    shell.classList.toggle('sidebar-open', open);
                    document.body.classList.toggle('nav-open', open);

                    if (toggle) {
                        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                    }
                };

                if (toggle) {
                    toggle.addEventListener('click', () => {
                        setSidebarOpen(!shell.classList.contains('sidebar-open'));
                    });
                }

                if (closeButton) {
                    closeButton.addEventListener('click', () => setSidebarOpen(false));
                }

                if (backdrop) {
                    backdrop.addEventListener('click', () => setSidebarOpen(false));
                }

                window.addEventListener('resize', () => {
                    if (window.innerWidth > 1024) {
                        setSidebarOpen(false);
                    }
                });

                document.addEventListener('keydown', (event) => {
                    if (event.key === 'Escape') {
                        setSidebarOpen(false);
                    }
                });
            })();
        </script>
</body>

</html>
