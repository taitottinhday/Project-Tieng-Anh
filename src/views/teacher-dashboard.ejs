<%- include('partials/teacher-workspace-style') %>
<%
  const safeTeacher = (typeof teacher !== 'undefined' && teacher) ? teacher : { full_name: 'Giáo viên' };
  const safeStats = (typeof stats !== 'undefined' && stats) ? stats : {};
  const normalizeClass = (item) => ({
    phase: {
      label: item?.phase?.label || 'Đang vận hành',
      tone: item?.phase?.tone || 'blue',
      progress: typeof item?.phase?.progress === 'number' ? item.phase.progress : 18,
      supportingText: item?.phase?.supportingText || 'Theo dõi tiến độ lớp học theo từng buổi dạy.'
    },
    ...item,
    total_students: Number(item?.total_students || 0),
    total_comments: Number(item?.total_comments || 0)
  });
  const safeMyClasses = (Array.isArray(typeof myClasses !== 'undefined' ? myClasses : null) ? myClasses : []).map(normalizeClass);
  const safeTodayClasses = (Array.isArray(typeof todayClasses !== 'undefined' ? todayClasses : null) ? todayClasses : []).map(normalizeClass);
  const safeWeeklyLoad = Array.isArray(typeof weeklyLoad !== 'undefined' ? weeklyLoad : null) ? weeklyLoad : [];
  const safeRecentComments = Array.isArray(typeof recentComments !== 'undefined' ? recentComments : null) ? recentComments : [];
  const safePriorityCards = Array.isArray(typeof priorityCards !== 'undefined' ? priorityCards : null) ? priorityCards : [];
  const safeTodayIso = typeof todayIso !== 'undefined' ? todayIso : null;
  const shortDate = (value) => {
    if (!value) return 'Chưa ấn định';
    const raw = String(value);
    const parsed = /^\d{4}-\d{2}-\d{2}$/.test(raw) ? new Date(`${raw}T00:00:00`) : new Date(raw);
    return Number.isNaN(parsed.getTime()) ? 'Chưa ấn định' : parsed.toLocaleDateString('vi-VN');
  };
  const previewComment = (value, limit = 140) => {
    const text = String(value || '').trim();
    return text.length > limit ? `${text.slice(0, limit)}...` : text;
  };
  const attendanceRateLabel = typeof safeStats.attendanceRate === 'number' ? `${safeStats.attendanceRate}%` : 'Chưa có';
  const weeklyPeak = safeWeeklyLoad.length ? Math.max(...safeWeeklyLoad.map((item) => item.count), 1) : 1;
  const teacherPresenceMetaMap = {
    present: { label: 'Đã có mặt', tone: 'green' },
    late: { label: 'Đi muộn', tone: 'gold' },
    absent: { label: 'Vắng mặt', tone: 'pink' },
    excused: { label: 'Có phép', tone: 'blue' }
  };
  const formatDateTime = (value) => {
    if (!value) return 'Chưa cập nhật';
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? 'Chưa cập nhật' : parsed.toLocaleString('vi-VN');
  };
%>

<div class="teacher-shell">
  <section class="teacher-hero">
    <div class="teacher-hero-grid">
      <div>
        <p class="teacher-hero-kicker">Teacher Workspace</p>
        <h1 class="teacher-hero-title">Không gian điều hành lớp học dành cho <%= safeTeacher.full_name %></h1>
        <p class="teacher-hero-text">
          Theo dõi chuyên cần, tiến độ lớp học, phản hồi học viên và lịch dạy trong cùng một trải nghiệm hiện đại,
          sáng sủa và dễ đọc.
        </p>
        <div class="teacher-hero-badges">
          <span class="teacher-pill soft">Ngày làm việc: <%= shortDate(safeTodayIso) %></span>
          <span class="teacher-pill soft"><%= Number(safeStats.activeClasses || 0) %> lớp đang vận hành</span>
          <span class="teacher-pill soft"><%= Number(safeStats.studentsWithFeedback || 0) %> học viên đã có nhận xét</span>
          <span class="teacher-pill soft"><%= Number(safeStats.todayTeacherCheckInCount || 0) %> lớp đã check-in hôm nay</span>
        </div>
      </div>

      <div class="teacher-panel" style="background: rgba(255,255,255,0.16); color: white; border-color: rgba(255,255,255,0.18);">
        <div class="teacher-panel-head">
          <div>
            <h2 class="teacher-panel-title" style="color: white;">Điểm nhấn trong ngày</h2>
            <p class="teacher-panel-desc" style="color: rgba(255,255,255,0.8);">Những chỉ số quan trọng nhất để vào việc nhanh.</p>
          </div>
        </div>
        <div class="teacher-kpi-strip">
          <div class="teacher-mini-kpi" style="background: rgba(255,255,255,0.16); border-color: rgba(255,255,255,0.1);">
            <strong style="color: white;"><%= Number(safeStats.totalClasses || 0) %></strong>
            <span style="color: rgba(255,255,255,0.78);">Lớp phụ trách</span>
          </div>
          <div class="teacher-mini-kpi" style="background: rgba(255,255,255,0.16); border-color: rgba(255,255,255,0.1);">
            <strong style="color: white;"><%= Number(safeStats.totalStudents || 0) %></strong>
            <span style="color: rgba(255,255,255,0.78);">Tổng học viên</span>
          </div>
          <div class="teacher-mini-kpi" style="background: rgba(255,255,255,0.16); border-color: rgba(255,255,255,0.1);">
            <strong style="color: white;"><%= attendanceRateLabel %></strong>
            <span style="color: rgba(255,255,255,0.78);">Tỷ lệ hiện diện</span>
          </div>
        </div>
        <div class="teacher-hero-actions" style="margin-top: 18px;">
          <a href="<%= baseUrl %>/teacher/attendance" class="teacher-link-button secondary">Điểm danh ngay</a>
          <a href="<%= baseUrl %>/teacher/comments" class="teacher-link-button ghost" style="background: rgba(255,255,255,0.18); color: white; border-color: rgba(255,255,255,0.16);">Thêm nhận xét</a>
        </div>
      </div>
    </div>
  </section>

  <% if (teacherCheckInSuccess) { %>
    <div class="teacher-alert">Đã ghi nhận trạng thái có mặt của giáo viên cho buổi dạy. Admin sẽ thấy log này trong hồ sơ giáo viên.</div>
  <% } %>

  <section class="teacher-grid four">
    <article class="teacher-stat-card">
      <span class="teacher-stat-label">Lớp đang dạy</span>
      <strong class="teacher-stat-value"><%= Number(safeStats.totalClasses || 0) %></strong>
      <p class="teacher-stat-note">Số lớp bạn đang theo dõi trong toàn bộ hệ thống giáo viên.</p>
    </article>

    <article class="teacher-stat-card">
      <span class="teacher-stat-label">Học viên</span>
      <strong class="teacher-stat-value"><%= Number(safeStats.totalStudents || 0) %></strong>
      <p class="teacher-stat-note">Tổng quy mô học viên hiện được phân vào các lớp bạn phụ trách.</p>
    </article>

    <article class="teacher-stat-card">
      <span class="teacher-stat-label">Check-in hôm nay</span>
      <strong class="teacher-stat-value"><%= Number(safeStats.todayTeacherCheckInCount || 0) %></strong>
      <p class="teacher-stat-note">Số lớp bạn đã xác nhận có mặt để dạy trong hôm nay.</p>
    </article>

    <article class="teacher-stat-card">
      <span class="teacher-stat-label">Nhận xét đã gửi</span>
      <strong class="teacher-stat-value"><%= Number(safeStats.recentCommentsCount || 0) %></strong>
      <p class="teacher-stat-note">Toàn bộ phản hồi học viên bạn đã ghi nhận trong teacher workspace.</p>
    </article>
  </section>

  <section class="teacher-action-grid">
    <a href="<%= baseUrl %>/teacher/classes" class="teacher-action-card">
      <h2 class="teacher-card-title">Lớp phụ trách</h2>
      <p class="teacher-card-text">Xem nhanh sĩ số, tiến độ lớp và các điểm cần hoàn thiện của từng lớp học.</p>
    </a>
    <a href="<%= baseUrl %>/teacher/attendance" class="teacher-action-card">
      <h2 class="teacher-card-title">Điểm danh</h2>
      <p class="teacher-card-text">Cập nhật chuyên cần, ghi chú từng buổi học và lưu trạng thái chỉ trong vài thao tác.</p>
    </a>
    <a href="<%= baseUrl %>/teacher/comments" class="teacher-action-card">
      <h2 class="teacher-card-title">Nhận xét</h2>
      <p class="teacher-card-text">Ghi nhận sự tiến bộ, điểm cần cải thiện và kỹ năng trọng tâm của từng học viên.</p>
    </a>
    <a href="<%= baseUrl %>/teacher/schedule" class="teacher-action-card">
      <h2 class="teacher-card-title">Lịch dạy</h2>
      <p class="teacher-card-text">Theo dõi nhịp dạy theo tuần, theo tháng và chuẩn bị trước các lớp sắp khai giảng.</p>
    </a>
  </section>

  <section class="teacher-grid two">
    <article class="teacher-panel highlight">
      <div class="teacher-panel-head">
        <div>
          <h2 class="teacher-panel-title">Lớp dạy cần check-in hôm nay</h2>
          <p class="teacher-panel-desc">Xác nhận nhanh việc bạn đã có mặt dạy lớp, đồng thời mở ngay luồng điểm danh học viên.</p>
        </div>
      </div>

      <% if (safeTodayClasses.length) { %>
        <div class="teacher-stack" style="margin-top: 18px;">
          <% safeTodayClasses.forEach((item) => { %>
            <article class="teacher-class-card" style="padding: 18px;">
              <div class="teacher-class-top">
                <div>
                  <h3 class="teacher-card-title"><%= item.course_name %></h3>
                  <p class="teacher-card-text">Mã lớp <strong><%= item.code %></strong> · <%= item.room || 'Chưa có phòng' %></p>
                </div>
                <span class="teacher-pill <%= item.phase.tone %>"><%= item.phase.label %></span>
              </div>
              <div class="teacher-class-meta" style="margin-top: 14px;">
                <p class="teacher-muted">Lịch học: <%= item.schedule_text || 'Chưa cập nhật' %></p>
                <p class="teacher-muted">Thời gian: <%= item.start_label || 'Chưa có ngày bắt đầu' %> đến <%= item.end_label || 'Chưa có ngày kết thúc' %></p>
                <% if (item.teacher_check_in_status) { %>
                  <% const presenceMeta = teacherPresenceMetaMap[item.teacher_check_in_status] || teacherPresenceMetaMap.present; %>
                  <p class="teacher-muted">Check-in hôm nay: <span class="teacher-pill <%= presenceMeta.tone %>"><%= presenceMeta.label %></span> · <%= item.teacher_checked_in_label || 'Đã ghi nhận' %></p>
                <% } else { %>
                  <p class="teacher-muted">Check-in hôm nay: Chưa đánh dấu có mặt cho buổi dạy này.</p>
                <% } %>
              </div>
              <div class="teacher-progress">
                <div class="teacher-progress-bar" style="width: <%= item.phase.progress || 18 %>%;"></div>
              </div>
              <p class="teacher-note" style="margin-top: 12px;"><%= item.phase.supportingText %></p>
              <div class="teacher-card-actions" style="margin-top: 16px;">
                <% if (!item.teacher_check_in_status || item.teacher_check_in_status !== 'present') { %>
                  <form method="POST" action="<%= baseUrl %>/teacher/attendance/<%= item.id %>/teacher-check-in">
                    <input type="hidden" name="lesson_date" value="<%= safeTodayIso %>">
                    <input type="hidden" name="status" value="present">
                    <input type="hidden" name="source" value="dashboard">
                    <button class="teacher-link-button secondary" type="submit">Tôi đã có mặt</button>
                  </form>
                <% } %>
                <a href="<%= baseUrl %>/teacher/attendance/<%= item.id %>?date=<%= safeTodayIso %>" class="teacher-link-button">Mở điểm danh lớp</a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="teacher-empty" style="margin-top: 18px;">Hôm nay chưa có lớp nào nổi bật để check-in, hoặc lịch dạy chưa đủ dữ liệu ngày trong tuần.</div>
      <% } %>
    </article>

    <article class="teacher-panel">
      <div class="teacher-panel-head">
        <div>
          <h2 class="teacher-panel-title">Việc nên ưu tiên</h2>
          <p class="teacher-panel-desc">Những điểm cần xử lý để luồng giảng dạy luôn đầy đủ và chỉn chu.</p>
        </div>
      </div>

      <div class="teacher-stack" style="margin-top: 18px;">
        <% safePriorityCards.forEach((item) => { %>
          <article class="teacher-class-card" style="padding: 18px;">
            <div class="teacher-class-top">
              <div>
                <h3 class="teacher-card-title"><%= item.title %></h3>
                <p class="teacher-card-text"><%= item.description %></p>
              </div>
              <span class="teacher-pill <%= item.tone %>">Ưu tiên</span>
            </div>
            <div class="teacher-card-actions" style="margin-top: 16px;">
              <a href="<%= baseUrl %><%= item.href %>" class="teacher-link-button"><%= item.action %></a>
            </div>
          </article>
        <% }) %>
      </div>
    </article>
  </section>

  <section class="teacher-grid two">
    <article class="teacher-panel">
      <div class="teacher-panel-head">
        <div>
          <h2 class="teacher-panel-title">Tải giảng dạy theo ngày</h2>
          <p class="teacher-panel-desc">Nhìn nhanh xem các buổi đang tập trung nhiều ở ngày nào trong tuần.</p>
        </div>
      </div>

      <% if (safeWeeklyLoad.length) { %>
        <div class="teacher-bar-list" style="margin-top: 20px;">
          <% safeWeeklyLoad.forEach((item) => { %>
            <div class="teacher-bar-row">
              <div class="teacher-bar-top">
                <span><%= item.label %></span>
                <strong><%= item.count %> lớp</strong>
              </div>
              <div class="teacher-bar-track">
                <div class="teacher-bar-fill" style="width: <%= Math.max(18, Math.round((item.count / weeklyPeak) * 100)) %>%;"></div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="teacher-empty" style="margin-top: 18px;">Chưa có dữ liệu lịch học đủ để hiển thị phân bổ theo ngày.</div>
      <% } %>
    </article>

    <article class="teacher-panel">
      <div class="teacher-panel-head">
        <div>
          <h2 class="teacher-panel-title">Nhận xét gần đây</h2>
          <p class="teacher-panel-desc">Dòng phản hồi mới nhất để bạn nắm nhanh chất lượng chăm sóc học viên.</p>
        </div>
        <a href="<%= baseUrl %>/teacher/comments" class="teacher-link-button secondary">Xem tất cả</a>
      </div>

      <% if (safeRecentComments.length) { %>
        <div class="teacher-stack" style="margin-top: 18px;">
          <% safeRecentComments.forEach((item) => { %>
            <article class="teacher-comment-card" style="padding: 18px;">
              <div class="teacher-class-top">
                <div>
                  <h3 class="teacher-card-title"><%= item.full_name %></h3>
                  <p class="teacher-card-text"><%= item.course_name || 'Khóa học' %> · <%= item.class_code || 'Chưa rõ mã lớp' %></p>
                </div>
                <span class="teacher-pill pink"><%= item.skill_focus || 'Tổng quát' %></span>
              </div>
              <p class="teacher-card-text" style="margin-top: 14px;"><%= previewComment(item.comment) %></p>
              <p class="teacher-note" style="margin-top: 10px;">Buổi học: <%= shortDate(item.lesson_date || item.created_at) %></p>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="teacher-empty" style="margin-top: 18px;">Chưa có nhận xét nào được tạo. Bạn có thể bắt đầu từ mục Nhận xét học viên.</div>
      <% } %>
    </article>
  </section>

  <section class="teacher-panel">
    <div class="teacher-panel-head">
      <div>
        <h2 class="teacher-panel-title">Lớp phụ trách nổi bật</h2>
        <p class="teacher-panel-desc">Những lớp học cần quan sát gần hơn về tiến độ, sĩ số hoặc thông tin vận hành.</p>
      </div>
      <a href="<%= baseUrl %>/teacher/classes" class="teacher-link-button secondary">Mở tất cả lớp</a>
    </div>

    <% if (safeMyClasses.length) { %>
      <div class="teacher-grid two" style="margin-top: 20px;">
        <% safeMyClasses.forEach((item) => { %>
          <article class="teacher-class-card">
            <div class="teacher-class-top">
              <div>
                <h3 class="teacher-card-title"><%= item.course_name %></h3>
                <p class="teacher-card-text">Mã lớp <strong><%= item.code %></strong> · <%= item.category || 'Đa kỹ năng' %></p>
              </div>
              <span class="teacher-pill <%= item.phase.tone %>"><%= item.phase.label %></span>
            </div>

            <div class="teacher-kpi-strip">
              <div class="teacher-mini-kpi">
                <strong><%= item.total_students %></strong>
                <span>Học viên</span>
              </div>
              <div class="teacher-mini-kpi">
                <strong><%= item.total_comments %></strong>
                <span>Nhận xét</span>
              </div>
              <div class="teacher-mini-kpi">
                <strong><%= item.last_attendance_label || 'Chưa có' %></strong>
                <span>Điểm danh gần nhất</span>
              </div>
            </div>

            <div class="teacher-class-meta">
              <p class="teacher-muted">Lịch học: <%= item.schedule_text || 'Chưa cập nhật' %></p>
              <p class="teacher-muted">Phòng học: <%= item.room || 'Chưa gán phòng' %></p>
            </div>

            <div class="teacher-card-actions" style="margin-top: 18px;">
              <a href="<%= baseUrl %>/teacher/classes/<%= item.id %>" class="teacher-link-button">Xem chi tiết</a>
              <a href="<%= baseUrl %>/teacher/attendance/<%= item.id %>" class="teacher-link-button secondary">Điểm danh</a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="teacher-empty" style="margin-top: 18px;">Chưa có lớp nào để hiển thị trong dashboard.</div>
    <% } %>
  </section>
</div>
