<%
const safeBaseUrl = typeof baseUrl !== "undefined" ? baseUrl : "";
const page = coursePage || {};
const menuItems = (courseMenu || []).map((item) => ({
  ...item,
  href: `${safeBaseUrl}/courses-blog/${item.slug}`,
  isActive: item.slug === page.slug,
}));
const resolveHref = (url) => {
  if (!url) return "#";
  if (/^(?:https?:|mailto:|tel:)/.test(url)) return url;
  return `${safeBaseUrl}${url}`;
};
%>

<style>
  .cl-page{display:grid;gap:28px;padding:12px 0 40px}.cl-page h1,.cl-page h2,.cl-page h3{margin:0;color:#0f172a}.cl-page p{margin:0;color:#334155;line-height:1.8}.cl-wrap{width:min(100%,1140px);margin:0 auto}.cl-crumbs,.cl-subnav,.cl-actions,.cl-stats,.cl-cards,.cl-teachers,.cl-steps{display:flex;flex-wrap:wrap;gap:12px}.cl-crumbs{color:#64748b;font-size:.95rem}.cl-chip,.cl-link,.cl-btn{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;font-weight:800}.cl-subnav{padding:14px;border-radius:22px;background:#fff;border:1px solid rgba(15,23,42,.08);box-shadow:0 14px 30px rgba(15,23,42,.05)}.cl-subnav a{min-height:40px;padding:0 14px;border-radius:999px;color:#475569;background:#f8fafc;border:1px solid rgba(15,23,42,.06);font-weight:800}.cl-subnav a.is-active{color:#fff;border-color:transparent;background:linear-gradient(135deg,#ef4444 0%,#2563eb 100%)}.cl-promo{display:grid;grid-template-columns:84px minmax(0,1fr) auto;gap:16px;align-items:center;padding:16px 18px;border-radius:24px;background:linear-gradient(135deg,#fff7ed 0%,#fef3c7 100%);border:1px solid rgba(245,158,11,.18)}.cl-promo img{width:84px;height:84px;object-fit:cover;border-radius:20px}.cl-link{min-height:40px;padding:0 14px;color:#1d4ed8;background:#fff;border:1px solid rgba(15,23,42,.08)}.cl-hero-shell{padding:26px;border-radius:30px;background:linear-gradient(180deg,#dff0ff 0%,#eef7ff 100%)}.cl-hero{display:grid;grid-template-columns:minmax(0,1fr) minmax(360px,.92fr);gap:24px;padding:32px;border-radius:30px;background:#fff;border:1px solid rgba(15,23,42,.08);box-shadow:0 24px 50px rgba(15,23,42,.08)}.cl-hero-copy{display:grid;gap:16px}.cl-kicker{font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:clamp(2.4rem,5vw,4.6rem);line-height:.95;letter-spacing:-.06em;color:#1d9bf0;text-transform:uppercase}.cl-badge{width:max-content;padding:16px 24px;border-radius:20px;background:linear-gradient(135deg,#1d9bf0 0%,#2563eb 100%);font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:clamp(1.8rem,4vw,3rem);line-height:1;color:#fff;text-transform:uppercase}.cl-btn{min-height:50px;padding:0 22px;border:0;color:#fff;background:linear-gradient(135deg,#ef4444 0%,#dc2626 100%);box-shadow:0 14px 26px rgba(239,68,68,.2)}.cl-stat{display:grid;gap:4px;min-width:136px}.cl-stat strong{font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:2rem;line-height:1;color:#ef4444}.cl-collage{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));overflow:hidden;border-radius:22px;background:#eaf4ff}.cl-collage > div{min-height:122px;display:grid;place-items:center;padding:14px;text-align:center}.cl-collage img{width:100%;height:100%;object-fit:cover}.cl-collage .text{font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:1.8rem;line-height:1.1;background:#fff}.cl-head{display:grid;gap:10px;justify-items:center;text-align:center}.cl-head h2{font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:clamp(2rem,4vw,3.4rem);line-height:1.06;letter-spacing:-.05em}.cl-head p{max-width:820px}.cl-red{color:#ef4444}.cl-benefits{display:grid;gap:26px}.cl-benefit-body{display:grid;grid-template-columns:minmax(0,1fr) minmax(320px,.92fr);gap:26px;align-items:center}.cl-levels{display:grid;gap:18px;grid-template-columns:64px minmax(0,1fr)}.cl-scale{position:relative;display:grid;gap:72px;justify-items:center;padding-top:8px}.cl-scale:before{content:"";position:absolute;top:0;bottom:0;width:3px;border-radius:999px;background:rgba(148,163,184,.45)}.cl-scale span{position:relative;z-index:1;width:60px;height:60px;border-radius:50%;display:grid;place-items:center;background:#ececec;font-family:"Lexend","Be Vietnam Pro",sans-serif;font-weight:800}.cl-benefit-list{display:grid;gap:18px}.cl-benefit-list div{min-height:80px;padding:0 28px;border-radius:999px;display:flex;align-items:center;background:#fff;font-size:1.25rem;font-weight:800;box-shadow:0 14px 30px rgba(15,23,42,.06)}.cl-benefit-list div:first-child{color:#fff;background:linear-gradient(135deg,#7dd3fc 0%,#2563eb 100%)}.cl-photo{overflow:hidden;border-radius:24px;background:linear-gradient(135deg,#dbeafe 0%,#fef3c7 100%)}.cl-photo img{width:100%;height:100%;object-fit:cover}.cl-photo.tall{min-height:560px}.cl-story-main{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(280px,.72fr);gap:18px;padding:24px;border-radius:26px;background:linear-gradient(135deg,#faf5ff 0%,#f8fafc 100%);border:1px solid rgba(15,23,42,.08)}.cl-story-copy{display:grid;gap:14px}.cl-story-copy h3{font-size:1.7rem;line-height:1.24}.cl-meta{display:grid;gap:4px;padding-top:18px;border-top:1px solid rgba(15,23,42,.1)}.cl-cards{gap:18px}.cl-card{flex:1 1 320px;display:grid;grid-template-columns:minmax(0,1fr) 220px;gap:16px;padding:22px;border-radius:24px;background:linear-gradient(135deg,#fff7ed 0%,#f8fafc 100%);border:1px solid rgba(15,23,42,.08)}.cl-card.alt{background:linear-gradient(135deg,#eef2ff 0%,#eff6ff 100%)}.cl-pillars{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));border-radius:26px;overflow:hidden;border:1px solid rgba(15,23,42,.08);background:#fff}.cl-pillar{min-height:240px;padding:28px 24px;display:grid;gap:14px;align-content:start;border-right:1px solid rgba(15,23,42,.08)}.cl-pillar:last-child{border-right:0}.cl-pillar.primary{color:#fff;background:linear-gradient(180deg,#60a5fa 0%,#2563eb 100%)}.cl-pillar.primary h3,.cl-pillar.primary p{color:#fff}.cl-roadmap{display:grid;gap:22px}.cl-track,.cl-track-labels{display:grid;grid-template-columns:repeat(4,minmax(0,1fr))}.cl-track div{min-height:200px;padding:16px;display:grid;align-content:end;justify-items:center;text-align:center}.cl-track strong{font-size:1.05rem}.cl-track h3{font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:1.8rem;line-height:1.1}.cl-track span{font-weight:900}.cl-track .gold{background:#ecd06a}.cl-track .amber{background:#e4b92e}.cl-track .mint{background:#9bcfcf}.cl-track .teal{background:#6ba8a3}.cl-track-labels{padding-top:12px;text-align:center;font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:1.4rem}.cl-row{display:grid;grid-template-columns:220px minmax(0,1fr);gap:14px}.cl-label,.cl-box,.cl-table,.cl-knowledge-anchor,.cl-resource,.cl-consult-card{border-radius:22px;background:rgba(228,242,255,.82)}.cl-label{padding:24px 18px;text-align:center;font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:1.35rem;color:#0f4c81}.cl-box{padding:24px}.cl-knowledge{display:grid;grid-template-columns:220px repeat(3,minmax(0,1fr));gap:14px}.cl-knowledge-anchor{padding:24px 18px;display:grid;place-items:center;text-align:center;font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:1.4rem;color:#fff;background:linear-gradient(180deg,#8fc0f8 0%,#5e9ce0 100%)}.cl-table{overflow:hidden;background:#fff;border:1px solid rgba(15,23,42,.08)}.cl-table table{width:100%;border-collapse:collapse}.cl-table th,.cl-table td{padding:14px;border:1px solid rgba(15,23,42,.08);text-align:left;vertical-align:top}.cl-table th{background:#5b93d5;color:#fff}.cl-dark{padding:36px 24px;border-radius:30px;background:radial-gradient(circle at top right,rgba(124,58,237,.18),transparent 22%),radial-gradient(circle at left bottom,rgba(59,130,246,.18),transparent 20%),#08124a}.cl-dark .cl-head h2,.cl-dark .cl-head p{color:#fff}.cl-resource-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:18px}.cl-resource{overflow:hidden;background:#fff;border:2px solid rgba(123,163,255,.35)}.cl-resource img{width:100%;height:220px;object-fit:contain;background:#fff}.cl-resource-copy{display:grid;gap:6px;padding:18px}.cl-resource-copy strong{color:#2563eb}.cl-step-grid{justify-content:stretch}.cl-step{position:relative;flex:1 1 220px;min-height:150px;padding:34px 24px 24px;border-radius:22px;display:grid;align-content:end;background:#eef9ff;font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:1.3rem}.cl-step:nth-child(2){background:#f3ecff}.cl-step:nth-child(3){background:#fff1f2}.cl-step span{position:absolute;top:12px;left:18px;font-size:5rem;line-height:1;color:rgba(15,23,42,.06)}.cl-banner{display:flex;align-items:center;justify-content:space-between;gap:18px;padding:22px 26px;border-radius:24px;background:#f8fafc;border:1px solid rgba(15,23,42,.08)}.cl-banner strong{color:#ef4444}.cl-teachers{justify-content:stretch}.cl-teacher{flex:1 1 190px;display:grid;gap:12px}.cl-teacher .cl-photo{min-height:260px;background:linear-gradient(180deg,#36a9e1 0%,#d8f3ff 100%)}.cl-faq{display:grid;gap:16px}.cl-faq-item{border-radius:22px;overflow:hidden;background:#fff;border:1px solid rgba(15,23,42,.08);box-shadow:0 18px 34px rgba(15,23,42,.05)}.cl-faq-trigger{width:100%;min-height:76px;padding:0 24px;display:flex;align-items:center;justify-content:space-between;gap:14px;border:0;background:#fff;text-align:left;font-size:1.15rem;font-weight:800;cursor:pointer}.cl-faq-item.open .cl-faq-trigger{color:#fff;background:#4f83c4}.cl-faq-answer{display:none;padding:22px 24px}.cl-faq-item.open .cl-faq-answer{display:block}.cl-consult{display:grid;grid-template-columns:minmax(0,1fr) minmax(320px,.92fr);gap:24px;padding:28px;border-radius:30px;background:linear-gradient(180deg,#f7fbff 0%,#fff 100%);border:1px solid rgba(15,23,42,.08);box-shadow:0 18px 34px rgba(15,23,42,.05)}.cl-consult-copy{display:grid;gap:18px}.cl-consult-copy h2{font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:clamp(2rem,4vw,3.4rem);line-height:1.08;letter-spacing:-.05em}.cl-consult-points{display:grid;gap:14px}.cl-consult-points div{display:flex;align-items:center;gap:14px;font-size:1.1rem;font-weight:700}.cl-consult-points i{width:42px;height:42px;border-radius:14px;display:grid;place-items:center;background:#eff6ff;color:#1d4ed8;font-style:normal;font-weight:900}.cl-consult-grid{display:grid;gap:10px;grid-template-columns:1.1fr .9fr .62fr;grid-template-rows:repeat(2,160px)}.cl-consult-grid .cl-photo:first-child{grid-row:1/span 2}.cl-consult-card{display:grid;gap:12px;padding:24px;background:#fff;border:1px solid rgba(15,23,42,.08)}.cl-consult-card h3{font-size:1.9rem;color:#1e3a8a}.cl-consult-card input,.cl-consult-card textarea{width:100%;min-height:52px;padding:0 14px;border-radius:16px;border:1px solid rgba(15,23,42,.12);background:#f8fafc;font:inherit;color:#0f172a}.cl-consult-card textarea{min-height:110px;padding:14px;resize:vertical}.cl-placeholder{display:grid;gap:16px;padding:28px;border-radius:28px;background:#fff;border:1px solid rgba(15,23,42,.08);box-shadow:0 18px 34px rgba(15,23,42,.05)}.cl-placeholder h1{font-family:"Lexend","Be Vietnam Pro",sans-serif;font-size:clamp(2.4rem,5vw,4rem);line-height:1.06;letter-spacing:-.05em}@media (max-width:1180px){.cl-hero,.cl-benefit-body,.cl-story-main,.cl-consult{grid-template-columns:1fr}.cl-pillars,.cl-resource-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.cl-row,.cl-knowledge{grid-template-columns:1fr}.cl-track,.cl-track-labels{grid-template-columns:repeat(2,minmax(0,1fr))}}@media (max-width:760px){.cl-promo,.cl-card,.cl-banner,.cl-consult{grid-template-columns:1fr;justify-items:start}.cl-hero,.cl-promo{text-align:left}.cl-collage,.cl-pillars,.cl-resource-grid,.cl-track,.cl-track-labels{grid-template-columns:1fr}.cl-levels{grid-template-columns:1fr}.cl-scale{grid-auto-flow:column;gap:12px;padding:0}.cl-scale:before{top:50%;bottom:auto;left:0;right:0;width:auto;height:3px;transform:translateY(-50%)}.cl-consult-grid{grid-template-columns:1fr 1fr;grid-template-rows:repeat(3,120px)}.cl-consult-grid .cl-photo:first-child{grid-row:span 2}}
</style>

<div class="cl-page cl-wrap">
  <nav class="cl-crumbs" aria-label="Breadcrumb">
    <a href="<%= safeBaseUrl %>/">Trang chủ</a><span>&gt;</span>
    <a href="<%= safeBaseUrl %>/courses-blog">Khóa học</a><span>&gt;</span>
    <span><%= page.title %></span>
  </nav>

  <nav class="cl-subnav" aria-label="Danh mục khóa học">
    <% menuItems.forEach((item) => { %><a href="<%= item.href %>" class="<%= item.isActive ? 'is-active' : '' %>"><%= item.label %></a><% }) %>
  </nav>

  <% if (page.placeholder) { %>
    <section class="cl-placeholder">
      <span class="cl-link" style="width:max-content;"><%= page.eyebrow %></span>
      <h1><%= page.title %></h1>
      <p><%= page.summary %></p>
      <div class="cl-actions">
        <a href="<%= safeBaseUrl %>/courses-blog" class="cl-btn">Xem overview khóa học</a>
        <a href="<%= safeBaseUrl %>/contact" class="cl-link">Nhận tư vấn trước</a>
      </div>
    </section>
  <% } else { %>
    <% if (page.promoStrip) { %>
      <section class="cl-promo">
        <img src="<%= page.promoStrip.image %>" alt="<%= page.promoStrip.title %>">
        <div><strong><%= page.promoStrip.title %></strong><p><%= page.promoStrip.text %></p></div>
        <a href="<%= resolveHref(page.promoStrip.href) %>" class="cl-link"><%= page.promoStrip.hrefLabel %></a>
      </section>
    <% } %>

    <section class="cl-hero-shell">
      <article class="cl-hero">
        <div class="cl-hero-copy">
          <span class="cl-kicker"><%= page.hero.title %></span>
          <span class="cl-badge"><%= page.hero.badge %></span>
          <h1><%= page.hero.subtitle %></h1>
          <p><%= page.hero.text %></p>
          <div class="cl-actions"><a href="<%= resolveHref(page.hero.ctaHref) %>" class="cl-btn"><%= page.hero.ctaLabel %></a></div>
          <div class="cl-stats"><% (page.hero.stats || []).forEach((item) => { %><div class="cl-stat"><strong><%= item.value %></strong><span><%= item.label %></span></div><% }) %></div>
        </div>
        <div class="cl-collage">
          <% (page.hero.collage || []).forEach((item) => { %>
            <% if (item.type === 'image') { %><div><img src="<%= item.image %>" alt="<%= item.alt %>"></div><% } else { %><div class="text"><span><%= item.label %></span></div><% } %>
          <% }) %>
        </div>
      </article>
    </section>

    <section class="cl-benefits">
      <div class="cl-head"><h2><%= page.benefits.title %> <span class="cl-red"><%= page.benefits.highlight %></span></h2><p><%= page.benefits.subtitle %></p></div>
      <div class="cl-benefit-body">
        <div class="cl-levels">
          <div class="cl-scale"><% (page.benefits.levels || []).forEach((item) => { %><span><%= item %></span><% }) %></div>
          <div class="cl-benefit-list"><% (page.benefits.items || []).forEach((item) => { %><div><%= item %></div><% }) %></div>
        </div>
        <div class="cl-photo tall"><img src="<%= page.benefits.image %>" alt="<%= page.benefits.title %>"></div>
      </div>
    </section>

    <section class="cl-benefits">
      <div class="cl-head"><h2><%= page.stories.title %> <span class="cl-red"><%= page.stories.highlight %></span></h2></div>
      <article class="cl-story-main">
        <div class="cl-story-copy">
          <h3><%= page.stories.featured.title %></h3>
          <p><%= page.stories.featured.excerpt %></p>
          <div class="cl-meta"><strong><%= page.stories.featured.metaTitle %></strong><span><%= page.stories.featured.metaValue %></span></div>
        </div>
        <div class="cl-photo"><img src="<%= page.stories.featured.image %>" alt="<%= page.stories.featured.title %>"></div>
      </article>
      <div class="cl-cards">
        <% (page.stories.items || []).forEach((item, index) => { %>
          <article class="cl-card <%= index === 1 ? 'alt' : '' %>">
            <div class="cl-story-copy">
              <h3><%= item.title %></h3>
              <p><%= item.excerpt %></p>
              <div class="cl-meta"><strong><%= item.metaTitle %></strong><span><%= item.metaValue %></span></div>
            </div>
            <div class="cl-photo"><img src="<%= item.image %>" alt="<%= item.title %>"></div>
          </article>
        <% }) %>
      </div>
      <div class="cl-actions" style="justify-content:center;"><a href="<%= resolveHref(page.stories.ctaHref) %>" class="cl-link"><%= page.stories.ctaLabel %></a></div>
    </section>

    <section class="cl-benefits">
      <div class="cl-head"><h2><%= page.pillars.title %> <span class="cl-red"><%= page.pillars.highlight %></span></h2></div>
      <div class="cl-pillars">
        <% (page.pillars.items || []).forEach((item) => { %><article class="cl-pillar <%= item.tone === 'primary' ? 'primary' : '' %>"><h3><%= item.title %></h3><p><%= item.text %></p></article><% }) %>
      </div>
      <div class="cl-actions" style="justify-content:center;"><a href="<%= resolveHref(page.pillars.ctaHref) %>" class="cl-btn"><%= page.pillars.ctaLabel %></a></div>
    </section>

    <section class="cl-roadmap">
      <div class="cl-head"><h2><span class="cl-red"><%= page.roadmap.title %></span></h2><h3 style="font-size:clamp(1.6rem,3vw,2.4rem);"><%= page.roadmap.subtitle %></h3><p><%= page.roadmap.desc %></p></div>
      <div class="cl-track">
        <% (page.roadmap.tiers || []).forEach((item) => { %><div class="<%= item.tone %>"><strong><%= item.duration %></strong><h3><%= item.range %></h3><span><%= item.label %></span></div><% }) %>
      </div>
      <div class="cl-track-labels"><% (page.roadmap.tiers || []).forEach((item) => { %><div><%= item.label %></div><% }) %></div>
      <% (page.roadmap.supportRows || []).forEach((item) => { %><div class="cl-row"><div class="cl-label"><%= item.label %></div><div class="cl-box"><p><%= item.text %></p></div></div><% }) %>
      <div class="cl-knowledge">
        <div class="cl-knowledge-anchor">Kiến thức chính</div>
        <% (page.roadmap.knowledgeCards || []).forEach((item) => { %><div class="cl-box"><h3><%= item.title %></h3><p><%= item.text %></p></div><% }) %>
      </div>
      <div class="cl-table">
        <table>
          <thead><tr><th>STT</th><th>Kỹ năng</th><th>Nội dung</th><th>Review Test</th></tr></thead>
          <tbody><% (page.roadmap.tableRows || []).forEach((item) => { %><tr><td><%= item.session %></td><td><%= item.skill %></td><td><%= item.content %></td><td><%= item.review || '—' %></td></tr><% }) %></tbody>
        </table>
      </div>
    </section>

    <section class="cl-dark">
      <div class="cl-head"><h2><%= page.resources.title %></h2></div>
      <div class="cl-resource-grid">
        <% (page.resources.items || []).forEach((item) => { %><article class="cl-resource"><img src="<%= item.image %>" alt="<%= item.title %>"><div class="cl-resource-copy"><strong><%= item.subtitle %></strong><h3 style="font-size:1.45rem;"><%= item.title %></h3><span class="cl-link" style="width:max-content;">Xem thêm</span></div></article><% }) %>
      </div>
    </section>

    <section class="cl-benefits">
      <div class="cl-head"><h2><span class="cl-red"><%= page.steps.title %></span></h2><h3 style="font-size:clamp(1.8rem,3vw,3rem);"><%= page.steps.highlight %></h3><p><%= page.steps.desc %></p></div>
      <div class="cl-steps"><% (page.steps.items || []).forEach((item, index) => { %><article class="cl-step"><span>0<%= index + 1 %></span><strong><%= item %></strong></article><% }) %></div>
      <div class="cl-banner"><p><%= page.steps.banner %></p><a href="<%= resolveHref(page.steps.ctaHref) %>" class="cl-btn"><%= page.steps.ctaLabel %></a></div>
    </section>

    <section class="cl-benefits">
      <div class="cl-head"><h2><%= page.teachers.title %> <span class="cl-red"><%= page.teachers.highlight %></span></h2><p><%= page.teachers.desc %></p></div>
      <div class="cl-teachers"><% (page.teachers.items || []).forEach((item) => { %><article class="cl-teacher"><div class="cl-photo"><img src="<%= item.image %>" alt="<%= item.name %>"></div><div><h3><%= item.name %></h3><p><%= item.role %></p></div></article><% }) %></div>
      <div class="cl-actions" style="justify-content:center;"><a href="<%= resolveHref(page.teachers.ctaHref) %>" class="cl-link"><%= page.teachers.ctaLabel %></a></div>
    </section>

    <section class="cl-faq">
      <div class="cl-head"><h2>Câu hỏi thường gặp?</h2></div>
      <% (page.faq || []).forEach((item, index) => { %>
        <article class="cl-faq-item <%= index === 0 ? 'open' : '' %>">
          <button type="button" class="cl-faq-trigger" aria-expanded="<%= index === 0 ? 'true' : 'false' %>"><span><%= item.q %></span><span><%= index === 0 ? '−' : '+' %></span></button>
          <div class="cl-faq-answer"><p><%= item.a %></p></div>
        </article>
      <% }) %>
    </section>

    <section class="cl-consult">
      <div class="cl-consult-copy">
        <h2><%= page.consult.title %></h2>
        <div class="cl-consult-points"><% (page.consult.bullets || []).forEach((item, index) => { %><div><i><%= index + 1 %></i><span><%= item %></span></div><% }) %></div>
        <div class="cl-consult-grid"><% (page.consult.collage || []).forEach((item) => { %><div class="cl-photo"><img src="<%= item %>" alt="Không gian tư vấn"></div><% }) %></div>
      </div>
      <form class="cl-consult-card">
        <h3><%= page.consult.formTitle %></h3>
        <p><%= page.consult.formText %></p>
        <input type="text" placeholder="Họ và tên">
        <input type="tel" placeholder="Số điện thoại">
        <input type="email" placeholder="Email">
        <textarea placeholder="Mục tiêu điểm / thời gian bạn muốn học"></textarea>
        <a href="<%= safeBaseUrl %>/register-course" class="cl-btn"><%= page.consult.primaryLabel %></a>
        <a href="<%= resolveHref(page.consult.secondaryHref) %>" class="cl-link"><%= page.consult.secondaryLabel %></a>
      </form>
    </section>
  <% } %>
</div>

<script>
  (() => {
    document.querySelectorAll('.cl-faq-trigger').forEach((button) => {
      button.addEventListener('click', () => {
        const item = button.closest('.cl-faq-item');
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.cl-faq-item').forEach((node) => {
          node.classList.remove('open');
          const trigger = node.querySelector('.cl-faq-trigger');
          if (trigger) {
            trigger.setAttribute('aria-expanded', 'false');
            trigger.lastElementChild.textContent = '+';
          }
        });
        if (!isOpen) {
          item.classList.add('open');
          button.setAttribute('aria-expanded', 'true');
          button.lastElementChild.textContent = '−';
        }
      });
    });
  })();
</script>
