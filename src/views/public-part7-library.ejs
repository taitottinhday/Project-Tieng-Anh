<%
const data = catalog || {};
const items = Array.isArray(data.items) ? data.items : [];
const heroImage = data.heroImage || "";
%>

<style>
  .p7lib-page {
    width: min(1280px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 56px;
    display: grid;
    gap: 24px;
  }

  .p7lib-panel {
    border-radius: 18px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: #ffffff;
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.04);
    overflow: hidden;
  }

  .p7lib-hero {
    padding: 24px 24px 0;
  }

  .p7lib-cover {
    min-height: 340px;
    border-radius: 18px;
    overflow: hidden;
    background: linear-gradient(135deg, #dff7fb 0%, #d8eff7 38%, #b8d8e9 100%);
    display: grid;
    place-items: center;
  }

  .p7lib-cover img {
    width: 100%;
    height: 100%;
    max-height: 420px;
    object-fit: cover;
    display: block;
  }

  .p7lib-cover-fallback {
    padding: 40px 24px;
    text-align: center;
    color: #174164;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.12;
    letter-spacing: -0.04em;
  }

  .p7lib-list {
    display: grid;
    gap: 16px;
    padding: 24px;
  }

  .p7lib-item {
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr) auto;
    gap: 14px;
    align-items: center;
    min-height: 64px;
    padding: 0 20px;
    border-radius: 8px;
    border: 1px solid #d9e1ec;
    color: #183153;
    text-decoration: none;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .p7lib-item:hover {
    transform: translateY(-1px);
    border-color: #acc2df;
    box-shadow: 0 14px 26px rgba(15, 23, 42, 0.06);
  }

  .p7lib-icon {
    width: 20px;
    height: 20px;
    border-radius: 4px;
    border: 2px solid #2e4c78;
    color: #2e4c78;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.82rem;
    font-weight: 900;
  }

  .p7lib-copy {
    display: grid;
    gap: 4px;
  }

  .p7lib-copy strong {
    font-size: 1rem;
    color: #1d3557;
  }

  .p7lib-copy span {
    color: #6b7a90;
    font-size: 0.92rem;
  }

  .p7lib-go {
    color: #167db6;
    font-weight: 800;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .p7lib-page {
      width: min(100% - 20px, 1280px);
      padding-top: 18px;
    }

    .p7lib-hero,
    .p7lib-list {
      padding-inline: 16px;
    }

    .p7lib-hero {
      padding-top: 16px;
    }

    .p7lib-list {
      padding-top: 18px;
      padding-bottom: 18px;
      gap: 12px;
    }

    .p7lib-item {
      grid-template-columns: 24px minmax(0, 1fr);
      padding: 14px;
      min-height: 0;
    }

    .p7lib-go {
      display: none;
    }
  }
</style>

<div class="p7lib-page">
  <section class="p7lib-panel">
    <div class="p7lib-hero">
      <div class="p7lib-cover">
        <% if (heroImage) { %>
          <img src="<%= heroImage %>" alt="<%= data.heroImageAlt || 'Luyện TOEIC Part 7' %>">
        <% } else { %>
          <div class="p7lib-cover-fallback"><%= data.heroTitle || "Hướng dẫn TOEIC Part 7" %></div>
        <% } %>
      </div>
    </div>

    <div class="p7lib-list">
      <% items.forEach((item) => { %>
        <a href="<%= item.href %>" class="p7lib-item">
          <span class="p7lib-icon">x</span>
          <span class="p7lib-copy">
            <strong><%= item.title %></strong>
            <% if (item.subtitle) { %>
              <span><%= item.subtitle %></span>
            <% } %>
          </span>
          <span class="p7lib-go"><%= data.listActionLabel || "Xem chi tiết" %></span>
        </a>
      <% }) %>
    </div>
  </section>
</div>
