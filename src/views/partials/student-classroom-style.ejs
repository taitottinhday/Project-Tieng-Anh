<style>
  :root {
    --sc-ink: #18304c;
    --sc-ink-soft: #5b6f85;
    --sc-border: rgba(89, 106, 191, 0.14);
    --sc-surface: rgba(255, 255, 255, 0.96);
    --sc-shadow: 0 24px 54px rgba(39, 62, 122, 0.12);
    --sc-hero-start: #102845;
    --sc-hero-mid: #1a4b84;
    --sc-hero-end: #355c8e;
    --sc-hero-title: #f7fbff;
    --sc-hero-copy: rgba(226, 232, 240, 0.9);
    --sc-hero-kicker-bg: linear-gradient(135deg, rgba(226, 239, 255, 0.12) 0%, rgba(255, 223, 239, 0.14) 100%);
    --sc-hero-kicker-border: rgba(255, 255, 255, 0.1);
    --sc-primary: #2f78ed;
    --sc-primary-strong: #163f73;
    --sc-primary-soft: linear-gradient(135deg, rgba(224, 238, 255, 0.84) 0%, rgba(255, 233, 242, 0.84) 100%);
  }

  .sc-page {
    width: min(1480px, calc(100% - 26px));
    margin: 0 auto;
    padding: 28px 0 46px;
    display: grid;
    gap: 22px;
    color: var(--sc-ink);
  }

  .sc-page * {
    box-sizing: border-box;
  }

  .sc-shell,
  .sc-panel,
  .sc-card,
  .sc-hero {
    border: 1px solid var(--sc-border);
    box-shadow: var(--sc-shadow);
    background: var(--sc-surface);
  }

  .sc-hero {
    position: relative;
    overflow: hidden;
    padding: 34px;
    border-radius: 34px;
    background:
      radial-gradient(circle at top right, rgba(232, 155, 188, 0.18), transparent 24%),
      radial-gradient(circle at bottom left, rgba(255, 255, 255, 0.06), transparent 28%),
      linear-gradient(135deg, var(--sc-hero-start) 0%, var(--sc-hero-mid) 46%, var(--sc-hero-end) 100%);
    color: var(--sc-hero-title);
  }

  .sc-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, rgba(255, 255, 255, 0.05), transparent 42%, rgba(232, 155, 188, 0.08) 100%);
    pointer-events: none;
  }

  .sc-hero::after {
    content: "";
    position: absolute;
    inset: auto -60px -90px auto;
    width: 220px;
    height: 220px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(232, 155, 188, 0.18), transparent 72%);
    filter: blur(2px);
    pointer-events: none;
  }

  .sc-hero h1,
  .sc-panel h2,
  .sc-card h3 {
    margin: 0;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .sc-hero h1,
  .sc-panel h2,
  .sc-card h3,
  .sc-post-card h3 {
    background: none;
    -webkit-background-clip: border-box;
    background-clip: border-box;
    color: inherit;
  }

  .sc-hero h1 {
    margin-top: 14px;
    font-size: clamp(2.35rem, 4.6vw, 3.85rem);
    line-height: 1.02;
    color: var(--sc-hero-title);
  }

  .sc-hero p {
    margin: 14px 0 0;
    max-width: 58ch;
    line-height: 1.82;
    color: var(--sc-hero-copy);
  }

  .sc-kicker,
  .sc-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 0 14px;
    border-radius: 999px;
    font-weight: 800;
  }

  .sc-kicker {
    background: var(--sc-hero-kicker-bg);
    border: 1px solid var(--sc-hero-kicker-border);
    color: rgba(241, 245, 249, 0.94);
    font-size: 0.84rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    backdrop-filter: blur(14px);
  }

  .sc-pill {
    gap: 8px;
    font-size: 0.86rem;
    border: 1px solid transparent;
  }

  .sc-pill.blue {
    color: #18436f;
    background: rgba(228, 237, 248, 0.96);
    border-color: rgba(96, 130, 173, 0.16);
  }

  .sc-pill.pink {
    color: #87415d;
    background: rgba(248, 236, 241, 0.96);
    border-color: rgba(185, 120, 145, 0.15);
  }

  .sc-pill.green {
    color: #205e51;
    background: rgba(226, 242, 236, 0.96);
    border-color: rgba(74, 130, 113, 0.14);
  }

  .sc-pill.soft {
    color: #516477;
    background: rgba(244, 247, 250, 0.96);
    border-color: rgba(148, 163, 184, 0.14);
  }

  .sc-grid,
  .sc-grid.two,
  .sc-grid.three,
  .sc-feed-layout,
  .sc-card-grid {
    display: grid;
    gap: 18px;
  }

  .sc-grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .sc-grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .sc-feed-layout {
    grid-template-columns: minmax(0, 1fr) 360px;
    align-items: start;
  }

  .sc-panel,
  .sc-card {
    border-radius: 30px;
    padding: 24px;
  }

  .sc-panel p,
  .sc-card p,
  .sc-meta {
    color: var(--sc-ink-soft);
    line-height: 1.78;
  }

  .sc-card {
    position: relative;
    overflow: hidden;
  }

  .sc-card::after {
    content: "";
    position: absolute;
    inset: auto -34px -50px auto;
    width: 140px;
    height: 140px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(232, 155, 188, 0.12), transparent 72%);
    pointer-events: none;
  }

  .sc-card h3 {
    font-size: 1.4rem;
    color: #1f344a;
  }

  .sc-card-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .sc-attachment-list,
  .sc-post-list,
  .sc-side-list {
    display: grid;
    gap: 12px;
  }

  .sc-attachment {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 14px 16px;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(241, 246, 252, 0.96) 0%, rgba(255, 244, 248, 0.96) 100%);
    border: 1px solid rgba(89, 106, 191, 0.12);
    color: #244563;
    font-weight: 700;
    text-decoration: none;
  }

  .sc-post-card {
    padding: 22px;
    border-radius: 28px;
    background: rgba(255,255,255,0.98);
    border: 1px solid rgba(148, 163, 184, 0.14);
    box-shadow: 0 18px 40px rgba(39, 62, 122, 0.10);
  }

  .sc-post-card h3 {
    margin: 12px 0 0;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    font-size: 1.44rem;
    letter-spacing: -0.04em;
    color: #1f344a;
  }

  .sc-post-meta,
  .sc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .sc-post-meta {
    margin-top: 14px;
  }

  .sc-actions {
    margin-top: 18px;
  }

  .sc-btn,
  .sc-btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    border-radius: 999px;
    font-weight: 800;
    text-decoration: none;
    cursor: pointer;
    border: 0;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .sc-btn {
    color: #f8fafc;
    background: linear-gradient(135deg, var(--sc-primary-strong) 0%, var(--sc-primary) 100%);
    box-shadow: 0 18px 32px rgba(47, 120, 237, 0.18);
  }

  .sc-btn-secondary {
    color: #1d4f8f;
    background: var(--sc-primary-soft);
    border: 1px solid rgba(89, 106, 191, 0.14);
  }

  .sc-btn:hover,
  .sc-btn-secondary:hover {
    transform: translateY(-2px);
  }

  .sc-form-grid {
    display: grid;
    gap: 14px;
  }

  .sc-label {
    font-weight: 700;
    color: #34506f;
  }

  .sc-input,
  .sc-textarea {
    width: 100%;
    min-height: 52px;
    padding: 0 16px;
    border-radius: 18px;
    border: 1px solid rgba(89, 106, 191, 0.12);
    background: #fff;
    color: #18324a;
    outline: none;
  }

  .sc-textarea {
    min-height: 120px;
    padding: 14px 16px;
    resize: vertical;
  }

  .sc-empty {
    padding: 22px;
    border-radius: 24px;
    border: 1px dashed rgba(89, 106, 191, 0.24);
    background: linear-gradient(180deg, rgba(248, 250, 252, 0.94) 0%, rgba(255, 244, 248, 0.94) 100%);
    color: var(--sc-ink-soft);
    text-align: center;
    line-height: 1.7;
  }

  @media (max-width: 1120px) {
    .sc-feed-layout,
    .sc-card-grid,
    .sc-grid.two,
    .sc-grid.three {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .sc-page {
      width: min(100% - 18px, 1480px);
      padding: 20px 0 28px;
    }

    .sc-hero,
    .sc-panel,
    .sc-card,
    .sc-post-card {
      border-radius: 24px;
      padding: 20px;
    }

    .sc-actions .sc-btn,
    .sc-actions .sc-btn-secondary {
      width: 100%;
    }
  }
</style>
