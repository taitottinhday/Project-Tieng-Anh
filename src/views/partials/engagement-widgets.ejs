<%
  const safeBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : '';
  const widgetScope = typeof scope !== 'undefined' ? scope : 'guest';
  const chatbotTitle = widgetScope === 'student' ? 'Trợ lý lớp học' : 'Trợ lý tư vấn';
%>

<style>
  .eng-fixed-stack {
    position: fixed;
    right: 18px;
    bottom: 24px;
    z-index: 80;
    display: grid;
    gap: 12px;
    align-items: end;
    justify-items: end;
    pointer-events: none;
  }

  .eng-fixed-left {
    position: fixed;
    left: 18px;
    bottom: 26px;
    z-index: 78;
    pointer-events: none;
  }

  .eng-phone,
  .eng-discount,
  .eng-chat-toggle,
  .eng-chat-send,
  .eng-chat-suggestion {
    border: 0;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
  }

  .eng-phone,
  .eng-chat-toggle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    box-shadow: 0 22px 34px rgba(38, 75, 130, 0.22);
  }

  .eng-phone {
    background: linear-gradient(135deg, #ff7a59 0%, #ff5d8f 100%);
    pointer-events: auto;
  }

  .eng-chat-toggle {
    background: linear-gradient(135deg, #2f78ed 0%, #5aa4ff 100%);
    pointer-events: auto;
  }

  .eng-phone:hover,
  .eng-chat-toggle:hover,
  .eng-discount:hover,
  .eng-chat-send:hover,
  .eng-chat-suggestion:hover {
    transform: translateY(-2px);
  }

  .eng-discount {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-height: 62px;
    padding: 0 18px;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(255, 122, 89, 0.96) 0%, rgba(255, 93, 143, 0.96) 100%);
    color: #fff;
    box-shadow: 0 22px 34px rgba(255, 93, 143, 0.22);
    pointer-events: auto;
  }

  .eng-discount strong {
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    font-size: 1rem;
    letter-spacing: -0.04em;
  }

  .eng-discount span {
    display: block;
    font-size: 0.84rem;
    opacity: 0.92;
  }

  .eng-chat-panel {
    width: min(380px, calc(100vw - 28px));
    border-radius: 28px;
    border: 1px solid rgba(120, 152, 205, 0.18);
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 28px 64px rgba(53, 92, 153, 0.16);
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px) scale(0.98);
    transform-origin: bottom right;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .eng-chat-panel.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .eng-chat-head {
    padding: 18px 18px 16px;
    background: linear-gradient(135deg, #2f78ed 0%, #ff7a59 100%);
    color: #fff;
  }

  .eng-chat-head strong {
    display: block;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    font-size: 1.2rem;
    letter-spacing: -0.04em;
  }

  .eng-chat-head span {
    display: block;
    margin-top: 8px;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.88);
  }

  .eng-chat-body {
    padding: 16px;
    max-height: 360px;
    overflow: auto;
    display: grid;
    gap: 12px;
    background: linear-gradient(180deg, rgba(248,251,255,0.96), rgba(255,246,250,0.96));
  }

  .eng-chat-msg {
    max-width: 90%;
    padding: 12px 14px;
    border-radius: 18px;
    line-height: 1.7;
    font-size: 0.94rem;
  }

  .eng-chat-msg.bot {
    background: rgba(233, 243, 255, 0.92);
    color: #173f73;
    border-bottom-left-radius: 8px;
  }

  .eng-chat-msg.user {
    margin-left: auto;
    background: linear-gradient(135deg, #2f78ed 0%, #5aa4ff 100%);
    color: #fff;
    border-bottom-right-radius: 8px;
  }

  .eng-chat-suggestions {
    padding: 0 16px 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    background: linear-gradient(180deg, rgba(248,251,255,0.96), rgba(255,246,250,0.96));
  }

  .eng-chat-suggestion {
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(47, 120, 237, 0.08);
    color: #18416e;
    font-weight: 700;
  }

  .eng-chat-form {
    padding: 14px 16px 16px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    border-top: 1px solid rgba(120, 152, 205, 0.14);
    background: #fff;
  }

  .eng-chat-input {
    min-height: 48px;
    padding: 0 16px;
    border-radius: 16px;
    border: 1px solid rgba(120, 152, 205, 0.16);
    outline: none;
    color: #18324a;
  }

  .eng-chat-send {
    min-width: 96px;
    border-radius: 16px;
    background: linear-gradient(135deg, #2f78ed 0%, #5aa4ff 100%);
    color: #fff;
    font-weight: 800;
    pointer-events: auto;
  }

  @media (max-width: 1024px) {
    .eng-fixed-left {
      display: none;
    }

    .eng-fixed-stack {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .eng-fixed-left {
      left: 12px;
      bottom: 18px;
    }

    .eng-discount {
      min-height: 56px;
      padding: 0 16px;
    }
  }
</style>

<div class="eng-fixed-left">
  <a href="<%= safeBaseUrl %>/<%= widgetScope === 'student' ? 'student/courses' : 'courses-blog' %>" class="eng-discount">
    <div>
      <strong>Giảm 25% khóa học</strong>
      <span>Ưu đãi cố định cho <%= widgetScope === 'student' ? 'học viên' : 'khách truy cập' %></span>
    </div>
  </a>
</div>

<div class="eng-fixed-stack">
  <div class="eng-chat-panel" id="engChatPanel">
    <div class="eng-chat-head">
      <strong><%= chatbotTitle %></strong>
      <span>Hỏi nhanh về học phí, lịch khai giảng, đăng ký Gmail + OTP, bài tập, nộp bài hoặc gọi tổng đài 0344772436.</span>
    </div>
    <div class="eng-chat-body" id="engChatBody">
      <div class="eng-chat-msg bot">Chào bạn. Tôi có thể tư vấn ngay về khóa học, lịch khai giảng, đăng ký Gmail thật + OTP, bài tập và cách liên hệ tổng đài.</div>
    </div>
    <div class="eng-chat-suggestions" id="engChatSuggestions">
      <button type="button" class="eng-chat-suggestion">Học phí</button>
      <button type="button" class="eng-chat-suggestion">Lịch khai giảng</button>
      <button type="button" class="eng-chat-suggestion">Đăng ký Gmail</button>
    </div>
    <form class="eng-chat-form" id="engChatForm">
      <input class="eng-chat-input" id="engChatInput" type="text" placeholder="Nhập câu hỏi..." autocomplete="off">
      <button class="eng-chat-send" type="submit">Gửi</button>
    </form>
  </div>

  <a href="tel:0344772436" class="eng-phone" aria-label="Gọi tổng đài ngay">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.9v3a2 2 0 0 1-2.2 2A19.8 19.8 0 0 1 11.2 19a19.4 19.4 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7l.5 3a2 2 0 0 1-.6 1.8L7.7 9.8a16 16 0 0 0 6.4 6.4l1.3-1.3a2 2 0 0 1 1.8-.6l3 .5A2 2 0 0 1 22 16.9Z"></path>
    </svg>
  </a>

  <button type="button" class="eng-chat-toggle" id="engChatToggle" aria-label="Mở chatbot tư vấn">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15a3 3 0 0 1-3 3H7l-4 3V6a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3z"></path>
      <path d="M8 9h8"></path>
      <path d="M8 13h5"></path>
    </svg>
  </button>
</div>

<script>
  (() => {
    const panel = document.getElementById('engChatPanel');
    const toggle = document.getElementById('engChatToggle');
    const form = document.getElementById('engChatForm');
    const input = document.getElementById('engChatInput');
    const body = document.getElementById('engChatBody');
    const suggestionWrap = document.getElementById('engChatSuggestions');
    const apiUrl = '<%= safeBaseUrl %>/chatbot/respond';

    if (!panel || !toggle || !form || !input || !body || !suggestionWrap) {
      return;
    }

    const appendMessage = (role, text) => {
      const node = document.createElement('div');
      node.className = `eng-chat-msg ${role}`;
      node.textContent = text;
      body.appendChild(node);
      body.scrollTop = body.scrollHeight;
    };

    const setSuggestions = (items) => {
      suggestionWrap.innerHTML = '';
      (items || []).slice(0, 3).forEach((item) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'eng-chat-suggestion';
        button.textContent = item;
        button.addEventListener('click', () => {
          input.value = item;
          form.requestSubmit();
        });
        suggestionWrap.appendChild(button);
      });
    };

    const askBot = async (message) => {
      appendMessage('user', message);

      try {
        const response = await fetch(apiUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message }),
        });

        if (!response.ok) {
          throw new Error('request_failed');
        }

        const payload = await response.json();
        appendMessage('bot', payload.answer || 'Tôi chưa xử lý được yêu cầu này lúc này.');
        setSuggestions(payload.suggestions || []);
      } catch (error) {
        appendMessage('bot', 'Hệ thống tư vấn tạm thời bị gián đoạn. Bạn có thể gọi ngay 0344772436 để được hỗ trợ.');
      }
    };

    toggle.addEventListener('click', () => {
      panel.classList.toggle('is-open');
      if (panel.classList.contains('is-open')) {
        input.focus();
      }
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const message = input.value.trim();

      if (!message) {
        return;
      }

      input.value = '';
      await askBot(message);
    });

    suggestionWrap.querySelectorAll('.eng-chat-suggestion').forEach((button) => {
      button.addEventListener('click', () => {
        input.value = button.textContent.trim();
        form.requestSubmit();
      });
    });
  })();
</script>
