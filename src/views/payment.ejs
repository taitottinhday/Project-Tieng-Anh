<%
const safeBaseUrl = typeof baseUrl !== "undefined" ? baseUrl : "";
const paymentInfo = typeof info !== "undefined" && info ? info : {};
const coursePricing = typeof pricing !== "undefined" && pricing ? pricing : {};
const discountRate = Number(typeof discountRatePercent !== "undefined" ? discountRatePercent : 25);
const originalValue = Number(typeof originalAmount !== "undefined" ? originalAmount : 0);
const discountedValue = Number(typeof amount !== "undefined" ? amount : 0);
const courseLabel = coursePricing.displayTitle || paymentInfo.course_name || "Khóa học";
const otherCoursesHref = typeof browseCoursesHref !== "undefined" && browseCoursesHref
  ? browseCoursesHref
  : `${safeBaseUrl}/courses-blog`;

function formatMoney(value) {
  return `${Number(value || 0).toLocaleString("vi-VN")} đ`;
}
%>

<style>
  .pay-page {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 24px 0 40px;
    display: grid;
    gap: 22px;
  }

  .pay-card,
  .pay-grid > section {
    border-radius: 30px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 22px 42px rgba(15, 23, 42, 0.08);
  }

  .pay-card {
    padding: 30px;
    display: grid;
    gap: 18px;
  }

  .pay-card h1,
  .pay-section-title,
  .pay-summary strong {
    margin: 0;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    letter-spacing: -0.05em;
    color: #173f73;
  }

  .pay-card h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.04;
  }

  .pay-lead,
  .pay-meta-row span,
  .pay-note,
  .pay-bank p,
  .pay-qr p {
    margin: 0;
    color: #58708f;
    line-height: 1.75;
  }

  .pay-success {
    padding: 16px 18px;
    border-radius: 18px;
    background: rgba(22, 163, 74, 0.12);
    border: 1px solid rgba(22, 163, 74, 0.14);
    color: #166534;
    font-weight: 700;
  }

  .pay-summary {
    display: grid;
    gap: 10px;
    padding: 20px 22px;
    border-radius: 24px;
    background: linear-gradient(135deg, rgba(239, 246, 255, 0.96) 0%, rgba(255, 244, 214, 0.92) 100%);
    border: 1px solid rgba(37, 99, 235, 0.10);
  }

  .pay-summary strong {
    font-size: 1.22rem;
  }

  .pay-meta {
    display: grid;
    gap: 10px;
  }

  .pay-meta-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  }

  .pay-meta-row:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .pay-price-original {
    color: #7c8598;
    font-size: 1rem;
    text-decoration: line-through;
    text-decoration-thickness: 2px;
  }

  .pay-price-discounted {
    color: #0f172a;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    font-size: clamp(2.1rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .pay-discount-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(249, 115, 22, 0.14);
    color: #c2410c;
    font-size: 0.9rem;
    font-weight: 800;
  }

  .pay-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr);
    gap: 20px;
  }

  .pay-bank,
  .pay-qr {
    padding: 24px;
    display: grid;
    gap: 14px;
  }

  .pay-section-title {
    font-size: 1.34rem;
  }

  .pay-transfer-code {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 46px;
    padding: 0 16px;
    border-radius: 14px;
    background: #111827;
    color: #fde68a;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-weight: 800;
  }

  .pay-qr img {
    width: min(100%, 320px);
    margin: 0 auto;
    border-radius: 18px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: #fff;
  }

  .pay-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .pay-btn,
  .pay-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 20px;
    border-radius: 999px;
    border: 0;
    font: inherit;
    font-weight: 800;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .pay-btn:hover,
  .pay-link:hover {
    transform: translateY(-1px);
  }

  .pay-btn {
    background: linear-gradient(135deg, #2563eb 0%, #60a5fa 100%);
    color: #fff;
    box-shadow: 0 18px 28px rgba(37, 99, 235, 0.20);
  }

  .pay-link.secondary {
    background: #111827;
    color: #fff;
  }

  .pay-link.ghost {
    background: rgba(37, 99, 235, 0.08);
    color: #173f73;
    border: 1px solid rgba(37, 99, 235, 0.10);
  }

  @media (max-width: 960px) {
    .pay-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="pay-page">
  <section class="pay-card">
    <h1>Thanh toán chuyển khoản</h1>
    <p class="pay-lead">Số tiền bên dưới đã là mức học phí thực đóng sau ưu đãi học viên. Bạn chỉ cần chuyển đúng số tiền và nội dung để trung tâm đối soát nhanh.</p>

    <% if (success) { %>
      <div class="pay-success">Bạn đã gửi xác nhận thanh toán thành công. Trung tâm sẽ kiểm tra giao dịch, sau đó mới thêm bạn vào lớp và gửi thông báo về tài khoản học viên.</div>
    <% } %>

    <div class="pay-summary">
      <strong><%= courseLabel %></strong>
      <div class="pay-meta">
        <div class="pay-meta-row">
          <span>Học viên</span>
          <span><%= paymentInfo.student_name || "Học viên" %> (<%= paymentInfo.student_phone || "Chưa có số điện thoại" %>)</span>
        </div>
        <div class="pay-meta-row">
          <span>Lớp</span>
          <span><%= paymentInfo.class_code || "Đang cập nhật" %></span>
        </div>
      </div>

      <span class="pay-price-original"><%= formatMoney(originalValue) %></span>
      <span class="pay-price-discounted"><%= formatMoney(discountedValue) %></span>
      <span class="pay-discount-chip">Giảm <%= discountRate %>% cho học viên đăng ký online</span>
      <p class="pay-note">Giá niêm yết vẫn được giữ để học viên thấy rõ phần ưu đãi, còn QR và xác nhận thanh toán đều dùng đúng số tiền sau giảm.</p>
    </div>
  </section>

  <div class="pay-grid">
    <section class="pay-bank">
      <h2 class="pay-section-title">Thông tin chuyển khoản</h2>
      <p>Ngân hàng: <strong><%= bank.bankCode %></strong></p>
      <p>Số tài khoản: <strong><%= bank.accountNumber %></strong></p>
      <p>Chủ tài khoản: <strong><%= bank.accountName %></strong></p>
      <p>Nội dung chuyển khoản:</p>
      <span class="pay-transfer-code"><%= content %></span>
      <p class="pay-note">Vui lòng ghi đúng nội dung để hệ thống đối soát nhanh hơn.</p>
    </section>

    <section class="pay-qr">
      <h2 class="pay-section-title">Quét QR để thanh toán</h2>
      <img src="<%= vietqrUrl %>" alt="QR thanh toán khóa học">
      <p>QR này đã chứa sẵn số tiền <strong><%= formatMoney(discountedValue) %></strong> và nội dung chuyển khoản.</p>
    </section>
  </div>

  <section class="pay-card">
    <div class="pay-actions">
      <form method="POST" action="<%= safeBaseUrl %>/payment/<%= paymentInfo.enrollment_id %>/confirm">
        <input type="hidden" name="token" value="<%= paymentToken %>">
        <input type="hidden" name="course_key" value="<%= typeof courseKey !== 'undefined' ? courseKey : '' %>">
        <input type="hidden" name="method" value="bank">
        <button class="pay-btn" type="submit">Tôi đã chuyển khoản</button>
      </form>

      <a href="<%= safeBaseUrl %>/" class="pay-link secondary">Về trang chủ</a>
      <a href="<%= otherCoursesHref %>" class="pay-link ghost">Xem khóa học khác</a>
    </div>
  </section>
 </div>
