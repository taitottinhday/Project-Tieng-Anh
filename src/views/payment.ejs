<div class="max-w-3xl mx-auto space-y-6">

    <h1 class="text-3xl font-bold">Thanh toán chuyển khoản</h1>

    <% if (success) { %>
        <div class="bg-green-900/40 border border-green-500 text-green-300 px-4 py-3 rounded-xl">
            Bạn đã gửi xác nhận thanh toán thành công. Trung tâm sẽ kiểm tra và xác nhận sớm.
        </div>
        <% } %>

            <div class="bg-gray-800 p-6 rounded-xl space-y-4">

                <p class="text-gray-300">
                    Học viên:
                    <span class="font-semibold text-white">
                        <%= info.student_name %>
                    </span>
                    (<%= info.student_phone || 'N/A' %>)
                </p>

                <p class="text-gray-300">
                    Khóa học:
                    <span class="font-semibold text-white">
                        <%= info.course_name %>
                    </span>
                </p>

                <p class="text-gray-300">
                    Lớp:
                    <span class="font-semibold text-white">
                        <%= info.class_code %>
                    </span>
                </p>

                <hr class="border-gray-700 my-3" />

                <p class="text-gray-300">Số tiền cần thanh toán:</p>

                <p class="text-4xl font-bold text-green-400">
                    <%= Number(amount || 0).toLocaleString('vi-VN') %> đ
                </p>

                <!-- THÔNG TIN CHUYỂN KHOẢN -->
                <div class="grid md:grid-cols-2 gap-6 mt-4">

                    <div class="bg-gray-900 p-4 rounded-lg text-gray-100">
                        <p class="text-sm font-semibold text-gray-200 mb-2">Thông tin chuyển khoản</p>

                        <p>Ngân hàng:
                            <b>
                                <%= bank.bankCode %>
                            </b>
                        </p>

                        <p>STK:
                            <b>
                                <%= bank.accountNumber %>
                            </b>
                        </p>

                        <p>Chủ TK:
                            <b>
                                <%= bank.accountName %>
                            </b>
                        </p>

                        <p class="mt-3">Nội dung CK:</p>

                        <p class="bg-gray-800 inline-block px-3 py-2 rounded font-mono text-yellow-300">
                            <%= content %>
                        </p>

                        <p class="text-xs text-gray-300 mt-2">
                            * Vui lòng ghi đúng nội dung để hệ thống đối soát.
                        </p>
                    </div>

                    <!-- QR CODE -->
                    <div class="bg-gray-900 p-4 rounded-lg text-center text-gray-100">
                        <p class="text-sm font-semibold text-gray-200 mb-2">Quét QR để chuyển khoản</p>

                        <img src="<%= vietqrUrl %>" alt="VietQR" class="mx-auto rounded-lg border border-gray-700" />

                        <p class="text-xs text-gray-300 mt-2">
                            QR đã chứa sẵn số tiền và nội dung chuyển khoản.
                        </p>
                    </div>

                </div>

                <!-- BUTTONS -->
                <div class="flex flex-wrap gap-4 mt-6">

                    <!-- BUTTON XÁC NHẬN ĐÃ CHUYỂN KHOẢN -->
                    <form method="POST" action="<%= baseUrl %>/payment/<%= info.enrollment_id %>/confirm">
                        <input type="hidden" name="token" value="<%= paymentToken %>" />
                        <input type="hidden" name="amount" value="<%= amount %>" />
                        <input type="hidden" name="method" value="bank" />

                        <button class="px-5 py-3 rounded bg-blue-600 hover:bg-blue-500 font-semibold">
                            Tôi đã chuyển khoản (Chờ admin xác nhận)
                        </button>
                    </form>

                    <a href="<%= baseUrl %>/" class="px-5 py-3 rounded bg-gray-700 hover:bg-gray-600 font-semibold">
                        Về trang chủ
                    </a>

                    <a href="<%= baseUrl %>/courses-blog"
                        class="px-5 py-3 rounded bg-teal-700 hover:bg-teal-600 font-semibold">
                        Xem khóa học khác
                    </a>

                </div>

            </div>

</div>
