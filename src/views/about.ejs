<% const safeBaseUrl=typeof baseUrl !=='undefined' ? baseUrl : '' ; const
  heroImage='https://i.pinimg.com/1200x/b8/6e/4b/b86e4b0613c2f6e71d2427c38c9a0274.jpg' ;
  const materialsHeroImage='https://thaylongtoeic.com/wp-content/uploads/2023/11/tai-lieu-1446x1536.jpg.webp' ; const resultCards=[ { name: 'Tran Vu Hoang' , score: '780 TOEIC LR' ,
  image: 'https://thaylongtoeic.com/wp-content/uploads/2026/03/ac023-768x691.jpg.webp' , placeholder: 'Ảnh học viên 01'
  }, { name: 'Nguyen Minh Tri' , score: '918 TOEIC LR' , image: 'https://thaylongtoeic.com/wp-content/uploads/2026/03/ac022-768x691.jpg' , placeholder: 'Ảnh học viên 02' }, {
  name: 'Dao Phuong Chi' , score: '820 TOEIC LR' , image: 'https://thaylongtoeic.com/wp-content/uploads/2026/03/ac020-768x691.jpg' , placeholder: 'Ảnh học viên 03' }, {
