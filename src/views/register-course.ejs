<%
const safeBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : '';
const safeCourses = Array.isArray(courses) ? courses : [];
%>

<style>
  .gr-page{display:grid;gap:28px}
  .gr-hero{padding:34px;border-radius:32px;background:linear-gradient(135deg,#eff6ff 0%,#ffffff 52%,#dbeafe 100%);border:1px solid rgba(37,99,235,.12);box-shadow:0 24px 46px rgba(37,99,235,.10)}
  .gr-hero h1{margin:0;font-family:"Sora","Be Vietnam Pro",sans-serif;font-size:clamp(2.1rem,5vw,3.8rem);letter-spacing:-.05em;line-height:1.03;color:#102a43}
  .gr-hero p{margin:16px 0 0;max-width:820px;color:#4b6382;line-height:1.9}
  .gr-grid{display:grid;grid-template-columns:minmax(0,.85fr) minmax(0,1.15fr);gap:20px}
  .gr-side,.gr-form{padding:26px;border-radius:30px;background:#fff;border:1px solid rgba(37,99,235,.10);box-shadow:0 18px 34px rgba(15,23,42,.05)}
  .gr-side h2,.gr-form h2{margin:0 0 14px;font-family:"Sora","Be Vietnam Pro",sans-serif;font-size:1.55rem;letter-spacing:-.04em;color:#173f73}
  .gr-side p,.gr-form p{margin:0;color:#58708f;line-height:1.8}
  .gr-points{margin-top:20px;display:grid;gap:14px}
  .gr-point{padding:16px;border-radius:20px;background:#f7fbff;border:1px solid rgba(37,99,235,.08)}
  .gr-point strong{display:block;color:#102a43}
  .gr-point span{display:block;margin-top:6px;color:#58708f;line-height:1.75}
  .gr-form-grid{margin-top:22px;display:grid;gap:16px}
  .gr-field{display:grid;gap:8px}
  .gr-field label{font-size:.94rem;font-weight:700;color:#365278}
  .gr-field input,.gr-field select{width:100%;min-height:52px;padding:0 16px;border-radius:18px;border:1px solid rgba(37,99,235,.12);background:#fff;color:#102a43;outline:none;transition:border-color .2s ease,box-shadow .2s ease}
  .gr-field input:focus,.gr-field select:focus{border-color:rgba(37,99,235,.34);box-shadow:0 0 0 4px rgba(37,99,235,.08)}
  .gr-btn{display:inline-flex;align-items:center;justify-content:center;min-height:52px;padding:0 20px;border-radius:999px;border:0;background:linear-gradient(135deg,#60a5fa 0%,#2563eb 100%);color:#fff;font-weight:800;cursor:pointer;box-shadow:0 18px 30px rgba(37,99,235,.24);transition:.2s ease}
  .gr-btn:hover{transform:translateY(-1px)}
  .gr-note{padding:16px 18px;border-radius:20px;background:rgba(37,99,235,.08);border:1px solid rgba(37,99,235,.12);color:#1d4ed8;font-weight:700}
  @media (max-width:980px){.gr-grid{grid-template-columns:1fr}}
</style>

<div class="gr-page">
  <section class="gr-hero">
    <h1>Đăng ký khóa học TOEIC.</h1>
    <p>
      Điền thông tin và chọn khóa học phù hợp. Sau khi gửi đăng ký, hệ thống sẽ đưa bạn đến bước tiếp theo
      để hoàn tất quy trình.
    </p>
  </section>

  <section class="gr-grid">
    <article class="gr-side">
      <h2>Quy trình đăng ký</h2>
      <p>Chỉ cần điền thông tin cần thiết, hệ thống sẽ tạo đăng ký và chuyển bạn sang bước tiếp theo.</p>
      <div class="gr-points">
        <div class="gr-point">
          <strong>Bước 1</strong>
          <span>Chọn khóa học và điền thông tin liên hệ.</span>
        </div>
        <div class="gr-point">
          <strong>Bước 2</strong>
          <span>Hệ thống tạo đăng ký cho học viên mới.</span>
        </div>
        <div class="gr-point">
          <strong>Bước 3</strong>
          <span>Bạn được chuyển đến trang thanh toán để hoàn tất.</span>
        </div>
      </div>
    </article>

    <article class="gr-form">
      <h2>Thông tin đăng ký</h2>
      <p>Nếu bạn chưa chắc nên chọn khóa học nào, hãy quay sang trang liên hệ để nhận tư vấn trước.</p>

      <% if (typeof message !== 'undefined' && message) { %>
        <div class="gr-note"><%= message %></div>
      <% } %>

      <form method="POST" action="<%= safeBaseUrl %>/register-course" class="gr-form-grid">
        <div class="gr-field">
          <label>Họ và tên</label>
          <input type="text" name="full_name" placeholder="Nhập họ và tên" required>
        </div>

        <div class="gr-field">
          <label>Số điện thoại</label>
          <input type="text" name="phone" placeholder="Nhập số điện thoại" required>
        </div>

        <div class="gr-field">
          <label>Email</label>
          <input type="email" name="email" placeholder="Nhập email">
        </div>

        <div class="gr-field">
          <label>Chọn khóa học</label>
          <select name="course_id" required>
            <option value="">Chọn khóa học</option>
            <% safeCourses.forEach((course) => { %>
              <option value="<%= course.id %>"><%= course.name %></option>
            <% }) %>
          </select>
        </div>

        <button class="gr-btn" type="submit">Tiếp tục đăng ký</button>
      </form>
    </article>
  </section>
</div>
