<%
const safeBaseUrl = typeof baseUrl !== "undefined" ? baseUrl : "";
const options = Array.isArray(typeof courseOptions !== "undefined" ? courseOptions : null) ? courseOptions : [];
const values = typeof formValues !== "undefined" && formValues ? formValues : {};
const selected = typeof selectedCourse !== "undefined" && selectedCourse ? selectedCourse : null;
const selectedKey = selected && selected.courseKey
  ? selected.courseKey
  : String(typeof selectedCourseKey !== "undefined" ? selectedCourseKey : "").trim();
const discountRate = Number(typeof discountRatePercent !== "undefined" ? discountRatePercent : 25);
const blocker = typeof registrationBlocker !== "undefined" && registrationBlocker ? registrationBlocker : null;

function formatMoney(value) {
  return `${Number(value || 0).toLocaleString("vi-VN")}đ`;
}
%>

<style>
  .gr-page {
    display: grid;
    gap: 26px;
  }

  .gr-hero,
  .gr-grid > article {
    border-radius: 32px;
    border: 1px solid rgba(37, 99, 235, 0.10);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 22px 42px rgba(15, 23, 42, 0.07);
  }

  .gr-hero {
    padding: 34px;
    background:
      radial-gradient(circle at top right, rgba(191, 219, 254, 0.52), transparent 28%),
      linear-gradient(135deg, rgba(239, 246, 255, 0.96) 0%, rgba(255, 255, 255, 0.96) 55%, rgba(219, 234, 254, 0.9) 100%);
  }

  .gr-hero h1,
  .gr-side h2,
  .gr-form h2,
  .gr-summary h3 {
    margin: 0;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    letter-spacing: -0.05em;
    color: #173f73;
  }

  .gr-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.7rem);
    line-height: 1.02;
  }

  .gr-hero p {
    margin: 14px 0 0;
    max-width: 820px;
    color: #58708f;
    line-height: 1.85;
  }

  .gr-grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.84fr) minmax(0, 1.16fr);
    gap: 22px;
  }

  .gr-side,
  .gr-form {
    padding: 28px;
  }

  .gr-side {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .gr-side h2,
  .gr-form h2 {
    font-size: 1.58rem;
  }

  .gr-side p,
  .gr-form p,
  .gr-point span,
  .gr-summary-note,
  .gr-summary-empty {
    margin: 0;
    color: #58708f;
    line-height: 1.8;
  }

  .gr-points {
    display: grid;
    gap: 14px;
  }

  .gr-point {
    padding: 16px 18px;
    border-radius: 22px;
    background: #f7fbff;
    border: 1px solid rgba(37, 99, 235, 0.08);
  }

  .gr-point strong {
    display: block;
    color: #173f73;
    font-size: 1rem;
  }

  .gr-form {
    display: grid;
    gap: 22px;
  }

  .gr-note {
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(37, 99, 235, 0.08);
    border: 1px solid rgba(37, 99, 235, 0.12);
    color: #1d4ed8;
    font-weight: 700;
  }

  .gr-summary {
    display: grid;
    gap: 10px;
    padding: 18px 20px;
    border-radius: 24px;
    background: linear-gradient(135deg, rgba(239, 246, 255, 0.96) 0%, rgba(255, 244, 214, 0.92) 100%);
    border: 1px solid rgba(37, 99, 235, 0.10);
  }

  .gr-summary h3 {
    font-size: 1.18rem;
  }

  .gr-summary-title {
    color: #102a43;
    font-size: 1.15rem;
    font-weight: 800;
  }

  .gr-price-stack {
    display: grid;
    gap: 4px;
  }

  .gr-price-original {
    color: #7c8598;
    font-size: 1rem;
    text-decoration: line-through;
    text-decoration-thickness: 2px;
  }

  .gr-price-discounted {
    color: #0f172a;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    font-size: clamp(1.7rem, 3vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.05em;
  }

  .gr-price-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(249, 115, 22, 0.14);
    color: #c2410c;
    font-size: 0.9rem;
    font-weight: 800;
  }

  .gr-form-grid {
    display: grid;
    gap: 16px;
  }

  .gr-field {
    display: grid;
    gap: 8px;
  }

  .gr-field label {
    font-size: 0.95rem;
    font-weight: 800;
    color: #365278;
  }

  .gr-field input,
  .gr-field select {
    width: 100%;
    min-height: 54px;
    padding: 0 18px;
    border-radius: 20px;
    border: 1px solid rgba(37, 99, 235, 0.12);
    background: #fff;
    color: #102a43;
    outline: none;
    font: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .gr-field input:focus,
  .gr-field select:focus {
    border-color: rgba(37, 99, 235, 0.32);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.08);
  }

  .gr-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 56px;
    padding: 0 22px;
    border: 0;
    border-radius: 999px;
    background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%);
    color: #fff;
    font-size: 1rem;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 18px 30px rgba(37, 99, 235, 0.22);
    transition: transform 0.2s ease;
  }

  .gr-btn:hover {
    transform: translateY(-1px);
  }

  .gr-blocker {
    display: grid;
    gap: 16px;
    padding: 22px;
    border-radius: 24px;
    border: 1px solid rgba(245, 158, 11, 0.18);
    background: linear-gradient(135deg, rgba(255, 251, 235, 0.96) 0%, rgba(255, 255, 255, 0.98) 100%);
  }

  .gr-blocker-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .gr-blocker-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(245, 158, 11, 0.14);
    color: #b45309;
    font-size: 0.84rem;
    font-weight: 800;
  }

  .gr-blocker h3 {
    margin: 0;
    color: #0f172a;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    font-size: 1.24rem;
    letter-spacing: -0.03em;
  }

  .gr-blocker p,
  .gr-blocker li {
    margin: 0;
    color: #5b6475;
    line-height: 1.75;
  }

  .gr-blocker ul {
    margin: 0;
    padding-left: 18px;
    display: grid;
    gap: 8px;
  }

  .gr-blocker-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .gr-link-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 20px;
    border-radius: 999px;
    font-weight: 800;
  }

  .gr-link-btn.primary {
    background: #111827;
    color: #fff;
  }

  .gr-link-btn.soft {
    background: rgba(37, 99, 235, 0.08);
    color: #1d4ed8;
  }

  @media (max-width: 980px) {
    .gr-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="gr-page">
  <section class="gr-hero">
    <h1>Đăng ký khóa học TOEIC</h1>
    <p>
      Chọn đúng khóa bạn vừa quan tâm và hệ thống sẽ tự giữ sẵn ưu đãi giảm <%= discountRate %>%.
      Sau khi gửi đăng ký, bạn sẽ được chuyển ngay sang bước thanh toán với số tiền thực đóng đã được cập nhật.
    </p>
  </section>

  <section class="gr-grid">
    <article class="gr-side">
      <div>
        <h2>Quy trình đăng ký</h2>
        <p>Điền thông tin liên hệ, xác nhận khóa học rồi tiếp tục sang trang thanh toán để hoàn tất đăng ký.</p>
      </div>

      <div class="gr-points">
        <div class="gr-point">
          <strong>Bước 1</strong>
          <span>Chọn khóa học muốn tham gia. Nếu bạn vừa bấm từ trang khóa học, lựa chọn này đã được chọn sẵn.</span>
        </div>
        <div class="gr-point">
          <strong>Bước 2</strong>
          <span>Hệ thống lưu thông tin học viên và tạo đăng ký vào lớp phù hợp của khóa học đó.</span>
        </div>
        <div class="gr-point">
          <strong>Bước 3</strong>
          <span>Trang payment sẽ tự dùng số tiền sau ưu đãi <%= discountRate %>% để học viên thanh toán đúng thực tế.</span>
        </div>
      </div>
    </article>

    <article class="gr-form">
      <div>
        <h2>Thông tin đăng ký</h2>
        <p>Bạn có thể chỉnh lại khóa học ngay tại đây, giá niêm yết và giá sau giảm sẽ cập nhật tức thì.</p>
      </div>

      <% if (typeof message !== "undefined" && message) { %>
        <div class="gr-note"><%= message %></div>
      <% } %>

      <% if (blocker) { %>
        <section class="gr-blocker">
          <div class="gr-blocker-top">
            <span class="gr-blocker-badge"><%= blocker.statusLabel %></span>
            <span class="gr-summary-note">Mỗi học viên chỉ mở tối đa 1 lớp tại một thời điểm</span>
          </div>
          <h3><%= blocker.title %></h3>
          <p><%= blocker.message %></p>
          <ul>
            <li><strong>Khóa học:</strong> <%= blocker.courseName %></li>
            <li><strong>Lớp hiện tại:</strong> <%= blocker.classCode %></li>
            <li><strong>Giáo viên:</strong> <%= blocker.teacherName %></li>
            <li><strong>Lịch học:</strong> <%= blocker.scheduleText %></li>
          </ul>
          <div class="gr-blocker-actions">
            <a href="<%= safeBaseUrl %><%= blocker.actionHref %>" class="gr-link-btn primary"><%= blocker.actionLabel %></a>
            <a href="<%= safeBaseUrl %><%= blocker.secondaryHref %>" class="gr-link-btn soft"><%= blocker.secondaryLabel %></a>
          </div>
        </section>
      <% } %>

      <section class="gr-summary" id="courseSummary">
        <h3>Khóa học bạn đang chọn</h3>
        <div class="gr-summary-title" id="courseSummaryTitle"><%= selected ? selected.optionLabel : "Chưa chọn khóa học" %></div>
        <div class="gr-price-stack" id="courseSummaryPrice" <%= selected ? "" : "hidden" %>>
          <span class="gr-price-original" id="courseSummaryOriginal"><%= selected ? formatMoney(selected.originalFee) : "" %></span>
          <strong class="gr-price-discounted" id="courseSummaryDiscounted"><%= selected ? formatMoney(selected.discountedFee) : "" %></strong>
          <span class="gr-summary-note">Số tiền thực đóng sau giảm <%= discountRate %>%</span>
        </div>
        <span class="gr-price-badge">Ưu đãi học viên: giảm <%= discountRate %>%</span>
        <p class="gr-summary-empty" id="courseSummaryEmpty" <%= selected ? "hidden" : "" %>>
          Chọn một khóa học để hệ thống hiển thị ngay mức học phí thực cần thanh toán.
        </p>
      </section>

      <% if (!blocker) { %>
        <form method="POST" action="<%= safeBaseUrl %>/register-course" class="gr-form-grid" id="registerCourseForm">
          <input type="hidden" name="course_key" id="selectedCourseKey" value="<%= selectedKey %>">

          <div class="gr-field">
            <label>Họ và tên</label>
            <input type="text" name="full_name" placeholder="Nhập họ và tên" value="<%= values.fullName || "" %>" required>
          </div>

          <div class="gr-field">
            <label>Số điện thoại</label>
            <input type="text" name="phone" placeholder="Nhập số điện thoại" value="<%= values.phone || "" %>" required>
          </div>

          <div class="gr-field">
            <label>Email</label>
            <input type="email" name="email" placeholder="Nhập email" value="<%= values.email || "" %>">
          </div>

          <div class="gr-field">
            <label>Chọn khóa học</label>
            <select name="course_id" id="courseSelect" required>
              <option value="">Chọn khóa học</option>
              <% options.forEach((course) => { %>
                <option
                  value="<%= course.id %>"
                  data-course-key="<%= course.courseKey || "" %>"
                  data-display-label="<%= course.optionLabel %>"
                  data-original-fee="<%= Number(course.originalFee || 0) %>"
                  data-discounted-fee="<%= Number(course.discountedFee || 0) %>"
                  <%= selectedKey && selectedKey === (course.courseKey || "") ? "selected" : "" %>>
                  <%= course.optionLabel %>
                </option>
              <% }) %>
            </select>
          </div>

          <button class="gr-btn" type="submit">Tiếp tục đăng ký</button>
        </form>
      <% } %>
    </article>
  </section>
</div>

<script>
  (() => {
    const select = document.getElementById("courseSelect");
    const hiddenCourseKey = document.getElementById("selectedCourseKey");
    const title = document.getElementById("courseSummaryTitle");
    const priceWrap = document.getElementById("courseSummaryPrice");
    const original = document.getElementById("courseSummaryOriginal");
    const discounted = document.getElementById("courseSummaryDiscounted");
    const empty = document.getElementById("courseSummaryEmpty");

    if (!select || !hiddenCourseKey || !title || !priceWrap || !original || !discounted || !empty) {
      return;
    }

    const formatMoney = (value) => `${Number(value || 0).toLocaleString("vi-VN")}đ`;

    const syncSummary = () => {
      const option = select.options[select.selectedIndex];
      const courseId = String(select.value || "").trim();

      if (!option || !courseId) {
        hiddenCourseKey.value = "";
        title.textContent = "Chưa chọn khóa học";
        original.textContent = "";
        discounted.textContent = "";
        priceWrap.hidden = true;
        empty.hidden = false;
        return;
      }

      hiddenCourseKey.value = option.dataset.courseKey || "";
      title.textContent = option.dataset.displayLabel || option.textContent.trim();
      original.textContent = formatMoney(option.dataset.originalFee || 0);
      discounted.textContent = formatMoney(option.dataset.discountedFee || 0);
      priceWrap.hidden = false;
      empty.hidden = true;
    };

    select.addEventListener("change", syncSummary);
    syncSummary();
  })();
</script>
