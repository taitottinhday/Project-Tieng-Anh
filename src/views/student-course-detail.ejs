<%
const detail = course || {};
const safeBaseUrl = typeof baseUrl !== "undefined" ? baseUrl : "";
const activeTab = activeCourseTab === "comments" ? "comments" : "content";
const comments = Array.isArray(courseComments) ? courseComments : [];
const commenterName = user && user.username ? user.username : "Học viên";
const commenterAvatar = String(commenterName || "H").trim().charAt(0).toUpperCase() || "H";
const commentSuccessMessage = typeof commentSuccess !== "undefined" && commentSuccess
  ? "Đã gửi bình luận thành công."
  : "";
const commentErrorMessage = typeof commentError !== "undefined" ? commentError : "";

function formatCommentDate(value) {
  if (!value) return "";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return "";
  return date.toLocaleDateString("vi-VN");
}
%>

<style>
  .scd-page {
    width: min(1480px, calc(100% - 32px));
    margin: 0 auto;
    padding: 24px 0 44px;
    display: grid;
    gap: 20px;
  }

  .scd-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: #667085;
    font-size: 0.95rem;
  }

  .scd-breadcrumb a {
    color: #475467;
    text-decoration: none;
  }

  .scd-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.72fr) minmax(470px, 0.96fr);
    gap: 24px;
    align-items: stretch;
  }

  .scd-panel,
  .scd-side {
    border-radius: 28px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 22px 48px rgba(15, 23, 42, 0.08);
  }

  .scd-panel {
    padding: 34px;
  }

  .scd-side {
    padding: 16px;
    display: grid;
    grid-template-rows: auto auto 1fr;
    align-content: start;
    gap: 16px;
    height: 100%;
  }

  .scd-head {
    display: grid;
    gap: 14px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  }

  .scd-head h1,
  .scd-sidebar-title,
  .scd-content h2,
  .scd-comment-title,
  .scd-empty strong {
    margin: 0;
    font-family: "Sora", "Be Vietnam Pro", sans-serif;
    letter-spacing: -0.05em;
    color: #344054;
  }

  .scd-head h1 {
    font-size: clamp(2rem, 3.6vw, 3.3rem);
    line-height: 1.04;
  }

  .scd-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    color: #667085;
    font-size: 0.98rem;
  }

  .scd-meta span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .scd-tabs {
    display: flex;
    gap: 12px;
    padding-top: 20px;
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  }

  .scd-tab {
    display: inline-flex;
    align-items: center;
    min-height: 46px;
    padding: 0 18px;
    border-bottom: 3px solid transparent;
    color: #667085;
    font-weight: 700;
    text-decoration: none;
  }

  .scd-tab.is-active {
    color: #1f2937;
    border-bottom-color: #2f2f34;
  }

  .scd-content {
    padding-top: 22px;
    display: grid;
    gap: 22px;
  }

  .scd-content h2,
  .scd-comment-title {
    font-size: 1.5rem;
  }

  .scd-content p,
  .scd-content li,
  .scd-side p,
  .scd-comment-note,
  .scd-comment-item p {
    margin: 0;
    color: #667085;
    line-height: 1.8;
  }

  .scd-highlight-list,
  .scd-outline {
    display: grid;
    gap: 14px;
  }

  .scd-highlight-list li {
    list-style: none;
    padding: 14px 16px;
    border-radius: 18px;
    background: #f8fafc;
    border: 1px solid rgba(15, 23, 42, 0.06);
  }

  .scd-outline-card {
    padding: 18px 20px;
    border-radius: 22px;
    background: linear-gradient(135deg, rgba(255, 244, 214, 0.44) 0%, rgba(255, 255, 255, 0.96) 100%);
    border: 1px solid rgba(15, 23, 42, 0.06);
    display: grid;
    gap: 12px;
  }

  .scd-outline-card strong {
    color: #1f2937;
    font-size: 1.04rem;
  }

  .scd-outline-list {
    display: grid;
    gap: 10px;
  }

  .scd-outline-item {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 14px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.86);
    color: #475467;
    font-size: 0.95rem;
  }

  .scd-cover {
    width: 100%;
    min-height: 324px;
    aspect-ratio: 16 / 9;
    border-radius: 22px;
    overflow: hidden;
    background: linear-gradient(135deg, #fff0bf 0%, #ffe299 100%);
  }

  .scd-cover img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center center;
  }

  .scd-learn-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 66px;
    border-radius: 18px;
    background: linear-gradient(135deg, #5b4ee6 0%, #6254ea 100%);
    color: #fff;
    font-size: 1.25rem;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 18px 30px rgba(91, 78, 230, 0.2);
  }

  .scd-side-box {
    width: 100%;
    padding: 10px 6px 2px;
    display: grid;
    gap: 6px;
    align-content: start;
    align-self: start;
  }

  @media (max-width: 1360px) {
    .scd-layout {
      grid-template-columns: minmax(0, 1.5fr) minmax(420px, 0.9fr);
    }

    .scd-cover {
      min-height: 300px;
    }
  }

  .scd-side-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 14px 0;
    color: #475467;
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  }

  .scd-side-row:last-child {
    border-bottom: 0;
  }

  .scd-comment-wrap {
    padding-top: 22px;
    display: grid;
    gap: 18px;
  }

  .scd-comment-alert {
    padding: 14px 16px;
    border-radius: 16px;
    font-weight: 600;
  }

  .scd-comment-alert.success {
    background: rgba(22, 163, 74, 0.12);
    color: #166534;
  }

  .scd-comment-alert.error {
    background: rgba(220, 38, 38, 0.1);
    color: #b42318;
  }

  .scd-comment-form {
    display: grid;
    gap: 12px;
  }

  .scd-editor {
    display: grid;
    grid-template-columns: 58px minmax(0, 1fr);
    gap: 14px;
    align-items: start;
  }

  .scd-avatar,
  .scd-comment-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #2f2f34 0%, #475467 100%);
    color: #fff;
    font-weight: 800;
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.16);
  }

  .scd-editor-shell {
    border-radius: 18px;
    border: 1px solid rgba(15, 23, 42, 0.12);
    overflow: hidden;
    background: #fff;
  }

  .scd-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 10px 12px;
    background: #f8fafc;
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  }

  .scd-toolbar span,
  .scd-toolbar button {
    min-width: 34px;
    height: 34px;
    padding: 0 10px;
    border-radius: 10px;
    border: 0;
    background: transparent;
    color: #344054;
    font: inherit;
    font-weight: 700;
  }

  .scd-toolbar .scd-toolbar-label {
    min-width: 108px;
    justify-content: flex-start;
    background: rgba(15, 23, 42, 0.04);
  }

  .scd-editor textarea {
    width: 100%;
    min-height: 164px;
    padding: 16px;
    border: 0;
    resize: vertical;
    font: inherit;
    color: #1f2937;
  }

  .scd-editor textarea:focus {
    outline: none;
  }

  .scd-submit {
    width: fit-content;
    min-height: 46px;
    padding: 0 22px;
    border: 0;
    border-radius: 14px;
    background: linear-gradient(135deg, #5b4ee6 0%, #6254ea 100%);
    color: #fff;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 16px 26px rgba(91, 78, 230, 0.16);
  }

  .scd-comment-list {
    display: grid;
    gap: 16px;
  }

  .scd-comment-item {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 14px;
    padding: 18px;
    border-radius: 22px;
    background: #f8fafc;
    border: 1px solid rgba(15, 23, 42, 0.06);
  }

  .scd-comment-item strong {
    color: #1f2937;
  }

  .scd-comment-item small {
    display: block;
    margin-top: 2px;
    color: #98a2b3;
  }

  .scd-empty {
    padding: 40px 20px;
    border-radius: 22px;
    border: 1px dashed rgba(15, 23, 42, 0.12);
    text-align: center;
    color: #98a2b3;
  }

  .scd-empty-icon {
    width: 68px;
    height: 68px;
    margin: 0 auto 14px;
    border-radius: 20px;
    display: grid;
    place-items: center;
    background: rgba(15, 23, 42, 0.04);
    font-size: 1.7rem;
  }

  @media (max-width: 1120px) {
    .scd-layout {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .scd-side {
      height: auto;
    }
  }

  @media (max-width: 720px) {
    .scd-page {
      width: min(100% - 20px, 1480px);
      padding: 18px 0 28px;
    }

    .scd-panel {
      padding: 20px;
    }

    .scd-tabs {
      overflow-x: auto;
      padding-bottom: 4px;
    }

    .scd-editor {
      grid-template-columns: 1fr;
    }

    .scd-avatar {
      display: none;
    }
  }
</style>

<div class="scd-page">
  <div class="scd-breadcrumb">
    <a href="<%= safeBaseUrl %>/student/courses/video-bai-giang">Video bài giảng</a>
    <span>/</span>
    <span><%= detail.title || "Chi tiết khóa học" %></span>
  </div>

  <div class="scd-layout">
    <section class="scd-panel">
      <div class="scd-head">
        <h1><%= detail.title || "Khóa học TOEIC" %></h1>
        <div class="scd-meta">
          <span>Giáo viên: <strong><%= detail.teacher || "Đang cập nhật" %></strong></span>
          <span><%= detail.publishedAt || "Chưa cập nhật" %></span>
          <span><%= detail.studentCount || 0 %> học viên</span>
        </div>
      </div>

      <div class="scd-tabs">
        <a href="<%= detail.contentHref || '#' %>" class="scd-tab <%= activeTab === 'content' ? 'is-active' : '' %>">Nội dung bài học</a>
        <a href="<%= detail.commentsHref || '#' %>" class="scd-tab <%= activeTab === 'comments' ? 'is-active' : '' %>">Bình luận</a>
      </div>

      <% if (activeTab === "comments") { %>
        <div class="scd-comment-wrap">
          <h2 class="scd-comment-title">Bình luận về khóa học</h2>
          <p class="scd-comment-note">Trao đổi nhanh, để lại câu hỏi hoặc nhắn giáo viên phần bạn muốn chữa sâu hơn.</p>

          <% if (commentSuccessMessage) { %>
            <div class="scd-comment-alert success"><%= commentSuccessMessage %></div>
          <% } %>
          <% if (commentErrorMessage) { %>
            <div class="scd-comment-alert error"><%= commentErrorMessage %></div>
          <% } %>

          <form method="POST" action="<%= detail.href %>/comments" class="scd-comment-form">
            <div class="scd-editor">
              <div class="scd-avatar"><%= commenterAvatar %></div>
              <div class="scd-editor-shell">
                <div class="scd-toolbar" aria-hidden="true">
                  <span class="scd-toolbar-label">Paragraph</span>
                  <button type="button">B</button>
                  <button type="button"><i>I</i></button>
                  <button type="button">•</button>
                  <button type="button">1.</button>
                  <button type="button">↶</button>
                  <button type="button">↷</button>
                </div>
                <textarea name="comment" placeholder="Bình luận gì đó..." required></textarea>
              </div>
            </div>
            <button type="submit" class="scd-submit">Bình luận</button>
          </form>

          <% if (comments.length) { %>
            <div class="scd-comment-list">
              <% comments.forEach((item) => { %>
                <article class="scd-comment-item">
                  <div class="scd-comment-avatar"><%= item.avatar || "H" %></div>
                  <div>
                    <strong><%= item.author || "Học viên" %></strong>
                    <small><%= formatCommentDate(item.createdAt) %></small>
                    <p><%= item.content %></p>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="scd-empty">
              <div class="scd-empty-icon">🗂</div>
              <strong>Trống</strong>
              <p>Chưa có bình luận nào cho khóa học này.</p>
            </div>
          <% } %>
        </div>
      <% } else { %>
        <div class="scd-content">
          <div class="scd-content-copy">
            <h2>Nội dung bài học</h2>
            <p><%= detail.summary || "Khóa học đang được cập nhật mô tả chi tiết." %></p>
            <% (detail.overview || []).forEach((item) => { %>
              <p><%= item %></p>
            <% }) %>
          </div>

          <% if (detail.highlights && detail.highlights.length) { %>
            <div>
              <h2>Điểm nổi bật</h2>
              <ul class="scd-highlight-list">
                <% detail.highlights.forEach((item) => { %>
                  <li><%= item %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>

          <div>
            <h2>Lộ trình bài học</h2>
            <div class="scd-outline">
              <% (detail.sections || []).forEach((section) => { %>
                <article class="scd-outline-card">
                  <strong><%= section.title %></strong>
                  <div class="scd-outline-list">
                    <% (section.lessons || []).forEach((lesson) => { %>
                      <div class="scd-outline-item">
                        <span><%= lesson.title %></span>
                        <span><%= lesson.duration %></span>
                      </div>
                    <% }) %>
                  </div>
                </article>
              <% }) %>
            </div>
          </div>
        </div>
      <% } %>
    </section>

    <aside class="scd-side">
      <div class="scd-cover">
        <img src="<%= detail.image %>" alt="<%= detail.title %>">
      </div>

      <a href="<%= detail.learnHref || '#' %>" class="scd-learn-btn">Tiếp tục bài học</a>

      <div class="scd-side-box">
        <h2 class="scd-sidebar-title">Khóa học bao gồm:</h2>
        <div class="scd-side-row">
          <span>Bài giảng</span>
          <strong><%= detail.lessonCount || 0 %></strong>
        </div>
        <div class="scd-side-row">
          <span>Thời lượng</span>
          <strong><%= detail.durationText || "Đang cập nhật" %></strong>
        </div>
        <div class="scd-side-row">
          <span>Học phí</span>
          <strong><%= detail.isFree ? "Hoàn toàn miễn phí" : "Liên hệ" %></strong>
        </div>
      </div>
    </aside>
  </div>
</div>
