<%
const safeBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : '';
const courseName = course && course.name ? course.name : 'Khóa học TOEIC';
const coursePrice = course && course.price ? course.price : 'Liên hệ';
const safeTeacher = teacher || 'Đang cập nhật';
const safeStudents = typeof totalStudents !== 'undefined' ? totalStudents : 0;
%>

<style>
  .gd-page{display:grid;gap:28px}
  .gd-hero{padding:36px;border-radius:32px;background:linear-gradient(135deg,#eff6ff 0%,#ffffff 52%,#dbeafe 100%);border:1px solid rgba(37,99,235,.12);box-shadow:0 24px 46px rgba(37,99,235,.10)}
  .gd-hero h1{margin:0;font-family:"Sora","Be Vietnam Pro",sans-serif;font-size:clamp(2.2rem,5vw,4rem);line-height:1.03;letter-spacing:-.05em;color:#102a43}
  .gd-hero p{margin:16px 0 0;max-width:820px;color:#4b6382;line-height:1.9}
  .gd-stats{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px}
  .gd-stat{padding:22px;border-radius:28px;background:#fff;border:1px solid rgba(37,99,235,.10);box-shadow:0 18px 34px rgba(15,23,42,.05)}
  .gd-stat span{display:block;color:#5b6f8b;font-size:.9rem}
  .gd-stat strong{display:block;margin-top:8px;font-family:"Sora","Be Vietnam Pro",sans-serif;font-size:1.75rem;letter-spacing:-.04em;color:#102a43}
  .gd-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(320px,.78fr);gap:20px}
  .gd-card{padding:26px;border-radius:30px;background:#fff;border:1px solid rgba(37,99,235,.10);box-shadow:0 18px 34px rgba(15,23,42,.05)}
  .gd-card h2{margin:0 0 14px;font-family:"Sora","Be Vietnam Pro",sans-serif;font-size:1.55rem;letter-spacing:-.04em;color:#173f73}
  .gd-card p{margin:0;color:#58708f;line-height:1.82}
  .gd-list{display:grid;gap:12px;margin-top:18px}
  .gd-list-item{padding:16px;border-radius:20px;background:#f7fbff;border:1px solid rgba(37,99,235,.08);color:#4c6483;line-height:1.8}
  .gd-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:22px}
  .gd-btn{display:inline-flex;align-items:center;justify-content:center;min-height:50px;padding:0 20px;border-radius:999px;text-decoration:none;font-weight:800;transition:.2s ease}
  .gd-btn:hover{transform:translateY(-1px)}
  .gd-btn-primary{background:linear-gradient(135deg,#60a5fa 0%,#2563eb 100%);color:#fff;box-shadow:0 18px 30px rgba(37,99,235,.24)}
  .gd-btn-secondary{background:#173f73;color:#fff;box-shadow:0 18px 30px rgba(23,63,115,.18)}
  .gd-btn-soft{background:#dbeafe;color:#1d4ed8;border:1px solid rgba(37,99,235,.12)}
  @media (max-width:980px){.gd-grid,.gd-stats{grid-template-columns:1fr}}
</style>

<div class="gd-page">
  <section class="gd-hero">
    <h1><%= courseName %></h1>
    <p>
      Thông tin khóa học được trình bày gọn gàng để bạn nhanh nhìn thấy mục tiêu, học phí tham khảo
      và các bước tiếp theo nếu muốn đăng ký.
    </p>
    <div class="gd-actions">
      <a href="<%= safeBaseUrl %>/register-course" class="gd-btn gd-btn-primary">Đăng ký khóa học</a>
      <a href="<%= safeBaseUrl %>/contact" class="gd-btn gd-btn-secondary">Nhận tư vấn</a>
    </div>
  </section>

  <section class="gd-stats">
    <article class="gd-stat"><span>Số học viên đã tham gia</span><strong><%= safeStudents %></strong></article>
    <article class="gd-stat"><span>Giảng viên / phụ trách</span><strong><%= safeTeacher %></strong></article>
    <article class="gd-stat"><span>Học phí tham khảo</span><strong><%= coursePrice %></strong></article>
  </section>

  <section class="gd-grid">
    <article class="gd-card">
      <h2>Giá trị nhận được</h2>
      <p>Khóa học được mô tả theo hướng để bạn nhanh hình dung mục tiêu và quyết định có nên đi tiếp đến đăng ký hay không.</p>
      <div class="gd-list">
        <div class="gd-list-item">Lộ trình rõ ràng theo mục tiêu điểm và đầu vào.</div>
        <div class="gd-list-item">Theo dõi bước tiếp theo đơn giản: tìm hiểu, tư vấn, đăng ký, thanh toán.</div>
        <div class="gd-list-item">Thông tin được sắp xếp gọn gàng để bạn so sánh và chọn lộ trình phù hợp.</div>
      </div>
    </article>

    <aside class="gd-card">
      <h2>Đi nhanh tiếp theo</h2>
      <div class="gd-list">
        <a href="<%= safeBaseUrl %>/register-course" class="gd-list-item">Đăng ký khóa học ngay</a>
        <a href="<%= safeBaseUrl %>/contact" class="gd-list-item">Nhận tư vấn trước khi đăng ký</a>
        <a href="<%= safeBaseUrl %>/placement-tests" class="gd-list-item">Làm placement test</a>
      </div>
      <div class="gd-actions">
        <a href="<%= safeBaseUrl %>/contact" class="gd-btn gd-btn-soft">Liên hệ tư vấn</a>
      </div>
    </aside>
  </section>
</div>
