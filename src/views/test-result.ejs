<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Lexend:wght@500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --tr-bg: #e8eeff;
      --tr-surface: rgba(255, 255, 255, 0.94);
      --tr-surface-strong: rgba(255, 255, 255, 0.98);
      --tr-line: rgba(89, 106, 191, 0.16);
      --tr-text: #0f1d32;
      --tr-muted: #5d6e84;
      --tr-brand: #2f78ed;
      --tr-accent: #f2a9d2;
      --tr-shadow-lg: 0 28px 54px rgba(39, 62, 122, 0.14);
      --tr-shadow-md: 0 16px 30px rgba(39, 62, 122, 0.10);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
      color: var(--tr-text);
      background:
        radial-gradient(circle at top left, rgba(47, 120, 237, 0.28), transparent 24%),
        radial-gradient(circle at top right, rgba(242, 169, 210, 0.32), transparent 24%),
        radial-gradient(circle at bottom left, rgba(177, 154, 255, 0.22), transparent 30%),
        linear-gradient(180deg, #eaf0ff 0%, #f9deef 52%, var(--tr-bg) 100%);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    h1,
    h2,
    h3 {
      margin: 0;
      font-family: "Lexend", "Be Vietnam Pro", sans-serif;
      letter-spacing: -0.04em;
    }

    p {
      margin: 0;
      color: var(--tr-muted);
      line-height: 1.75;
    }

    .tr-header {
      position: sticky;
      top: 0;
      z-index: 60;
      backdrop-filter: blur(18px);
      background: linear-gradient(135deg, rgba(222, 236, 255, 0.78) 0%, rgba(255, 219, 237, 0.72) 100%);
      border-bottom: 1px solid rgba(89, 106, 191, 0.12);
      box-shadow: 0 10px 30px rgba(39, 62, 122, 0.08);
    }

    .tr-shell {
      width: min(1480px, calc(100% - 32px));
      margin: 0 auto;
    }

    .tr-bar {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 18px;
      min-height: 88px;
    }

    .tr-brand {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .tr-brand-mark {
      width: 58px;
      height: 58px;
      border-radius: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: linear-gradient(135deg, rgba(152, 204, 255, 0.28) 0%, rgba(255, 193, 223, 0.36) 100%);
      border: 1px solid rgba(89, 106, 191, 0.14);
      box-shadow: 0 16px 34px rgba(47, 120, 237, 0.16);
    }

    .tr-brand-mark img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
      padding: 4px;
    }

    .tr-brand-copy {
      display: grid;
      gap: 2px;
    }

    .tr-brand-copy strong {
      font-family: "Lexend", "Be Vietnam Pro", sans-serif;
      font-size: 0.98rem;
      letter-spacing: -0.04em;
      color: #101828;
    }

    .tr-brand-copy span {
      color: var(--tr-muted);
      font-size: 0.78rem;
    }

    .tr-nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      min-width: 0;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .tr-nav::-webkit-scrollbar {
      display: none;
    }

    .tr-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 0 14px;
      border-radius: 999px;
      color: #344054;
      font-size: 0.9rem;
      font-weight: 700;
      white-space: nowrap;
      transition: color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    }

    .tr-link:hover {
      color: #111827;
      background: linear-gradient(135deg, rgba(47, 120, 237, 0.08) 0%, rgba(242, 169, 210, 0.12) 100%);
      transform: translateY(-1px);
    }

    .tr-actions {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .tr-user-chip {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 6px 8px 6px 16px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(89, 106, 191, 0.12);
      box-shadow: var(--tr-shadow-md);
    }

    .tr-user-copy {
      display: grid;
      gap: 2px;
      min-width: 0;
    }

    .tr-user-copy strong,
    .tr-user-copy span {
      max-width: 170px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .tr-user-copy strong {
      font-size: 0.92rem;
      color: #1f2937;
    }

    .tr-user-copy span {
      font-size: 0.76rem;
      color: var(--tr-muted);
    }

    .tr-user-avatar {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #1f2937 0%, #374151 100%);
      color: #ffffff;
      font-weight: 800;
      box-shadow: 0 10px 22px rgba(17, 24, 39, 0.22);
    }

    .tr-header-btn,
    .tr-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 18px;
      border-radius: 999px;
      border: 1px solid transparent;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, color 0.2s ease;
    }

    .tr-header-btn:hover,
    .tr-btn:hover {
      transform: translateY(-1px);
    }

    .tr-header-btn--secondary,
    .tr-btn--secondary,
    .tr-btn--ghost {
      background: linear-gradient(135deg, rgba(194, 220, 255, 0.88) 0%, rgba(255, 210, 231, 0.9) 100%);
      border-color: rgba(89, 106, 191, 0.14);
      color: #173f73;
      box-shadow: var(--tr-shadow-md);
    }

    .tr-header-btn--primary,
    .tr-btn--primary,
    .tr-btn--register {
      background: linear-gradient(135deg, #2f78ed 0%, #e89bbc 100%);
      color: #ffffff;
      box-shadow: 0 18px 32px rgba(47, 120, 237, 0.22);
    }

    .tr-btn:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }

    .tr-page {
      width: min(1320px, calc(100% - 32px));
      margin: 0 auto;
      padding: 28px 0 40px;
      display: grid;
      gap: 22px;
    }

    .tr-panel {
      border: 1px solid var(--tr-line);
      border-radius: 30px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(248, 251, 255, 0.96) 100%);
      box-shadow: var(--tr-shadow-lg);
    }

    .tr-hero {
      padding: 28px;
    }

    .tr-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
      color: var(--tr-brand);
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .tr-kicker::before {
      content: "";
      width: 30px;
      height: 1px;
      background: currentColor;
      opacity: 0.72;
    }

    .tr-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.18fr) minmax(320px, 0.92fr);
      gap: 20px;
      align-items: center;
    }

    .tr-hero-copy {
      display: grid;
      gap: 14px;
    }

    .tr-hero-copy h1 {
      font-size: clamp(2.2rem, 4.2vw, 4rem);
      line-height: 0.98;
      color: #173f73;
    }

    .tr-score-main {
      padding: 26px;
      border-radius: 28px;
      background: linear-gradient(145deg, rgba(219, 233, 255, 0.82) 0%, rgba(255, 235, 246, 0.86) 100%);
      border: 1px solid rgba(89, 106, 191, 0.14);
      display: grid;
      gap: 10px;
    }

    .tr-score-main span,
    .tr-card span {
      display: block;
      color: var(--tr-muted);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .tr-score-main strong {
      display: block;
      font-family: "Lexend", "Be Vietnam Pro", sans-serif;
      font-size: clamp(3.4rem, 6vw, 5rem);
      line-height: 0.92;
      color: #102a43;
    }

    .tr-score-main small {
      display: block;
      color: var(--tr-muted);
      font-size: 0.98rem;
      line-height: 1.7;
    }

    .tr-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .tr-split {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
    }

    .tr-card {
      padding: 24px;
      display: grid;
      gap: 10px;
    }

    .tr-card strong {
      display: block;
      font-family: "Lexend", "Be Vietnam Pro", sans-serif;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      line-height: 1.05;
      color: #173f73;
    }

    .tr-mini {
      background: linear-gradient(180deg, rgba(249, 251, 255, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
    }

    .tr-mini strong {
      font-size: 1.45rem;
    }

    .tr-recommend {
      padding: 24px;
      display: grid;
      gap: 18px;
    }

    .tr-recommend-copy {
      display: grid;
      gap: 12px;
    }

    .tr-recommend-copy h2 {
      font-size: clamp(1.9rem, 3vw, 2.8rem);
      line-height: 1.02;
      color: #173f73;
    }

    .tr-recommend-copy strong {
      color: #102a43;
    }

    .tr-recommend-box {
      padding: 22px;
      border-radius: 26px;
      background: linear-gradient(135deg, #173f73 0%, #2f78ed 58%, #e89bbc 100%);
      border: 1px solid rgba(89, 106, 191, 0.14);
    }

    .tr-recommend-box h3 {
      margin-bottom: 10px;
      font-size: 1.5rem;
      color: #ffffff;
    }

    .tr-recommend-box p {
      color: rgba(239, 246, 255, 0.9);
    }

    .tr-action-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    @media (max-width: 1260px) {
      .tr-bar {
        grid-template-columns: 1fr;
        justify-items: start;
        padding: 14px 0 18px;
      }

      .tr-nav,
      .tr-actions {
        justify-content: flex-start;
      }

      .tr-nav {
        width: 100%;
      }
    }

    @media (max-width: 980px) {
      .tr-page {
        width: min(100% - 20px, 1320px);
        padding: 20px 0 32px;
      }

      .tr-hero-grid,
      .tr-grid,
      .tr-split {
        grid-template-columns: 1fr;
      }

      .tr-hero,
      .tr-card,
      .tr-recommend {
        padding: 20px;
      }
    }

    @media (max-width: 720px) {
      .tr-shell {
        width: min(100% - 20px, 1480px);
      }

      .tr-brand-copy span,
      .tr-user-copy span {
        display: none;
      }

      .tr-actions {
        width: 100%;
      }

      .tr-header-btn,
      .tr-btn {
        width: 100%;
      }

      .tr-user-chip {
        width: 100%;
        justify-content: space-between;
      }
    }
  </style>
</head>
<body>
  <%
    const data = result || {};
    const recommendation = data.recommendation || {};
    const safeBaseUrl = typeof baseUrl !== 'undefined' ? baseUrl : '';
    const buildHref = (path) => `${safeBaseUrl}${path}`;
    const reviewAvailable = Boolean(data.review && data.review.available && Array.isArray(data.review.parts) && data.review.parts.length);
    const displayName = (typeof studentName !== 'undefined' && studentName) ? studentName : (data.guestName || 'Học viên');
    const displaySubline = data.guestEmail || 'Đã hoàn thành bài kiểm tra đầu vào';
    const displayInitial = (displayName || 'H').trim().charAt(0).toUpperCase() || 'H';
    const retakeHref = data.examId ? buildHref(`/placement-tests/${data.examId}`) : buildHref('/placement-tests');
    const quickLinks = [
      { label: 'Trang chủ', href: buildHref('/') },
      { label: 'Classroom', href: buildHref('/student/classroom') },
      { label: 'Góc học tập', href: buildHref('/goc-hoc-tap') },
      { label: 'Khóa học', href: buildHref('/courses-blog') },
      { label: 'Lịch khai giảng', href: buildHref('/lich-khai-giang') },
      { label: 'Liên hệ', href: buildHref('/contact') },
      { label: 'Góp ý', href: buildHref('/student/feedback') }
    ];
  %>

  <header class="tr-header">
    <div class="tr-shell tr-bar">
      <a href="<%= buildHref('/') %>" class="tr-brand">
        <span class="tr-brand-mark">
          <img src="https://i.postimg.cc/P5r5F9Mt/logo.jpg" alt="Logo Thầy Tài Toeic">
        </span>
        <span class="tr-brand-copy">
          <strong>Thầy Tài Toeic</strong>
          <span>Trung tâm luyện thi TOEIC trực tuyến</span>
        </span>
      </a>

      <nav class="tr-nav" aria-label="Điều hướng nhanh">
        <% quickLinks.forEach((item) => { %>
          <a href="<%= item.href %>" class="tr-link"><%= item.label %></a>
        <% }) %>
      </nav>

      <div class="tr-actions">
        <div class="tr-user-chip">
          <span class="tr-user-copy">
            <strong><%= displayName %></strong>
            <span><%= displaySubline %></span>
          </span>
          <span class="tr-user-avatar"><%= displayInitial %></span>
        </div>
        <a href="<%= buildHref('/') %>" class="tr-header-btn tr-header-btn--secondary">Trang chủ</a>
        <a href="<%= buildHref('/register-course') %>" class="tr-header-btn tr-header-btn--primary">Đăng ký khóa học</a>
      </div>
    </div>
  </header>

  <main class="tr-page">
    <section class="tr-panel tr-hero">
      <div class="tr-hero-grid">
        <div class="tr-hero-copy">
          <span class="tr-kicker">Kết quả placement test</span>
          <h1><%= data.examTitle || 'Kết quả TOEIC Placement Test' %></h1>
          <p>
            Kết quả được tính ngay sau khi nộp bài. Trang này hiển thị cả điểm TOEIC quy đổi theo 2 kỹ năng,
            điểm thô và phần review chi tiết để học viên xem lại câu sai, câu bỏ trống và transcript nếu có.
          </p>
        </div>
        <div class="tr-score-main">
          <span>Điểm TOEIC quy đổi</span>
          <strong><%= data.toeicScore || 0 %></strong>
          <small>Listening <%= data.listeningScore || 0 %> • Reading <%= data.readingScore || 0 %> • Max 990</small>
        </div>
      </div>
    </section>

    <section class="tr-grid">
      <div class="tr-panel tr-card">
        <span>Điểm thô</span>
        <strong><%= data.rawPracticeScore || 0 %> / <%= data.rawPracticeMax || 0 %></strong>
        <p>Công thức: số câu đúng x 5.</p>
      </div>
      <div class="tr-panel tr-card">
        <span>Số câu đúng</span>
        <strong><%= data.correctCount || 0 %> / <%= data.totalQuestions || 0 %></strong>
        <p>Sai: <%= data.incorrectCount || 0 %> • Bỏ trống: <%= data.unansweredCount || 0 %></p>
      </div>
    </section>

    <section class="tr-split">
      <div class="tr-panel tr-card tr-mini">
        <span>Listening</span>
        <strong><%= data.listeningCorrect || 0 %> / <%= data.listeningTotal || 0 %></strong>
        <p>Điểm quy đổi: <%= data.listeningScore || 0 %></p>
      </div>
      <div class="tr-panel tr-card tr-mini">
        <span>Reading</span>
        <strong><%= data.readingCorrect || 0 %> / <%= data.readingTotal || 0 %></strong>
        <p>Điểm quy đổi: <%= data.readingScore || 0 %></p>
      </div>
      <div class="tr-panel tr-card tr-mini">
        <span>Thí sinh</span>
        <strong><%= data.guestName || 'Khách' %></strong>
        <p><%= data.guestEmail || 'Chưa cung cấp email' %></p>
      </div>
    </section>

    <section class="tr-panel tr-recommend">
      <div class="tr-recommend-copy">
        <span class="tr-kicker">Gợi ý khóa học</span>
        <h2><%= recommendation.course || 'Chưa có gợi ý khóa học' %></h2>
        <p>Trình độ đánh giá: <strong><%= recommendation.level || 'Chưa xác định' %></strong></p>
      </div>

      <div class="tr-recommend-box">
        <h3>Lộ trình gợi ý</h3>
        <p><%= recommendation.note || 'Hệ thống sẽ đề xuất khóa học phù hợp dựa trên tổng điểm TOEIC quy đổi của bạn.' %></p>
      </div>

      <div class="tr-action-row">
        <a href="<%= retakeHref %>" class="tr-btn tr-btn--primary">Làm lại bài thi</a>
        <button type="button" class="tr-btn tr-btn--secondary" data-review-toggle="placement-result-review" <%= reviewAvailable ? '' : 'disabled' %>>Hiện review từng phần</button>
        <a href="<%= buildHref('/placement-tests') %>" class="tr-btn tr-btn--secondary">Đề khác</a>
        <a href="<%= buildHref('/') %>" class="tr-btn tr-btn--ghost">Quay về trang chủ</a>
        <a href="<%= buildHref('/register-course') %>" class="tr-btn tr-btn--register">Đăng ký khóa học</a>
      </div>
    </section>

    <% if (reviewAvailable) { %>
      <%- include('partials/result-review', {
        reviewData: data.review,
        reviewRootId: 'placement-result-review'
      }) %>
    <% } %>
  </main>
</body>
</html>
