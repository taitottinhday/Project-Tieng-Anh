                    <a href="<%= buildHref('/ve-chung-toi') %>">V&#7873; ch&#250;ng t&#244;i</a>
                    <a href="<%= buildHref('/lich-khai-giang') %>">L&#7883;ch khai gi&#7843;ng</a>
                    <a href="<%= buildHref('/goc-hoc-tap') %>">Góc học tập</a>
                </section>
                <section class="g-footer-col">
                    <h3>Danh mục</h3>
                    <a href="<%= buildHref('/') %>">Trang chủ</a>
                    <a href="<%= buildHref('/courses-blog') %>">Khóa học</a>
                    <a href="<%= buildHref('/placement-tests') %>">Đề thi online</a>
                    <a href="<%= buildHref('/contact') %>">Liên hệ</a>
                    <a href="<%= buildHref('/register-course') %>">Đăng ký khóa học</a>
                </section>
                <section class="g-footer-col">
                    <h3>Liên kết nhanh</h3>
                    <span class="g-footer-chip">TOEIC A</span>
                    <span class="g-footer-chip">TOEIC B</span>
