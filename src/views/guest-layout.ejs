                    <span class="g-footer-chip">Full Test</span>
                    <span class="g-footer-chip">Tư vấn đầu vào</span>
                </section>
                <section class="g-footer-col">
                    <h3>Thông tin liên hệ</h3>
                    <p><strong>Hotline:</strong> 0344772436</p>
                    <p><strong>Email:</strong> realtoeiccentral@gmail.com</p>
