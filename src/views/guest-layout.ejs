<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Th&#7847;y T&#224;i Toeic</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Lexend:wght@500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --bg: #e8eeff;
            --surface: linear-gradient(145deg, rgba(219, 233, 255, 0.78) 0%, rgba(255, 214, 234, 0.78) 100%);
            --surface-soft: linear-gradient(145deg, rgba(202, 222, 255, 0.6) 0%, rgba(255, 214, 234, 0.62) 100%);
            --ink: #0f1d32;
            --ink-soft: #5d6e84;
            --line: rgba(89, 106, 191, 0.16);
            --brand: #2f78ed;
            --accent: #f2a9d2;
            --accent-soft: rgba(242, 169, 210, 0.18);
            --shadow-lg: 0 28px 54px rgba(39, 62, 122, 0.14);
            --shadow-sm: 0 16px 30px rgba(39, 62, 122, 0.1);
        }

        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(47, 120, 237, 0.28), transparent 24%),
                radial-gradient(circle at top right, rgba(242, 169, 210, 0.32), transparent 24%),
                radial-gradient(circle at bottom left, rgba(177, 154, 255, 0.22), transparent 30%),
                linear-gradient(180deg, #eaf0ff 0%, #f9deef 52%, var(--bg) 100%);
        }

        body.menu-open { overflow: hidden; }
        a { color: inherit; text-decoration: none; }

        .g-topbar {
            background: linear-gradient(90deg, #102845 0%, #2f78ed 48%, #e89bbc 100%);
            color: #eff6ff;
            font-size: 0.92rem;
        }

        .g-topbar-inner,
        .g-wrap,
        .g-footer-inner,
        .g-mobile-inner {
            width: min(1480px, calc(100% - 32px));
            margin: 0 auto;
        }

        .g-topbar-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            min-height: 46px;
        }

        .g-topbar-copy {
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .g-topbar-copy strong { font-weight: 800; }

        .g-topbar-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 32px;
            padding: 0 14px;
            border-radius: 999px;
            background: linear-gradient(135deg, rgba(120, 191, 255, 0.18) 0%, rgba(242, 169, 210, 0.22) 100%);
            font-weight: 700;
            transition: transform .2s ease, background .2s ease;
        }

        .g-topbar-link:hover {
            transform: translateY(-1px);
            background: linear-gradient(135deg, rgba(120, 191, 255, 0.28) 0%, rgba(242, 169, 210, 0.3) 100%);
        }

        .g-header {
            position: sticky;
            top: 0;
            z-index: 50;
            isolation: isolate;
            backdrop-filter: blur(18px);
            background: linear-gradient(135deg, rgba(222, 236, 255, 0.78) 0%, rgba(255, 219, 237, 0.7) 100%);
            border-bottom: 1px solid rgba(89, 106, 191, 0.12);
            box-shadow: 0 10px 30px rgba(39, 62, 122, 0.08);
        }

        .g-nav {
            position: relative;
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto auto;
            align-items: center;
            gap: 18px;
            min-height: 82px;
        }

        .g-brand {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            flex: 0 0 auto;
            min-width: 0;
        }

        .g-brand-mark {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: linear-gradient(135deg, rgba(152, 204, 255, 0.28) 0%, rgba(255, 193, 223, 0.36) 100%);
            border: 1px solid rgba(89,106,191,.14);
            box-shadow: 0 16px 34px rgba(47,120,237,.16);
        }

        .g-brand-mark img {
            width: 100%;
            height: 100%;
            display: block;
            object-fit: contain;
            padding: 4px;
        }

        .g-brand-copy { display: grid; gap: 2px; }

        .g-brand-copy strong {
            font-family: "Lexend", "Be Vietnam Pro", sans-serif;
            font-size: .96rem;
            letter-spacing: -.04em;
            color: #101828;
        }

        .g-brand-copy span {
            color: var(--ink-soft);
            font-size: .78rem;
        }

        .g-nav-links {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            gap: 2px;
            min-width: 0;
            flex: 1;
            overflow: visible;
            justify-self: stretch;
        }

        .g-nav-links::-webkit-scrollbar { display: none; }

        .g-nav-item {
            position: relative;
            flex: 0 0 auto;
        }

        .g-nav-link {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 42px;
            padding: 0 13px;
            border-radius: 999px;
            color: #344054;
            font-size: .89rem;
            font-weight: 700;
            transition: color .2s ease, background .2s ease, transform .2s ease;
        }

        .g-nav-link.is-with-flyout {
            gap: 8px;
        }

        .g-nav-caret {
            width: 14px;
            height: 14px;
            transition: transform .2s ease;
        }

        .g-nav-link:hover {
            color: #111827;
            background: linear-gradient(135deg, rgba(47,120,237,.08) 0%, rgba(242,169,210,.12) 100%);
            transform: translateY(-1px);
        }

        .g-nav-link.is-active {
            color: var(--brand);
            background: linear-gradient(135deg, rgba(47,120,237,.10) 0%, rgba(242,183,207,.16) 100%);
        }

        .g-nav-flyout {
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            width: min(300px, 78vw);
            display: grid;
            gap: 4px;
            padding: 12px;
            border-radius: 24px;
            border: 1px solid rgba(89,106,191,.14);
            background: rgba(255, 255, 255, 0.96);
            box-shadow: 0 22px 48px rgba(15, 23, 42, 0.16);
            opacity: 0;
            visibility: hidden;
            transform: translateY(8px);
            pointer-events: none;
            transition: opacity .18s ease, transform .18s ease, visibility .18s ease;
        }

        .g-nav-flyout::before {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            top: -18px;
            height: 22px;
        }

        .g-nav-item:hover .g-nav-flyout,
        .g-nav-item:focus-within .g-nav-flyout {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
            pointer-events: auto;
        }

        .g-nav-item:hover .g-nav-caret,
        .g-nav-item:focus-within .g-nav-caret {
            transform: rotate(180deg);
        }

        .g-flyout-link {
            display: flex;
            align-items: center;
            min-height: 46px;
            padding: 0 14px;
            border-radius: 16px;
            color: #334155;
            font-size: .96rem;
            font-weight: 600;
            transition: background .2s ease, color .2s ease, transform .2s ease;
        }

        .g-flyout-link:hover {
            color: #111827;
            background: linear-gradient(135deg, rgba(47,120,237,.08) 0%, rgba(242,169,210,.12) 100%);
            transform: translateX(2px);
        }

        .g-actions {
            position: relative;
            z-index: 3;
            display: flex;
            align-items: center;
            gap: 10px;
            flex: 0 0 auto;
            min-width: max-content;
            justify-self: end;
        }

        .g-btn {
            position: relative;
            z-index: 4;
            pointer-events: auto;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 44px;
            padding: 0 16px;
            border-radius: 999px;
            font-size: .92rem;
            font-weight: 800;
            transition: transform .2s ease, box-shadow .2s ease, background .2s ease;
        }

        .g-btn:hover { transform: translateY(-1px); }

        .g-btn-primary {
            color: #fff;
            background: linear-gradient(135deg, #2f78ed 0%, #e89bbc 100%);
            box-shadow: 0 18px 32px rgba(47,120,237,.22);
        }

        .g-btn-secondary {
            color: #173f73;
            background: linear-gradient(135deg, rgba(194, 220, 255, 0.88) 0%, rgba(255, 210, 231, 0.9) 100%);
            border: 1px solid rgba(89,106,191,.14);
            box-shadow: var(--shadow-sm);
        }

        .g-menu-btn {
            display: none;
            width: 46px;
            height: 46px;
            border-radius: 14px;
            border: 1px solid rgba(89,106,191,.12);
            background: linear-gradient(135deg, rgba(212, 230, 255, 0.88) 0%, rgba(255, 214, 234, 0.88) 100%);
            align-items: center;
            justify-content: center;
            color: #111827;
            justify-self: end;
        }

        .g-mobile-panel {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            z-index: 120;
            max-height: calc(100dvh - 82px);
            overflow-y: auto;
            overscroll-behavior: contain;
            -webkit-overflow-scrolling: touch;
            touch-action: pan-y;
            border-top: 1px solid rgba(89,106,191,.1);
            background: linear-gradient(180deg, rgba(229, 240, 255, 0.94) 0%, rgba(255, 223, 239, 0.94) 100%);
            box-shadow: 0 20px 44px rgba(39, 62, 122, 0.12);
        }

        body.menu-open .g-mobile-panel { display: block; }
        body.menu-open .g-header { z-index: 140; }
        body.menu-open .eng-fixed-left,
        body.menu-open .eng-fixed-stack {
            opacity: 0;
            pointer-events: none;
        }

        .g-mobile-inner {
            padding: 14px 0 18px;
            display: grid;
            gap: 10px;
        }

        .g-mobile-group {
            display: grid;
            gap: 8px;
        }

        .g-mobile-item {
            display: grid;
            align-items: center;
            gap: 12px;
            min-height: 58px;
            padding: 8px 12px;
            border-radius: 18px;
            background: linear-gradient(135deg, rgba(201, 223, 255, 0.72) 0%, rgba(255, 214, 234, 0.74) 100%);
            border: 1px solid rgba(89,106,191,.1);
        }

        .g-mobile-item.has-children {
            grid-template-columns: minmax(0, 1fr) auto;
        }

        .g-mobile-disclosure {
            width: 38px;
            height: 38px;
            border: 1px solid rgba(89,106,191,.1);
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.48);
            color: #1f2937;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            flex: 0 0 auto;
            order: 2;
            justify-self: end;
        }

        .g-mobile-disclosure svg {
            width: 16px;
            height: 16px;
            transition: transform .2s ease;
        }

        .g-mobile-group.is-open .g-mobile-disclosure svg {
            transform: rotate(180deg);
        }

        .g-mobile-submenu {
            display: grid;
            gap: 8px;
            padding-left: 18px;
            padding-top: 2px;
        }

        .g-mobile-submenu[hidden] {
            display: none !important;
        }

        .g-mobile-sublink {
            display: flex;
            align-items: center;
            padding: 12px 14px;
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.46);
            border: 1px solid rgba(89,106,191,.08);
            color: #344054;
            font-size: .95rem;
            font-weight: 600;
        }

        .g-mobile-link,
        .g-mobile-cta {
            display: flex;
            align-items: center;
            position: relative;
            z-index: 1;
            pointer-events: auto;
            touch-action: manipulation;
            color: #1f2937;
            font-weight: 700;
        }

        .g-mobile-link {
            min-height: 42px;
            min-width: 0;
            justify-content: flex-start;
            padding: 0 4px 0 0;
            order: 1;
        }

        .g-mobile-link span:first-child {
            flex: 1 1 auto;
            min-width: 0;
        }

        .g-brand,
        .g-nav-link,
        .g-menu-btn,
        .g-btn,
        .g-mobile-link,
        .g-mobile-cta,
        .g-topbar-link {
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent;
        }

        .g-mobile-cta {
            justify-content: center;
            padding: 14px 16px;
            border-radius: 18px;
            background: linear-gradient(135deg, rgba(201, 223, 255, 0.72) 0%, rgba(255, 214, 234, 0.74) 100%);
            border: 1px solid rgba(89,106,191,.1);
        }
        .g-stage { min-height: calc(100vh - 130px); }

        .g-content {
            width: min(1360px, calc(100% - 32px));
            margin: 0 auto;
            padding: 30px 0 40px;
        }

        .g-content :is(h1, h2) {
            font-family: "Lexend", "Be Vietnam Pro", sans-serif;
            letter-spacing: -0.05em;
            background: linear-gradient(90deg, #ff7a59 0%, #ff5d8f 46%, #ffb14a 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .g-flash-stack {
            display: grid;
            gap: 12px;
            margin-bottom: 24px;
        }

        .g-flash {
            padding: 15px 18px;
            border-radius: 18px;
            border: 1px solid var(--line);
            background: var(--surface);
            box-shadow: var(--shadow-sm);
        }

        .g-flash.success { color: #067647; border-color: rgba(6,118,71,.12); }
        .g-flash.error { color: #b42318; border-color: rgba(180,35,24,.12); }
        .g-flash.info { color: #175cd3; border-color: rgba(23,92,211,.12); }

        .g-footer {
            background:
                radial-gradient(circle at top right, rgba(242, 183, 207, 0.12), transparent 24%),
                linear-gradient(180deg, #0f2138 0%, #091627 100%);
            color: #e5e7eb;
            margin-top: 34px;
        }

        .g-footer-inner { padding: 38px 0 26px; }

        .g-footer-grid {
            display: grid;
            grid-template-columns: 1.2fr 1fr 1fr 1.2fr;
            gap: 28px;
        }

        .g-footer-col h3 {
            margin: 0 0 16px;
            font-family: "Lexend", "Be Vietnam Pro", sans-serif;
            font-size: 1.02rem;
            letter-spacing: -.02em;
            color: #fff;
        }

        .g-footer-col p,
        .g-footer-col a {
            display: block;
            margin: 0 0 10px;
            color: #cbd5e1;
            line-height: 1.65;
        }

        .g-footer-col a:hover { color: #fff; }

        .g-footer-chip {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 34px;
            padding: 0 12px;
            border-radius: 999px;
            background: linear-gradient(135deg, rgba(120, 191, 255, 0.12) 0%, rgba(242, 169, 210, 0.14) 100%);
            color: #fff;
            font-size: .86rem;
            font-weight: 700;
            margin: 0 8px 8px 0;
        }

        .g-footer-bottom {
            margin-top: 22px;
            padding-top: 18px;
            border-top: 1px solid rgba(147, 197, 253, .14);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            flex-wrap: wrap;
            color: #94a3b8;
            font-size: .92rem;
        }

        .g-footer-bottom span:last-child {
            font-size: 0;
        }

        .g-footer-bottom span:last-child::after {
            content: "Copyright (c) Th\1ea7y T\00e0i Toeic";
            font-size: .92rem;
        }

        @media (max-width: 1380px) {
            .g-nav { gap: 14px; }
            .g-brand-copy strong { font-size: .88rem; }
            .g-brand-copy span { font-size: .75rem; }
            .g-nav-link { padding: 0 11px; font-size: .84rem; }
            .g-btn { padding: 0 14px; font-size: .88rem; }
        }

        @media (max-width: 1180px) {
            .g-nav {
                grid-template-columns: auto minmax(0, 1fr) auto;
            }

            .g-nav-links,
            .g-actions .g-btn {
                display: none;
            }

            .g-menu-btn { display: inline-flex; }
            .g-footer-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
        }

        @media (max-width: 760px) {
            .g-topbar-inner,
            .g-wrap,
            .g-footer-inner,
            .g-mobile-inner,
            .g-content {
                width: min(100% - 20px, 1480px);
            }

            .g-topbar-inner {
                min-height: 56px;
                flex-direction: column;
                justify-content: center;
                padding: 10px 0;
            }

            .g-nav { min-height: 74px; }
            .g-mobile-panel { max-height: calc(100dvh - 74px); }
            .g-brand-copy span { display: none; }
            .g-footer-grid { grid-template-columns: 1fr; }
            .g-content { padding-bottom: 22px; }
        }
    </style>
</head>
<body>
    <%
    const normalizePath = (value) => {
        const raw = String(value || '/').split('?')[0].split('#')[0];
        const trimmed = raw.replace(/\/+$/, '');
        return trimmed || '/';
    };
    const safeBaseUrl = baseUrl || '';
    const buildHref = (path) => `${safeBaseUrl}${path}`;
    const currentRoute = normalizePath(currentPath || '/');
    const brandLogo = 'https://i.postimg.cc/P5r5F9Mt/logo.jpg';
    const safeSuccessMessages = typeof success_msg !== 'undefined' ? success_msg : [];
    const safeErrorMessages = typeof error_msg !== 'undefined' ? error_msg : [];
    const safeInfoMessages = typeof error !== 'undefined' ? error : [];
    const aboutNavChildren = [
        { label: 'Về Thầy Tài TOEIC', href: buildHref('/ve-chung-toi/ve-thay-tai-toeic') },
        { label: 'Về thầy Tài', href: buildHref('/ve-chung-toi/ve-thay-tai') },
        { label: 'Phương pháp đào tạo', href: buildHref('/ve-chung-toi/phuong-phap-dao-tao') },
        { label: 'Hệ thống cơ sở', href: buildHref('/ve-chung-toi/he-thong-co-so') },
        { label: 'Đội ngũ giáo viên', href: buildHref('/ve-chung-toi/doi-ngu-giao-vien') },
        { label: 'Học viên điểm cao', href: buildHref('/ve-chung-toi/hoc-vien-diem-cao') },
        { label: 'Tuyển dụng', href: buildHref('/ve-chung-toi/tuyen-dung') },
        { label: 'Hoạt động nội bộ', href: buildHref('/ve-chung-toi/hoat-dong-noi-bo') }
    ];
    const courseNavChildren = [
        { label: 'TOEIC 2 k\u1ef9 n\u0103ng', href: buildHref('/courses-blog/toeic-2-ky-nang') },
        { label: 'TOEIC 4 k\u1ef9 n\u0103ng', href: buildHref('/courses-blog/toeic-4-ky-nang') },
        { label: 'Kh\u00f3a h\u1ecdc c\u1ea5p t\u1ed1c', href: buildHref('/courses-blog/khoa-hoc-cap-toc') },
        { label: 'Ti\u1ebfng Anh doanh nghi\u1ec7p', href: buildHref('/courses-blog/tieng-anh-doanh-nghiep') }
    ];
    const studyNavChildren = [
        { label: 'LUY\u1ec6N T\u1eacP FULL TEST TOEIC', href: buildHref('/placement-tests') },
        { label: 'Luy\u1ec7n t\u1eadp Part 5-6', href: buildHref('/goc-hoc-tap/part-5-6') },
        { label: 'H\u01b0\u1edbng d\u1eabn TOEIC Part 7', href: buildHref('/goc-hoc-tap/part-7') },
        { label: 'Wordform Test', href: buildHref('/goc-hoc-tap/wordform') }
    ];
    const getNavChildren = (href) => {
        if (href === buildHref('/ve-chung-toi')) return aboutNavChildren;
        if (href === buildHref('/courses-blog')) return courseNavChildren;
        if (href === buildHref('/goc-hoc-tap')) return studyNavChildren;
        return [];
    };
    const guestNavItems = [
        { label: 'Trang chủ', href: buildHref('/'), matches: ['/'] },
        { label: 'Về chúng tôi', href: buildHref('/ve-chung-toi'), matches: ['/ve-chung-toi'] },
        { label: 'Khóa học', href: buildHref('/courses-blog'), matches: ['/courses-blog', '/course-detail', '/register-course', '/payment'] },
        { label: 'Lịch khai giảng', href: buildHref('/lich-khai-giang'), matches: ['/lich-khai-giang'] },
        { label: 'Đề thi online', href: buildHref('/placement-tests'), matches: ['/placement-tests'] },
        { label: 'Góc học tập', href: buildHref('/goc-hoc-tap'), matches: ['/goc-hoc-tap'] },
        { label: 'Liên hệ', href: buildHref('/contact'), matches: ['/contact'] }
    ];
    const isActive = (item) => (item.matches || []).some((target) => {
        const normalized = normalizePath(safeBaseUrl + target);
        if (normalized === '/') return currentRoute === '/';
        return currentRoute === normalized || currentRoute.startsWith(normalized + '/');
    });
    %>

    <div class="g-topbar">
        <div class="g-topbar-inner">
            <div class="g-topbar-copy">
                <strong>Thông tin nhanh</strong>
                <span>Xem khóa học, lịch khai giảng, đề thi online, chatbot tức thời và ưu đãi giảm 25% tại đây.</span>
            </div>
            <a href="<%= buildHref('/courses-blog') %>" class="g-topbar-link">Nhận ưu đãi 25%</a>
        </div>
    </div>

    <header class="g-header">
        <div class="g-wrap g-nav">
            <a href="<%= buildHref('/') %>" class="g-brand">
                <span class="g-brand-mark">
                    <img src="<%= brandLogo %>" alt="Logo Thầy Tài Toeic">
                </span>
                <span class="g-brand-copy">
                    <strong>Th&#7847;y T&#224;i Toeic</strong>
                    <span>Trung t&#226;m luy&#7879;n thi TOEIC tr&#7921;c tuy&#7871;n</span>
                </span>
            </a>

            <nav class="g-nav-links" aria-label="Điều hướng khách">
                <% guestNavItems.forEach((item) => { %>
                    <% const flyoutLinks = getNavChildren(item.href); %>
                    <div class="g-nav-item">
                        <a href="<%= item.href %>" class="g-nav-link <%= flyoutLinks.length ? 'is-with-flyout' : '' %> <%= isActive(item) ? 'is-active' : '' %>">
                            <span><%= item.label %></span>
                            <% if (flyoutLinks.length) { %>
                                <svg class="g-nav-caret" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M5 7.5L10 12.5L15 7.5"></path>
                                </svg>
                            <% } %>
                        </a>
                        <% if (flyoutLinks.length) { %>
                            <div class="g-nav-flyout" role="menu" aria-label="<%= item.label %>">
                                <% flyoutLinks.forEach((child) => { %>
                                    <a href="<%= child.href %>" class="g-flyout-link"><%= child.label %></a>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
            </nav>

            <div class="g-actions">
                <a href="<%= buildHref('/placement-tests') %>" class="g-btn g-btn-secondary">Kiểm tra đầu vào</a>
                <a href="<%= buildHref('/login') %>" class="g-btn g-btn-primary">Đăng nhập</a>
            </div>

            <button type="button" class="g-menu-btn" id="guestMenuToggle" aria-label="Mở menu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 7h16"></path>
                    <path d="M4 12h16"></path>
                    <path d="M4 17h16"></path>
                </svg>
            </button>
        </div>

        <div class="g-mobile-panel" id="guestMobilePanel">
            <div class="g-mobile-inner">
                <% guestNavItems.forEach((item, index) => { %>
                    <% const mobileFlyoutLinks = getNavChildren(item.href); %>
                    <% const submenuId = 'guest-mobile-submenu-' + index; %>
                    <div class="g-mobile-group <%= mobileFlyoutLinks.length ? 'has-children' : '' %>" <%= mobileFlyoutLinks.length ? 'data-mobile-group' : '' %>>
                        <div class="g-mobile-item <%= mobileFlyoutLinks.length ? 'has-children' : '' %>">
                            <% if (mobileFlyoutLinks.length) { %>
                                <button
                                    type="button"
                                    class="g-mobile-disclosure"
                                    data-mobile-disclosure
                                    aria-expanded="false"
                                    aria-controls="<%= submenuId %>"
                                    aria-label="Mo danh muc con <%= item.label %>">
                                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M5 7.5L10 12.5L15 7.5"></path>
                                    </svg>
                                </button>
                            <% } %>
                            <a href="<%= item.href %>" class="g-mobile-link">
                                <span><%= item.label %></span>
                            </a>
                        </div>
                        <% if (mobileFlyoutLinks.length) { %>
                            <div class="g-mobile-submenu" id="<%= submenuId %>" data-mobile-submenu hidden>
                                <% mobileFlyoutLinks.forEach((child) => { %>
                                    <a href="<%= child.href %>" class="g-mobile-sublink"><%= child.label %></a>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
                <a href="<%= buildHref('/placement-tests') %>" class="g-mobile-cta">Kiểm tra đầu vào</a>
                <a href="<%= buildHref('/login') %>" class="g-mobile-cta">Đăng nhập</a>
            </div>
        </div>
    </header>

    <main class="g-stage">
        <div class="g-content">
            <% if (safeSuccessMessages.length || safeErrorMessages.length || safeInfoMessages.length) { %>
                <section class="g-flash-stack">
                    <% safeSuccessMessages.forEach((msg) => { %><div class="g-flash success"><%= msg %></div><% }) %>
                    <% safeErrorMessages.forEach((msg) => { %><div class="g-flash error"><%= msg %></div><% }) %>
                    <% safeInfoMessages.forEach((msg) => { %><div class="g-flash info"><%= msg %></div><% }) %>
                </section>
            <% } %>
            <%- content %>
        </div>
    </main>

